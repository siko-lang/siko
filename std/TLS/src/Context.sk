module TLS.Context {

import Std.Error
import Std.Libc.String
import Std.Ptr
import Std.Vec
import TLS.OpenSSL.CApi
import TLS.Util
import TLS.Config
import TLS.Error

@safe
pub fn drain_error_queue(fallback: String) -> String {
    let messages: Vec[String] = Vec.new();
    loop {
        let code = CApi.err_get_error();
        if code == 0 {
            break;
        }
        let buffer: Vec[U8] = Vec.with_value(256, 0);
        CApi.err_error_string_n(code, buffer.as_ptr(), 256);
        messages.push(from_cstring(buffer.as_ptr()));
    }
    if messages.is_empty() {
        fallback
    } else {
        Std.Vec.join(messages, " | ")
    }
}

pub fn library_error(operation: String, class: I32, fallback: String) -> SslError {
    SslError.Library(operation, class, drain_error_queue(fallback))
}

@safe
pub fn operation_error(ssl: void*, verify_peer: Bool, operation: String, class: I32) -> SslError {
    let details = drain_error_queue("OpenSSL returned no error-queue entry");
    if verify_peer {
        let verify_code = CApi.ssl_get_verify_result(ssl);
        if verify_code != CApi.X509_V_OK {
            let verify_text = from_cstring(CApi.x509_verify_cert_error_string(verify_code));
            let message = if details == "OpenSSL returned no error-queue entry" {
                verify_text
            } else {
                "${verify_text}: ${details}"
            };
            return SslError.Verification(operation, verify_code, message);
        }
    }
    SslError.Library(operation, class, details)
}

@safe
fn configure_versions(ctx: void*, config: Config) -> Result[(), Error] {
    CApi.err_clear_error();
    if CApi.ssl_ctx_set_min_proto_version(ctx, Util.version_code(config.min_version())) <= 0 {
        return Err(library_error("set minimum protocol version", 0, "SSL_CTX_ctrl failed")).context();
    }
    match config.max_version() {
        Some(max_version) => {
            CApi.err_clear_error();
            if CApi.ssl_ctx_set_max_proto_version(ctx, Util.version_code(max_version)) <= 0 {
                return Err(library_error("set maximum protocol version", 0, "SSL_CTX_ctrl failed")).context();
            }
        }
        None => {}
    }
    Ok(())
}

@safe
pub fn new_context(config: Config, server: Bool) -> Result[void*, Error] {
    if server {
        config.validate_server_config()?;
    } else {
        config.validate_client_config()?;
    }
    let method = if server { CApi.tls_server_method() } else { CApi.tls_client_method() };
    if is_null_voidptr(method) {
        return Err(library_error("select TLS method", 0, "TLS method is null")).context();
    }
    CApi.err_clear_error();
    let ctx = CApi.ssl_ctx_new(method);
    if is_null_voidptr(ctx) {
        return Err(library_error("create context", 0, "SSL_CTX_new returned null")).context();
    }
    match configure_versions(ctx, config) {
        Ok(_) => {}
        Err(error) => {
            CApi.ssl_ctx_free(ctx);
            return Err(error);
        }
    }
    if server {
        let certificate = config.certificate_file().unwrap();
        let private_key = config.private_key_file().unwrap();
        let certificate_path = CString.from_string(certificate);
        let private_key_path = CString.from_string(private_key);
        CApi.err_clear_error();
        if CApi.ssl_ctx_use_certificate_chain_file(ctx, certificate_path.as_ptr()) != 1 {
            let error = library_error("load certificate chain", 0, "certificate loading failed");
            CApi.ssl_ctx_free(ctx);
            return Err(error).context();
        }
        CApi.err_clear_error();
        if CApi.ssl_ctx_use_private_key_file(ctx, private_key_path.as_ptr(), CApi.SSL_FILETYPE_PEM) != 1 {
            let error = library_error("load private key", 0, "private-key loading failed");
            CApi.ssl_ctx_free(ctx);
            return Err(error).context();
        }
        CApi.err_clear_error();
        if CApi.ssl_ctx_check_private_key(ctx) != 1 {
            let error = library_error("check private key", 0, "certificate and key do not match");
            CApi.ssl_ctx_free(ctx);
            return Err(error).context();
        }
    } else {
        if !config.insecure_skip_verify() {
            CApi.ssl_ctx_set_verify(ctx, CApi.SSL_VERIFY_PEER, get_null_voidptr());
            CApi.err_clear_error();
            if CApi.ssl_ctx_set_default_verify_paths(ctx) != 1 {
                let error = library_error("load default trust paths", 0, "default trust paths unavailable");
                CApi.ssl_ctx_free(ctx);
                return Err(error).context();
            }
        }
    }
    Ok(ctx)
}

@safe
pub fn configure_client_name(ssl: void*, config: Config) -> Result[(), Error] {
    match config.server_name() {
        Some(server_name) => {
            let name = CString.from_string(server_name);
            CApi.err_clear_error();
            if CApi.ssl_set_tlsext_host_name(ssl, name.as_ptr()) <= 0 {
                return Err(library_error("set SNI server name", 0, "SSL_ctrl failed")).context();
            }
            if !config.insecure_skip_verify() {
                CApi.err_clear_error();
                if CApi.ssl_set1_host(ssl, name.as_ptr()) != 1 {
                    return Err(library_error("set verification server name", 0, "SSL_set1_host failed")).context();
                }
            }
        }
        None => {}
    }
    Ok(())
}

}
