module Std.Libc.Stdlib {

@extern("C")
pub fn rand() -> Int

@extern("C")
pub fn abort() -> !

@extern("C")
pub fn exit(code: I32) -> !

@extern("C")
pub fn malloc(size: U64) -> void*

@extern("C")
pub fn free(ptr: void*) -> void

@extern("C")
pub fn realpath(path: *I8, resolved_path: *U8) -> *U8

}
