@unsafe
pub fn load[T](ptr: *T, order: A.Ordering) -> T {
    match order {
        A.Relaxed => atomic_load_relaxed(ptr),
        A.Acquire => atomic_load_acquire(ptr),
        A.SeqCst => atomic_load_seqcst(ptr),
        A.Release => panic("Release is not valid for an atomic load"),
        A.AcqRel => panic("AcqRel is not valid for an atomic load"),
    }
}

@unsafe
pub fn store[T](ptr: *T, value: T, order: A.Ordering) {
    match order {
        A.Relaxed => atomic_store_relaxed(ptr, value),
        A.Release => atomic_store_release(ptr, value),
        A.SeqCst => atomic_store_seqcst(ptr, value),
        A.Acquire => panic("Acquire is not valid for an atomic store"),
        A.AcqRel => panic("AcqRel is not valid for an atomic store"),
    }
}

@unsafe
pub fn swap[T](ptr: *T, value: T, order: A.Ordering) -> T {
    match order {
        A.Relaxed => atomic_swap_relaxed(ptr, value),
        A.Release => atomic_swap_release(ptr, value),
        A.Acquire => atomic_swap_acquire(ptr, value),
        A.AcqRel => atomic_swap_acqrel(ptr, value),
        A.SeqCst => atomic_swap_seqcst(ptr, value),
    }
}

