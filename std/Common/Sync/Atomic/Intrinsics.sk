pub fn fetch_add[T](ptr: *T, value: T, order: A.Ordering) -> T {
    match order {
        A.Relaxed => atomic_fetch_add_relaxed(ptr, value),
        A.Release => atomic_fetch_add_release(ptr, value),
        A.Acquire => atomic_fetch_add_acquire(ptr, value),
        A.AcqRel => atomic_fetch_add_acqrel(ptr, value),
        A.SeqCst => atomic_fetch_add_seqcst(ptr, value),
    }
}

