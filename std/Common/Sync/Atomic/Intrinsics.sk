@unsafe
fn compare_exchange_raw[T](ptr: *T, current: T, new: T, success: A.Ordering, failure: A.Ordering) -> AtomicCasResult[T] {
    match failure {
        A.Relaxed => match success {
            A.Relaxed => atomic_compare_exchange_relaxed_relaxed(ptr, current, new),
            A.Release => atomic_compare_exchange_release_relaxed(ptr, current, new),
            A.Acquire => atomic_compare_exchange_acquire_relaxed(ptr, current, new),
            A.AcqRel => atomic_compare_exchange_acqrel_relaxed(ptr, current, new),
            A.SeqCst => atomic_compare_exchange_seqcst_relaxed(ptr, current, new),
        },
        A.Acquire => match success {
            A.Relaxed => atomic_compare_exchange_relaxed_acquire(ptr, current, new),
            A.Release => atomic_compare_exchange_release_acquire(ptr, current, new),
            A.Acquire => atomic_compare_exchange_acquire_acquire(ptr, current, new),
            A.AcqRel => atomic_compare_exchange_acqrel_acquire(ptr, current, new),
            A.SeqCst => atomic_compare_exchange_seqcst_acquire(ptr, current, new),
        },
        A.SeqCst => match success {
            A.Relaxed => atomic_compare_exchange_relaxed_seqcst(ptr, current, new),
            A.Release => atomic_compare_exchange_release_seqcst(ptr, current, new),
            A.Acquire => atomic_compare_exchange_acquire_seqcst(ptr, current, new),
            A.AcqRel => atomic_compare_exchange_acqrel_seqcst(ptr, current, new),
            A.SeqCst => atomic_compare_exchange_seqcst_seqcst(ptr, current, new),
        },
        A.Release => panic("Release is not valid for compare-exchange failure"),
        A.AcqRel => panic("AcqRel is not valid for compare-exchange failure"),
    }
}

@unsafe
fn compare_exchange_weak_raw[T](ptr: *T, current: T, new: T, success: A.Ordering, failure: A.Ordering) -> AtomicCasResult[T] {
    match failure {
        A.Relaxed => match success {
            A.Relaxed => atomic_compare_exchange_weak_relaxed_relaxed(ptr, current, new),
            A.Release => atomic_compare_exchange_weak_release_relaxed(ptr, current, new),
            A.Acquire => atomic_compare_exchange_weak_acquire_relaxed(ptr, current, new),
            A.AcqRel => atomic_compare_exchange_weak_acqrel_relaxed(ptr, current, new),
            A.SeqCst => atomic_compare_exchange_weak_seqcst_relaxed(ptr, current, new),
        },
        A.Acquire => match success {
            A.Relaxed => atomic_compare_exchange_weak_relaxed_acquire(ptr, current, new),
            A.Release => atomic_compare_exchange_weak_release_acquire(ptr, current, new),
            A.Acquire => atomic_compare_exchange_weak_acquire_acquire(ptr, current, new),
            A.AcqRel => atomic_compare_exchange_weak_acqrel_acquire(ptr, current, new),
            A.SeqCst => atomic_compare_exchange_weak_seqcst_acquire(ptr, current, new),
        },
        A.SeqCst => match success {
            A.Relaxed => atomic_compare_exchange_weak_relaxed_seqcst(ptr, current, new),
            A.Release => atomic_compare_exchange_weak_release_seqcst(ptr, current, new),
            A.Acquire => atomic_compare_exchange_weak_acquire_seqcst(ptr, current, new),
            A.AcqRel => atomic_compare_exchange_weak_acqrel_seqcst(ptr, current, new),
            A.SeqCst => atomic_compare_exchange_weak_seqcst_seqcst(ptr, current, new),
        },
        A.Release => panic("Release is not valid for compare-exchange failure"),
        A.AcqRel => panic("AcqRel is not valid for compare-exchange failure"),
    }
}

fn cas_result[T](raw: AtomicCasResult[T]) -> Result[T, T] {
    if raw.success == 0 { Err(raw.old) } else { Ok(raw.old) }
}

@unsafe
pub fn compare_exchange[T](ptr: *T, current: T, new: T, success: A.Ordering, failure: A.Ordering) -> Result[T, T] {
    cas_result(compare_exchange_raw(ptr, current, new, success, failure))
}

@unsafe
pub fn compare_exchange_weak[T](ptr: *T, current: T, new: T, success: A.Ordering, failure: A.Ordering) -> Result[T, T] {
    cas_result(compare_exchange_weak_raw(ptr, current, new, success, failure))
}

@unsafe
pub fn fence(order: A.Ordering) {
    match order {
        A.Acquire => atomic_fence_acquire(),
        A.Release => atomic_fence_release(),
        A.AcqRel => atomic_fence_acqrel(),
        A.SeqCst => atomic_fence_seqcst(),
        A.Relaxed => panic("Relaxed is not valid for an atomic fence"),
    }
}

}
