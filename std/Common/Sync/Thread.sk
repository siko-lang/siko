module Std.Sync.Thread {

import Std.Arch.Pthread
import Std.Libc.Pthread
import Std.Libc.Unistd
import Std.Ptr
import Std.Intrinsics

@value_type
struct Arg {
    f: fn() -> ()
}

pub struct JoinHandle {
    thread: PThread,

    pub fn new(thread: PThread) -> JoinHandle {
        JoinHandle(thread: thread)
    }

    @safe
    pub fn join(j: JoinHandle) {
        gc_pthread_join(j.thread.handle, get_null_ptr());
    }
}

@unsafe
@c_callback
fn entrypoint(arg_ptr: *Arg) -> void* {
    let arg = *arg_ptr;
    let f = arg.f;
    deallocate(arg_ptr);
    f();
    return get_null_voidptr();
}

// pthread_create with the payload spelled as *Arg instead of void*:
// closure-content inference rides on types and a void* carries none, so the
// typed binding is what lets the closure set flow from spawn's argument
// through the C runtime into entrypoint. ABI-identical to the libc
// prototype.
@unsafe
@closure_alias
fn pthread_create_typed(thread: *PThread, attr: *PthreadAttr, start_routine: fn*(*Arg) -> void*, arg: *Arg) -> I32 {
    gc_pthread_create(thread, attr, transmute(start_routine), transmute(arg))
}

@safe
pub fn spawn(f: fn() -> ()) -> JoinHandle {
    let thread = PThread.new();
    let attr = PthreadAttr.new();
    let arg = Arg(f: f);
    let arg_ptr: *Arg = allocate();
    *arg_ptr = arg;
    pthread_attr_init(&attr);
    pthread_create_typed(&thread, &attr, entrypoint, arg_ptr);
    JoinHandle.new(thread)
}

@safe
pub fn sleep(microseconds: U32) {
    Std.Libc.Unistd.usleep(microseconds);
}

pub struct Mutex {
    inner: Std.Arch.Pthread.Mutex,

    @safe
    pub fn new() -> Mutex {
        // Initialize the pthread object at its permanent address. pthread
        // synchronization objects must not be copied after initialization.
        let mutex = Mutex(inner: Std.Arch.Pthread.Mutex.new());
        if pthread_mutex_init(&mutex.inner, get_null_ptr()) != 0 {
            panic("Failed to initialize mutex");
        }
        mutex
    }

    @safe
    pub fn lock(m: Mutex) {
        if pthread_mutex_lock(&m.inner) != 0 {
            panic("Failed to lock mutex");
        }
    }

    @safe
    pub fn unlock(m: Mutex) {
        if pthread_mutex_unlock(&m.inner) != 0 {
            panic("Failed to unlock mutex");
        }
    }
}

pub struct Condvar {
    inner: Std.Arch.Pthread.Cond,

    @safe
    pub fn new() -> Condvar {
        // As with Mutex, initialize the pthread object only after the final
        // GC-managed Siko object has been allocated.
        let condvar = Condvar(inner: Std.Arch.Pthread.Cond.new());
        if pthread_cond_init(&condvar.inner, get_null_ptr()) != 0 {
            panic("Failed to initialize condition variable");
        }
        condvar
    }

    // The caller must hold mutex. wait atomically releases it while sleeping
    // and returns with it locked again. Callers must re-check their predicate
    // after every wakeup because wakeups may be spurious.
    @safe
    pub fn wait(c: Condvar, mutex: Mutex) {
        if pthread_cond_wait(&c.inner, &mutex.inner) != 0 {
            panic("Failed to wait on condition variable");
        }
    }

    // Wake one waiter. Predicate changes and notification should normally be
    // performed while holding the associated mutex.
    @safe
    pub fn notify_one(c: Condvar) {
        if pthread_cond_signal(&c.inner) != 0 {
            panic("Failed to notify condition variable");
        }
    }

    // Wake every current waiter.
    @safe
    pub fn notify_all(c: Condvar) {
        if pthread_cond_broadcast(&c.inner) != 0 {
            panic("Failed to notify condition variable");
        }
    }
}

}
