module Std.Effects.Console {

import Std.Console

// Console output, abstracted so a server's logging can be redirected or captured.
// Kept to what is used: print a line.
pub effect Console {
    fn println(line: String)
}

// Production handler, writing to standard output.
pub instance StdConsole Console {
    fn println(line: String) {
        Std.Console.println(line)
    }
}

}
