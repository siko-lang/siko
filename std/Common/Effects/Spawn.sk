module Std.Effects.Spawn {

import Std.Sync.Thread as Thread
import Std.IO.Async.Scheduler as Async

pub effect Spawn {
    fn spawn(f: fn(Int) -> ())
}

pub instance ThreadSpawn Spawn {
    fn spawn(f: fn(Int) -> ()) {
        let _ = Thread.spawn(|| f(0));
    }
}

pub instance AsyncSpawn Spawn {
    fn spawn(f: fn(Int) -> ()) {
        Async.spawn(f);
    }
}

}
