module Std.Effects.Sleep {

import Std.Time
import Std.Time as T
import Std.IO.Async.Scheduler as Async

pub effect Sleep {
    fn sleep(d: Duration)
}

pub instance ThreadSleep Sleep {
    fn sleep(d: Duration) {
        T.sleep(d);
    }
}

pub instance AsyncSleep Sleep {
    fn sleep(d: Duration) {
        Async.sleep(d);
    }
}

}
