@prelude
module Std.Float.F32 {

@builtin
pub struct F32 {
    @builtin
    @op(eq)
    pub fn eq(a: F32, b: F32) -> Bool

    @builtin
    @op(lt)
    pub fn lt(a: F32, b: F32) -> Bool

    @builtin
    @op(add)
    pub fn add(a: F32, b: F32) -> F32

    @builtin
    @op(sub)
    pub fn sub(a: F32, b: F32) -> F32

    @builtin
    @op(mul)
    pub fn mul(a: F32, b: F32) -> F32

    @builtin
    @op(div)
    pub fn div(a: F32, b: F32) -> F32

    @builtin
    @op(neg)
    pub fn neg(a: F32) -> F32
}

instance PartialEq[F32] {
    fn eq(a: F32, b: F32) -> Bool {
        a.eq(b)
    }
}

instance PartialOrd[F32] {
    fn partial_cmp(a: F32, b: F32) -> Option[Ordering] {
        if a.eq(b) {
            Some(Ordering.Equal)
        } else {
            if a.lt(b) {
                Some(Ordering.Less)
            } else {
                if b.lt(a) {
                    Some(Ordering.Greater)
                } else {
                    None
                }
            }
        }
    }
}

instance Add[F32] {
    type Output = F32
    fn add(a: F32, b: F32) -> F32 {
        a.add(b)
    }
}

instance Sub[F32] {
    type Output = F32
    fn sub(a: F32, b: F32) -> F32 {
        a.sub(b)
    }
}

instance Mul[F32] {
    type Output = F32
    fn mul(a: F32, b: F32) -> F32 {
        a.mul(b)
    }
}

instance Div[F32] {
    type Output = F32
    fn div(a: F32, b: F32) -> F32 {
        a.div(b)
    }
}

instance Neg[F32] {
    type Output = F32
    fn neg(a: F32) -> F32 {
        a.neg()
    }
}

instance Clone[F32] {
    fn clone(a: F32) -> F32 {
        a
    }
}

}
