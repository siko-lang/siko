module Std.IO.Writer {

import Std.IO.Error
import Std.IO.Buffer

pub trait Writer[T] {
    fn write(t: T, buffer: ReadBuffer) -> Result[Int, Error]

    fn write_string(t: T, input: String) -> Result[Int, Error] {
        let buffer = ByteBuffer.from_vec(input.to_bytes());
        t.write(buffer.as_read_buffer())
    }
}

}