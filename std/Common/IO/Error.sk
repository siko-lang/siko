module Std.IO.Error {

import Std.Arch.Errno

pub struct Error {
    code: Errno,
    msg: String,

    pub fn new(code: Errno) -> Error {
        Error(code, "")
    }

    pub fn with_message(code: Errno, msg: String) -> Error {
        Error(code, msg)
    }

    pub fn is_eagain(e: Error) -> Bool {
        e.code == Errno.EAGAIN
    }

    pub fn is_econnrefused(e: Error) -> Bool {
        e.code == Errno.ECONNREFUSED
    }
}

instance ToString[Error] {
    fn to_string(e: Error) -> String {
        if e.msg.len() > 0 {
            "${e.code}: ${e.msg}"
        } else {
            "${e.code}"
        }
    }
}

}
