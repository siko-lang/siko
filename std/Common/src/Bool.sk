@prelude
module Std.Bool {

@derive(PartialEq, Eq, PartialOrd, Ord, Clone)
pub enum Bool {
    False,
    True
}

instance Not[Bool] {
    type Output = Bool
    fn not(a: Bool) -> Bool {
        match a {
            True => False,
            False => True
        }
    }
}

instance ToString[Bool] {
    fn to_string(a: Bool) -> String {
        match a {
            True => "true",
            False => "false"
        }
    }
}

}
