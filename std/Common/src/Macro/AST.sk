module Std.Macro {

// The first macro MVP intentionally exposes only opaque markers. The compiler
// bridge will grow these types without ever exposing the compiler's real AST.
pub struct StructDef {}
pub struct EnumDef {}
pub struct TraitDef {}
pub struct InstanceHeader {}
pub struct InstanceBody {}
pub struct InstanceDef {}

pub enum MacroError {
    NotSupported(String),
}

}
