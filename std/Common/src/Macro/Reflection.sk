module Std.Macro.Reflection {

// Opaque handles into the compiler-side bridge state. Macro code can pass
// these values to builders, but cannot manufacture their identities.
pub struct QualifiedName {
    id: Int,
}

pub struct TypeDef {
    id: Int,
}

pub struct TypeParameter {
    id: Int,
}

pub struct FieldDef {
    id: Int,
}

pub struct VariantItemDef {
    id: Int,
}

pub struct VariantDef {
    id: Int,
    pub items: Vec[VariantItemDef],
    pub constructor: QualifiedName,
}

pub struct StructDef {
    pub type_def: TypeDef,
    pub type_params: Vec[TypeParameter],
    pub fields: Vec[FieldDef],
    pub constructor: QualifiedName,
}

pub struct EnumDef {
    pub type_def: TypeDef,
    pub type_params: Vec[TypeParameter],
    pub variants: Vec[VariantDef],
}

pub struct TraitDef {
    pub name: String,
    qualified_name: QualifiedName,

    pub fn qualified_name(def: TraitDef) -> QualifiedName {
        def.qualified_name
    }
}

}
