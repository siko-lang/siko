module Std.Time {

import Std.Libc.Time
import Std.Libc.Unistd

pub struct Duration {
    pub seconds: I64,
    pub nanoseconds: I64,

    pub fn zero() -> Duration {
        Duration(0, 0)
    }

    pub fn to_millis(d: Duration) -> I64 {
        d.seconds * 1000 + d.nanoseconds / 1000000
    }

    pub fn to_seconds(d: Duration) -> I64 {
        d.seconds
    }

    pub fn to_minutes(d: Duration) -> I64 {
        d.seconds / 60
    }

    pub fn to_hours(d: Duration) -> I64 {
        d.seconds / 3600
    }

    pub fn to_microseconds(d: Duration) -> I64 {
        d.seconds * 1000000 + d.nanoseconds / 1000
    }
}

// Attach a time unit to an integer. Besides making literals read naturally,
// this keeps unit conversion in one place for thread sleeps, async sleeps,
// timers, and other timeout APIs.
pub trait DurationUnits[T] {
    fn nanoseconds(value: T) -> Duration
    fn microseconds(value: T) -> Duration
    fn milliseconds(value: T) -> Duration
    fn seconds(value: T) -> Duration
    fn minutes(value: T) -> Duration
    fn hours(value: T) -> Duration
}

pub instance DurationUnits[Int] {
    fn nanoseconds(value: Int) -> Duration {
        let value = value.as_i64();
        Duration(value / 1000000000, value % 1000000000)
    }

    fn microseconds(value: Int) -> Duration {
        let value = value.as_i64();
        Duration(value / 1000000, (value % 1000000) * 1000)
    }

    fn milliseconds(value: Int) -> Duration {
        let value = value.as_i64();
        Duration(value / 1000, (value % 1000) * 1000000)
    }

    fn seconds(value: Int) -> Duration {
        Duration(value.as_i64(), 0)
    }

    fn minutes(value: Int) -> Duration {
        Duration(value.as_i64() * 60, 0)
    }

    fn hours(value: Int) -> Duration {
        Duration(value.as_i64() * 3600, 0)
    }
}

pub struct Instant {
    pub seconds: I64,
    pub nanoseconds: I64,

    pub fn now() -> Instant {
        let ts = get_monotonic_clock().expect("Failed to get monotonic clock");
        Instant(ts.tv_sec, ts.tv_nsec)
    }

    pub fn elapsed(instant: Instant) -> Duration {
        let now = Instant.now();
        let sec = now.seconds - instant.seconds;
        let nsec = now.nanoseconds - instant.nanoseconds;
        if nsec < 0 {
            Duration(sec - 1, nsec + 1000000000)
        } else {
            Duration(sec, nsec)
        }
    }
}

@safe
pub fn sleep(d: Duration) {
    Unistd.usleep(d.to_microseconds().as_int().as_u32());
}

instance Add[Duration] {
    type Output = Duration
    fn add(a: Duration, b: Duration) -> Duration {
        let sec = a.seconds + b.seconds;
        let nsec = a.nanoseconds + b.nanoseconds;
        if nsec >= 1000000000 {
            Duration(sec + 1, nsec - 1000000000)
        } else {
            Duration(sec, nsec)
        }
    }
}

instance Sub[Duration] {
    type Output = Duration
    fn sub(a: Duration, b: Duration) -> Duration {
        let sec = a.seconds - b.seconds;
        let nsec = a.nanoseconds - b.nanoseconds;
        if nsec < 0 {
            Duration(sec - 1, nsec + 1000000000)
        } else {
            Duration(sec, nsec)
        }
    }
}

}
