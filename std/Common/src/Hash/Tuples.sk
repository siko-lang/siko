module Std.Hash.Tuples {

import Std.Hash
import Std.Hash.Hasher

instance[A, B: Hash[A], Hash[B]] Hash[(A, B)] {
    fn hash[H: Hasher[H]](value: (A, B), hasher: H) {
        let (a, b) = value;
        a.hash(hasher);
        b.hash(hasher);
    }
}

instance[A, B, C: Hash[A], Hash[B], Hash[C]] Hash[(A, B, C)] {
    fn hash[H: Hasher[H]](value: (A, B, C), hasher: H) {
        let (a, b, c) = value;
        a.hash(hasher);
        b.hash(hasher);
        c.hash(hasher);
    }
}

instance[A, B, C, D: Hash[A], Hash[B], Hash[C], Hash[D]] Hash[(A, B, C, D)] {
    fn hash[H: Hasher[H]](value: (A, B, C, D), hasher: H) {
        let (a, b, c, d) = value;
        a.hash(hasher);
        b.hash(hasher);
        c.hash(hasher);
        d.hash(hasher);
    }
}

instance[A, B, C, D, E: Hash[A], Hash[B], Hash[C], Hash[D], Hash[E]]
    Hash[(A, B, C, D, E)] {
    fn hash[H: Hasher[H]](value: (A, B, C, D, E), hasher: H) {
        let (a, b, c, d, e) = value;
        a.hash(hasher);
        b.hash(hasher);
        c.hash(hasher);
        d.hash(hasher);
        e.hash(hasher);
    }
}

instance[A, B, C, D, E, F: Hash[A], Hash[B], Hash[C], Hash[D], Hash[E], Hash[F]]
    Hash[(A, B, C, D, E, F)] {
    fn hash[H: Hasher[H]](value: (A, B, C, D, E, F), hasher: H) {
        let (a, b, c, d, e, f) = value;
        a.hash(hasher);
        b.hash(hasher);
        c.hash(hasher);
        d.hash(hasher);
        e.hash(hasher);
        f.hash(hasher);
    }
}

}
