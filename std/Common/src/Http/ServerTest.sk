module Std.Http.ServerTest {

import Std.Effects.Network
import Std.Effects.Console
import Std.Http
import Std.Http.Server
import Std.Http.TestUtil
import Std.Mock.Network
import Std.Mock.Console
import Std.Mock.Wire

fn drain(peer: MockPeer) -> String {
    let buf: Vec[U8] = Vec.with_value(1024, 0);
    let out: Vec[U8] = Vec.new();
    loop {
        let n = peer.recv(buf.slice()).unwrap();
        if n == 0 {
            break;
        }
        out.extend_from_slice(buf.slice().sub(0, n));
    }
    String.from_slice(out.slice())
}

fn request(log: ConsoleLog, handler: fn(Request) -> Response, line: String) -> Response {
    let gateway = Gateway.new();
    let peer = gateway.open(Config.new(64, 64, 1024));
    peer.send(line.as_slice()).unwrap();

    with mock_gateway = gateway, mock_console = log, TcpNetwork = MockNet, Console = MockConsole {
        let listener = TcpNetwork.listen(8080).unwrap();
        let socket = TcpNetwork.accept(listener).unwrap();
        serve(socket, handler);
    }

    Response.parse(drain(peer))
}

@test
fn test_query_string_parsing() {
    let log = ConsoleLog.new();

    let r = request(log, |req| Response.new("200 OK", "text/plain", req.path()), RequestBuilder.new("/search?q=foo&page=2").build());
    assert(r.body() == "/search");

    let r = request(log, |req| Response.new("200 OK", "text/plain", req.query()), RequestBuilder.new("/search?q=foo&page=2").build());
    assert(r.body() == "q=foo&page=2");

    let r = request(log, |req| Response.new("200 OK", "text/plain", req.query()), RequestBuilder.new("/index.html").build());
    assert(r.body() == "");
}

@test
fn test_bad_request() {
    let log = ConsoleLog.new();

    let response = request(log, |_req| Response.new("200 OK", "text/plain", "ok"), "not http at all\r\n\r\n");
    assert(response.status() == "400 Bad Request");
}

@test
fn test_version_echo() {
    let log = ConsoleLog.new();
    let handler = |_req| Response.new("200 OK", "text/plain", "ok");

    let r11 = request(log, handler, RequestBuilder.new("/").version("HTTP/1.1").build());
    assert(r11.proto() == "HTTP/1.1");

    let r10 = request(log, handler, RequestBuilder.new("/").build());
    assert(r10.proto() == "HTTP/1.0");
}

@test
fn test_request_headers_reach_handler() {
    let log = ConsoleLog.new();
    let handler = |req| {
        let value = match req.header("X-Custom") {
            Some(v) => v,
            None => "missing",
        };
        Response.new("200 OK", "text/plain", value)
    };

    let response = request(log, handler, RequestBuilder.new("/").header("X-Custom", "hello").build());
    assert(response.body() == "hello");

    let response_missing = request(log, handler, RequestBuilder.new("/").build());
    assert(response_missing.body() == "missing");
}

@test
fn test_handler_response_passthrough() {
    let log = ConsoleLog.new();

    let response = request(log, |_req| Response.new("418 I'm a Teapot", "text/plain", "short and stout"), RequestBuilder.new("/").build());
    assert(response.status() == "418 I'm a Teapot");
    assert(response.body() == "short and stout");
}

@test
fn test_response_extra_headers() {
    let log = ConsoleLog.new();
    let handler = |_req| {
        Response.new("200 OK", "text/plain", "ok")
            .with_header("X-Foo", "bar")
            .with_header("X-Baz", "qux")
    };

    let response = request(log, handler, RequestBuilder.new("/").build());
    assert(response.header("X-Foo") == Some("bar"));
    assert(response.header("X-Baz") == Some("qux"));
}

@test
fn test_head_no_body() {
    let log = ConsoleLog.new();
    let handler = |_req| Response.new("200 OK", "text/plain", "full body content");

    let response = request(log, handler, RequestBuilder.new("/").method("HEAD").build());
    assert(response.status() == "200 OK");
    assert(response.header("Content-Length") == Some("17"));
    assert(response.body() == "");
}

@test
fn test_request_body() {
    let log = ConsoleLog.new();
    let handler = |req| Response.new("200 OK", "application/json", req.body());

    let response = request(log, handler,
        RequestBuilder.new("/api/echo")
            .method("POST")
            .body("{\"hello\": \"world\"}")
            .build());
    assert(response.status() == "200 OK");
    assert(response.body() == "{\"hello\": \"world\"}");
}

@test
fn test_redirect() {
    let log = ConsoleLog.new();
    let handler = |_req| Response.redirect("/new-location");

    let response = request(log, handler, RequestBuilder.new("/old").build());
    assert(response.status() == "302 Found");
    assert(response.header("Location") == Some("/new-location"));
    assert(response.body() == "");
}

}
