module Std.Net.AddressTest {

import Std.Net.Address

@test
fn test_split_host_port() {
    let (host, port) = split_host_port("example.com:443").unwrap();
    assert(host == "example.com");
    assert(port == "443");

    let (host, port) = split_host_port("[::1]:http").unwrap();
    assert(host == "::1");
    assert(port == "http");

    let (host, port) = split_host_port(":8080").unwrap();
    assert(host == "");
    assert(port == "8080");
}

@test
fn test_join_host_port() {
    assert(join_host_port("example.com", 443) == "example.com:443");
    assert(join_host_port("::1", 8080) == "[::1]:8080");
}

@test
fn test_parse_host_port() {
    let (host, port) = parse_host_port("example.com:443").unwrap();
    assert(host == "example.com");
    assert(port == 443);
    assert(parse_host_port("example.com:http").is_err());
    assert(parse_host_port("example.com:65536").is_err());
}

@test
fn test_resolve_localhost() {
    let addresses = resolve("localhost").unwrap();
    assert(!addresses.is_empty());
    for address in addresses {
        assert(!address.value().is_empty());
    }
}

@test
fn test_resolve_literal() {
    let addresses = resolve("127.0.0.1").unwrap();
    assert(addresses.len() == 1);
    match addresses[0] {
        IpAddress.V4(address) => {
            assert(address[0] == 127);
            assert(address[1] == 0);
            assert(address[2] == 0);
            assert(address[3] == 1);
        }
        _ => panic("expected an IPv4 address"),
    }
    assert(addresses[0].to_string() == "127.0.0.1");
}

@test
fn test_resolve_ipv6_literal() {
    let addresses = resolve("::1").unwrap();
    assert(addresses.len() == 1);
    match addresses[0] {
        IpAddress.V6(_, scope_id) => assert(scope_id == 0),
        _ => panic("expected an IPv6 address"),
    }
    assert(addresses[0].to_string() == "::1");
}

}
