module Std.TimeTest {

import Std.Time

@test
fn test_duration_units() {
    let nanos = 1500000001.nanoseconds();
    assert(nanos.seconds == 1.as_i64());
    assert(nanos.nanoseconds == 500000001.as_i64());

    let micros = 1500001.microseconds();
    assert(micros.seconds == 1.as_i64());
    assert(micros.nanoseconds == 500001000.as_i64());

    let millis = 1501.milliseconds();
    assert(millis.seconds == 1.as_i64());
    assert(millis.nanoseconds == 501000000.as_i64());

    assert(2.seconds().seconds == 2.as_i64());
    assert(2.minutes().seconds == 120.as_i64());
    assert(2.hours().seconds == 7200.as_i64());
}

}
