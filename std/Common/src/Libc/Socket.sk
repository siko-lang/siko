module Std.Libc.Socket {

import Std.Arch.Socket

pub fn htons(value: U16) -> U16 {
    ((value & 0xFF) << 8) | ((value >> 8) & 0xFF)
}

pub fn htonl(value: U32) -> U32 {
    ((value & 0xFF) << 24) |
    (((value >> 8) & 0xFF) << 16) |
    (((value >> 16) & 0xFF) << 8) |
    ((value >> 24) & 0xFF)
}

@derive(Clone, PartialEq, Eq)
pub enum Domain {
    AF_UNSPEC,
    AF_UNIX,
    AF_INET,

    pub fn code(d: Domain) -> I32 {
        discriminator(d).as_i32()
    }
}

@derive(Clone, PartialEq, Eq)
pub enum SockType {
    Unused,
    SOCK_STREAM,
    SOCK_DGRAM,
    SOCK_RAW,

    pub fn code(s: SockType) -> I32 {
        discriminator(s).as_i32()
    }
}

@value_type
pub struct InAddr {
    pub s_addr: U32,
}

@extern("C")
pub fn socket(domain: I32, ty: I32, protocol: I32) -> I32

@extern("C")
pub fn bind(sockfd: I32, addr: *SockaddrIn, addrlen: I32) -> I32

@extern("C")
pub fn listen(sockfd: I32, backlog: I32) -> I32

@extern("C")
pub fn accept(sockfd: I32, addr: void*, addrlen: void*) -> I32

@extern("C")
pub fn setsockopt(sockfd: I32, level: I32, optname: I32, optval: *I32, optlen: I32) -> I32

@extern("C")
pub fn getsockopt(sockfd: I32, level: I32, optname: I32, optval: *I32, optlen: *U32) -> I32

@extern("C")
pub fn inet_pton(af: I32, src: *I8, dst: *InAddr) -> I32

@extern("C")
pub fn connect(sockfd: I32, addr: void*, addrlen: I32) -> I32

@extern("C")
pub fn getaddrinfo(node: *I8, service: *I8, hints: *AddrInfo, result: **AddrInfo) -> I32

@extern("C")
pub fn freeaddrinfo(result: *AddrInfo) -> void

@extern("C")
pub fn gai_strerror(code: I32) -> *U8

}
