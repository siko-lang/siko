module Std.Arch.Fs {

pub let O_RDONLY : I32 = 0x0;
pub let O_WRONLY : I32 = 0x1;
pub let O_RDWR   : I32 = 0x2;
pub let O_CREAT  : I32 = 0x200;
pub let O_TRUNC  : I32 = 0x400;
pub let O_APPEND    : I32 = 0x8;
pub let O_NONBLOCK  : I32 = 0x4;
pub let O_CLOEXEC   : I32 = 0x01000000;

pub let F_GETFL : I32 = 3;
pub let F_SETFL : I32 = 4;

}
