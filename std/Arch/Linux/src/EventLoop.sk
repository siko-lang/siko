module Std.Arch.EventLoop {

import Std.Arch.Epoll
import Std.Arch.Errno
import Std.Libc.Time as T
import Std.Libc.Unistd
import Std.Map
import Std.Time
import Std.Ptr
import Std.Array

pub struct IoRegistration {
    fd: I32,
    read_waiter: Option[fn() -> ()],
    write_waiter: Option[fn() -> ()],
    armed_read: Bool,
    armed_write: Bool,
}

pub struct EventLoop {
    epoll_fd: I32,
    registrations: Map[I32, IoRegistration],
    timer_callbacks: Map[Int, fn() -> ()],
    timer_to_fd: Map[Int, I32],
    fd_to_timer: Map[I32, Int],
    next_timer_id: Int,

    @safe
    pub fn new() -> EventLoop {
        let efd = epoll_create1(EPOLL_CLOEXEC);
        if efd < 0 {
            panic("epoll_create1() failed");
        }
        EventLoop(efd, Map.new(), Map.new(), Map.new(), Map.new(), 0)
    }

    fn get_or_create(el: EventLoop, fd: I32) -> IoRegistration {
        match el.registrations.get(fd) {
            Some(r) => r,
            None => {
                let r = IoRegistration(fd: fd, read_waiter: None, write_waiter: None,
                                        armed_read: False, armed_write: False);
                el.registrations.insert(fd, r);
                r
            }
        }
    }

    pub fn register_read(el: EventLoop, fd: I32, callback: fn() -> ()) {
        let r = el.get_or_create(fd);
        r.read_waiter = Some(callback);
        el.sync_registration(fd, r);
    }

    pub fn register_write(el: EventLoop, fd: I32, callback: fn() -> ()) {
        let r = el.get_or_create(fd);
        r.write_waiter = Some(callback);
        el.sync_registration(fd, r);
    }

    // Diffs the desired interest (union of read/write waiters) against what's
    // currently armed at the OS level and issues ADD/MOD/DEL accordingly, so a
    // fd already in the epoll set never gets a second ADD (which fails EEXIST).
    @safe
    fn sync_registration(el: EventLoop, fd: I32, r: IoRegistration) {
        let want_read = r.read_waiter.is_some();
        let want_write = r.write_waiter.is_some();
        if want_read == r.armed_read && want_write == r.armed_write {
            if !want_read && !want_write {
                el.registrations.remove(fd);
            }
            return;
        }
        if !r.armed_read && !r.armed_write {
            let ev = EpollEvent(events: flags_for(want_read, want_write), data: fd.as_int().as_u64());
            let ret = epoll_ctl(el.epoll_fd, EPOLL_CTL_ADD, fd, &ev);
            if ret < 0 {
                panic("epoll_ctl register failed");
            }
        } else if !want_read && !want_write {
            let dummy = EpollEvent(events: 0, data: 0);
            epoll_ctl(el.epoll_fd, EPOLL_CTL_DEL, fd, &dummy);
        } else {
            let ev = EpollEvent(events: flags_for(want_read, want_write), data: fd.as_int().as_u64());
            let ret = epoll_ctl(el.epoll_fd, EPOLL_CTL_MOD, fd, &ev);
            if ret < 0 {
                panic("epoll_ctl modify failed");
            }
        }
        r.armed_read = want_read;
        r.armed_write = want_write;
        if !want_read && !want_write {
            el.registrations.remove(fd);
        }
    }

    @safe
    pub fn add_timer(el: EventLoop, timeout: Duration, callback: fn() -> ()) -> Int {
        let id = el.next_timer_id;
        el.next_timer_id = id + 1;
        let tfd = timerfd_create(CLOCK_MONOTONIC, TFD_CLOEXEC);
        if tfd < 0 {
            panic("timerfd_create failed");
        }
        let spec = ItimerSpec(
            it_interval: T.TimeSpec(0, 0),
            it_value:    T.TimeSpec(timeout.seconds, timeout.nanoseconds),
        );
        let ret = timerfd_settime(tfd, 0, &spec, get_null_ptr());
        if ret < 0 {
            panic("timerfd_settime failed");
        }
        let ev = EpollEvent(
            events: EPOLLIN,
            data:   tfd.as_int().as_u64(),
        );
        let ret2 = epoll_ctl(el.epoll_fd, EPOLL_CTL_ADD, tfd, &ev);
        if ret2 < 0 {
            panic("epoll_ctl add_timer failed");
        }
        el.timer_callbacks.insert(id, callback);
        el.timer_to_fd.insert(id, tfd);
        el.fd_to_timer.insert(tfd, id);
        id
    }

    @safe
    pub fn cancel_timer(el: EventLoop, id: Int) {
        match el.timer_to_fd.remove(id) {
            None => {}
            Some(tfd) => {
                el.fd_to_timer.remove(tfd);
                el.timer_callbacks.remove(id);
                defer Std.Libc.Unistd.close(tfd);
                let dummy = EpollEvent(events: 0, data: 0);
                epoll_ctl(el.epoll_fd, EPOLL_CTL_DEL, tfd, &dummy);
            }
        }
    }

    @safe
    pub fn run_once(el: EventLoop, timeout: Duration) {
        let timeout_ms = timeout.to_millis().as_int().as_i32();
        let batch_size = 64;
        let events: [EpollEvent; 64] = uninitialized();
        let event_num = 0;
        loop {
            event_num = epoll_wait(el.epoll_fd, Std.Array.as_ptr(&events), batch_size.as_i32(), timeout_ms);
            if event_num < 0 {
                let errno = Std.Arch.Errno.get_errno();
                if errno == Std.Arch.Errno.Errno.EINTR {
                    continue;
                }
                panic("epoll_wait failed: ${errno}");
            }
            break;
        }
        for i in 0..event_num.as_int() {
            let ev = events[i];
            let fd = ev.data.as_int().as_i32();
            match el.fd_to_timer.get(fd) {
                Some(id) => {
                    // drain the timerfd (must read 8 bytes to re-arm)
                    let buf = Vec.with_value(8, 0);
                    Std.Libc.Unistd.read(fd, buf.as_ptr(), 8);
                    el.fd_to_timer.remove(fd);
                    el.timer_to_fd.remove(id);
                    let dummy = EpollEvent(events: 0, data: 0);
                    epoll_ctl(el.epoll_fd, EPOLL_CTL_DEL, fd, &dummy);
                    {
                        defer Std.Libc.Unistd.close(fd);
                    };
                    match el.timer_callbacks.remove(id) {
                        None => {}
                        Some(cb) => cb(),
                    }
                }
                None => {
                    match el.registrations.get(fd) {
                        None => {}
                        Some(r) => {
                            // epoll always reports HUP/ERR/RDHUP regardless of the
                            // requested mask, so a dropped/reset peer must wake
                            // whichever waiter is present, not just the one whose
                            // bit literally fired.
                            let hup = (ev.events & (EPOLLHUP | EPOLLERR | EPOLLRDHUP)) != 0;
                            let readable = ((ev.events & EPOLLIN) != 0) || hup;
                            let writable = ((ev.events & EPOLLOUT) != 0) || hup;
                            let read_cb = if readable { r.read_waiter } else { None };
                            let write_cb = if writable { r.write_waiter } else { None };
                            if read_cb.is_some() {
                                r.read_waiter = None;
                            }
                            if write_cb.is_some() {
                                r.write_waiter = None;
                            }
                            el.sync_registration(fd, r);
                            match read_cb {
                                Some(cb) => cb(),
                                None => {}
                            }
                            match write_cb {
                                Some(cb) => cb(),
                                None => {}
                            }
                        }
                    }
                }
            }
        }
    }
}

fn flags_for(want_read: Bool, want_write: Bool) -> U32 {
    let flags = 0;
    if want_read {
        flags = flags | EPOLLIN;
    }
    if want_write {
        flags = flags | EPOLLOUT;
    }
    flags
}

}
