module Std.Arch.Fs {

// Linux open(2) flags (octal values match Linux kernel)
pub let O_RDONLY : I32 = 0x0.as_i32();
pub let O_WRONLY : I32 = 0x1.as_i32();
pub let O_RDWR   : I32 = 0x2.as_i32();
pub let O_CREAT  : I32 = 0x40.as_i32();   // 0100 octal
pub let O_TRUNC  : I32 = 0x200.as_i32();  // 01000 octal
pub let O_APPEND : I32 = 0x400.as_i32();  // 02000 octal

}
