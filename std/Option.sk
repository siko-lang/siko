module Option where

import Json
import Json.Serialize

data Option a = Some a | None deriving (PartialEq, Eq, PartialOrd, Ord, Show, ToJson, FromJson)

isSome a :: Option a -> Bool
isSome o = case o of
    Some _ -> True
    None -> False

isNone a :: Option a -> Bool
isNone o = case o of
    Some _ -> False
    None -> True

unwrap a :: Option a -> a
unwrap o = case o of
    Some a -> a
    None -> panic "Option unwrap called on None"

expect a ::  Option a -> String -> a
expect o msg = case o of
    Some a -> a
    None -> panic "Option expect failed: {}" % msg