{
   "name": "siko",
   "displayName": "siko",
   "publisher": "elszben",
   "description": "siko language support for VS Code",
   "version": "0.2.1",
   "engines": {
      "vscode": "^1.41.0"
   },
   "categories": [
      "Programming Languages"
   ],
   "repository": {
      "url": "https://github.com/elszben/siko.git",
      "type": "git"
   },
   "license": "MIT",
   "main": "./extension.js",
   "activationEvents": [
      "onLanguage:siko"
   ],
   "contributes": {
      "languages": [
         {
            "id": "siko",
            "aliases": [
               "siko"
            ],
            "extensions": [
               ".sk"
            ],
            "configuration": "./language-configuration.json"
         }
      ],
      "grammars": [
         {
            "language": "siko",
            "scopeName": "source.siko",
            "path": "./syntaxes/siko.tmLanguage.json"
         }
      ],
      "configuration": {
         "title": "Siko",
         "properties": {
            "siko.lspCommand": {
               "type": "array",
               "items": {
                  "type": "string"
               },
               "default": [
                  "./siko-lsp.bin"
               ],
               "description": "Command that starts the standalone Siko LSP server. Executable paths are resolved from the workspace root; the process runs in the configured project directory."
            },
            "siko.projectPath": {
               "type": "string",
               "default": "",
               "scope": "resource",
               "description": "Optional directory for the package checked by the Siko LSP. Relative paths are resolved from the workspace root; the workspace root is used when empty."
            }
         }
      }
   }
}
