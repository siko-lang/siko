# Boehm GC reads uninitialized stack/heap regions as part of conservative
# root scanning. All errors from within libgc are expected and suppressed.
{
   boehm_gc_cond
   Memcheck:Cond
   obj:*libgc.so*
}
{
   boehm_gc_value8
   Memcheck:Value8
   obj:*libgc.so*
}
{
   boehm_gc_value4
   Memcheck:Value4
   obj:*libgc.so*
}
