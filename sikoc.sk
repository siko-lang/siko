module Main where

data Color = Blue Int | Red

data Color2 = Blue2 Int

foo :: Int -> String -> (Int, String)
foo a b = (a, b)

nextInt :: Int -> Option (Int, Int)
nextInt s = if s < 10 then Some (s + 1, s) else None

main = do
    it <- createIterator 0 nextInt
    it |> map (\x -> x * 2) |> forEach \x -> println x
    ()
