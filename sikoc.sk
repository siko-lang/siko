module Main where

createIterator s a :: s -> (s -> Option (s, a)) -> Iterator a
createIterator s f = extern

nextInt :: Int -> Option (Int, Int)
nextInt a = if a > 10 then None else Some (a + 1, a)

nextInt2 :: () -> Option ((), Int)
nextInt2 a = None

main = do
    createIterator 5 nextInt
    createIterator () nextInt2
    ()