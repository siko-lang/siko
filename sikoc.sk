module Main where

adder :: Int -> Int -> (Int, Int)
adder a b = (a, a)

less :: Int -> Int -> (Int, Int)
less a = adder a

data Foo = { func :: Int -> Int -> (Int, Int) }

main = do
    Foo less
    b <- less 1 2
    a <- adder
    a 3 4
    a <- adder 2
    b <- a 2