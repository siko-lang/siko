module Httpd.Network {

import Std.Net.TcpListener
import Std.Net.TcpStream
import Std.IO.Reader
import Std.IO.Writer
import Std.IO.Error

// The network layer the server runs against. `Socket` is left abstract, but it is
// required to be both readable and writable — so server code can do byte IO on a
// connection without ever naming the concrete socket type.
pub effect[Socket: Reader[Socket], Writer[Socket]] TcpNetwork {
    type Listener
    type Socket

    fn listen(port: U16) -> Result[Listener, Error]
    fn accept(listener: Listener) -> Result[Socket, Error]
    fn close(socket: Socket)
}

// Production handler, backed by the OS TCP stack. TcpStream already has Reader and
// Writer instances, which is what satisfies the effect's bounds on `Socket`.
pub instance Tcp TcpNetwork {
    type Listener = TcpListener
    type Socket = TcpStream

    fn listen(port: U16) -> Result[TcpListener, Error] {
        TcpListener.bind(port)
    }

    fn accept(listener: TcpListener) -> Result[TcpStream, Error] {
        listener.accept()
    }

    fn close(socket: TcpStream) {
        socket.close();
    }
}

}
