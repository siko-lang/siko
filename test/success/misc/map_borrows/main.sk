module Main where

data Foo = Foo String deriving (Show)

data Boo = Boo deriving (PartialEq, Eq, PartialOrd, Ord)

import Map
import Map2

getter m = case Map.get m Boo of
    Some f -> ()
    None -> ()

getter2 m = case Map2.get m Boo of
    Some f -> ()
    None -> ()

main = do
    m <- Map.empty
    m <- Map.put m Boo (Foo "a")
    getter m
    getter m
    m2 <- Map2.empty
    m2 <- Map2.put m2 Boo (Foo "a")
    getter2 m2
    getter2 m2
    ()
