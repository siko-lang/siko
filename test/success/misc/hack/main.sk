module Main where

import IO
import Map2
import Std.Util

data Foo = Foo deriving (PartialEq, Eq, PartialOrd, Ord, Show)

foo a :: (Ord a , Show a) => a -> ()
foo a = ()

main = do
    writeTextFile "apple.txt" "apple"
    apple <- readTextFile "apple.txt"
    assert (apple == "apple")
    args <- getArgs
    m :: Map2 Foo Foo <- Map2.empty
    foo m