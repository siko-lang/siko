          | If Expr Expr Expr
          | List [Expr]
          | Integer Int

module Main where

import HL as HL
import LL as LL

lower h_expr =
    case h_expr of
        HL.Call args -> LL.Call (List.map args lower)
        HL.Call2 args -> LL.Call2 (List.map args lower)
        HL.Call3 args -> LL.Call3 (List.map args lower)
        HL.Call4 args -> LL.Call4 (List.map args lower)
        HL.Call5 args -> LL.Call5 (List.map args lower)
        HL.Call6 args -> LL.Call6 (List.map args lower)
        HL.Call7 args -> LL.Call7 (List.map args lower)
        HL.Call8 args -> LL.Call8 (List.map args lower)
        HL.Call9 args -> LL.Call9 (List.map args lower)
        HL.Call10 args -> LL.Call10 (List.map args lower)
        HL.Call11 args -> LL.Call11 (List.map args lower)
        HL.Call12 args -> LL.Call12 (List.map args lower)
        HL.Call13 args -> LL.Call13 (List.map args lower)
        HL.Call14 args -> LL.Call14 (List.map args lower)
        HL.Call15 args -> LL.Call15 (List.map args lower)
        HL.Call16 args -> LL.Call16 (List.map args lower)
        HL.Call17 args -> LL.Call17 (List.map args lower)
        HL.Call18 args -> LL.Call18 (List.map args lower)
        HL.Call19 args -> LL.Call19 (List.map args lower)
        HL.Call20 args -> LL.Call20 (List.map args lower)
        HL.Call21 args -> LL.Call21 (List.map args lower)
        HL.Call22 args -> LL.Call22 (List.map args lower)
        HL.Call23 args -> LL.Call23 (List.map args lower)
        HL.Call24 args -> LL.Call24 (List.map args lower)
        HL.Call25 args -> LL.Call25 (List.map args lower)
        HL.Call26 args -> LL.Call26 (List.map args lower)
        HL.Call27 args -> LL.Call27 (List.map args lower)
        HL.Call28 args -> LL.Call28 (List.map args lower)
        HL.Call29 args -> LL.Call29 (List.map args lower)
        HL.Call30 args -> LL.Call30 (List.map args lower)
        HL.Call31 args -> LL.Call31 (List.map args lower)
        HL.Call32 args -> LL.Call32 (List.map args lower)
        HL.Call33 args -> LL.Call33 (List.map args lower)
        HL.Call34 args -> LL.Call34 (List.map args lower)
        HL.Call35 args -> LL.Call35 (List.map args lower)
        HL.Call36 args -> LL.Call36 (List.map args lower)
        HL.Call37 args -> LL.Call37 (List.map args lower)
        HL.Call38 args -> LL.Call38 (List.map args lower)
        HL.Call39 args -> LL.Call39 (List.map args lower)
        HL.Call40 args -> LL.Call40 (List.map args lower)
        HL.Call41 args -> LL.Call41 (List.map args lower)
        HL.Call42 args -> LL.Call42 (List.map args lower)
        HL.Call43 args -> LL.Call43 (List.map args lower)
        HL.Call44 args -> LL.Call44 (List.map args lower)
        HL.Call45 args -> LL.Call45 (List.map args lower)
        HL.Call46 args -> LL.Call46 (List.map args lower)
        HL.Call47 args -> LL.Call47 (List.map args lower)
        HL.Call48 args -> LL.Call48 (List.map args lower)
        HL.Call49 args -> LL.Call49 (List.map args lower)
        HL.Call50 args -> LL.Call50 (List.map args lower)
        HL.If cond true false -> LL.If (lower cond) (lower true) (lower false)
        HL.List args -> LL.List (List.map args lower)
        HL.Integer v -> LL.Integer v

main = do
    lower (HL.Integer 5)
    ()
