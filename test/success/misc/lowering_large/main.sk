module HL where

data Expr = Call [Expr]
          | Call2 [Expr]
          | Call3 [Expr]
          | Call4 [Expr]
          | Call5 [Expr]
          | Call6 [Expr]
          | Call7 [Expr]
          | Call8 [Expr]
          | Call9 [Expr]
          | Call10 [Expr]
          | Call11 [Expr]
          | Call12 [Expr]
          | Call13 [Expr]
          | Call14 [Expr]
          | Call15 [Expr]
          | Call16 [Expr]
          | Call17 [Expr]
          | Call18 [Expr]
          | Call19 [Expr]
          | Call20 [Expr]
          | Call21 [Expr]
          | Call22 [Expr]
          | Call23 [Expr]
          | Call24 [Expr]
          | Call25 [Expr]
          | Call26 [Expr]
          | Call27 [Expr]
          | Call28 [Expr]
          | Call29 [Expr]
          | Call30 [Expr]
          | Call31 [Expr]
          | Call32 [Expr]
          | Call33 [Expr]
          | Call34 [Expr]
          | Call35 [Expr]
          | Call36 [Expr]
          | Call37 [Expr]
          | Call38 [Expr]
          | Call39 [Expr]
          | Call40 [Expr]
          | Call41 [Expr]
          | Call42 [Expr]
          | Call43 [Expr]
          | Call44 [Expr]
          | Call45 [Expr]
          | Call46 [Expr]
          | Call47 [Expr]
          | Call48 [Expr]
          | Call49 [Expr]
          | Call50 [Expr]
          | If Expr Expr Expr
          | List [Expr]
          | Integer Int

module LL where

data Expr = Call [Expr]
          | Call2 [Expr]
          | Call3 [Expr]
          | Call4 [Expr]
          | Call5 [Expr]
          | Call6 [Expr]
          | Call7 [Expr]
          | Call8 [Expr]
          | Call9 [Expr]
