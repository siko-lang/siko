module Main {

fn first(done: Bool, f: fn() -> ()) -> fn() -> () {
    if done {
        f
    } else {
        second(True, f)
    }
}

fn second(done: Bool, f: fn() -> ()) -> fn() -> () {
    if done {
        f
    } else {
        first(True, f)
    }
}

fn main() {
    let f = first(True, || {});
}

}
