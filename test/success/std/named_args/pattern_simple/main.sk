module Main {

struct Point {
    x: Int,
    y: Int,
}

enum Shape {
    Circle(radius: Int),
    Rect(w: Int, h: Int),
}

fn main() {
    let p = Point(x: 3, y: 4);
    match p {
        Point(x: px, y: py) => println("${px} ${py}"),
    }

    let s = Shape.Circle(radius: 10);
    match s {
        Shape.Circle(radius: r) => println("circle ${r}"),
        Shape.Rect(w: w, h: h) => println("rect ${w} ${h}"),
    }
}

}
