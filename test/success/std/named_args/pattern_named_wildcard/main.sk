module Main {

struct Point {
    x: Int,
    y: Int,
}

enum Shape {
    Circle(radius: Int),
    Rect(w: Int, h: Int),
}

fn main() {
    let p = Point(x: 3, y: 4);
    match p {
        Point(y: py, ..) => println("${py}"),
    }

    let s = Rect(10, 5);
    match s {
        Circle(radius: r) => println("circle ${r}"),
        Rect(h: h, ..) => println("rect ${h}"),
    }
}

}
