module Main {

struct Point {
    x: Int,
    y: Int,
}

enum Shape {
    Circle(radius: Int),
}

fn main() {
    let p = Point(x: 3, y: 4);
    match p {
        Point(..) => println("point"),
    }

    let s = Shape.Circle(radius: 10);
    match s {
        Shape.Circle(..) => println("circle"),
    }
}

}
