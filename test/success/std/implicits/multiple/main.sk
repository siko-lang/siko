module Main {

// Two implicits set in a single with block; function reads and writes both.

implicit x : Int
implicit y : Int

fn swap() {
    let tmp = x;
    x = y;
    y = tmp;
}

fn main() {
    let a = 1;
    let b = 2;
    with x = a, y = b {
        swap();
    }
    assert(a == 2);
    assert(b == 1);
    println(a.to_string());
    println(b.to_string());
}

}
