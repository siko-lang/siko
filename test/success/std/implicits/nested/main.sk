module Main {

// Like effects/04_nested_effects: two different implicits, each set in a separate
// with block. The inner function needs both.

implicit x : Int
implicit y : Int

fn sum() {
    x = x + y;
}

fn main() {
    let a = 3;
    let b = 4;
    with x = a {
        with y = b {
            sum();
        }
    }
    assert(a == 7);
    println(a.to_string());
}

}
