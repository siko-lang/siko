module Main {

import Std.IO.EventLoop
import Std.Net.TcpListener
import Std.Net.TcpStream
import Std.Time

struct State {
    listener: TcpListener,
    eventloop: EventLoop,
    stop: Bool,
}

implicit current: State

fn on_listener_ready(ev: IoEvent) {
    match current.listener.accept() {
        Ok(_) => println("accepted connection"),
        Err(e) => panic("accept failed: ${e}"),
    }
    current.eventloop.deregister(current.listener.get_fd().get_fd());
    current.stop = True;
}

fn main() {
    let port = 19876.as_u16();
    let listener = match TcpListener.bind(port) {
        Ok(l) => l,
        Err(e) => panic("bind failed: ${e}"),
    };
    let _ = listener.set_nonblocking(True);
    let eventloop = EventLoop.new();
    let s = State(listener, eventloop, False);
    with current = s {
        let fd = current.listener.get_fd().get_fd();
        eventloop.register(fd, Interest.Read, |ev| on_listener_ready(ev));
        let client = match TcpStream.connect_async("127.0.0.1", port) {
            Ok(stream) => stream,
            Err(e) => panic("connect failed: ${e}"),
        };
        while !current.stop {
            eventloop.run_once(seconds(10));
        }
        let _ = client.close();
    }
}

}
