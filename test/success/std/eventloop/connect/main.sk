module Main {

import Std.IO.EventLoop
import Std.Net.TcpListener
import Std.Net.TcpStream
import Std.Net.Address
import Std.Net.SocketAddress
import Std.Time

struct State {
    listener: TcpListener,
    eventloop: EventLoop,
    stop: Bool,
}

implicit current: State

fn on_listener_ready() {
    match current.listener.accept() {
        Ok(_) => println("accepted connection"),
        Err(e) => panic("accept failed: ${e}"),
    }
    current.stop = True;
}

fn main() {
    let port = 19869.as_u16();
    let listener = match TcpListener.bind(port) {
        Ok(l) => l,
        Err(e) => panic("bind failed: ${e}"),
    };
    let _ = listener.set_nonblocking(True);
    let eventloop = EventLoop.new();
    let s = State(listener, eventloop, False);
    with current = s {
        let fd = current.listener.get_fd().get_fd();
        eventloop.register_read(fd, || on_listener_ready());
        let socket_address = SocketAddress.from_ip(resolve("127.0.0.1").unwrap()[0], port);
        let client = match TcpStream.start_connect(socket_address, True) {
            Ok(stream) => stream,
            Err(e) => panic("connect failed: ${e}"),
        };
        while !current.stop {
            eventloop.run_once(10.seconds());
        }
        let _ = client.close();
    }
}

}
