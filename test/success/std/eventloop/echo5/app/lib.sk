module App {

import Std.IO.Buffered as Buffered
import Std.Effects.Network
import Std.Effects.Spawn
import Std.Effects.Sleep
import Std.Time as Time

pub fn handler(conn: Socket) {
    let reader = Buffered.Reader.new(conn, 1024);
    let writer = Buffered.Writer.new(conn);
    for i in 0..3 {
        let line = match reader.read_line() {
            Ok(Some(l)) => {
                println("received line: ${l}");
                l
            }
            Ok(None) => {
                println("no line received");
                continue;
            }
            Err(e) => {
                println("read_line error: ${e}");
                continue;
            }
        };
        match writer.write("${line}\n".as_slice()) {
            Ok(_) => println("wrote line: ${line}"),
            Err(e) => println("write error: ${e}"),
        }
        match writer.flush() {
            Ok(_) => println("flushed"),
            Err(e) => println("flush error: ${e}"),
        }
    }
}

pub fn server(port: U16) {
    let listener = match listen(port) {
        Ok(l) => l,
        Err(e) => panic("listen error: ${e}"),
    };
    let conn = match accept(listener) {
        Ok(c) => c,
        Err(e) => panic("accept error: ${e}"),
    };
    spawn(|_| handler(conn));
}

fn connect_with_retry(host: String, port: U16) -> Socket {
    let max_attempts = 100;
    for attempt in 0..max_attempts {
        match connect(host, port) {
            Ok(s) => return s,
            Err(e) => {
                if e.is_econnrefused() {
                    sleep(Time.milliseconds(10));
                } else {
                    panic("connect error: ${e}");
                }
            }
        }
    }
    panic("connect failed after ${max_attempts} attempts: connection refused");
}

pub fn client(port: U16) {
    let stream = connect_with_retry("127.0.0.1", port);
    let reader = Buffered.Reader.new(stream, 1024);
    let writer = Buffered.Writer.new(stream);
    for i in 0..3 {
        match writer.write("hello ${i}\n".as_slice()) {
            Ok(_) => println("wrote: hello ${i}"),
            Err(e) => println("write error: ${e}"),
        }
        match writer.flush() {
            Ok(_) => println("flushed"),
            Err(e) => println("flush error: ${e}"),
        }
        match reader.read_line() {
            Ok(Some(line)) => println("received line: ${line}"),
            Ok(None) => println("no line received"),
            Err(e) => println("read_line error: ${e}"),
        }
    }
}

}
