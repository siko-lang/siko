module Main {

import App
import Std.Effects.Network
import Std.Effects.Spawn
import Std.Effects.Sleep
import Std.IO.Async.Scheduler as Async
import Std.Time

fn stopper() {
    Async.sleep(2.seconds());
    Async.stop();
}

fn main() {
    let port = 19875.as_u16();
    let s = Async.Scheduler.new();
    with Async.current = s,
         TcpNetwork = AsyncTcp,
         Spawn = AsyncSpawn,
         Sleep = AsyncSleep {
        spawn(|| server(port));
        spawn(|| client(port));
        spawn(|| stopper());
        s.run_tasks();
    }
}

}
