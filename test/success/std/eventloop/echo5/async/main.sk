module Main {

import App
import Std.Effects.Network
import Std.Effects.Spawn
import Std.Effects.Sleep
import Std.IO.Async.Scheduler as Async
import Std.Time as Time

fn stopper() {
    Async.sleep(Time.seconds(2));
    Async.stop();
}

fn main() {
    let port = 19878.as_u16();
    let s = Async.Scheduler.new();
    with Async.current = s,
         TcpNetwork = AsyncTcp,
         Spawn = AsyncSpawn,
         Sleep = AsyncSleep {
        spawn(|_| server(port));
        spawn(|_| client(port));
        spawn(|_| stopper());
        s.run_tasks();
    }
}

}
