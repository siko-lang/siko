module Main {

import App
import Std.Time as Time
import Std.Effects.Spawn
import Std.Effects.Network
import Std.Effects.Sleep

fn main() {
    let port = 19878.as_u16();
    with TcpNetwork = Tcp, Spawn = ThreadSpawn, Sleep = ThreadSleep {
        spawn(|_| server(port));
        spawn(|_| client(port));
        Time.sleep(Time.seconds(1));
    }
}

}
