module Main {

import Std.IO.Buffered as Buffered
import Std.Effects.Network
import Std.Effects.Spawn
import Std.Net.TcpStream
import Std.Time
import Std.IO.Async.Scheduler as Async

fn handler(conn: Socket) {
    let reader = Buffered.Reader.new(conn, 1024);
    let writer = Buffered.Writer.new(conn);
    for _ in 0..3 {
        let line = reader.read_line().unwrap().unwrap();
        writer.write("${line}\n".as_slice()).unwrap();
        writer.flush().unwrap();
    }
}

fn server(port: U16) {
    let listener = listen(port).unwrap();
    let conn = accept(listener).unwrap();
    spawn(|| handler(conn));
}

fn client(port: U16) {
    let stream = TcpStream.connect("127.0.0.1", port).unwrap();
    let reader = Buffered.Reader.new(stream, 1024);
    let writer = Buffered.Writer.new(stream);
    for i in 0..3 {
        writer.write("hello ${i}\n".as_slice()).unwrap();
        writer.flush().unwrap();
        let line = reader.read_line().unwrap().unwrap();
        println(line);
    }
}

fn main() {
    let port = 19878.as_u16();
    with TcpNetwork = Tcp, Spawn = ThreadSpawn {
        spawn(|| server(port));
        spawn(|| client(port));
        sleep(seconds(1));
    }
    // let s = Async.Scheduler.new();
    // with Async.current = s,
    //      TcpNetwork = AsyncTcp,
    //      Spawn = AsyncSpawn {
    //     spawn(|| server(port));
    //     spawn(|| client(port));
    //     s.run_tasks();
    // }
}

}
