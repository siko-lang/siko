module Main {

effect Alarm {
    fn alert(msg: String)
}

fn system_alert(msg: String) {
    println("system_alert")
}

fn another_alert(msg: String) {
    println("another_alert")
}

fn foo() {
    Alarm.alert("world")
}

fn main() {
    with alert = system_alert, alert = another_alert {
        foo()
    }
    with alert = another_alert, alert = system_alert {
        foo()
    }
}
}
