module Main {

effect Logger {
    fn log(msg: String)
}

effect Alarm {
    fn alert(msg: String)
}

fn system_alert(msg: String) {
    println("system_alert")
}

fn my_log(msg: String) {
    Alarm.alert(msg)
}

fn foo() {
    Logger.log("hello")
}

fn main() {
    with log = my_log, alert = system_alert {
        foo()
    }
}
}
