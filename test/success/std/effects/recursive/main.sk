module Main {

effect Bar {
    fn bar()
}

fn foo() {
    println("foo")
}

fn baz() {
    println("baz")
}

fn recursive(v: Bool) {
    if v {
        with bar = baz {
            Bar.bar();
            recursive(False)
        };
        recursive(False)
    } else {
        Bar.bar()
    }
}

fn main() {
    with bar = foo {
        Bar.bar();
        recursive(True)
    }
}
}
