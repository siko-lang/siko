module Main {

effect MyEffect {
    fn op1()
    fn op2()
    fn op3()
}

fn foo() {
    op1();
    op2();
    op3();
}

fn op1_handler() {
    println("op1");
}

fn op2_handler() {
    println("op2");
}

fn op3_handler() {
    println("op3");
}

// instance Stuff MyEffect {
//     fn op1() {
//         println("op1");
//     }
//     fn op2() {
//         println("op2");
//     }
//     fn op3() {
//         println("op3");
//     }
// }

fn main() {
    with MyEffect.op1 = op1_handler,
         MyEffect.op2 = op2_handler,
         MyEffect.op3 = op3_handler {
            foo();
    }

    // with MyEffect = Stuff {
    //         foo();
    // }
}

}