module Main {

effect MyEff {
    type Foo

    fn create() -> Foo

    fn do(f: Foo)
}

struct Boo {

}

struct Q {
    a: Foo,
}

instance I MyEff {
    type Foo = Boo

    fn create() -> Boo {
        Boo()
    }

    fn do(f: Boo) {

    }
}

fn main() {
    with MyEff = I {
        let a = create();
        let q = Q(a);
        do(q.a);
    }
}

}