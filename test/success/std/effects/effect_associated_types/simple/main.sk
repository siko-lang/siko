module Main {

effect MyEff {
    type Foo

    fn create() -> Foo

    fn do(f: Foo)
}

struct Boo {

}

fn create_handler() -> Boo {
    Boo()
}

fn do_handler(f: Boo) {

}

fn main() {
    with type MyEff.Foo = Boo,
        MyEff.create = create_handler,
        do = do_handler {
        let a = create();
        do(a);
    }
}

}