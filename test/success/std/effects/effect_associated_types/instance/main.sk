module Main {

effect MyEff {
    type Foo

    fn create() -> Foo

    fn do(f: Foo)
}

struct Boo {

}

instance I MyEff {
    type Foo = Boo

    fn create() -> Boo {
        Boo()
    }

    fn do(f: Boo) {

    }
}


fn main() {
    with MyEff = I {
        let a = create();
        do(a);
    }
}

}