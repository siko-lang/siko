module Main {

effect Logger {
    fn log(msg: String)
}

fn console_log(msg: String) {
    println("console")
}

fn file_log(msg: String) {
    println("file")
}

fn foo() {
    Logger.log("hello")
}

fn main() {
    with log = console_log {
        foo()
    };
    with log = file_log {
        foo()
    }
}
}
