module Main {

struct Point {
    x: Int,
    y: Int
}

struct Segment {
    from: Point,
    to: Point
}

fn describe_point(p: Point) -> String {
    match p {
        Point(0, 0) => "origin",
        Point(0, _) => "on y-axis",
        Point(_, 0) => "on x-axis",
        Point(x, y) => "at ${x},${y}",
    }
}

fn main() -> () {
    println(describe_point(Point(0, 0)));
    println(describe_point(Point(0, 5)));
    println(describe_point(Point(3, 0)));
    println(describe_point(Point(3, 7)));

    let seg = Segment(Point(1, 2), Point(3, 4));
    let result = match seg {
        Segment(Point(0, _), _) => "starts at x=0",
        Segment(Point(x, _), Point(x2, _)) => "from x=${x} to x=${x2}",
    };
    println(result);
}

}
