module Main {

fn dump[T: ToString[T]](v: Vec[T]) {
    for i in v {
        println(i);
    }
}

fn main() {
    let numbers = Vec.new();
    for i in 0..10 {
        numbers.push(i);
    }
    println("numbers: 0-10")
    dump(numbers);
    numbers.remove(4);
    println("numbers: remove(4)")
    dump(numbers);
    for i in 20..30 {
        numbers.push(i);
    }
    println("numbers: 0-10 expect 4 +20-30")
    dump(numbers);
}

}