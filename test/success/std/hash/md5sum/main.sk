module Main {

import Std.Hash.MD5
import Std.Util

fn check(input: String, expected: String) {
    let digest = MD5.compute(input.to_bytes());
    assert(bytes_to_hex(digest) == expected);
}

fn main() {
    check("", "d41d8cd98f00b204e9800998ecf8427e");
    check("a", "0cc175b9c0f1b6a831c399e269772661");
    check("abc", "900150983cd24fb0d6963f7d28e17f72");
    check("message digest", "f96b697d7cb7938d525a2f31aaf161d0");
    check("abcdefghijklmnopqrstuvwxyz", "c3fcd3d76192e4007dfb496cca67e13b");
    check(
        "ABCDEFGHIJKLMNOPQRSTUVWXYZabcdefghijklmnopqrstuvwxyz0123456789",
        "d174ab98d277d9f5a5611c2c9f419d9f",
    );
    check(
        "123456789012345678901234567890123456789012345678901234567890" +
        "12345678901234567890",
        "57edf4a22be3c955ac49da2e2107b67a",
    );

    let input = "this is a good day to die\n".to_bytes();
    let digest = MD5.compute(input);
    let hex = bytes_to_hex(digest);
    assert(hex == "ce96495307139fb599d5182772716eb0");
    println(hex);
}

}
