module Main {

import Std.Hash.FNV1a
import Std.Util

fn check(input: String, expected32: U32, expected64: U64) {
    let bytes = input.to_bytes();
    assert(FNV1a.compute32(bytes) == expected32);
    assert(FNV1a.compute64(bytes) == expected64);
}

fn main() {
    check("", 0x811c9dc5, 0xcbf29ce484222325);
    check("a", 0xe40c292c, 0xaf63dc4c8601ec8c);
    check("hello", 0x4f9f2cab, 0xa430d84680aabd0b);
    check("foobar", 0xbf9cf968, 0x85944171f73967e8);
    println("FNV-1a vectors passed");
}

}
