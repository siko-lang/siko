module Main {

effect Printer {
    fn print_line(msg: String, prefix: String = "")
}

fn console_printer(msg: String, prefix: String) {
    println(prefix + msg)
}

fn foo() {
    Printer.print_line("hello");
    Printer.print_line("world", "> ");
}

fn main() {
    with print_line = console_printer {
        foo()
    }
}

}
