module Main {

trait Greeter[T] {
    fn greet(t: T, name: String, greeting: String = "Hello")
}

struct Person {
    name: String,
}

instance MyGreeter Greeter[Person] {
    fn greet(t: Person, name: String, greeting: String) {
        println(greeting + ", " + name + "!")
    }
}

fn main() {
    let p = Person(name: "Alice");
    greet(p, "Alice");
    greet(p, "Bob", "Hi");
}

}
