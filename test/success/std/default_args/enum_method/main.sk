module Main {

enum Color {
    Red,
    Green,
    Blue,

    pub fn label(c: Color, prefix: String = "color") -> String {
        match c {
            Red => prefix + ":red",
            Green => prefix + ":green",
            Blue => prefix + ":blue",
        }
    }
}

fn main() {
    println((Red).label());
    println((Green).label("hue"));
}

}
