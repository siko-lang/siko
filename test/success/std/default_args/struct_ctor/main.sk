module Main {

struct Point {
    x: Int,
    y: Int = 0,

    pub fn get_x(p: Point) -> Int { p.x }
    pub fn get_y(p: Point) -> Int { p.y }
}

fn main() {
    let p1 = Point(3);
    let p2 = Point(3, 7);
    println(p1.get_x());
    println(p1.get_y());
    println(p2.get_x());
    println(p2.get_y());
}

}
