module Main {

enum Wrap {
    Some(Int),
    None
}

trait MyFold[T] {
    fn my_fold(a: T)
}

instance MyFold[Int] {
    fn my_fold(a: Int) {
        println(a)
    }
}

instance MyFold[Wrap] = auto(Fold)

fn main() {
    let x = Wrap.Some(42);
    my_fold(x);
    let y = Wrap.None;
    my_fold(y);
}

}
