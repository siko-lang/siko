module Main {

//@derive(FromInt)
enum Color {
    Red,
    Green,
    Blue
}

instance FromInt[Color] = auto

instance ToString[Color] {
    fn to_string(c: Color) -> String {
        match c {
            Color.Red => "Red",
            Color.Green => "Green",
            Color.Blue => "Blue",
        }
    }
}

fn print_color(c: Option[Color]) {
    match c {
        Some(c) => println(c.to_string()),
        None => println("None"),
    }
}

fn main() {
    print_color(from_int(0));
    print_color(from_int(1));
    print_color(from_int(2));
    print_color(from_int(3));
}

}
