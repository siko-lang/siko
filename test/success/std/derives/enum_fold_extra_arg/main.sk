module Main {

enum Wrap {
    Some(Int),
    None
}

trait MyFold[T] {
    fn my_fold(a: T, ctx: String)
}

instance MyFold[Int] {
    fn my_fold(a: Int, ctx: String) {
        println("${ctx}: ${a}")
    }
}

instance MyFold[Wrap] = auto(Fold, my_fold)

fn main() {
    let x = Wrap.Some(42);
    my_fold(x, "value");
    let y = Wrap.None;
    my_fold(y, "value");
}

}
