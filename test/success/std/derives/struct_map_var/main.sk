module Main {

struct Pair {
    first: Int,
    second: Int
}

trait MyMap[T] {
    fn my_map(a: T) -> T
}

instance MyMap[Int] {
    fn my_map(a: Int) -> Int { a + 1 }
}

instance MyMap[Pair] = auto2(Map, my_map)

fn main() {
    let p = Pair(3, 7);
    let q = my_map(p);
    println(q.first);
    println(q.second);
}

}
