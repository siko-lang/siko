module Main {

fn main() {
    let numbers : Vec[_] = (0..10).into_iter().filter(|x| x > 2).cloned().collect();
    for number in numbers {
        println("number: ${number}");
    }
    let other_numbers = [1, 2, 3];
    let numbers : Vec[_] = numbers.iter().cloned().chain(other_numbers).collect();
    for number in numbers {
        println("number: ${number}");
    }
}

}