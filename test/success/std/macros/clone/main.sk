module Main {

import Std.Macro.Derive.Clone

@derive2(Clone)
struct Example {
    number: Int,
    text: String,
}

@derive2(Clone)
struct Wrapper[T] {
    value: T,
}

@derive2(Clone)
enum Choice[T] {
    Empty,
    One(T),
    Pair(T, T),
}

fn main() {
    let original = Example(42, "hello");
    let cloned = original.clone();
    println(cloned.number);
    println(cloned.text);

    let wrapped = Wrapper("generic");
    let cloned_wrapper = wrapped.clone();
    println(cloned_wrapper.value);

    let choice = Choice.Pair("left", "right");
    match choice.clone() {
        Choice.Pair(left, right) => {
            println(left);
            println(right);
        }
        _ => println("wrong variant"),
    }
}

}
