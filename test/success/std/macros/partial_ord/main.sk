module Main {

import Std.Macro.Derive.PartialOrd

@derive2(PartialEq)
@derive2(PartialOrd)
struct Duo[T] {
    first: T,
    second: T,
}

@derive2(PartialEq)
@derive2(PartialOrd)
enum Choice[T] {
    Empty,
    One(T),
    Pair(T, T),
}

struct Unordered {}

instance PartialEq[Unordered] {
    fn eq(a: Unordered, b: Unordered) -> Bool {
        True
    }
}

instance PartialOrd[Unordered] {
    fn partial_cmp(a: Unordered, b: Unordered) -> Option[Ordering] {
        None
    }
}

fn print_ordering(value: Option[Ordering]) {
    match value {
        Some(Ordering.Less) => println("less"),
        Some(Ordering.Equal) => println("equal"),
        Some(Ordering.Greater) => println("greater"),
        None => println("none"),
    }
}

fn main() {
    print_ordering(Duo(1, 2).partial_cmp(Duo(1, 3)));
    print_ordering(Duo(1, 2).partial_cmp(Duo(1, 2)));
    print_ordering(Duo(2, 0).partial_cmp(Duo(1, 9)));

    let empty: Choice[Int] = Choice.Empty;
    print_ordering(empty.partial_cmp(Choice.One(0)));
    print_ordering(Choice.Pair(1, 3).partial_cmp(Choice.Pair(1, 2)));
    print_ordering(Choice.One(4).partial_cmp(Choice.One(4)));
    print_ordering(Duo(Unordered(), Unordered()).partial_cmp(Duo(Unordered(), Unordered())));
}

}
