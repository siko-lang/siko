module Main {

import Std.Macro.Derive.FromInt

@derive2(FromInt)
enum Color {
    Red,
    Green,
    Blue,
}

instance ToString[Color] {
    fn to_string(color: Color) -> String {
        match color {
            Color.Red => "Red",
            Color.Green => "Green",
            Color.Blue => "Blue",
        }
    }
}

fn print_color(color: Option[Color]) {
    match color {
        Some(color) => println(color.to_string()),
        None => println("None"),
    }
}

fn main() {
    print_color(from_int(-1));
    print_color(from_int(0));
    print_color(from_int(1));
    print_color(from_int(2));
    print_color(from_int(3));
}

}
