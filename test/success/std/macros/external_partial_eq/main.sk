module ExternalPartialEqTypes {

pub struct Duo[T] {
    pub first: T,
    pub second: T,
}

pub enum Choice[T] {
    Empty,
    One(T),
    Pair(T, T),
}

}

module Main {

import Std.Macro.Derive.PartialEq
import ExternalPartialEqTypes

instance[T: PartialEq[T]] PartialEq[Duo[T]] = auto(PartialEq)
instance[T: PartialEq[T]] PartialEq[Choice[T]] = auto(PartialEq)

fn main() {
    println(Duo(1, 2) == Duo(1, 2));
    println(Duo(1, 2) == Duo(1, 3));
    let empty: Choice[Int] = Choice.Empty;
    println(empty == empty);
    println(empty == Choice.One(1));
    println(Choice.Pair(1, 2) == Choice.Pair(1, 2));
    println(Choice.Pair(1, 2) == Choice.Pair(1, 3));
}

}
