module ExternalCloneTypes {

pub struct Example {
    pub number: Int,
    pub text: String,
}

pub struct Wrapper[T] {
    pub value: T,
}

pub enum Choice[T] {
    Empty,
    One(T),
    Pair(T, T),
}

}

module Main {

import Std.Macro.Derive.Clone
import ExternalCloneTypes

instance Clone[Example] = auto2(Clone)
instance[T: Clone[T]] Clone[Wrapper[T]] = auto2(Clone)
instance[T: Clone[T]] Clone[Choice[T]] = auto2(Clone)

fn main() {
    let original = Example(42, "hello");
    let cloned = original.clone();
    println(cloned.number);
    println(cloned.text);

    let wrapped = Wrapper("generic");
    println(wrapped.clone().value);

    match Choice.Pair("left", "right").clone() {
        Choice.Pair(left, right) => {
            println(left);
            println(right);
        }
        _ => println("wrong variant"),
    }
}

}
