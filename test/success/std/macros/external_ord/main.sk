module ExternalOrdTypes {

@derive(PartialEq, Eq, PartialOrd)
pub struct Duo[T] {
    pub first: T,
    pub second: T,
}

@derive(PartialEq, Eq, PartialOrd)
pub enum Choice[T] {
    Empty,
    One(T),
    Pair(T, T),
}

}

module Main {

import Std.Macro.Derive.Ord
import ExternalOrdTypes

instance[T: Ord[T]] Ord[Duo[T]] = auto2(Ord)
instance[T: Ord[T]] Ord[Choice[T]] = auto2(Ord)

fn print_ordering(value: Ordering) {
    match value {
        Ordering.Less => println("less"),
        Ordering.Equal => println("equal"),
        Ordering.Greater => println("greater"),
    }
}

fn main() {
    print_ordering(Duo(1, 2).cmp(Duo(1, 3)));
    print_ordering(Duo(1, 2).cmp(Duo(1, 2)));
    print_ordering(Duo(2, 0).cmp(Duo(1, 9)));

    let empty: Choice[Int] = Choice.Empty;
    print_ordering(empty.cmp(Choice.One(0)));
    print_ordering(Choice.Pair(1, 3).cmp(Choice.Pair(1, 2)));
    print_ordering(Choice.One(4).cmp(Choice.One(4)));
}

}
