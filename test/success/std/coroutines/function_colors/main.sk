module App {

import IO

pub fn app_func() {
    some_io();
}

}

module IO {

pub effect IO {
    fn some_io()
}

}

module Sync.IO {

import IO

pub instance SyncIO IO {
    fn some_io() {
        println("Sync!");
    }
}

}

module Async.IO {

import IO

pub instance AsyncIO IO {
    fn some_io() co(()) -> () {
        println("async!");
        yield ();
        println("async woo!");
    }
}

}

module Main {

import App
import IO
import Sync.IO
import Async.IO
import Std.Coroutine

fn main() {
    with IO = SyncIO {
        app_func();
    }
    with IO = AsyncIO {
        complete(co app_func());
    }
}

}