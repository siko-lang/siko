module Main {

import Std.Coroutine

fn foo(a: Int) co(Int) -> Int {
    yield 5 + a;
    return 5;
}

fn bar() {
    let c : co(Int) -> Int = co foo(4);
    let r = resume(c);
    assert(r == CoResult.Yielded(9));
    let r = resume(c);
    assert(r == CoResult.Returned(5));
    let r = resume(c);
    assert(r == CoResult.Completed);
}

fn main() {
    bar();
}

}