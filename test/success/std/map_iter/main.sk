module Main {

fn int_to_str(x: Int) -> String {
    "item_${x}"
}

fn main() {
    let doubled : Vec[Int] = (0..5).into_iter().map(|x| x * 2).collect();
    for n in doubled {
        println("${n}");
    }

    let strs : Vec[String] = (1..4).into_iter().map(|s| int_to_str(s)).collect();
    for s in strs {
        println(s);
    }
}

}
