module Main {

@safe
fn main() {
    let decimal = 1_000_000;
    let hexadecimal = 0xF_F;
    let octal = 0o1_000;

    println("${decimal}");
    println("${hexadecimal}");
    println("${octal}");

    match decimal {
        1_000_000 => println("matched"),
        _ => println("not matched")
    }

    let values: [Int; 1_0] = uninitialized();
    values[9] = 10;
    println("${values[9]}");
}

}
