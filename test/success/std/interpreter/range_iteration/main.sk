module Main {

import Std.Macro.Debug

fn exercise_range_iteration() {
    for value in 0..2 {
        match value {
            0 => println("zero"),
            1 => println("one"),
            _ => println("unexpected"),
        }
    }
}

@interpreter_test(exercise_range_iteration)
struct RangeIterationMacro {
}

fn main() {
}
}
