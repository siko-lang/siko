module Alpha.Beta.Library {

pub enum Choice {
    Selected,
    TestLocalFunctionNames

    pub fn inspect(choice: Choice) {}
}

pub fn exercise(mode: Choice) {
    match mode {
        TestLocalFunctionNames => {
            Alpha.Beta.Library.exercise(Selected);
            Beta.Library.exercise(Selected);
            Library.exercise(Selected);
            exercise(Selected);
        }
        Selected => {}
    }

    let a: Alpha.Beta.Library.Choice = Alpha.Beta.Library.Choice.Selected;
    let b: Beta.Library.Choice = Beta.Library.Choice.Selected;
    let c: Library.Choice = Library.Choice.Selected;
    let d: Choice = Choice.Selected;
    let e: Choice = Selected;

    Alpha.Beta.Library.Choice.inspect(a);
    Beta.Library.Choice.inspect(b);
    Library.Choice.inspect(c);
    Choice.inspect(d);
    inspect(e);
}

}

module Main {

import Alpha.Beta.Library

fn main() {
    Alpha.Beta.Library.exercise(Selected);
    Beta.Library.exercise(Selected);
    Library.exercise(Selected);
    exercise(Selected);

    let a: Alpha.Beta.Library.Choice = Alpha.Beta.Library.Choice.Selected;
    let b: Beta.Library.Choice = Beta.Library.Choice.Selected;
    let c: Library.Choice = Library.Choice.Selected;
    let d: Choice = Choice.Selected;
    let e: Choice = Selected;

    Alpha.Beta.Library.Choice.inspect(a);
    Beta.Library.Choice.inspect(b);
    Library.Choice.inspect(c);
    Choice.inspect(d);
    inspect(e);
}

}
