module Main {

trait Format[F] {
    fn format(value: F, prefix: String, suffix: String) -> String
}

enum Word {
    Hello
}

instance Format[Word] {
    fn format(value: Word, prefix: String, suffix: String) -> String {
        "${prefix}hello${suffix}"
    }
}

fn erase(value: Word) -> Format {
    Format(value)
}

fn main() {
    let object = erase(Hello);
    println(format(object, prefix: "<", sufix: ">"));
}

}
