module Main {

import Std.Macro

trait CopyLike[T] {}

struct Target {}

pub macro RejectStruct {
    fn external_derive_struct(ctx: MacroContext) -> Result[InstanceBody, MacroError] {
        Err(MacroError.NotSupported("external struct rejected"))
    }
}

instance CopyLike[Target] = auto2(RejectStruct)

fn main() {}

}
