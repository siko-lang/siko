module Derives {

import Std.Macro

pub macro RejectStruct {
    fn derive_struct(def: StructDef) -> Result[InstanceDef, MacroError] {
        Err(MacroError.NotSupported("attached struct rejected"))
    }
}

}

module Main {

import Derives

@derive2(RejectStruct)
struct Target {}

fn main() {}

}
