module Main {

import Std.Macro

trait Rewrite[T] {}

enum Target {
    A,
}

pub macro RejectEnum {
    fn external_derive_enum(ctx: MacroContext) -> Result[InstanceBody, MacroError] {
        Err(MacroError.NotSupported("external enum rejected"))
    }
}

instance Rewrite[Target] = auto(RejectEnum)

fn main() {}

}
