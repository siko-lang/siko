module Main {

import Std.Macro

trait Rewrite[T] {}

pub macro RejectEnum {
    fn derive_enum(def: EnumDef, trait_def: TraitDef) -> Result[InstanceDef, MacroError] {
        Err(MacroError.NotSupported("attached enum rejected"))
    }
}

@derive2(RejectEnum(Rewrite))
enum Target {
    A,
}

fn main() {}

}
