module Siko.Syntax.Expr where

import Json
import Json.Serialize
import Siko.Syntax.Ident
import Siko.Syntax.Pattern as P
import Siko.Syntax.Location

data Case = { pattern :: P.Pattern,
              body :: Expr,
            } deriving (Show, ToJson, FromJson)

data RecordConstructionItem = { field_name :: Ident,
                                body :: Expr,
                              } deriving (Show, ToJson, FromJson)

data Op = Equal
        | NotEqual
        | And
        | Or
        | LessThan
        | GreaterThan
        | LessOrEqualThan
        | GreaterOrEqualThan
        | Add
        | Sub
        | Mul
        | Div
        | PipeForward
        deriving (Show, PartialEq, ToJson, FromJson)

data Expr = Expr SimpleExpr Location deriving (ToJson, FromJson)

data EffectHandler = { name :: Ident,
                       value :: Expr
                     } deriving (Show, ToJson, FromJson)

instance Show Expr where
    show (Expr s _) = show s

data SimpleExpr = Lambda [P.Pattern] Expr
                | Paren Expr
                | FunctionCall Expr [Expr]
                | BinaryOp Op Expr Expr
                | If Expr Expr Expr
                | Tuple [Expr]
                | List [Expr]
                | Path Ident
                | IntegerLiteral String
                | FloatLiteral String
                | StringLiteral String
                | CharLiteral Char
                | Do [Expr]
                | Bind P.Pattern Expr
                | FieldAccess Ident Expr
                | TupleFieldAccess String Expr
                | Formatter String [Expr]
                | CaseOf Expr [Case]
                | Not Expr
                | Negative Expr
                | RecordInitialization Ident [RecordConstructionItem]
                | RecordUpdate Ident [RecordConstructionItem]
                | Return Expr
                | Try Expr
                | Continue Expr
                | Break Expr
                | Loop P.Pattern Expr Expr
                | ArgRef Int
                | With [EffectHandler] Expr
                deriving (Show, ToJson, FromJson)