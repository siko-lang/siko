module Siko.Transpiler.TranspilerNormal where

import Siko.Transpiler.ExternalsNormal

import Siko.MIR.Expr as ME
import Siko.MIR.Data as MD
import Siko.MIR.Function
import Siko.MIR.Program
import Siko.MIR.Type as MT
import Siko.Transpiler.Rust as R
import Siko.Transpiler.Rust.Type as RT
import Siko.Util.Format
import Map

data ExternalId = ExternalId String String deriving (PartialEq, Eq, PartialOrd, Ord)

data TypeStore = { structs :: Map RT.Type R.Struct,
                   enums :: Map RT.Type R.Enum  }

data ExternStructBuilder = ExternStructBuilder ([MT.Type] -> [R.StructField])
data ExternFnBuilder = ExternFnBuilder (Program -> TypeStore -> [MT.Type] -> MT.Type -> R.Expr)

createTypeStore :: TypeStore
createTypeStore = TypeStore empty empty

addStruct :: TypeStore -> RT.Type -> R.Struct -> TypeStore
addStruct type_store type struct = do
    (structs, _) <- insert type_store.structs type struct
    type_store { structs = structs }

getStruct :: TypeStore -> RT.Type -> R.Struct
getStruct type_store type = case get type_store.structs type of
    Some struct -> struct
    None -> panic "Struct {} not found" % type

addEnum :: TypeStore -> RT.Type -> R.Enum -> TypeStore
addEnum type_store type enum = do
    (enums, _) <- insert type_store.enums type enum
    type_store { enums = enums }

getEnum :: TypeStore -> RT.Type -> R.Enum
getEnum type_store type = case get type_store.enums type of
    Some enum -> enum
    None -> panic "Enum {} not found" % type

getArgName :: Int -> String
getArgName index = "arg{}" % index

innerValueField = "value"
cloneName = "clone"
stringTypeName = "String_String_0"
intTypeName = "Int_Int_0"
floatTypeName = "Float_Float_0"
boolTypeName = "Bool_Bool_0"
charTypeName = "Char_Char_0"
stdOpsAdd = "std::ops::Add::add"
stdOpsSub = "std::ops::Sub::sub"
stdOpsMul = "std::ops::Mul::mul"
stdOpsDiv = "std::ops::Div::div"
derefName = "std::ops::Deref::deref"

getRustFriendlyName :: String -> String
getRustFriendlyName input = case input of
    "type" -> "_type"
    "ref" -> "_ref"
    _ -> do
        output <- replace input "." "_"
        output

getRustIdentity :: Identity -> String
getRustIdentity id = getRustFriendlyName (show id)

convertType :: MT.Type -> RT.Type
convertType mir_type = do
    t <- case mir_type of
        MT.Adt id _ -> getRustFriendlyName (show id)
        MT.Record id _ -> getRustFriendlyName (show id)
        MT.Ref t -> return RT.Ref (convertType t)
        MT.Never ->  return RT.Never
        MT.Box t -> return typeToBoxedType (convertType t)
        MT.Var _ t -> return (convertType t)
    RT.Named t

typeToBoxedType :: RT.Type -> RT.Type
typeToBoxedType type = RT.Box type

typeToRcType :: RT.Type -> RT.Type
typeToRcType type = RT.Rc type

boxExpr :: R.Expr -> R.Expr
boxExpr expr = R.FunctionCall "std::boxed::Box::new" [expr]

convertPattern :: TypeStore -> ME.Checker -> (R.Pattern, Option R.Expr)
convertPattern type_store checker = case checker of
    ME.IntegerChecker lit -> (R.IntegerPattern lit, None)
    ME.StringChecker lit -> do
        guard <- R.VarRef "a"
        guard <- R.FieldAccess "value" guard
        guard <- R.MethodCall guard "eq" [R.StringLiteral (escapeString lit)]
        (R.StringPattern lit, Some guard)
    ME.CharChecker lit -> (R.CharPattern lit, None)
    ME.CharRangeChecker s e kind -> do
        kind <- case kind of
            ME.Inclusive -> R.Inclusive
            ME.Exclusive -> R.Exclusive
        (R.CharRangePattern s e kind, None)
    ME.VariantChecker index v type -> do
        case type of
            MT.Adt _ _ -> do
                rust_type <- convertType type
                enum <- getEnum type_store rust_type
                variant <- atIndex enum.variants index
                variant_name <- "{}::{}" % (rust_type, variant.name)
                (R.VariantPattern variant_name (Some (show v)), None)
            MT.Record _ _ -> do
                (R.VariantPattern (show v) None, None)
            _ -> panic "Variant is not a record nor an adt"
    ME.WildcardChecker -> (R.WildcardPattern, None)

data Context = { type_store :: TypeStore, loop_var :: Option String }

convertExpr :: Context -> ME.Expr -> R.Expr
convertExpr context mir_expr = do
    ME.Expr expr expr_type _ <- mir_expr
    case expr of
        ME.Do args -> do
            args <- args |> List.iter |> map (\arg -> convertExpr context arg) |> toList
            last <- atIndex args (getLength args - 1)
            is_var_decl <- case last of
                R.VarDecl _ _ _ -> True
                R.VarDeclMut _ _ _ -> True
                _ -> False
            if is_var_decl
                then do
                    rust_type <- convertType expr_type
                    unit <- R.StructCtor (show rust_type) []
                    R.Block (args + [unit])
                else R.Block args
        ME.StaticFunctionCall id args -> do
            rust_function_name <- getRustIdentity id
            args <- args |> List.iter |> map (\arg -> convertExpr context arg) |> toList
            R.FunctionCall rust_function_name args
        ME.IntegerLiteral lit -> R.StructCtor intTypeName [R.FieldInitItem innerValueField (R.IntegerLiteral lit)]
        ME.FloatLiteral lit -> R.StructCtor floatTypeName [R.FieldInitItem innerValueField (R.FloatLiteral lit)]
        ME.StringLiteral lit -> do
            literal <- R.StringLiteral lit
            to_string_call <- R.MethodCall literal "to_string" []
            R.StructCtor stringTypeName [R.FieldInitItem innerValueField to_string_call]
        ME.CharLiteral lit -> R.StructCtor charTypeName [R.FieldInitItem innerValueField (R.CharLiteral lit)]
        ME.VarDecl v rhs -> do
            n <- show v
            ME.Expr _ rhs_type _ <- rhs
            rhs_expr <- convertExpr context rhs
            t <- Some (convertType rhs_type)
            R.VarDecl n rhs_expr t
        ME.VarRef v -> case v of
            ME.Arg index -> R.VarRef (getArgName index)
            _ -> R.VarRef (show v)
        ME.CaseOf body cases -> do
            cases <- cases |> List.iter |> map (\c -> do
                (case_pattern, case_guard) <- convertPattern context.type_store c.checker
                case_body <- convertExpr context c.body
                R.MatchCase case_pattern case_body case_guard) |> toList
            body <- convertExpr context body
            R.Match body cases
        ME.FieldAccess name receiver -> R.FieldAccess (getRustFriendlyName name) (convertExpr context receiver)
        ME.If cond true_branch false_branch -> do
            true_pattern <- R.VariantPattern ("{}::True" % boolTypeName) (Some "_")
            false_pattern <- R.VariantPattern ("{}::False" % boolTypeName) (Some "_")
            true_case <- R.MatchCase true_pattern (convertExpr context true_branch) None
            false_case <- R.MatchCase false_pattern (convertExpr context false_branch) None
            cases <- [true_case, false_case]
            R.Match (convertExpr context cond) cases
        ME.Loop v initializer args -> do
            n <- show v
            var_decl <- R.VarDeclMut n (convertExpr context initializer) None
            inner_context <- Context context.type_store (Some n)
            args <- args |> List.iter |> map (\arg -> convertExpr inner_context arg) |> toList
            loop_body <- R.Assign (R.VarRef n) (R.Block args)
            loop_expr <- R.Loop [loop_body]
            R.Block [var_decl, loop_expr]
        ME.Break e -> R.Break (convertExpr context e)
        ME.Continue e -> do
            case context.loop_var of
                Some n -> do
                    assign <- R.Assign (R.VarRef n) (convertExpr context e)
                    R.Block [assign, R.Continue]
                None -> panic "No loop var found for continue"
        ME.Return e -> R.Return (convertExpr context e)
        ME.RecordUpdate v items -> do
            n <- show v
            new <- "new"
            var_decl <- R.VarDeclMut new (R.VarRef n) None
            assignments <- items |> List.iter |> map (\update -> do
            lhs <- (R.FieldAccess (getRustFriendlyName update.field_name) (R.VarRef new))
            rhs <- (convertExpr context update.body)
            R.Assign lhs rhs) |> toList
            R.Block ([var_decl] + assignments + [R.VarRef new])
        ME.List args -> do
            rust_type <- convertType expr_type
            args <- args |> List.iter |> map (\arg -> convertExpr context arg) |> toList
            R.StructCtor (show rust_type) [R.FieldInitItem innerValueField (R.List args)]
        ME.Clone expr -> do
            expr <- convertExpr context expr
            R.MethodCall expr cloneName []
        ME.Multi _ -> panic "Multi in transpiler"
        ME.Deref expr -> do
            expr <- convertExpr context expr
            R.Deref expr
        ME.Ref expr -> do
            expr <- convertExpr context expr
            R.Ref expr
        ME.Move expr -> convertExpr context expr
        ME.Box expr -> do
            expr <- convertExpr context expr
            boxExpr expr

convertRecord :: MD.Record -> Map ExternalId ExternStructBuilder -> R.Struct
convertRecord record external_struct_gens = do
    name <- getRustIdentity record.id
    rust_fields <- case record.external_info of
        Some info -> do
            info :: MD.ExternalRecordInfo <- info
            Identity mod name _ <- record.id
            id <- ExternalId mod name
            case get external_struct_gens id of
                Some struct_gen -> do
                    ExternStructBuilder struct_gen <- struct_gen
                    struct_gen info.type_args
                None -> panic "Extern struct {}/{} is not implemented" % (mod, name)
        None ->
            record.fields |> List.iter |> map (\field -> do
                R.StructField (getRustFriendlyName field.name) (convertType field.type)) |> toList
    R.Struct name rust_fields [R.Clone]

convertAdt :: MD.AlgebraicDataType -> R.Enum
convertAdt adt = do
    name <- getRustIdentity adt.id
    rust_variants <- adt.variants |> List.iter |> map (\variant -> do
                R.Variant (getRustFriendlyName variant.name) (convertType variant.type)) |> toList
    R.Enum name rust_variants [R.Clone]

processImpl :: Program -> R.Program -> Context -> String -> MD.ExternalClassImpl -> Option ME.Expr -> R.Program
processImpl mir_program program context type_name impl impl_body_fragment = do
    rust_type_name <- RT.Named type_name
    (name, methods) <- case impl of
            MD.Show -> do
                impl_body_fragment <- Option.unwrap impl_body_fragment
                args <- [("fmt", RT.Named "&mut std::fmt::Formatter")]
                result <- RT.Named "std::fmt::Result"
                var_decl <- R.VarDecl (getArgName 0) (R.MethodCall (R.VarRef "self") cloneName []) None
                show_call <- convertExpr context impl_body_fragment
                fmt_call <- R.FunctionCall "write!" [R.VarRef "fmt", R.StringLiteral "{}", R.FieldAccess innerValueField show_call]
                body <- R.Block [var_decl, fmt_call]
                method <- R.Function "fmt" True args result body
                ("std::fmt::Display", [method])
            MD.PartialEq -> do
                impl_body_fragment <- Option.unwrap impl_body_fragment
                args <- [(getArgName 1, RT.Named "&{}" % type_name)]
                result <- RT.Named "bool"
                var0_decl <- R.VarDecl (getArgName 0) (R.MethodCall (R.VarRef "self") cloneName []) (Some rust_type_name)
                var1_decl <- R.VarDecl (getArgName 1) (R.MethodCall (R.VarRef (getArgName 1)) cloneName []) (Some rust_type_name)
                op_call <- convertExpr context impl_body_fragment
                body <- R.Block [var0_decl, var1_decl, sikoBoolToRustBool op_call (RT.Named boolTypeName)]
                method <- R.Function "eq" True args result body
                ("std::cmp::PartialEq", [method])
            MD.Eq -> do
                ("std::cmp::Eq", [])
            MD.PartialOrd -> do
                impl_body_fragment <- Option.unwrap impl_body_fragment
                args <- [(getArgName 1, RT.Named "&{}" % type_name)]
                result <- RT.Named "Option<std::cmp::Ordering>"
                var0_decl <- R.VarDecl (getArgName 0) (R.MethodCall (R.VarRef "self") cloneName []) (Some rust_type_name)
                var1_decl <- R.VarDecl (getArgName 1) (R.MethodCall (R.VarRef (getArgName 1)) cloneName []) (Some rust_type_name)
                ME.Expr _ optional_ordering_type _ <- impl_body_fragment
                op_call <- convertExpr context impl_body_fragment
                body <- R.Block [var0_decl, var1_decl, sikoOptionalOrderingToRustOptionalOrdering mir_program op_call optional_ordering_type]
                method <- R.Function "partial_cmp" True args result body
                ("std::cmp::PartialOrd", [method])
            MD.Ord -> do
                impl_body_fragment <- Option.unwrap impl_body_fragment
                args <- [(getArgName 1, RT.Named "&{}" % type_name)]
                result <- RT.Named "std::cmp::Ordering"
                var0_decl <- R.VarDecl (getArgName 0) (R.MethodCall (R.VarRef "self") cloneName []) (Some rust_type_name)
                var1_decl <- R.VarDecl (getArgName 1) (R.MethodCall (R.VarRef (getArgName 1)) cloneName []) (Some rust_type_name)
                ME.Expr _ ordering_type _ <- impl_body_fragment
                op_call <- convertExpr context impl_body_fragment
                rust_ordering_type <- convertType ordering_type
                body <- R.Block [var0_decl, var1_decl, sikoOrderingToRustOrdering op_call rust_ordering_type]
                method <- R.Function "cmp" True args result body
                ("std::cmp::Ord", [method])
    //println "processImpl: {} {}" % (name, rust_type_name)
    trait_impl <- R.TraitImpl name rust_type_name methods
    impls <- program.impls + [trait_impl]
    program { impls = impls }

transpile :: Program -> String
transpile program = do
    external_functions <- initializeExternalFunctions
    external_structs <- initializeExternalStructFields
    type_store <- createTypeStore
    rust_program <- R.Program [] [] [] []
    (type_store, rust_program) <- program.adts |> Map.iter |> fold (\(type_store, rust_program), (_, adt) -> do
        enum <- convertAdt adt
        enum_type <- RT.Named enum.name
        type_store <- addEnum type_store enum_type enum
        enums <- rust_program.enums + [enum]
        rust_program <- rust_program { enums = enums }
        (type_store, rust_program)) (type_store, rust_program)
    (type_store, rust_program) <- program.records |> Map.iter |> fold (\(type_store, rust_program), (_, record) -> do
        struct <- convertRecord record external_structs
        struct_type <- RT.Named struct.name
        type_store <- addStruct type_store struct_type struct
        structs <- rust_program.structs + [struct]
        rust_program <- rust_program { structs = structs }
        (type_store, rust_program)) (type_store, rust_program)
    context <- Context type_store None
    rust_program <- program.adts |> Map.iter |> fold (\rust_program, (_, adt) -> do
            name <- getRustIdentity adt.id
            adt.external_class_impls |> List.iter |> fold (\rust_program, (external_class_impl, impl_body_fragment) -> do
                processImpl program rust_program context name external_class_impl impl_body_fragment) rust_program
        ) rust_program
    rust_program <- program.records |> Map.iter |> fold (\rust_program, (_, record) -> do
            name <- getRustIdentity record.id
            record.external_class_impls |> List.iter |> fold (\rust_program, (external_class_impl, impl_body_fragment) -> do
                processImpl program rust_program context name external_class_impl impl_body_fragment) rust_program
        ) rust_program
    rust_program <- program.functions |> Map.iter |> fold (\rust_program, (_, mir_function) -> do
        rust_function_name <- getRustIdentity mir_function.id
        (rust_args, _) <- mir_function.args |> List.iter |> fold (\(args, index), arg -> do
            arg_type <- convertType arg
            arg_name <- getArgName index
            args <- args + [(arg_name, arg_type)]
            (args, index + 1)) ([], 0)
        rust_result <- convertType mir_function.result
        rust_body <- case mir_function.kind of
            Normal mir_body -> do
                    ME.Expr b _ _ <- mir_body
                    case b of
                        ME.Do _ -> convertExpr context mir_body
                        _ -> R.Block [convertExpr context mir_body]
            Extern -> do
                    Identity mod name _ <- mir_function.id
                    id <- ExternalId mod name
                    case get external_functions id of
                        Some external_gen -> do
                            ExternFnBuilder external_gen <- external_gen
                            external_gen program type_store mir_function.args mir_function.result
                        None -> do
                            println "Extern function {}/{} is not implemented" % (mod, name)
                            R.Block [R.FunctionCall "unimplemented!" []]
            VariantCtor index ->
                do
                enum <- getEnum type_store rust_result
                variant <- atIndex enum.variants index
                struct <- getStruct type_store (RT.getInnerType variant.type)
                fields <- struct.fields |> List.iter |> fold (\fields, field -> do
                    arg <- getArgName (getLength fields)
                    field_init_item <- if RT.isBoxed field.type
                        then R.FieldInitItem field.name (boxExpr (R.VarRef arg))
                        else R.FieldInitItem field.name (R.VarRef arg)
                    fields <- fields + [field_init_item]
                    fields) []
                name <- "{}::{}" % (enum.name, variant.name)
                R.Block [R.FunctionCall name [R.StructCtor struct.name fields]]
            RecordCtor -> do
                mir_record_id <- MT.getIdentity mir_function.result
                mir_record <- getRecord program mir_record_id
                struct <- getStruct type_store rust_result
                fields <- struct.fields |> List.iter |> fold (\fields, field -> do
                    index <- getLength fields
                    arg <- getArgName index
                    field_init_item <- if RT.isBoxed field.type
                        then R.FieldInitItem field.name (boxExpr (R.VarRef arg))
                        else R.FieldInitItem field.name (R.VarRef arg)
                    fields <- fields + [field_init_item]
                    fields) []
                R.Block [R.StructCtor struct.name fields]
        rust_function <- R.Function rust_function_name False rust_args rust_result rust_body
        functions <- rust_program.functions + [rust_function]
        rust_program { functions = functions }) rust_program
    R.generateProgram rust_program
