generateListNextItem :: Program -> TypeStore -> [MT.Type] -> MT.Type -> R.Expr
generateListNextItem program type_store arg_types result_type = do
    rust_type <- convertType result_type
    field_access0 <- R.FieldAccess innerValueField (R.VarRef (getArgName 0))
    deref0 <- R.FunctionCall derefName [R.Ref field_access0]
    state <- "state"
    state_decl <- R.VarDeclMut state (R.MethodCall deref0 cloneName []) None
    value <- "value"
    value_decl <- R.VarDecl value (R.MethodCall (R.VarRef state) "next" []) None
    item <- "item"
    some_pattern <- R.VariantPattern "Some" (Some item)
    none_pattern <- R.VariantPattern "None" None
    rust_result_type <- convertType result_type
    some_record_type <- getVariantRecordType program result_type "Some"
    none_record_type <- getVariantRecordType program result_type "None"
    rust_some_record_type <- convertType (MT.Record some_record_type)
    rust_none_record_type <- convertType (MT.Record none_record_type)
    some_record <- getRecord program some_record_type
    item_field <- atIndex some_record.fields 0
    rust_item_type <- convertType item_field.type
    tuple_record <- case item_field.type of
        MT.Record record_id -> getRecord program record_id
        _ -> panic "Tuple is not a record"
    state_field <- atIndex tuple_record.fields 0
    value_field <- atIndex tuple_record.fields 1
    rust_state_type <- convertType state_field.type
    clone_call <- R.MethodCall (R.VarRef item) cloneName []
    state_ctor <- R.StructCtor (show rust_state_type) [R.FieldInitItem innerValueField (R.VarRef state)]
    tuple_ctor <- R.StructCtor (show rust_item_type) [R.FieldInitItem state_field.name state_ctor,
                                                      R.FieldInitItem value_field.name (R.VarRef item)]
    some_ctor <- R.StructCtor (show rust_some_record_type) [R.FieldInitItem item_field.name tuple_ctor]
    none_ctor <- R.StructCtor (show rust_none_record_type) []
    some_case <- R.MatchCase some_pattern (R.FunctionCall ("{}::Some" % rust_result_type) [some_ctor])
    none_case <- R.MatchCase none_pattern (R.FunctionCall ("{}::None" % rust_result_type) [none_ctor])
    cases <- [some_case, none_case]
    match <- R.Match (R.VarRef value) cases
    R.Block [state_decl, value_decl, match]

