module Siko.Transpiler.ExternalsNormal where

import Siko.MIR.Data
import Siko.MIR.Program
import Siko.MIR.Type as MT
import Siko.Transpiler.Rust as R
import Siko.Transpiler.TranspilerNormal
import Map

getVariantRecordType :: Program -> MT.Type -> String -> Identity
getVariantRecordType program mir_type name = do
    adt_id <- case mir_type of
        MT.Adt adt_id -> adt_id
        _ -> panic "Not an ADT"
    adt <- getAdt program adt_id
    loop index <- 0 do
        variant <- atIndex adt.variants index
        if variant.name == name
            then return (MT.getIdentity variant.type)
            else index + 1

generatePrintStr :: Program -> TypeStore -> [MT.Type] -> MT.Type -> R.Expr
generatePrintStr program type_store arg_types result_type = do
    rust_type <- convertType result_type
    field_access <- R.FieldAccess innerValueField (R.VarRef (getArgName 0))
    print_call <- R.FunctionCall "print!" [R.StringLiteral "{}", field_access]
    unit <- R.StructCtor (show rust_type) []
    R.Block [print_call, unit]

generateStringAdd :: Program -> TypeStore -> [MT.Type] -> MT.Type -> R.Expr
generateStringAdd program type_store arg_types result_type = do
    rust_type <- convertType result_type
    new <- "new"
    new_decl <- R.VarDeclMut new (R.VarRef (getArgName 0)) None
    field_access0 <- R.FieldAccess innerValueField (R.VarRef new)
    field_access1 <- R.FieldAccess innerValueField (R.VarRef (getArgName 1))
    extend_call <- R.MethodCall (field_access0) "push_str" [R.Ref field_access1]
    R.Block [new_decl, extend_call, R.VarRef new]

generateAdd :: Program -> TypeStore -> [MT.Type] -> MT.Type -> R.Expr
generateAdd program type_store arg_types result_type = do
    rust_type <- convertType result_type
    field_access0 <- R.FieldAccess innerValueField (R.VarRef (getArgName 0))
    field_access1 <- R.FieldAccess innerValueField (R.VarRef (getArgName 1))
    add_call <- R.FunctionCall stdOpsAdd [R.Ref field_access0, R.Ref field_access1]
    new <- "new"
    new_decl <- R.VarDecl new add_call None
    struct_ctor <- R.StructCtor (show rust_type) [R.FieldInitItem innerValueField (R.VarRef new)]
    R.Block [new_decl, struct_ctor]

