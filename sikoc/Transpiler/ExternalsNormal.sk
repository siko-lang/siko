generateStringFields :: [MT.Type] -> [R.StructField]
generateStringFields args = [R.StructField innerValueField (R.Normal "std::string::String")]

generateIntFields :: [MT.Type] -> [R.StructField]
generateIntFields args = [R.StructField innerValueField (R.Normal "i64")]

generateFloatFields :: [MT.Type] -> [R.StructField]
generateFloatFields args = [R.StructField innerValueField (R.Normal "f64")]

generateCharFields :: [MT.Type] -> [R.StructField]
generateCharFields args = [R.StructField innerValueField (R.Normal "char")]

generateListFields :: [MT.Type] -> [R.StructField]
generateListFields args = do
    first <- atIndex args 0
    rust_type_arg <- convertType first
    [R.StructField innerValueField (R.Normal "std::vec::Vec<{}>" % rust_type_arg)]

generateListIteratorFields :: [MT.Type] -> [R.StructField]
generateListIteratorFields args = do
    first <- atIndex args 0
    rust_type_arg <- convertType first
    [R.StructField innerValueField (typeToRcType (R.Normal "std::vec::IntoIter<{}>" % rust_type_arg))]

generateMapFields :: [MT.Type] -> [R.StructField]
generateMapFields args = do
    first <- atIndex args 0
    second <- atIndex args 1
    rust_type_arg1 <- convertType first
    rust_type_arg2 <- convertType second
    [R.StructField innerValueField (typeToRcType (R.Normal "std::collections::BTreeMap<{}, {}>" % (rust_type_arg1, rust_type_arg2)))]

generateMapIteratorFields :: [MT.Type] -> [R.StructField]
generateMapIteratorFields args = do
    first <- atIndex args 0
    second <- atIndex args 1
    rust_type_arg1 <- convertType first
    rust_type_arg2 <- convertType second
    [R.StructField innerValueField (typeToRcType (R.Normal "std::vec::IntoIter<({}, {})>" % (rust_type_arg1, rust_type_arg2)))]

initializeExternalStructFields :: Map ExternalId ExternStructBuilder
initializeExternalStructFields = do
    externals <- Map.empty
    (externals, _) <- insert externals (ExternalId "String" "String") (ExternStructBuilder generateStringFields)
    (externals, _) <- insert externals (ExternalId "Int" "Int") (ExternStructBuilder generateIntFields)
    (externals, _) <- insert externals (ExternalId "Float" "Float") (ExternStructBuilder generateFloatFields)
    (externals, _) <- insert externals (ExternalId "Char" "Char") (ExternStructBuilder generateCharFields)
    (externals, _) <- insert externals (ExternalId "List" "List") (ExternStructBuilder generateListFields)
    (externals, _) <- insert externals (ExternalId "List" "ListIterator") (ExternStructBuilder generateListIteratorFields)
    (externals, _) <- insert externals (ExternalId "Map" "Map") (ExternStructBuilder generateMapFields)
    (externals, _) <- insert externals (ExternalId "Map" "MapIterator") (ExternStructBuilder generateMapIteratorFields)
    externals
