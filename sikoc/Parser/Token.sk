module Siko.Parser.Token.Kind where

data TokenKind = VarIdentifier
    | TypeIdentifier
    | Equal
    | LParen
    | RParen
    | LBracket
    | RBracket
    | LCurly
    | RCurly
    | StringLiteral
    | IntegerLiteral
    | CharLiteral
    | Dot
    | DoubleDot
    | Comma
    | ExclamationMark
    | Ampersand
    | Wildcard
    | KeywordModule
    | KeywordWhere
    | KeywordDo
    | KeywordClass
    | RightArrow
    | LeftArrow
    | InclusiveRange
    | EndOfItem
    | EndOfBlock
    | EndOfModule
    deriving (Show, PartialEq, Eq)

module Siko.Parser.Token where

import Siko.Syntax.Location
import Siko.Parser.Token.Kind as Kind

data Token = VarIdentifier String
    | TypeIdentifier String
    | Equal
    | LParen
    | RParen
    | LBracket
    | RBracket
    | LCurly
    | RCurly
    | StringLiteral String
    | IntegerLiteral String
    | CharLiteral Char
    | Dot
    | DoubleDot
    | Comma
    | ExclamationMark
    | Ampersand
    | Wildcard
    | KeywordModule
    | KeywordWhere
    | KeywordDo
    | KeywordClass
    | RightArrow
    | LeftArrow
    | InclusiveRange
    | EndOfItem
    | EndOfBlock
    | EndOfModule
    deriving (Show)


data TokenInfo = {
        token :: Token,
        span :: Span
    }

instance Show TokenInfo where
    show a = show a.token

getKind :: Token -> Kind.TokenKind
getKind token = case token of
    VarIdentifier _ -> Kind.VarIdentifier
    TypeIdentifier _ -> Kind.TypeIdentifier
    Equal -> Kind.Equal
    LParen -> Kind.LParen
    RParen -> Kind.RParen
    LBracket -> Kind.LBracket
    RBracket -> Kind.RBracket
    LCurly -> Kind.LCurly
    RCurly -> Kind.RCurly
    StringLiteral _ -> Kind.StringLiteral
    IntegerLiteral _ -> Kind.IntegerLiteral
    CharLiteral _ -> Kind.CharLiteral
    Dot -> Kind.Dot
    DoubleDot -> Kind.DoubleDot
    Comma -> Kind.Comma
    ExclamationMark -> Kind.ExclamationMark
    Ampersand -> Kind.Ampersand
    Wildcard -> Kind.Wildcard
    KeywordModule -> Kind.KeywordModule
    KeywordWhere -> Kind.KeywordWhere
    KeywordDo -> Kind.KeywordDo
    KeywordClass -> Kind.KeywordClass
    RightArrow -> Kind.RightArrow
    LeftArrow -> Kind.LeftArrow
    InclusiveRange -> Kind.InclusiveRange
    EndOfItem -> Kind.EndOfItem
    EndOfBlock -> Kind.EndOfBlock
    EndOfModule -> Kind.EndOfModule
