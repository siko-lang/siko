module Siko.TypedHIR.Data where

import Siko.Syntax.Location
import Siko.TypedHIR.Type
import Siko.TypedHIR.Program as HP

data DeriveInfo = { class_name :: HP.FullyQualifiedName,
                    location :: Location,
                  } deriving (Show)

data Variant = { name :: String,
                 location :: Location,
                 items :: [Type],
               } deriving (Show)

data VariantInfo = VariantInfo HP.FullyQualifiedName Int Location deriving (Show)

data AlgebraicDataType = { name :: HP.FullyQualifiedName,
                           location :: Location,
                           type_args :: [Type],
                           variants :: [Variant],
                           variant_ctors :: [Type],
                           derived_classes :: [DeriveInfo],
                           type :: Type,
                        } deriving (Show)

data RecordField = RecordField String Type deriving (Show)

data Record = { name :: HP.FullyQualifiedName,
                location :: Location,
                type_args :: [Type],
                fields :: [RecordField],
                external :: Bool,
                record_ctor :: Type,
                derived_classes :: [DeriveInfo],
                type :: Type,
              } deriving (Show)