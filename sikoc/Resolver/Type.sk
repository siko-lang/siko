module Siko.Resolver.Type where

import Siko.Syntax.TypeSignature as ST
import Siko.Syntax.Ident
import Siko.Resolver
import Siko.Syntax.Class as SC
import Siko.Resolver.Item as I
import Siko.Resolver.Module
import Siko.Resolver.Error
import Siko.Constants
import Siko.HIR.Type
import Siko.HIR.Program as HP
import Map

data TypeResolverState = { args :: Map String TypeVar,
                           constraints :: Map TypeVar [Constraint],
                           module_resolver :: ModuleResolver,
                           used_type_args :: [String],
                           next_type_var :: Int,
                           allow_implicit :: Bool }

disableImplicitTypeArgs :: TypeResolverState -> TypeResolverState
disableImplicitTypeArgs type_resolver = type_resolver { allow_implicit = False }

processClassConstraint :: ResolverState -> TypeResolverState -> ModuleResolver -> SC.Constraint -> (ResolverState, TypeResolverState)
processClassConstraint state type_resolver module_resolver c = do
    (state, type_resolver) <- case resolveClass module_resolver c.class_name of
        Ok class_name -> do
            constraint <- ClassConstraint class_name
            type_arg <- getString c.argument
            (success, type_resolver) <- addTypeArgumentConstraint type_resolver type_arg constraint
            if success
                then (state, type_resolver)
                else do
                    state <- addError state (UnknownTypeArg c.argument)
                    (state, type_resolver)
        Err err -> do
            state <- addError state err
            (state, type_resolver)
    (state, type_resolver)

resolveClass :: ModuleResolver -> Ident -> Result HP.FullyQualifiedName ResolverError
resolveClass module_resolver name = do
    ResolvedItem n item <- try resolveItem module_resolver.type_names UnknownType name
    case item of
        I.Class _ -> Ok (n)
        _ -> Err (NotAClassName name)

resolveTypeName :: TypeResolverState -> Ident -> Result HP.FullyQualifiedName ResolverError
resolveTypeName state name = do
    ResolvedItem name _ <- try resolveItem state.module_resolver.type_names UnknownType name
    Ok name

createTypeResolverState :: ModuleResolver -> Bool -> TypeResolverState
createTypeResolverState module_resolver allow_implicit =
    TypeResolverState empty empty module_resolver [] 0 allow_implicit

initTypeResolver :: ModuleResolver -> [Ident] -> TypeResolverState
initTypeResolver module_resolver type_arguments = do
    type_resolver <- createTypeResolverState module_resolver False
    type_resolver <- addTypeArguments type_resolver type_arguments
    type_resolver

processTypeArgs :: ResolverState -> TypeResolverState -> [Ident] -> (ResolverState, [Type])
processTypeArgs resolver_state state type_arguments = do
    resolver_state <- type_arguments |> List.iter |> fold (\resolver_state, arg -> do
        n <- getString arg
        if not (contains state.used_type_args n)
            then addError resolver_state (UnusedTypeArg arg)
            else resolver_state) resolver_state
    type_args <- state.args |> Map.iter |> map (\(n, var) -> FixedTypeArg n var []) |> toList
    (resolver_state, type_args)

addTypeArguments :: TypeResolverState -> [Ident] -> TypeResolverState
addTypeArguments type_resolver type_arguments =
    type_arguments |> List.iter |> fold (\type_resolver, arg -> addTypeArgument type_resolver arg) type_resolver

addTypeArgument :: TypeResolverState -> Ident -> TypeResolverState
addTypeArgument state arg = do
    arg <- getString arg
    case get state.args arg of
        Some _ -> state
        None -> do
            (state, var) <- getTypeVar state
            (args, _) <- insert state.args arg var
            state { args = args }

addConstraint :: Constraint -> Option [Constraint] -> Option [Constraint]
addConstraint constraint constraints = case constraints of
    Some constraints -> Some (constraints + [constraint])
    None -> Some [constraint]

addTypeArgumentConstraint :: TypeResolverState -> String -> Constraint -> (Bool, TypeResolverState)
addTypeArgumentConstraint state type_arg constraint = do
    var <- case get state.args type_arg of
        Some var -> var
        None -> return (False, state)
    (constraints, _) <- alter (addConstraint constraint) var state.constraints
    state <- state { constraints = constraints }
    (True, state)

processArgs :: TypeResolverState -> ResolverState -> [ST.TypeSignature] -> (TypeResolverState, ResolverState, [Type])
processArgs state resolver_state args = args |> List.iter |> fold (\(state, resolver_state, args), arg -> do
                        (state, resolver_state, arg) <- processTypeSignature state resolver_state arg
                        (state, resolver_state, args + [arg])) (state, resolver_state, [])

getTypeVar :: TypeResolverState -> (TypeResolverState, TypeVar)
getTypeVar state = do
    var <- state.next_type_var
    state <- state { next_type_var = var + 1 }
    (state, TypeVar var)

resolveTypeArg :: TypeResolverState -> ResolverState -> Ident -> (TypeResolverState, ResolverState, TypeVar, [Constraint])
resolveTypeArg state resolver_state name = do
        n <- getString name
        case get state.args n of
            Some var -> do
                    constraints <- case get state.constraints var of
                        Some constraints -> constraints
                        None -> []
                    used_type_args <- state.used_type_args + [n]
                    state <- state { used_type_args = used_type_args }
                    (state, resolver_state, var, constraints)
            None -> if state.allow_implicit
                    then
                        do
                        (state, var) <- getTypeVar state
                        (args, _) <- insert state.args n var
                        state <- state { args  = args }
                        (state, resolver_state, var, [])
                    else
                        do
                        resolver_state <- addError resolver_state (UnknownTypeArg name)
                        (state, var) <- getTypeVar state
                        (state, resolver_state, var, [])

processTypeSignature :: TypeResolverState -> ResolverState -> ST.TypeSignature -> (TypeResolverState, ResolverState, Type)
processTypeSignature state resolver_state (ST.TypeSignature type_signature location) = case type_signature of
    ST.TypeArg name -> do
            (state, resolver_state, var, constraints) <- resolveTypeArg state resolver_state name
            name <- getString name
            (state, resolver_state, FixedTypeArg name var constraints)
    ST.Named name args -> do
        case resolveTypeName state name of
            Ok resolved_name -> do
                (state, resolver_state, args) <- processArgs state resolver_state args
                (state, resolver_state, Named resolved_name args)
            Err error -> do
                resolver_state <- addError resolver_state error
                (state, var) <- getTypeVar state
                (state, resolver_state, TypeArg var [])
    ST.Variant _ _ -> unreachable
    ST.List arg -> do
        name <- HP.FullyQualifiedName getFullListTypeName
        (state, resolver_state, arg) <- processTypeSignature state resolver_state arg
        (state, resolver_state, Named name [arg])
    ST.Tuple args -> do
        (state, resolver_state, args) <- processArgs state resolver_state args
        (state, resolver_state, Tuple args)
    ST.Function from to -> do
        (state, resolver_state, from) <- processTypeSignature state resolver_state from
        (state, resolver_state, to) <- processTypeSignature state resolver_state to
        (state, resolver_state, Function from to)
    ST.Never -> do
        (state, var) <- getTypeVar state
        (state, resolver_state, Never var)
    ST.Ref arg -> do
        (state, resolver_state, arg) <- processTypeSignature state resolver_state arg
        (state, resolver_state, Ref arg)
    ST.Wildcard -> do
        (state, var) <- getTypeVar state
        (state, resolver_state, TypeArg var [])