module Siko.Resolver.Class where

import Siko.HIR.Type as HT
import Siko.HIR.Program as HP
import Siko.HIR.Class as HC
import Siko.HIR.Function as HF
import Siko.Resolver
import Siko.Resolver.Module
import Siko.Resolver.Error
import Siko.Resolver.Function
import Siko.Resolver.Type
import Siko.Resolver.Import
import Siko.Syntax.Module as SM
import Siko.Syntax.TypeSignature as ST
import Siko.Syntax.Class as SC
import Siko.Syntax.Ident
import Siko.Resolver.ModuleResolver
import Siko.Syntax.Function
import Map

processClassDependencies :: ResolverState -> ModuleResolver -> SC.Class -> String -> (ResolverState, [HP.FullyQualifiedName])
processClassDependencies state module_resolver c type_arg =
    List.fold (state, []) c.constraints (processClassDependency module_resolver type_arg)
        where
            processClassDependency :: ModuleResolver -> String -> (ResolverState, [HP.FullyQualifiedName]) -> SC.Constraint -> (ResolverState, [HP.FullyQualifiedName])
            processClassDependency module_resolver type_arg (state, constraints) constraint = do
                state <- if (getString constraint.argument) != type_arg
                    then addError state (UnknownTypeArg constraint.argument)
                    else state
                case resolveClass module_resolver constraint.class_name of
                    Ok class_name -> do
                        constraints <- constraints + [class_name]
                        (state, constraints)
                    Err err -> do
                        state <- addError state err
                        (state, constraints)

processClass :: ResolverState -> HP.Program () -> ModuleResolver -> SC.Class -> (ResolverState, HP.Program ())
processClass state hir_program module_resolver c = do
    module_name <- module_resolver.module_name
    (Ident name location) <- c.name
    qn <- HP.FullPath module_name name
    type_resolver <- createTypeResolverState module_resolver True
    type_arg <- c.argument
    type_arg_str <- getString type_arg
    self_constraint <- HT.ClassConstraint qn
    (type_resolver, state) <- addTypeArgument type_resolver state type_arg
    (_, type_resolver) <- addTypeArgumentConstraint type_resolver type_arg_str self_constraint
    (type_resolver, state, var, constraints) <- resolveTypeArg type_resolver state c.argument
    arg_type <- HT.FixedTypeArg (getString c.argument) var constraints
    (state, dependencies) <- processClassDependencies state module_resolver c type_arg_str
    state <- c.member_function_type_signatures |> List.iter |> Iterator.fold (\state, s -> do
        sig_type_args <- s.type_arguments |> List.iter |> Iterator.map (\arg -> getString arg) |> toList
        state <- if contains sig_type_args type_arg_str
            then state
            else do
                ST.TypeSignature _ location <- s.type_signature
                state <- addError state (UnusedClassArg type_arg location)
                state
        state) state
    type_resolver <- disableImplicitTypeArgs type_resolver
    kind <- HF.ClassMember qn
    (state, members) <- processFunctionsAndSignatures state hir_program module_resolver createEmptyFunctionScopeResolver type_resolver
                            kind c.member_functions c.member_function_type_signatures (HP.FullPath module_resolver.module_name)
    (state, hir_program, class_members) <- members |> List.iter |> Iterator.fold (\(state, hir_program, class_members), member -> case member.kind of
            HF.ClassMember _ -> do
                (hir_program, other_item) <- HP.addItem hir_program member.name (HP.Function member)
                state <- handleItemConflict state other_item location
                class_members <- class_members + [member.name]
                (state, hir_program, class_members)
            _ -> do
                (hir_program, other_item) <- HP.addItem hir_program member.name (HP.Function member)
                state <- handleItemConflict state other_item location
                (state, hir_program, class_members)
        ) (state, hir_program, [])
    hir_class <- HC.Class qn location arg_type dependencies class_members
    (hir_program, other_item) <- HP.addItem hir_program qn (HP.Class hir_class)
    state <- handleItemConflict state other_item location
    (state, hir_program)

processInstance :: ResolverState -> HP.Program () -> ModuleResolver -> SC.Instance -> Int -> (ResolverState, HP.Program ())
processInstance state hir_program module_resolver i instance_id = do
    (Ident _ class_location) <- i.class_name
    (state, class_name) <- case resolveClass module_resolver i.class_name of
        Ok class_name -> (state, class_name)
        Err err -> (addError state err, HP.FullPath "" "")
    type_resolver <- createTypeResolverState module_resolver True
    ST.TypeSignature type _ <- i.type_signature
    (state, type_resolver, hir_type) <- case type of
        ST.TypeArg type_arg -> do
            type_arg_str <- getString type_arg
            self_constraint <- HT.ClassConstraint class_name
            (type_resolver, state) <- addTypeArgument type_resolver state type_arg
            (_, type_resolver) <- addTypeArgumentConstraint type_resolver type_arg_str self_constraint
            (type_resolver, state, hir_type) <- processTypeSignature type_resolver state i.type_signature
            (state, type_resolver, hir_type)
        _ -> do
            (type_resolver, state, hir_type) <- processTypeSignature type_resolver state i.type_signature
            (state, type_resolver, hir_type)
    (state, type_resolver) <- i.constraints |> List.iter |> Iterator.fold (\(state, type_resolver), c ->
            processClassConstraint state type_resolver module_resolver c
        ) (state, type_resolver)
    hir_type <- updateTypeConstraints type_resolver hir_type
    type_resolver <- disableImplicitTypeArgs type_resolver
    instance_id <- HC.InstanceId instance_id
    kind <- HF.InstanceMember instance_id
    qn_creator <- \n -> HP.FullPathWithInstanceId module_resolver.module_name n instance_id
    (state, members) <- processFunctionsAndSignatures state hir_program module_resolver createEmptyFunctionScopeResolver type_resolver
                            kind i.member_functions i.member_function_type_signatures qn_creator
    (state, hir_program, instance_members) <- members |> List.iter |> Iterator.fold (\(state, hir_program, instance_members), member -> case member.kind of
            HF.InstanceMember _ -> do
                (hir_program, other_item) <- HP.addItem hir_program member.name (HP.Function member)
                state <- handleItemConflict state other_item class_location
                instance_members <- instance_members + [member.name]
                (state, hir_program, instance_members)
            _ -> do
                (hir_program, other_item) <- HP.addItem hir_program member.name (HP.Function member)
                state <- handleItemConflict state other_item class_location
                (state, hir_program, instance_members)
        ) (state, hir_program, [])
    hir_instance <- HC.Instance class_location instance_id class_name hir_type instance_members
    hir_program <- HP.addInstance hir_program hir_instance
    (state, hir_program)

processClassesAndInstances :: ResolverState -> HP.Program () -> ModuleResolver -> SM.Module -> (ResolverState, HP.Program ())
processClassesAndInstances state hir_program module_resolver mod = do
        init <- (state, hir_program, getSize hir_program.instances)
        (state, hir_program, _) <- List.fold init mod.items (processClassOrInstance module_resolver)
        (state, hir_program)
    where
        processClassOrInstance :: ModuleResolver -> (ResolverState, HP.Program (), Int) -> SM.Item -> (ResolverState, HP.Program (), Int)
        processClassOrInstance module_resolver (state, hir_program, next_instance_id) item = do
            (state, hir_program, next_instance_id) <- case item of
                    SM.Class c -> do
                        (state, hir_program) <- processClass state hir_program module_resolver c
                        (state, hir_program, next_instance_id)
                    SM.Instance i -> do
                        (state, hir_program) <- processInstance state hir_program module_resolver i next_instance_id
                        (state, hir_program, next_instance_id + 1)
                    _ -> (state, hir_program, next_instance_id)
            (state, hir_program, next_instance_id)