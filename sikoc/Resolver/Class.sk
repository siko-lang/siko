module Siko.Resolver.Class where

import Siko.HIR.Type as HT
import Siko.HIR.Program as HP
import Siko.HIR.Class as HC
import Siko.HIR.Function as HF
import Siko.Resolver
import Siko.Resolver.Module
import Siko.Resolver.Error
import Siko.Resolver.Function
import Siko.Resolver.Type
import Siko.Resolver.Import
import Siko.Syntax.Module as SM
import Siko.Syntax.TypeSignature as ST
import Siko.Syntax.Class as SC
import Siko.Syntax.Ident
import Siko.Syntax.Function
import Map

processClassDependencies :: ResolverState -> ModuleResolver -> SC.Class -> String -> (ResolverState, [HP.FullyQualifiedName])
processClassDependencies state module_resolver c type_arg = do
    (state, class_constraints) <- c.constraints |> List.iter |> fold (\(state, constraints), constraint -> do
                state <- if (getString constraint.argument) != type_arg
                    then
                        addError state (UnknownTypeArg constraint.argument)
                    else
                        state
                (state, constraints) <- case resolveClass module_resolver constraint.class_name of
                    Ok class_name -> do
                        constraints <- constraints + [class_name]
                        (state, constraints)
                    Err err -> do
                        state <- addError state err
                        (state, constraints)
                (state, constraints)) (state, [])
    (state, class_constraints)

processClass :: ResolverState -> HP.Program -> ModuleResolver -> SC.Class -> (ResolverState, HP.Program)
processClass state hir_program module_resolver c = do
    module_name <- module_resolver.module_name
    name <- getString c.name
    qn <- HP.FullPath module_name name
    ST.TypeSignature type location <- c.argument
    type_resolver <- createTypeResolverState module_resolver True
    (state, type_resolver, class_constraints, arg_type) <- case type of
        ST.TypeArg type_arg -> do
            type_arg_str <- getString type_arg
            self_constraint <- HT.ClassConstraint qn
            type_resolver <- addTypeArgument type_resolver type_arg
            (_, type_resolver) <- addTypeArgumentConstraint type_resolver type_arg_str self_constraint
            (type_resolver, state, arg_type) <- processTypeSignature type_resolver state c.argument
            (state, class_constraints) <- processClassDependencies state module_resolver c type_arg_str
            state <- c.member_function_type_signatures |> List.iter |> fold (\state, s -> do
                sig_type_args <- s.type_arguments |> List.iter |> map (\arg -> getString arg) |> toList
                state <- if contains sig_type_args type_arg_str
                    then state
                    else do
                        ST.TypeSignature _ location <- s.type_signature
                        state <- addError state (UnusedClassArg type_arg location)
                        state
                state) state
            (state, type_resolver, class_constraints, arg_type)
        _ -> do
            state <- addError state (InvalidClassArgument location)
            (state, type_resolver, [], HT.Tuple [])
    type_resolver <- disableImplicitTypeArgs type_resolver
    kind <- HF.ClassMember qn
    (state, members) <- processFunctionsAndSignatures state hir_program module_resolver type_resolver
                            kind c.member_functions c.member_function_type_signatures
    (hir_program, class_members) <- members |> List.iter |> fold (\(hir_program, class_members), member -> case member.kind of
            HF.ClassMember _ -> do
                hir_program <- HP.addItem hir_program member.name (HP.Function member)
                class_members <- class_members + [member.name]
                (hir_program, class_members)
            _ -> do
                hir_program <- HP.addItem hir_program member.name (HP.Function member)
                (hir_program, class_members)
        ) (hir_program, [])
    hir_class <- HC.Class name module_name arg_type class_constraints class_members
    hir_program <- HP.addItem hir_program qn (HP.Class hir_class)
    (state, hir_program)

processInstance :: ResolverState -> HP.Program -> ModuleResolver -> SC.Instance -> Int -> (ResolverState, HP.Program)
processInstance state hir_program module_resolver i instance_id = do
    (state, class_name) <- case resolveClass module_resolver i.class_name of
        Ok class_name -> (state, class_name)
        Err err -> (addError state err, HP.FullPath "" "")
    type_resolver <- createTypeResolverState module_resolver True
    ST.TypeSignature type location <- i.type_signature
    (state, type_resolver, hir_type) <- case type of
        ST.TypeArg type_arg -> do
            type_arg_str <- getString type_arg
            self_constraint <- HT.ClassConstraint class_name
            type_resolver <- addTypeArgument type_resolver type_arg
            (_, type_resolver) <- addTypeArgumentConstraint type_resolver type_arg_str self_constraint
            (type_resolver, state, hir_type) <- processTypeSignature type_resolver state i.type_signature
            (state, type_resolver, hir_type)
        _ -> do
            (type_resolver, state, hir_type) <- processTypeSignature type_resolver state i.type_signature
            (state, type_resolver, hir_type)
    (state, type_resolver) <- i.constraints |> List.iter |> fold (\(state, type_resolver), c ->
            processClassConstraint state type_resolver module_resolver c
        ) (state, type_resolver)
    hir_type <- updateTypeConstraints type_resolver hir_type
    type_resolver <- disableImplicitTypeArgs type_resolver
    instance_id <- HC.InstanceId instance_id
    kind <- HF.InstanceMember instance_id
    (state, members) <- processFunctionsAndSignatures state hir_program module_resolver type_resolver
                            kind i.member_functions i.member_function_type_signatures
    (hir_program, instance_members) <- members |> List.iter |> fold (\(hir_program, instance_members), member -> case member.kind of
            HF.ClassMember _ -> do
                hir_program <- HP.addItem hir_program member.name (HP.Function member)
                instance_members <- instance_members + [member.name]
                (hir_program, instance_members)
            _ -> do
                hir_program <- HP.addItem hir_program member.name (HP.Function member)
                (hir_program, instance_members)
        ) (hir_program, [])
    hir_instance <- HC.Instance instance_id class_name hir_type instance_members
    hir_program <- HP.addInstance hir_program hir_instance
    (state, hir_program)

processClassesAndInstances :: ResolverState -> HP.Program -> ModuleResolver -> SM.Module -> (ResolverState, HP.Program)
processClassesAndInstances state hir_program module_resolver mod = do
    (state, hir_program, _) <- mod.items |> List.iter |> fold (\(state, hir_program, instance_id), item -> do
        (state, hir_program) <- case item of
                SM.Class c -> processClass state hir_program module_resolver c
                SM.Instance i -> processInstance state hir_program module_resolver i instance_id
                _ -> (state, hir_program)
        (state, hir_program, instance_id + 1)) (state, hir_program, 0)
    (state, hir_program)