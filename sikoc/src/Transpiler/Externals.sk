generateMapInsert :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateMapInsert program type_store arg_types result_type = do
    map_type <- atIndex arg_types 0
    arg_key_type <- atIndex arg_types 1
    arg_value_type <- atIndex arg_types 2
    map_def <- getRecord program (LT.getIdentity map_type)
    map_info <- Option.unwrap map_def.external_info
    key_type <- atIndex map_info.type_args 0
    value_type <- atIndex map_info.type_args 1
    clone_key <- not (LT.isRef key_type) && LT.isRef arg_key_type
    clone_value <- not (LT.isRef value_type) && LT.isRef arg_value_type
    value_ref <- if clone_value
    then R.MethodCall (R.VarRef (getArgName 2)) cloneName []
    else R.VarRef (getArgName 2)
    key_ref <- if clone_key
    then R.MethodCall (R.VarRef (getArgName 1)) cloneName []
    else R.VarRef (getArgName 1)
    rust_type <- convertType result_type
    result_record <- case result_type of
        LT.Record i _ -> getRecord program i
        _ -> panic "Result is not a record in generateMapInsert"
    map_field <- atIndex result_record.fields 0
    value_field <- atIndex result_record.fields 1
    rust_map_type <- convertType map_field.type
    rust_value_type <- convertType value_field.type
    field_access0 <- R.FieldAccess innerValueField (R.VarRef (getArgName 0))
    map_ref <- if LT.isRef map_type
    then R.MethodCall field_access0 cloneName []
    else field_access0
    map <- "map"
    value <- "value"
    map_decl <- R.VarDeclMut map map_ref None
    insert_call <- R.MethodCall (R.VarRef map) "insert" [key_ref, value_ref]
    some_pattern <- R.VariantPattern "Some" (Some value)
    none_pattern <- R.VariantPattern "None" None
    some_record_type <- getVariantRecordTypeId program value_field.type "Some"
    none_record_type <- getVariantRecordTypeId program value_field.type "None"
    rust_some_record_type <- convertType (LT.Record some_record_type [])
    rust_none_record_type <- convertType (LT.Record none_record_type [])
    some_record <- getRecord program some_record_type
    item_field <- atIndex some_record.fields 0
    some_ctor <- R.StructCtor (RT.showBase rust_some_record_type) [R.FieldInitItem (getFieldName 0) (R.VarRef value)]
    none_ctor <- R.StructCtor (RT.showBase rust_none_record_type) []
    some_case <- R.MatchCase some_pattern (R.FunctionCall ("{}::Some" % RT.showBase rust_value_type) [some_ctor]) None
    none_case <- R.MatchCase none_pattern (R.FunctionCall ("{}::None" % RT.showBase rust_value_type) [none_ctor]) None
    match <- R.Match insert_call [some_case, none_case]
    value_decl <- R.VarDecl value match None
    map_ctor <- R.Block [R.StructCtor (RT.showBase rust_map_type) [R.FieldInitItem innerValueField (R.VarRef map)]]
    field0_init <- R.FieldInitItem (getFieldName 0) map_ctor
    field1_init <- R.FieldInitItem (getFieldName 1) (R.VarRef value)
    result_ctor <- R.StructCtor (RT.showBase rust_type) [field0_init, field1_init]
    R.Block [map_decl, value_decl, result_ctor]

generateMapGet :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateMapGet program type_store arg_types result_type = do
    rust_type <- convertType result_type
    field_access0 <- R.FieldAccess innerValueField (R.VarRef (getArgName 0))
    map <- "map"
    value <- "value"
    map_decl <- if RT.isRef (convertType (atIndex arg_types 0))
    then R.VarDecl map (R.Ref field_access0) None
    else R.VarDecl map field_access0 None
    get_call <- R.MethodCall (R.VarRef map) "get" [R.Ref (R.VarRef (getArgName 1))]
    some_pattern <- R.VariantPattern "Some" (Some value)
    none_pattern <- R.VariantPattern "None" None
    some_record_type <- getVariantRecordTypeId program result_type "Some"
    none_record_type <- getVariantRecordTypeId program result_type "None"
    rust_some_record_type <- convertType (LT.Record some_record_type [])
    rust_none_record_type <- convertType (LT.Record none_record_type [])
    some_record <- getRecord program some_record_type
    item_field <- atIndex some_record.fields 0
    value_clone <- if RT.isRef (convertType item_field.type)
    then R.Ref (R.VarRef value)
    else R.MethodCall (R.VarRef value) cloneName []
    some_ctor <- R.StructCtor (RT.showBase rust_some_record_type) [R.FieldInitItem (getFieldName 0) (value_clone)]
    none_ctor <- R.StructCtor (RT.showBase rust_none_record_type) []
    some_case <- R.MatchCase some_pattern (R.FunctionCall ("{}::Some" % RT.showBase rust_type) [some_ctor]) None
    none_case <- R.MatchCase none_pattern (R.FunctionCall ("{}::None" % RT.showBase rust_type) [none_ctor]) None
    match <- R.Match get_call [some_case, none_case]
    R.Block [map_decl, match]

