generateMapRemove :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateMapRemove program type_store arg_types result_type = do
    rust_type <- convertType result_type
    map_type <- atIndex arg_types 0
    result_record <- case result_type of
        LT.Record i _ -> getRecord program i
        _ -> panic "Result is not a record in generateMapInsert"
    map_field <- atIndex result_record.fields 0
    value_field <- atIndex result_record.fields 1
    rust_map_type <- convertType map_field.type
    rust_value_type <- convertType value_field.type
    field_access0 <- R.FieldAccess innerValueField (R.VarRef (getArgName 0))
    map_ref <- if LT.isRef map_type
    then R.MethodCall field_access0 cloneName []
    else field_access0
    map <- "map"
    value <- "value"
    map_decl <- R.VarDeclMut map map_ref None
    remove_call <- R.MethodCall (R.VarRef map) "remove" [R.Ref (R.VarRef (getArgName 1))]
    some_pattern <- R.VariantPattern "Some" (Some value)
    none_pattern <- R.VariantPattern "None" None
    some_record_type <- getVariantRecordTypeId program value_field.type "Some"
    none_record_type <- getVariantRecordTypeId program value_field.type "None"
    rust_some_record_type <- convertType (LT.Record some_record_type [])
    rust_none_record_type <- convertType (LT.Record none_record_type [])
    some_record <- getRecord program some_record_type
    item_field <- atIndex some_record.fields 0
    some_ctor <- R.StructCtor (RT.showBase rust_some_record_type) [R.FieldInitItem (getFieldName 0) (R.VarRef value)]
    none_ctor <- R.StructCtor (RT.showBase rust_none_record_type) []
    some_case <- R.MatchCase some_pattern (R.FunctionCall ("{}::Some" % RT.showBase rust_value_type) [some_ctor]) None
    none_case <- R.MatchCase none_pattern (R.FunctionCall ("{}::None" % RT.showBase rust_value_type) [none_ctor]) None
    match <- R.Match remove_call [some_case, none_case]
    value_decl <- R.VarDecl value match None
    map_ctor <- R.Block [R.StructCtor (RT.showBase rust_map_type) [R.FieldInitItem innerValueField (R.VarRef map)]]
    field0_init <- R.FieldInitItem (getFieldName 0) map_ctor
    field1_init <- R.FieldInitItem (getFieldName 1) (R.VarRef value)
    result_ctor <- R.StructCtor (RT.showBase rust_type) [field0_init, field1_init]
    R.Block [map_decl, value_decl, result_ctor]

generateMapIntoIter :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateMapIntoIter program type_store arg_types result_type = do
    rust_type <- convertType result_type
    iterator_type <- result_type
    iterator_id <- LT.getIdentity iterator_type
    iterator_record <- getRecord program iterator_id
    is_iterator_ref <- Option.isSome iterator_record.implicit_member_lifetime
    map_type <- atIndex arg_types 0
    field_access0 <- R.FieldAccess innerValueField (R.VarRef (getArgName 0))
    map_ref <- if LT.isRef map_type
    then if is_iterator_ref
        then R.Ref field_access0
        else R.MethodCall field_access0 cloneName []
    else field_access0
    new0 <- "new0"
    if is_iterator_ref
    then do
        new0_decl <- R.VarDecl new0 (R.Ref map_ref) None
        iter_call <- R.MethodCall (R.VarRef new0) "iter" []
        struct_ctor <- R.StructCtor (RT.showBase rust_type) [R.FieldInitItem innerValueField iter_call]
        R.Block [new0_decl, struct_ctor]
    else do
        new0_decl <- R.VarDecl new0 map_ref None
        into_iter_call <- R.MethodCall (R.VarRef new0) "into_iter" []
        collect <- R.MethodCall into_iter_call "collect" []
        v <- "v"
        v_decl <- R.VarDecl v collect (Some (RT.Named "Vec<_>" []))
        v_into_iter_call <- R.MethodCall (R.VarRef v) "into_iter" []
        struct_ctor <- R.StructCtor (RT.showBase rust_type) [R.FieldInitItem innerValueField v_into_iter_call]
        R.Block [new0_decl, v_decl, struct_ctor]

generateMapNextItem :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateMapNextItem program type_store arg_types result_type = do
    iterator_type <- atIndex arg_types 0
    iterator_id <- LT.getIdentity iterator_type
    iterator_record <- getRecord program iterator_id
    rust_iterator_type <- convertType iterator_type
    is_iterator_ref <- Option.isSome iterator_record.implicit_member_lifetime
    iterator_info <- Option.unwrap iterator_record.external_info
    iterator_item_type_key <- atIndex iterator_info.type_args 0
    iterator_item_type_value <- atIndex iterator_info.type_args 1
    rust_result_type <- convertType result_type
    result_id <- LT.getIdentity result_type
    result_record <- getRecord program result_id
    option_type <- (atIndex result_record.fields 1).type
    rust_option_type <- convertType option_type
    field_access0 <- R.FieldAccess innerValueField (R.VarRef (getArgName 0))
    iter_ref <- if LT.isRef iterator_type
    then R.MethodCall field_access0 cloneName []
    else field_access0
    state <- "state"
    state_decl <- R.VarDeclMut state iter_ref None
    value <- "value"
    value_decl <- R.VarDecl value (R.MethodCall (R.VarRef state) "next" []) None
    item <- "item"
    some_pattern <- R.VariantPattern "Some" (Some item)
    none_pattern <- R.VariantPattern "None" None
    some_record_type <- getVariantRecordTypeId program option_type "Some"
    none_record_type <- getVariantRecordTypeId program option_type "None"
    rust_some_record_type <- convertType (LT.Record some_record_type [])
    rust_none_record_type <- convertType (LT.Record none_record_type [])
    some_record <- getRecord program some_record_type
    item_field <- atIndex some_record.fields 0
    rust_item_type <- convertType item_field.type
    tuple_record <- case item_field.type of
        LT.Record record_id _ -> getRecord program record_id
        _ -> panic "Tuple is not a record"
    state_field <- atIndex tuple_record.fields 0
    value_field <- atIndex tuple_record.fields 1
    rust_state_type <- convertType state_field.type
    rust_value_type <- convertType value_field.type
    key_ctor <- if LT.isRef state_field.type
    then R.Ref (R.FieldAccess "0" (R.VarRef item))
    else if not (LT.isRef item_field.type) && (LT.isRef iterator_item_type_key || is_iterator_ref)
        then R.MethodCall (R.FieldAccess "0" (R.VarRef item)) cloneName []
        else R.FieldAccess "0" (R.VarRef item)
    value_ctor <- if LT.isRef value_field.type
    then R.Ref (R.FieldAccess "1" (R.VarRef item))
    else if not (LT.isRef value_field.type) && (LT.isRef iterator_item_type_value || is_iterator_ref)
        then R.MethodCall (R.FieldAccess "1" (R.VarRef item)) cloneName []
        else R.FieldAccess "1" (R.VarRef item)
    value_tuple_ctor <- R.StructCtor (RT.showBase rust_item_type) [R.FieldInitItem (getFieldName 0) key_ctor,
                                                                   R.FieldInitItem (getFieldName 1) value_ctor]
    some_ctor <- R.StructCtor (RT.showBase rust_some_record_type) [R.FieldInitItem (getFieldName 0) value_tuple_ctor]
    some_ctor <- R.FunctionCall ("{}::Some" % RT.showBase rust_option_type) [some_ctor]
    none_ctor <- R.StructCtor (RT.showBase rust_none_record_type) []
    none_ctor <- R.FunctionCall ("{}::None" % RT.showBase rust_option_type) [none_ctor]
    state_ctor <- R.StructCtor (RT.showBase rust_iterator_type) [R.FieldInitItem innerValueField (R.VarRef state)]

    tuple_ctor_some <- R.StructCtor (RT.showBase rust_result_type) [R.FieldInitItem (getFieldName 0) state_ctor,
                                                                    R.FieldInitItem (getFieldName 1) some_ctor]
    tuple_ctor_none <- R.StructCtor (RT.showBase rust_result_type) [R.FieldInitItem (getFieldName 0) state_ctor,
                                                                    R.FieldInitItem (getFieldName 1) none_ctor]
    some_case <- R.MatchCase some_pattern tuple_ctor_some None
    none_case <- R.MatchCase none_pattern tuple_ctor_none None
    cases <- [some_case, none_case]
    match <- R.Match (R.VarRef value) cases
    R.Block [state_decl, value_decl, match]

generateRcCreate :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateRcCreate program type_store arg_types result_type = do
    rust_type <- convertType result_type
    item_type <- convertType (atIndex arg_types 0)
    item_ref <- if RT.isRef item_type
    then R.MethodCall (R.VarRef (getArgName 0)) cloneName []
    else R.VarRef (getArgName 0)
    new0 <- "new0"
    create_call <- R.FunctionCall "std::rc::Rc::new" [item_ref]
    new0_decl <- R.VarDecl new0 create_call None
    struct_ctor <- R.StructCtor (RT.showBase rust_type) [R.FieldInitItem innerValueField (R.VarRef new0)]
    R.Block [new0_decl, struct_ctor]

generateRcGet :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateRcGet program type_store arg_types result_type = do
    rust_type <- convertType result_type
    field_access0 <- R.Deref (R.FieldAccess innerValueField (R.VarRef (getArgName 0)))
    item_ref <- if not (RT.isRef rust_type)
    then R.MethodCall field_access0 cloneName []
    else R.Ref field_access0
    R.Block [item_ref]

