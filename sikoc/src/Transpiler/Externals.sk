generateListTail :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateListTail program type_store arg_types result_type = do
    arg_type <- atIndex arg_types 0
    rust_arg_type <- convertType arg_type
    arg0 <- R.VarRef (getArgName 0)
    inner0 <- R.FieldAccess innerValueField arg0
    is_empty_call <- R.MethodCall inner0 "is_empty" []
    rust_result_type <- convertType result_type
    some_record_type <- getVariantRecordTypeId program result_type "Some"
    none_record_type <- getVariantRecordTypeId program result_type "None"
    rust_some_record_type <- convertType (LT.Record some_record_type [])
    rust_none_record_type <- convertType (LT.Record none_record_type [])
    none_ctor <- R.StructCtor (RT.showBase rust_none_record_type) []
    non_empty_branch <- do
        new <- "new"
        new_decl <- R.VarDeclMut new inner0 None
        remove_call <- R.MethodCall (R.VarRef new) "remove" [R.IntegerLiteral "0"]
        list_ctor <- R.StructCtor (RT.showBase rust_arg_type) [R.FieldInitItem innerValueField (R.VarRef new)]
        some_ctor <- R.StructCtor (RT.showBase rust_some_record_type) [R.FieldInitItem "field0" list_ctor]
        some_ctor <- R.FunctionCall ("{}::Some" % RT.showBase rust_result_type) [some_ctor]
        R.Block [new_decl, remove_call, some_ctor]
    empty_branch <- R.FunctionCall ("{}::None" % RT.showBase rust_result_type) [none_ctor]
    if_expr <- R.If is_empty_call empty_branch non_empty_branch
    R.Block [if_expr]

