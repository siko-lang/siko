generateListIntoIter :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateListIntoIter program type_store arg_types result_type = do
    iterator_id <- LT.getIdentity result_type
    iterator_record <- getRecord program iterator_id
    is_iterator_ref <- Option.isSome iterator_record.implicit_member_lifetime
    rust_type <- convertType result_type
    list_type <- atIndex arg_types 0
    field_access0 <- R.FieldAccess innerValueField (R.VarRef (getArgName 0))
    list_ref <- if LT.isRef list_type
    then if is_iterator_ref
        then R.Ref field_access0
        else R.MethodCall field_access0 cloneName []
    else field_access0
    new0 <- "new0"
    new0_decl <- R.VarDecl new0 list_ref None
    iter_call <- if is_iterator_ref
    then R.MethodCall (R.VarRef new0) "iter" []
    else R.MethodCall (R.VarRef new0) "into_iter" []
    struct_ctor <- R.StructCtor (RT.showBase rust_type) [R.FieldInitItem innerValueField iter_call]
    R.Block [new0_decl, struct_ctor]

generateListNextItem :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateListNextItem program type_store arg_types result_type = do
    result_id <- LT.getIdentity result_type
    result_record <- getRecord program result_id
    option_type <- (atIndex result_record.fields 1).type
    rust_option_type <- convertType option_type
    iterator_type <- atIndex arg_types 0
    iterator_id <- LT.getIdentity iterator_type
    iterator_record <- getRecord program iterator_id
    iterator_info <- Option.unwrap iterator_record.external_info
    is_iterator_ref <- Option.isSome iterator_record.implicit_member_lifetime
    iterator_item_type <- atIndex iterator_info.type_args 0
    field_access0 <- R.FieldAccess innerValueField (R.VarRef (getArgName 0))
    iter_ref <- if LT.isRef iterator_type
    then R.MethodCall field_access0 cloneName []
    else field_access0
    state <- "state"
    state_decl <- R.VarDeclMut state iter_ref None
    value <- "value"
    value_decl <- R.VarDecl value (R.MethodCall (R.VarRef state) "next" []) None
    item <- "item"
    some_pattern <- R.VariantPattern "Some" (Some item)
    none_pattern <- R.VariantPattern "None" None
    rust_result_type <- convertType result_type
    some_record_type <- getVariantRecordTypeId program option_type "Some"
    none_record_type <- getVariantRecordTypeId program option_type "None"
    rust_some_record_type <- convertType (LT.Record some_record_type [])
    rust_none_record_type <- convertType (LT.Record none_record_type [])
    some_record <- getRecord program some_record_type
    item_field <- atIndex some_record.fields 0
    rust_item_type <- convertType item_field.type
    tuple_record <- case result_type of
        LT.Record record_id _ -> getRecord program record_id
        ty -> panic "Tuple is not a record {}" % ty
    state_field <- atIndex tuple_record.fields 0
    value_field <- atIndex tuple_record.fields 1
    rust_state_type <- convertType state_field.type
    item_ref <- if not (LT.isRef item_field.type) && (LT.isRef iterator_item_type || is_iterator_ref)
    then R.MethodCall (R.Deref (R.VarRef item)) cloneName []
    else R.VarRef item
    item_ref <- if RT.isBoxed rust_item_type
    then boxExpr item_ref
    else item_ref
    state_ctor <- R.StructCtor (RT.showBase rust_state_type) [R.FieldInitItem innerValueField (R.VarRef state)]
    some_ctor <- R.StructCtor (RT.showBase rust_some_record_type) [R.FieldInitItem (getFieldName 0) item_ref]
    some_ctor <- R.FunctionCall ("{}::Some" % RT.showBase rust_option_type) [some_ctor]
    none_ctor <- R.StructCtor (RT.showBase rust_none_record_type) []
    none_ctor <- R.FunctionCall ("{}::None" % RT.showBase rust_option_type) [none_ctor]
    tuple_ctor_some <- R.StructCtor (RT.showBase rust_result_type) [R.FieldInitItem (getFieldName 0) state_ctor,
                                                                    R.FieldInitItem (getFieldName 1) some_ctor]
    tuple_ctor_none <- R.StructCtor (RT.showBase rust_result_type) [R.FieldInitItem (getFieldName 0) state_ctor,
                                                                    R.FieldInitItem (getFieldName 1) none_ctor]
    some_case <- R.MatchCase some_pattern tuple_ctor_some None
    none_case <- R.MatchCase none_pattern tuple_ctor_none None
    cases <- [some_case, none_case]
    match <- R.Match (R.VarRef value) cases
    R.Block [state_decl, value_decl, match]

