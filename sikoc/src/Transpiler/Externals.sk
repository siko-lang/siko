generateStringFields :: [LT.Type] -> Option LT.Lifetime -> [R.StructField]
generateStringFields args _ = [R.StructField innerValueField (RT.Named "std::string::String" [])]

generateIntFields :: [LT.Type] -> Option LT.Lifetime -> [R.StructField]
generateIntFields args _ = [R.StructField innerValueField (RT.Named "i64" [])]

generateFloatFields :: [LT.Type] -> Option LT.Lifetime -> [R.StructField]
generateFloatFields args _ = [R.StructField innerValueField (RT.Named "f64" [])]

generateCharFields :: [LT.Type] -> Option LT.Lifetime -> [R.StructField]
generateCharFields args _ = [R.StructField innerValueField (RT.Named "char" [])]

generateListFields :: [LT.Type] -> Option LT.Lifetime -> [R.StructField]
generateListFields args _ = do
    first <- atIndex args 0
    rust_type_arg <- convertType first
    [R.StructField innerValueField (RT.Named ("std::vec::Vec<{}>" % RT.showAll rust_type_arg) [])]

generateListIteratorFields :: [LT.Type] -> Option LT.Lifetime -> [R.StructField]
generateListIteratorFields args implicit_member_lifetime = do
    first <- atIndex args 0
    rust_type_arg <- convertType first
    case implicit_member_lifetime of
        Some lifetime -> [R.StructField innerValueField (RT.Named ("std::slice::Iter<{}, {}>" % (lifetime, RT.showAll rust_type_arg)) [])]
        None -> [R.StructField innerValueField (RT.Named ("std::vec::IntoIter<{}>" % RT.showAll rust_type_arg) [])]

generateMapFields :: [LT.Type] -> Option LT.Lifetime -> [R.StructField]
generateMapFields args _ = do
    first <- atIndex args 0
    second <- atIndex args 1
    rust_type_arg1 <- convertType first
    rust_type_arg2 <- convertType second
    [R.StructField innerValueField (RT.Named "std::collections::BTreeMap<{}, {}>" % (RT.showAll rust_type_arg1, RT.showAll rust_type_arg2) [])]

generateMapIteratorFields :: [LT.Type] -> Option LT.Lifetime -> [R.StructField]
generateMapIteratorFields args implicit_member_lifetime = do
    first <- atIndex args 0
    second <- atIndex args 1
    rust_type_arg1 <- convertType first
    rust_type_arg2 <- convertType second
    case implicit_member_lifetime of
        Some lifetime -> [R.StructField innerValueField (RT.Named "std::collections::btree_map::Iter<{}, {}, {}>" % (lifetime, RT.showAll rust_type_arg1, RT.showAll rust_type_arg2) [])]
        None -> [R.StructField innerValueField (RT.Named "std::vec::IntoIter<({}, {})>" % (RT.showAll rust_type_arg1, RT.showAll rust_type_arg2) [])]

generateRcFields :: [LT.Type] -> Option LT.Lifetime -> [R.StructField]
generateRcFields args _ = do
    first <- atIndex args 0
    rust_type_arg <- convertType first
    [R.StructField innerValueField (RT.Named ("std::rc::Rc<{}>" % RT.showAll rust_type_arg) [])]

initializeExternalStructFields :: Map ExternalId ExternStructBuilder
initializeExternalStructFields = do
    externals <- Map.empty
    (externals, _) <- insert externals (ExternalId "String" "String") (ExternStructBuilder generateStringFields)
    (externals, _) <- insert externals (ExternalId "Int" "Int") (ExternStructBuilder generateIntFields)
    (externals, _) <- insert externals (ExternalId "Float" "Float") (ExternStructBuilder generateFloatFields)
    (externals, _) <- insert externals (ExternalId "Char" "Char") (ExternStructBuilder generateCharFields)
    (externals, _) <- insert externals (ExternalId "List" "List") (ExternStructBuilder generateListFields)
    (externals, _) <- insert externals (ExternalId "List2" "List2") (ExternStructBuilder generateListFields)
    (externals, _) <- insert externals (ExternalId "List" "ListIterator") (ExternStructBuilder generateListIteratorFields)
    (externals, _) <- insert externals (ExternalId "List2" "ListIterator") (ExternStructBuilder generateListIteratorFields)
    (externals, _) <- insert externals (ExternalId "Map" "Map") (ExternStructBuilder generateMapFields)
    (externals, _) <- insert externals (ExternalId "Map2" "Map2") (ExternStructBuilder generateMapFields)
    (externals, _) <- insert externals (ExternalId "Map" "MapIterator") (ExternStructBuilder generateMapIteratorFields)
    (externals, _) <- insert externals (ExternalId "Map2" "MapIterator") (ExternStructBuilder generateMapIteratorFields)
    (externals, _) <- insert externals (ExternalId "Rc" "Rc") (ExternStructBuilder generateRcFields)
    externals
