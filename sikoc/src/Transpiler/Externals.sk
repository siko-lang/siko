generatePartialCmp :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generatePartialCmp program type_store arg_types result_type = do
    field_access0 <- R.FieldAccess innerValueField (R.VarRef (getArgName 0))
    field_access1 <- R.FieldAccess innerValueField (R.VarRef (getArgName 1))
    partial_cmp_call <- R.MethodCall field_access0 "partial_cmp" [R.Ref field_access1]
    rust_result_type <- convertType result_type
    some_record_type <- getVariantRecordTypeId program result_type "Some"
    none_record_type <- getVariantRecordTypeId program result_type "None"
    rust_some_record_type <- convertType (LT.Record some_record_type [])
    rust_none_record_type <- convertType (LT.Record none_record_type [])
    some_record <- getRecord program some_record_type
    ordering_field <- atIndex some_record.fields 0
    ordering_type <- ordering_field.type
    greater_record_type <- getVariantRecordTypeId program ordering_type "Greater"
    equal_record_type <- getVariantRecordTypeId program ordering_type "Equal"
    less_record_type <- getVariantRecordTypeId program ordering_type "Less"
    rust_ordering_type <- convertType ordering_type
    ordering_var <- "o"
    greater_ctor <- R.StructCtor (RT.showBase (convertType (LT.Record greater_record_type []))) []
    equal_ctor <- R.StructCtor (RT.showBase (convertType (LT.Record equal_record_type []))) []
    less_ctor <- R.StructCtor (RT.showBase (convertType (LT.Record less_record_type []))) []
    greater_ctor <- R.FunctionCall ("{}::Greater" % RT.showBase rust_ordering_type) [greater_ctor]
    equal_ctor <- R.FunctionCall ("{}::Equal" % RT.showBase rust_ordering_type) [equal_ctor]
    less_ctor <- R.FunctionCall ("{}::Less" % RT.showBase rust_ordering_type) [less_ctor]
    greater_case <- R.MatchCase (R.VariantPattern "std::cmp::Ordering::Greater" None) greater_ctor None
    equal_case <- R.MatchCase (R.VariantPattern "std::cmp::Ordering::Equal" None) equal_ctor None
    less_case <- R.MatchCase (R.VariantPattern "std::cmp::Ordering::Less" None) less_ctor None
    init <- R.FieldInitItem (getFieldName 0) (R.Match (R.VarRef ordering_var) [greater_case, equal_case, less_case])
    some_struct_ctor <- R.StructCtor (RT.showBase rust_some_record_type) [init]
    none_struct_ctor <- R.StructCtor (RT.showBase rust_none_record_type) []
    result_some_ctor <- R.FunctionCall ("{}::Some" % RT.showBase rust_result_type) [some_struct_ctor]
    result_none_ctor <- R.FunctionCall ("{}::None" % RT.showBase rust_result_type) [none_struct_ctor]
    some_case <- R.MatchCase (R.VariantPattern "std::option::Option::Some" (Some ordering_var)) result_some_ctor None
    none_case <- R.MatchCase (R.VariantPattern "std::option::Option::None" None) result_none_ctor None
    match <- R.Match partial_cmp_call [some_case, none_case]
    R.Block [match]

generateCmp :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateCmp program type_store arg_types result_type = do
    field_access0 <- R.FieldAccess innerValueField (R.VarRef (getArgName 0))
    field_access1 <- R.FieldAccess innerValueField (R.VarRef (getArgName 1))
    cmp_call <- R.MethodCall field_access0 "cmp" [R.Ref field_access1]
    rust_ordering_type <- convertType result_type
    greater_record_type <- getVariantRecordTypeId program result_type "Greater"
    equal_record_type <- getVariantRecordTypeId program result_type "Equal"
    less_record_type <- getVariantRecordTypeId program result_type "Less"
    greater_ctor <- R.StructCtor (RT.showBase (convertType (LT.Record greater_record_type []))) []
    equal_ctor <- R.StructCtor (RT.showBase (convertType (LT.Record equal_record_type []))) []
    less_ctor <- R.StructCtor (RT.showBase (convertType (LT.Record less_record_type []))) []
    greater_ctor <- R.FunctionCall ("{}::Greater" % RT.showBase rust_ordering_type) [greater_ctor]
    equal_ctor <- R.FunctionCall ("{}::Equal" % RT.showBase rust_ordering_type) [equal_ctor]
    less_ctor <- R.FunctionCall ("{}::Less" % RT.showBase rust_ordering_type) [less_ctor]
    greater_case <- R.MatchCase (R.VariantPattern "std::cmp::Ordering::Greater" None) greater_ctor None
    equal_case <- R.MatchCase (R.VariantPattern "std::cmp::Ordering::Equal" None) equal_ctor None
    less_case <- R.MatchCase (R.VariantPattern "std::cmp::Ordering::Less" None) less_ctor None
    match <- R.Match cmp_call [greater_case, equal_case, less_case]
    R.Block [match]

rustBoolToSikoBool :: Program -> R.Expr -> LT.Type -> R.Expr
rustBoolToSikoBool program bool_expr bool_type = do
    rust_bool_type <- convertType bool_type
    true_record_type <- getVariantRecordTypeId program bool_type "True"
    false_record_type <- getVariantRecordTypeId program bool_type "False"
    true_pattern <- R.VariantPattern "true" None
    false_pattern <- R.VariantPattern "false" None
    rust_true_record_type <- convertType (LT.Record true_record_type [])
    rust_false_record_type <- convertType (LT.Record false_record_type [])
    true_ctor <- R.StructCtor (RT.showBase (rust_true_record_type)) []
    false_ctor <- R.StructCtor (RT.showBase (rust_false_record_type)) []
    true_case <- R.MatchCase true_pattern (R.FunctionCall ("{}::True" % RT.showBase rust_bool_type) [true_ctor]) None
    false_case <- R.MatchCase false_pattern (R.FunctionCall ("{}::False" % RT.showBase rust_bool_type) [false_ctor]) None
    cases <- [true_case, false_case]
    R.Match bool_expr cases

sikoBoolToRustBool :: R.Expr -> RT.Type -> R.Expr
sikoBoolToRustBool bool_expr bool_type = do
    true_pattern <- R.VariantPattern ("{}::True" % RT.showBase bool_type) (Some "_")
    false_pattern <- R.VariantPattern ("{}::False" % RT.showBase bool_type) (Some "_")
    true_case <- R.MatchCase true_pattern (R.BoolLiteral True) None
    false_case <- R.MatchCase false_pattern (R.BoolLiteral False) None
    cases <- [true_case, false_case]
    R.Match bool_expr cases

sikoOrderingToRustOrdering :: R.Expr -> RT.Type -> R.Expr
sikoOrderingToRustOrdering ord_expr ordering_type = do
    greater_pattern <- R.VariantPattern ("{}::Greater" % RT.showBase ordering_type) (Some "_")
    equal_pattern <- R.VariantPattern ("{}::Equal" % RT.showBase ordering_type) (Some "_")
    less_pattern <- R.VariantPattern ("{}::Less" % RT.showBase ordering_type) (Some "_")
    greater_case <- R.MatchCase greater_pattern (R.EnumCtor "std::cmp::Ordering::Greater") None
    equal_case <- R.MatchCase equal_pattern (R.EnumCtor "std::cmp::Ordering::Equal") None
    less_case <- R.MatchCase less_pattern (R.EnumCtor "std::cmp::Ordering::Less") None
    cases <- [greater_case, equal_case, less_case]
    R.Match ord_expr cases

sikoOptionalOrderingToRustOptionalOrdering :: Program -> R.Expr -> LT.Type -> R.Expr
sikoOptionalOrderingToRustOptionalOrdering program partial_ord_expr optional_ordering_type = do
    rust_optional_ordering_type <- convertType optional_ordering_type
    some_ordering <- "some_ordering"
    some_pattern <- R.VariantPattern ("{}::Some" % RT.showBase rust_optional_ordering_type) (Some some_ordering)
    none_pattern <- R.VariantPattern ("{}::None" % RT.showBase rust_optional_ordering_type) (Some "_")
    some_record_type <- getVariantRecordTypeId program optional_ordering_type "Some"
    some_record <- getRecord program some_record_type
    ordering_type_field <- atIndex some_record.fields 0
    rust_some_record_type <- convertType ordering_type_field.type
    field_access <- R.FieldAccess (getFieldName 0) (R.VarRef some_ordering)
    some_match <- sikoOrderingToRustOrdering (R.Ref field_access) rust_some_record_type
    some_case <- R.MatchCase some_pattern (R.FunctionCall "Some" [some_match]) None
    none_case <- R.MatchCase none_pattern (R.EnumCtor "None") None
    cases <- [some_case, none_case]
    R.Match partial_ord_expr cases

generateEq :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateEq program type_store arg_types result_type = do
    rust_result_type <- convertType result_type
    field_access0 <- R.FieldAccess innerValueField (R.VarRef (getArgName 0))
    field_access1 <- R.FieldAccess innerValueField (R.VarRef (getArgName 1))
    eq_call <- R.MethodCall field_access0 "eq" [R.Ref field_access1]
    match <- rustBoolToSikoBool program eq_call result_type
    R.Block [match]

generateOpAnd :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateOpAnd program type_store arg_types result_type = do
    rust_result_type <- convertType result_type
    field_access0 <- R.FieldAccess innerValueField (R.VarRef (getArgName 0))
    field_access1 <- R.FieldAccess innerValueField (R.VarRef (getArgName 1))
    rust_result_type <- convertType result_type
    arg_type <- atIndex arg_types 0
    true_record_type <- getVariantRecordTypeId program arg_type "True"
    false_record_type <- getVariantRecordTypeId program arg_type "False"
    true_pattern <- R.VariantPattern "true" None
    false_pattern <- R.VariantPattern "false" None
    rust_true_record_type <- convertType (LT.Record true_record_type [])
    rust_false_record_type <- convertType (LT.Record false_record_type [])
    true_ctor <- R.StructCtor (RT.showBase (rust_true_record_type)) []
    false_ctor <- R.StructCtor (RT.showBase (rust_false_record_type)) []

    true_pattern <- R.VariantPattern ("{}::True" % RT.showBase rust_result_type) (Some "_")
    false_pattern <- R.VariantPattern ("{}::False" % RT.showBase rust_result_type) (Some "_")

    true_case <- R.MatchCase true_pattern (R.FunctionCall ("{}::True" % RT.showBase rust_result_type) [true_ctor]) None
    false_case <- R.MatchCase false_pattern (R.FunctionCall ("{}::False" % RT.showBase rust_result_type) [false_ctor]) None
    cases <- [true_case, false_case]
    match_true <- R.Match (R.VarRef (getArgName 1)) cases

    true_case <- R.MatchCase true_pattern (R.FunctionCall ("{}::False" % RT.showBase rust_result_type) [false_ctor]) None
    false_case <- R.MatchCase false_pattern (R.FunctionCall ("{}::False" % RT.showBase rust_result_type) [false_ctor]) None
    cases <- [true_case, false_case]
    match_false <- R.Match (R.VarRef (getArgName 1)) cases

    true_case <- R.MatchCase true_pattern match_true None
    false_case <- R.MatchCase false_pattern match_false None
    cases <- [true_case, false_case]
    match <- R.Match (R.VarRef (getArgName 0)) cases

    R.Block [match]

generateOpOr :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateOpOr program type_store arg_types result_type = do
    rust_result_type <- convertType result_type
    field_access0 <- R.FieldAccess innerValueField (R.VarRef (getArgName 0))
    field_access1 <- R.FieldAccess innerValueField (R.VarRef (getArgName 1))
    rust_result_type <- convertType result_type
    arg_type <- atIndex arg_types 0
    true_record_type <- getVariantRecordTypeId program arg_type "True"
    false_record_type <- getVariantRecordTypeId program arg_type "False"
    true_pattern <- R.VariantPattern "true" None
    false_pattern <- R.VariantPattern "false" None
    rust_true_record_type <- convertType (LT.Record true_record_type [])
    rust_false_record_type <- convertType (LT.Record false_record_type [])
    true_ctor <- R.StructCtor (RT.showBase (rust_true_record_type)) []
    false_ctor <- R.StructCtor (RT.showBase (rust_false_record_type)) []

    true_pattern <- R.VariantPattern ("{}::True" % RT.showBase rust_result_type) (Some "_")
    false_pattern <- R.VariantPattern ("{}::False" % RT.showBase rust_result_type) (Some "_")

    true_case <- R.MatchCase true_pattern (R.FunctionCall ("{}::True" % RT.showBase rust_result_type) [true_ctor]) None
    false_case <- R.MatchCase false_pattern (R.FunctionCall ("{}::True" % RT.showBase rust_result_type) [true_ctor]) None
    cases <- [true_case, false_case]
    match_true <- R.Match (R.VarRef (getArgName 1)) cases

    true_case <- R.MatchCase true_pattern (R.FunctionCall ("{}::True" % RT.showBase rust_result_type) [true_ctor]) None
    false_case <- R.MatchCase false_pattern (R.FunctionCall ("{}::False" % RT.showBase rust_result_type) [false_ctor]) None
    cases <- [true_case, false_case]
    match_false <- R.Match (R.VarRef (getArgName 1)) cases

    true_case <- R.MatchCase true_pattern match_true None
    false_case <- R.MatchCase false_pattern match_false None
    cases <- [true_case, false_case]
    match <- R.Match (R.VarRef (getArgName 0)) cases

    R.Block [match]

generateGetDiscriminant :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateGetDiscriminant program type_store arg_types result_type = do
    arg_type <- atIndex arg_types 0
    case arg_type of
        LT.Adt adt_id _ -> do
            adt <- getAdt program adt_id
            var_ref <- R.VarRef (getArgName 0)
            rust_type <- convertType arg_type
            rust_result_type <- convertType result_type
            cases <- adt.variants |> List.iter |> Iterator.fold (\cases, variant -> do
                index <- getLength cases
                name <- "{}::{}" % (RT.showBase rust_type, variant.name)
                pattern <- R.VariantPattern name (Some "_")
                struct_ctor <- R.StructCtor (RT.showBase rust_result_type) [R.FieldInitItem innerValueField (R.IntegerLiteral "{}" % index)]
                c <- R.MatchCase pattern struct_ctor None
                cases <- push cases c
                cases) []
            R.Block [R.Match var_ref cases]
        LT.Record _ _ -> do
            rust_result_type <- convertType result_type
            struct_ctor <- R.StructCtor (RT.showBase rust_result_type) [R.FieldInitItem innerValueField (R.IntegerLiteral "0")]
            R.Block [struct_ctor]
        _ -> panic "getDiscriminant not implemented for special types {}" % arg_type

generateAssert :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateAssert program type_store arg_types result_type = do
    rust_result_type <- convertType result_type
    arg_type <- atIndex arg_types 0
    rust_type <- convertType arg_type
    rust_result_type <- convertType result_type
    true_pattern <- R.VariantPattern ("{}::True" % RT.showBase rust_type) (Some "_")
    false_pattern <- R.VariantPattern ("{}::False" % RT.showBase rust_type) (Some "_")
    true_case <- R.MatchCase true_pattern (R.StructCtor (RT.showBase rust_result_type) []) None
    false_case <- R.MatchCase false_pattern (R.Block [R.FunctionCall "panic!" [R.StringLiteral "Assertion failed"]]) None
    cases <- [true_case, false_case]
    match <- R.Match (R.VarRef (getArgName 0)) cases
    R.Block [match]

generateIsUppercase :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateIsUppercase program type_store arg_types result_type = do
    field_access0 <- R.FieldAccess innerValueField (R.VarRef (getArgName 0))
    call <- R.MethodCall field_access0 "is_uppercase" []
    match <- rustBoolToSikoBool program call result_type
    R.Block [match]

generateReadTextFile :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateReadTextFile program type_store arg_types result_type = do
    rust_result_type <- convertType result_type
    field_access0 <- R.FieldAccess innerValueField (R.VarRef (getArgName 0))
    read_call <- R.FunctionCall "std::fs::read" [field_access0]
    read_call <- R.MethodCall read_call "expect" [R.StringLiteral "ReadTextFile failed"]
    convert <- R.FunctionCall "String::from_utf8_lossy" [R.Ref read_call]
    to_string_call <- R.MethodCall convert "to_string" []
    struct_ctor <- R.StructCtor (RT.showBase rust_result_type) [R.FieldInitItem innerValueField to_string_call]
    R.Block [struct_ctor]

generateWriteTextFile :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateWriteTextFile program type_store arg_types result_type = do
    rust_result_type <- convertType result_type
    field_access0 <- R.FieldAccess innerValueField (R.VarRef (getArgName 0))
    field_access1 <- R.FieldAccess innerValueField (R.VarRef (getArgName 1))
    write_call <- R.FunctionCall "std::fs::write" [field_access0, field_access1]
    write_call <- R.MethodCall write_call "expect" [R.StringLiteral "WriteTextFile failed"]
    struct_ctor <- R.StructCtor (RT.showBase rust_result_type) []
    R.Block [write_call, struct_ctor]

generateGetArgs :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateGetArgs program type_store arg_types result_type = do
    rust_result_type <- convertType result_type
    args_call <- R.FunctionCall "std::env::args" []
    arg <- "arg"
    string_ctor <- R.StructCtor stringTypeName [R.FieldInitItem innerValueField (R.VarRef arg)]
    map_body <- R.Lambda ("|{}|" % arg) string_ctor
    map <- R.MethodCall args_call "map" [map_body]
    collect <- R.MethodCall map "collect" []
    args <- "args"
    args_decl <- R.VarDecl args collect (Some (RT.Named "Vec<_>" []))
    struct_ctor <- R.StructCtor (RT.showBase rust_result_type) [R.FieldInitItem innerValueField (R.VarRef args)]
    R.Block [args_decl, struct_ctor]

generateSink :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateSink program type_store arg_types result_type = do
    rust_result_type <- convertType result_type
    struct_ctor <- R.StructCtor (RT.showBase rust_result_type) []
    R.Block [struct_ctor]

generateBorrower :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateBorrower program type_store arg_types result_type = do
    rust_result_type <- convertType result_type
    struct_ctor <- R.StructCtor (RT.showBase rust_result_type) []
    R.Block [struct_ctor]

generateIntParse :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateIntParse program type_store arg_types result_type = do
    rust_result_type <- convertType result_type
    field_access0 <- R.FieldAccess innerValueField (R.VarRef (getArgName 0))
    parse_call <- R.MethodCall field_access0 "parse::<i64>" []
    rust_result_type <- convertType result_type
    some_record_type <- getVariantRecordTypeId program result_type "Some"
    none_record_type <- getVariantRecordTypeId program result_type "None"
    rust_some_record_type <- convertType (LT.Record some_record_type [])
    rust_none_record_type <- convertType (LT.Record none_record_type [])
    some_record <- getRecord program some_record_type
    int_field <- atIndex some_record.fields 0
    rust_int_type <- convertType int_field.type
    int_ctor <- R.StructCtor (RT.showBase rust_int_type) [R.FieldInitItem innerValueField (R.VarRef "v")]
    some_ctor <- R.StructCtor (RT.showBase rust_some_record_type) [R.FieldInitItem (getFieldName 0) (int_ctor)]
    none_ctor <- R.StructCtor (RT.showBase rust_none_record_type) []
    ok_pattern <- R.VariantPattern ("Ok") (Some "v")
    err_pattern <- R.VariantPattern ("Err") (Some "_")
    ok_case <- R.MatchCase ok_pattern (R.FunctionCall ("{}::Some" % RT.showBase rust_result_type) [some_ctor]) None
    err_case <- R.MatchCase err_pattern (R.FunctionCall ("{}::None" % RT.showBase rust_result_type) [none_ctor]) None
    cases <- [ok_case, err_case]
    match <- R.Match parse_call cases
    R.Block [match]

generateListAtIndex :: Program -> TypeStore -> [LT.Type] -> LT.Type -> R.Expr
generateListAtIndex program type_store arg_types result_type = do
    rust_type <- convertType result_type
    arg0 <- R.VarRef (getArgName 0)
    arg1 <- R.VarRef (getArgName 1)
    inner0 <- R.FieldAccess innerValueField arg0
    inner1 <- R.FieldAccess innerValueField arg1
    index <- R.FunctionCall "std::ops::Index::index" [R.Ref inner0, R.As inner1 "usize"]
    if RT.isRef rust_type
