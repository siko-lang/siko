module Siko.MIR.Backend.Ownership.InferenceInfo where

import Siko.MIR.Expr as E
import Siko.MIR.Program as P
import Siko.Trace
import Siko.Config
import Map
import Set
import Siko.MIR.Backend.Ownership.FunctionInfo
import Siko.MIR.Backend.Ownership.Lowering.LoweringInfo
import Siko.MIR.Backend.Ownership.Lowering.LoweringInfo.FilterInfo
import Siko.MIR.Backend.Ownership.TypeVariableInfo
import Siko.MIR.Backend.Ownership.Allocator
import Siko.MIR.Backend.Ownership.BorrowId
import Siko.MIR.Backend.Ownership.MemberInfo as M
import Siko.MIR.Backend.Ownership.GroupDependencyMap
import Siko.MIR.Backend.Ownership.OwnershipDependencyMap
import Siko.MIR.Backend.Ownership.EqualitySolver
import Siko.Util.DependencyProcessorLinear
import Siko.MIR.Backend.Ownership.Converter

import List2 as List2
import List2 (List2)
import Map2 as Map2
import Map2 (Map2)

data Borrow = Local E.ExprId
            | External BorrowId
            | Internal BorrowId
            deriving (PartialEq, Eq, PartialOrd, Ord, Show)

data BorrowSet = { borrows :: Set Borrow } deriving (Show, PartialEq, Eq, PartialOrd, Ord)

data FunctionInferenceInfo = { args :: List2 TypeVariableInfo,
                               result :: TypeVariableInfo,
                             } deriving (PartialEq, Eq, PartialOrd, Ord, Show)

data GlobalExprId = { function_id :: P.Identity,
                      expr_id :: E.ExprId } deriving (PartialEq, Eq, PartialOrd, Ord, Show)

data GlobalVar = { function_id :: P.Identity,
                   var :: E.Var } deriving (PartialEq, Eq, PartialOrd, Ord, Show)

data FunctionInfoBase = { args :: List2 TypeVariableInfo,
                          result :: TypeVariableInfo,
                          members :: List2 M.MemberInfo,
                          converters :: List2 Converter,
                          relevant_ownership_vars :: List2 OwnershipTypeVariable,
                          result_only_vars :: List2 OwnershipTypeVariable,
                        } deriving (Show)

data InferenceInfo = { expr_type_variables :: Map2 GlobalExprId TypeVariableInfo,
                       var_type_variables :: Map2 GlobalVar TypeVariableInfo,
                       group :: List2 P.Identity,
                       function_infos :: Map2 P.Identity FunctionInferenceInfo,
                       ownership_values :: Map2 OwnershipTypeVariable M.OwnershipKind,
                       members :: List2 M.MemberInfo,
                       converters :: List2 Converter,
                       allocator :: Allocator,
                       function_converters :: Map2 E.ExprId (List2 Converter),
                       group_function_converters :: Map2 P.Identity (List2 Converter),
                       borrow_sets :: Map2 BorrowId BorrowSet,
                       external_borrows :: Map2 BorrowId BorrowId,
                       interrnal_borrows :: Map2 BorrowId BorrowId,
                       initials :: Map2 OwnershipTypeVariable M.OwnershipKind,
                       function_info_bases :: Map2 P.Identity FunctionInfoBase,
                     } deriving (Show)

createInferenceInfoFromLoweringInfo :: FunctionLoweringInfo -> P.Identity -> (InferenceInfo, List2 BorrowId)
createInferenceInfoFromLoweringInfo lowering_info function_id = do
    expr_type_variables <- Map2.empty
    var_type_variables <- Map2.empty
    ownership_values <- Map2.empty
    args <- lowering_info.args
    var_type_variables <- List2.foldE (\var_type_variables, index, arg ->
            Map2.put var_type_variables (GlobalVar function_id (E.Arg index)) arg) var_type_variables args
    result <- lowering_info.result
    function_inference_info <- FunctionInferenceInfo args result
    function_infos <- Map2.put Map2.empty function_id function_inference_info
    allocator <- lowering_info.allocator
    members <- lowering_info.members
    converters <- List2.empty
    function_converters <- Map2.empty
    group_function_converters <- Map2.empty
    borrow_sets <- Map2.empty
    group <- List2.single function_id
    inference_info <- InferenceInfo expr_type_variables var_type_variables group
        function_infos ownership_values members converters allocator
        function_converters group_function_converters borrow_sets  Map2.empty Map2.empty Map2.empty Map2.empty
    (inference_info, external_borrows) <- List2.fold (inference_info, List2.empty) lowering_info.ownershipinfos (\(inference_info, external_borrows), ownershipinfo -> do
            (inference_info, external_borrows, v, kind) <- case ownershipinfo of
                M.OwnershipInfo v M.Unknown -> panic "Unknown ownership in createInferenceInfoFromLoweringInfo"
                M.OwnershipInfo v M.Owner -> panic "Owner ownership in createInferenceInfoFromLoweringInfo"
                M.OwnershipInfo v (M.Borrower external_id) -> do
                    (inference_info, id) <- createBorrowSetForExternal inference_info external_id
                    (inference_info, List2.push external_borrows id, v, M.Borrower id)
            (ownership_values, _) <- Map2.insert inference_info.ownership_values v kind
            initials <- Map2.put inference_info.initials v kind
            inference_info <- inference_info { ownership_values = ownership_values, initials = initials }
            (inference_info, external_borrows)
        )
    (ownership_values, initials) <- List2.fold (inference_info.ownership_values, inference_info.initials) members (\(ownership_values, initials), member -> do
            case Map2.get ownership_values member.info.ownership_var of
                Some _ -> (ownership_values, initials)
                None -> (Map2.put ownership_values member.info.ownership_var M.Owner, Map2.put initials member.info.ownership_var M.Owner)
        )
    (ownership_values, initials) <- List2.fold (ownership_values, initials) args (\(ownership_values, initials), arg -> do
            case Map2.get ownership_values arg.ownership_var of
                Some _ -> (ownership_values, initials)
                None -> (Map2.put ownership_values arg.ownership_var M.Owner, Map2.put initials arg.ownership_var M.Owner)
        )
    (ownership_values, initials) <- case Map2.get ownership_values result.ownership_var of
                Some _ -> (ownership_values, initials)
                None -> (Map2.put ownership_values result.ownership_var M.Owner, Map2.put initials result.ownership_var M.Owner)
    inference_info <- inference_info { ownership_values = ownership_values, initials = initials }
    (inference_info, external_borrows)

addFunctionInferenceInfo :: InferenceInfo -> P.Identity -> Int -> InferenceInfo
addFunctionInferenceInfo inference_info id arg_count = do
    var_type_variables <- inference_info.var_type_variables
    args <- List2.empty
    allocator <- inference_info.allocator
    (var_type_variables, args, allocator) <- loop (var_type_variables, args, allocator, index) <- (var_type_variables, args, allocator, 0) do
        if index >= arg_count
        then break (var_type_variables, args, allocator)
        else do
            (allocator, info) <- getNextTypeVariableInfo allocator
            arg <- E.Arg index
            var_type_variables <- Map2.put var_type_variables (GlobalVar id arg) info
            args <- List2.push args info
            (var_type_variables, args, allocator, index + 1)
    (allocator, result) <- getNextTypeVariableInfo allocator
    function_inference_info <- FunctionInferenceInfo args result
    function_infos <- Map2.put inference_info.function_infos id function_inference_info
    group <- List2.push inference_info.group id
    inference_info { var_type_variables = var_type_variables,
                     group = group, allocator = allocator, function_infos = function_infos }

createInferenceInfo :: InferenceInfo
createInferenceInfo = do
    allocator <- createAllocator
    function_infos <- Map2.empty
    ownership_values <- Map2.empty
    function_converters <- Map2.empty
    group_function_converters <- Map2.empty
    borrow_sets <- Map2.empty
    InferenceInfo Map2.empty Map2.empty List2.empty function_infos ownership_values List2.empty List2.empty allocator
            function_converters group_function_converters borrow_sets Map2.empty Map2.empty Map2.empty Map2.empty

createBorrowSet :: InferenceInfo -> Borrow -> (InferenceInfo, BorrowId)
createBorrowSet inference_info borrow = do
    allocator <- inference_info.allocator
    (allocator, id) <- getNextBorrowId allocator
    borrows <- Set.empty
    borrow_set <- BorrowSet (Set.put borrows borrow)
    borrow_sets <- Map2.put inference_info.borrow_sets id borrow_set
    (inference_info { allocator = allocator, borrow_sets = borrow_sets }, id)

createBorrowSetForExpr :: InferenceInfo -> E.ExprId -> (InferenceInfo, BorrowId)
createBorrowSetForExpr inference_info expr_id = do
    (inference_info, id) <- createBorrowSet inference_info (Local expr_id)
    (inference_info, id)

createBorrowSetForExternal :: InferenceInfo -> BorrowId -> (InferenceInfo, BorrowId)
createBorrowSetForExternal inference_info external_id = do
    case Map2.get inference_info.external_borrows external_id of
        Some id -> (inference_info, id)
        None -> do
    (inference_info, id) <- createBorrowSet inference_info (External external_id)
    external_borrows <- Map2.put inference_info.external_borrows external_id id
    (inference_info { external_borrows = external_borrows }, id)

createBorrowSetForInternal :: InferenceInfo -> BorrowId -> (InferenceInfo, BorrowId)
createBorrowSetForInternal inference_info external_id = do
    case Map2.get inference_info.interrnal_borrows external_id of
        Some id -> (inference_info, id)
        None -> do
    (inference_info, id) <- createBorrowSet inference_info (Internal external_id)
    interrnal_borrows <- Map2.put inference_info.interrnal_borrows external_id id
    (inference_info { interrnal_borrows = interrnal_borrows }, id)

containsBorrows :: InferenceInfo -> BorrowId -> BorrowId -> (InferenceInfo, Bool)
containsBorrows inference_info id1 id2 = do
    if id1 == id2 then (inference_info, True)
    else do
        (inference_info, set1) <- getBorrowSet inference_info id1
        (inference_info, set2) <- getBorrowSet inference_info id2
        rest <- set1.borrows - set2.borrows
        (inference_info, Set.isEmpty rest)

mergeBorrowSets :: InferenceInfo -> BorrowId -> BorrowId -> (InferenceInfo, BorrowId)
mergeBorrowSets inference_info id1 id2 = do
    (inference_info, set1) <- getBorrowSet inference_info id1
    (inference_info, set2) <- getBorrowSet inference_info id2
    allocator <- inference_info.allocator
    (allocator, id) <- getNextBorrowId allocator
    merged <- set1.borrows + set2.borrows
    merged_set <- BorrowSet merged
    borrow_sets <- Map2.put inference_info.borrow_sets id merged_set
    (inference_info { allocator = allocator, borrow_sets = borrow_sets }, id)

getBorrowSet :: InferenceInfo -> BorrowId -> (InferenceInfo, BorrowSet) // FIXME
getBorrowSet inference_info id =
    case Map2.get inference_info.borrow_sets id of
        Some borrow_set -> (inference_info, borrow_set)
        None -> panic "No borrow set found for {}" % id

addVar :: InferenceInfo -> P.Identity -> E.Var -> InferenceInfo
addVar inference_info function_id var = do
    (allocator, info) <- getNextTypeVariableInfo inference_info.allocator
    var_type_variables <- Map2.put inference_info.var_type_variables (GlobalVar function_id var) info
    inference_info <- inference_info { var_type_variables = var_type_variables, allocator = allocator }
    inference_info

addExpr :: InferenceInfo -> P.Identity -> E.ExprId -> InferenceInfo
addExpr inference_info function_id expr_id = do
    (allocator, info) <- getNextTypeVariableInfo inference_info.allocator
    expr_type_variables <- Map2.put inference_info.expr_type_variables (GlobalExprId function_id expr_id) info
    inference_info <- inference_info { expr_type_variables = expr_type_variables, allocator = allocator }
    inference_info

addMemberInfo :: InferenceInfo -> M.MemberInfo -> InferenceInfo
addMemberInfo inference_info member_info = do
    members <- List2.push inference_info.members member_info
    inference_info { members = members }

addConverter :: InferenceInfo -> Converter -> InferenceInfo
addConverter inference_info converter = do
    converters <- List2.push inference_info.converters converter
    inference_info { converters = converters }

addOwnership :: InferenceInfo -> OwnershipTypeVariable -> M.OwnershipKind -> InferenceInfo
addOwnership inference_info var kind = do
    (ownership_values, _) <- Map2.insert inference_info.ownership_values var kind
    inference_info { ownership_values = ownership_values }

changeInitialOwnership :: Map2 OwnershipTypeVariable M.OwnershipKind -> Map2 OwnershipTypeVariable M.OwnershipKind ->
                          OwnershipTypeVariable -> M.OwnershipKind -> Bool ->
                          (Map2 OwnershipTypeVariable M.OwnershipKind, Map2 OwnershipTypeVariable M.OwnershipKind, Bool)
changeInitialOwnership ownership_values initials var kind force = do
    (kind, update) <- case Map2.get initials var of
        Some M.Unknown -> (kind, True)
        Some kind -> (kind, force)
        None -> (kind, True)
    ownership_values <- if update
    then Map2.put ownership_values var kind
    else ownership_values
    (ownership_values, initials, update)

addInferredOwnership :: InferenceInfo -> OwnershipTypeVariable -> M.OwnershipKind -> (InferenceInfo, Bool)
addInferredOwnership inference_info var kind = do
    (ownership_values, initials, update) <- changeInitialOwnership inference_info.ownership_values inference_info.initials var kind False
    (inference_info { ownership_values = ownership_values, initials = initials }, update)

maybeAddOwnership :: InferenceInfo -> OwnershipTypeVariable -> M.OwnershipKind -> InferenceInfo
maybeAddOwnership inference_info var kind = do
    (ownership_values, _) <- Map2.alter (\old -> case old of
        Some old -> case old of
            M.Unknown -> do
                //println "maybeAddOwnership: Added {} to {}" % (kind, var)
                Some kind
            old -> Some old
        None -> do
            //println "maybeAddOwnership: Added {} to {} 2" % (kind, var)
            Some kind) var inference_info.ownership_values
    inference_info { ownership_values = ownership_values }

enforceOwner :: InferenceInfo -> OwnershipTypeVariable -> List2 BorrowId -> InferenceInfo
enforceOwner inference_info var external_borrows = do
    kind <- case Map2.get inference_info.ownership_values var of
        Some old -> case old of
            M.Unknown -> M.Owner
            M.Borrower id -> if List2.contains external_borrows id
                            then old
                            else M.Owner
            M.Owner -> M.Owner
        None -> M.Owner
    (inference_info, update) <- addInferredOwnership inference_info var kind
    initials <- if update
    then Map2.put inference_info.initials var kind
    else inference_info.initials
    inference_info { initials = initials }

getOwnership :: InferenceInfo -> OwnershipTypeVariable -> (InferenceInfo, Option M.OwnershipKind)
getOwnership inference_info var = do
    result <- Map2.get inference_info.ownership_values var
    (inference_info, result)

getFunctionInferenceInfo :: InferenceInfo -> P.Identity -> (InferenceInfo, FunctionInferenceInfo)
getFunctionInferenceInfo inference_info function_id =
    case Map2.get inference_info.function_infos function_id of
        Some function_inference_info -> (inference_info, function_inference_info)
        None -> panic "function_inference_info not found in getFunctionInferenceInfo"

getTypeVariableInfoByExprId :: InferenceInfo -> E.ExprId -> P.Identity -> (InferenceInfo, TypeVariableInfo) // FIXME
getTypeVariableInfoByExprId inference_info expr_id function_id = do
    case Map2.get inference_info.expr_type_variables (GlobalExprId function_id expr_id) of
        Some i -> (inference_info, i)
        None -> panic "TypeVariableInfo not found for expr {}" % expr_id

getTypeVariableInfoByVar :: InferenceInfo -> E.Var -> P.Identity -> (InferenceInfo, TypeVariableInfo) // FIXME
getTypeVariableInfoByVar inference_info var function_id = do
    case Map2.get inference_info.var_type_variables (GlobalVar function_id var) of
        Some i -> (inference_info, i)
        None -> panic "TypeVariableInfo not found for var {}" % var

getFunctionConverters :: Config -> InferenceInfo -> P.Identity -> List2 Converter
getFunctionConverters config inference_info function_id = do
    (inference_info, function_inference_info) <- getFunctionInferenceInfo inference_info function_id
    members <- inference_info.members
    converters <- inference_info.converters
    (converters, converter_map) <- List2.foldLinear Map2.empty converters (\converter_map, converter ->
        Map2.put converter_map converter.from converter.to)
    (members, group_dep_map, _, _) <- calculateGroupDepMap config members
    input_group_vars <- List2.fold List2.empty function_inference_info.args
        (\input_group_vars, info -> do
            input_group_vars <- case Map2.get group_dep_map info.arg_group_var of
                Some group_vars -> input_group_vars + group_vars
                None -> input_group_vars
            List2.push input_group_vars info.arg_group_var)
    input_group_vars <- input_group_vars |> List2.sort |> List2.dedup
    //trace config "toFunctionInfo: collecting input group vars"
    output_group_vars <- case Map2.get group_dep_map function_inference_info.result.arg_group_var of
        Some group_vars -> group_vars
        None -> List2.empty
    output_group_vars <- List2.push output_group_vars function_inference_info.result.arg_group_var
    output_group_vars <- output_group_vars |> List2.sort |> List2.dedup
    (input_group_vars, input_members) <- List2.filterS input_group_vars members M.isSubMember
    //trace config "toFunctionInfo: filter output group vars"
    (output_group_vars, output_members) <- List2.filterS output_group_vars members M.isSubMember
    //trace config "toFunctionInfo: filter input members"
    output_ownership_vars <- List2.single function_inference_info.result.ownership_var
    input_ownership_vars <- List2.fold List2.empty function_inference_info.args
        (\ownership_vars, info -> List2.push ownership_vars info.ownership_var)
    //trace config "toFunctionInfo: to ownership infos"
    (input_members, input_ownership_vars) <- List2.foldLinear input_ownership_vars input_members (\vars, member ->
            List2.push vars member.info.ownership_var)
    //trace config "toFunctionInfo: collecting output_ownership_vars"
    (output_members, output_ownership_vars) <- List2.foldLinear output_ownership_vars output_members (\vars, member ->
            List2.push vars member.info.ownership_var)
    (converters, (converter_map, input_ownership_vars, output_ownership_vars, filtered_converters)) <- List2.foldLinear (converter_map, input_ownership_vars, output_ownership_vars, List2.empty) converters
        (\(converter_map, input_ownership_vars, output_ownership_vars, filtered_converters), converter -> do
            filtered_converters <- if List2.contains input_ownership_vars converter.from
            then do
                converter <- loop (visited, converter) <- (List2.single converter.from, converter) do
                    converter :: Converter <- converter // FIXME
                    case Map2.get converter_map converter.to of
                        Some another_to -> do
                            if List2.contains visited another_to
                            then break converter
                            else do
                                visited <- List2.push visited another_to
                                //println "Switching to {} -> {}" % (converter.to, another_to)
                                (visited, converter { to = another_to })
                        None -> break converter
                if List2.contains output_ownership_vars converter.to
                then List2.push filtered_converters converter
                else filtered_converters
            else filtered_converters
            (converter_map, input_ownership_vars, output_ownership_vars, filtered_converters))
    filtered_converters

createFunctionInfoBase :: Config -> InferenceInfo -> P.Identity -> (InferenceInfo, FunctionInfoBase)
createFunctionInfoBase config inference_info function_id = do
    (inference_info, function_inference_info) <- getFunctionInferenceInfo inference_info function_id
    // println "createFunctionInfoBase"
    // println "members: {}" % List2.getLength inference_info.members
    // println "converters: {}" % List2.getLength inference_info.converters
    // println "expr_type_variables: {}" % Map2.getSize inference_info.expr_type_variables
    // println "var_type_variables: {}" % Map2.getSize inference_info.var_type_variables
    // println "ownership_values: {}" % Map2.getSize inference_info.ownership_values
    // println "borrow_sets: {}" % Map2.getSize inference_info.borrow_sets

    members <- inference_info.members
    (members, group_dep_map, deps_map, groups) <- calculateGroupDepMap config members
    input_group_vars <- List2.fold List2.empty function_inference_info.args
        (\input_group_vars, info -> do
            input_group_vars <- case Map2.get group_dep_map info.arg_group_var of
                Some group_vars -> input_group_vars + group_vars
                None -> input_group_vars
            List2.push input_group_vars info.arg_group_var)
    input_group_vars <- input_group_vars |> List2.sort |> List2.dedup
    output_group_vars <- case Map2.get group_dep_map function_inference_info.result.arg_group_var of
        Some group_vars -> group_vars
        None -> List2.empty
    output_group_vars <- List2.push output_group_vars function_inference_info.result.arg_group_var
    output_group_vars <- output_group_vars |> List2.sort |> List2.dedup
    (input_group_vars, input_members) <- List2.filterS input_group_vars members M.isSubMember
    (output_group_vars, output_members) <- List2.filterS output_group_vars members M.isSubMember
    output_ownership_vars <- List2.single function_inference_info.result.ownership_var
    input_ownership_vars <- List2.fold List2.empty function_inference_info.args
        (\ownership_vars, info -> List2.push ownership_vars info.ownership_var)
    (input_members, input_ownership_vars) <- List2.foldLinear input_ownership_vars input_members (\vars, member ->
            List2.push vars member.info.ownership_var)
    (output_members, output_ownership_vars) <- List2.foldLinear output_ownership_vars output_members (\vars, member ->
            List2.push vars member.info.ownership_var)
    relevant_ownership_vars <- input_ownership_vars + output_ownership_vars

    converters <- mergeConverters config inference_info.converters
    ((input_ownership_vars, output_ownership_vars), filtered_converters) <- List2.filterS (input_ownership_vars, output_ownership_vars) converters (\(input_ownership_vars, output_ownership_vars), converter -> do
        match <- List2.contains input_ownership_vars converter.from && List2.contains output_ownership_vars converter.to
        ((input_ownership_vars, output_ownership_vars), match))

    members <- (input_members + output_members) |> List2.sort |> List2.dedup

    result_only_vars <- output_ownership_vars

    converter_results <- List2.fold List2.empty filtered_converters (\converter_results, converter -> List2.push converter_results converter.to)

    (_, result_only_vars) <- List2.filterS input_ownership_vars result_only_vars (\input_ownership_vars, var -> do
        r <- not (List2.contains input_ownership_vars var)
        (input_ownership_vars, r))
    (_, result_only_vars) <- List2.filterS converter_results result_only_vars (\converter_results, var -> do
        r <- not (List2.contains converter_results var)
        (converter_results, r))

    (inference_info, FunctionInfoBase function_inference_info.args function_inference_info.result
        members filtered_converters relevant_ownership_vars result_only_vars)

toFunctionInfo :: Config -> InferenceInfo -> P.Identity -> (InferenceInfo, FunctionInfo)
toFunctionInfo config inference_info function_id = do
    (inference_info, function_info_base) <- case Map2.get inference_info.function_info_bases function_id of
        Some function_info_base -> (inference_info, function_info_base)
        None -> createFunctionInfoBase config inference_info function_id

    (filtered_ownershipinfos, ownership_values) <- loop (filtered_ownershipinfos, relevant_ownership_vars, ownership_values, index) <- (List2.empty, function_info_base.relevant_ownership_vars, inference_info.ownership_values, 0) do
        if index >= List2.getLength relevant_ownership_vars
        then break (filtered_ownershipinfos, ownership_values)
        else do
            var <- List2.atIndex relevant_ownership_vars index
            filtered_ownershipinfos <- case Map2.get ownership_values var of
                Some kind -> List2.push filtered_ownershipinfos (M.OwnershipInfo var kind)
                None -> filtered_ownershipinfos // FIXME: investigate, why is this possible??
            (filtered_ownershipinfos, relevant_ownership_vars, ownership_values, index + 1)

    filtered_ownershipinfos <- filtered_ownershipinfos |> List2.sort |> List2.dedup

    (_, filtered_ownershipinfos) <- List2.mapS function_info_base.result_only_vars filtered_ownershipinfos (\result_only_vars, info -> do
        if List2.contains result_only_vars info.var
        then (result_only_vars, info { kind = M.Owner })
        else (result_only_vars, info))

    (inference_info, FunctionInfo function_info_base.args function_info_base.result
        function_info_base.members function_info_base.converters filtered_ownershipinfos)

instance Apply FunctionInferenceInfo where
    apply applier function_inference_info = do
        (applier, args) <- apply applier function_inference_info.args
        (applier, result) <- apply applier function_inference_info.result
        function_inference_info <- FunctionInferenceInfo args result
        (applier, function_inference_info)

instance Apply InferenceInfo where
    apply applier inference_info = do
        (applier, expr_type_variables) <- apply applier inference_info.expr_type_variables
        (applier, var_type_variables) <- apply applier inference_info.var_type_variables
        (applier, function_infos) <- apply applier inference_info.function_infos
        (applier, merged_ownership_values) <- Map2.fold (applier, Map2.empty) inference_info.ownership_values (\(applier, merged_ownership_values), (var, kind) -> do
            (applier, new_var) <- apply applier var
            //println "changed {} => {}" % (var, new_var)
            merged_ownership_values <- Map2.add merged_ownership_values new_var kind
            (applier, merged_ownership_values))

        (applier, merged_initials) <- Map2.fold (applier, Map2.empty) inference_info.initials (\(applier, merged_initials), (var, kind) -> do
            (applier, new_var) <- apply applier var
            merged_initials <- Map2.add merged_initials new_var kind
            (applier, merged_initials))

        initials <- Map2.fold Map2.empty merged_initials (\initials, (var, kinds) -> do
            kinds <- kinds |> List2.sort |> List2.dedup
            kind <- if List2.getLength kinds > 1
            then panic "initials with multiple kinds {}" % kinds
            else List2.atIndex kinds 0
            Map2.put initials var kind)
        inference_info <- inference_info { initials = initials }

        (applier, members) <- apply applier inference_info.members
        (applier, converters) <- apply applier inference_info.converters
        (applier, function_converters) <- apply applier inference_info.function_converters
        (applier, group_function_converters) <- apply applier inference_info.group_function_converters

        members <- List2.dedup (List2.sort members)
        converters <- List2.dedup (List2.sort converters)
        inference_info <- InferenceInfo expr_type_variables var_type_variables inference_info.group function_infos inference_info.ownership_values members converters inference_info.allocator
            function_converters group_function_converters inference_info.borrow_sets inference_info.external_borrows inference_info.interrnal_borrows inference_info.initials inference_info.function_info_bases
        (inference_info, ownership_values) <- Map2.fold (inference_info, Map2.empty) merged_ownership_values (\(inference_info, ownership_values), (var, kinds) -> do
            kinds <- kinds |> List2.sort |> List2.dedup
            kinds <- List2.filter kinds (\kind -> case kind of
                                                M.Unknown -> False
                                                _ -> True)
            (inference_info, kind) <- if List2.contains kinds M.Owner
            then (inference_info, M.Owner)
            else case List2.getLength kinds of
                    0 -> (inference_info, M.Unknown)
                    1 -> (inference_info, List2.atIndex kinds 0)
                    _ -> do
                        (inference_info, all_borrows) <- List2.fold (inference_info, List2.empty) kinds (\(inference_info, all_borrows), kind ->
                            case kind of
                                M.Borrower id -> do
                                        (inference_info, set) <- getBorrowSet inference_info id
                                        all_borrows <- Set.fold all_borrows set.borrows (\all_borrows, borrow -> List2.push all_borrows borrow)
                                        (inference_info, all_borrows)
                                _ -> panic "Non borrower {} found in borrow merge!" % kind)
                        allocator <- inference_info.allocator
                        (allocator, id) <- getNextBorrowId allocator
                        borrows <- List2.fold Set.empty all_borrows (\borrows, borrow -> Set.put borrows borrow)
                        borrow_set <- BorrowSet borrows
                        borrow_sets <- Map2.put inference_info.borrow_sets id borrow_set
                        inference_info <- inference_info { borrow_sets = borrow_sets, allocator = allocator }
                        (inference_info, M.Borrower id)
            (ownership_values, initials, update) <- changeInitialOwnership ownership_values inference_info.initials var kind True
            inference_info <- inference_info { initials = initials }
            (inference_info, ownership_values))
        inference_info <- inference_info { ownership_values = ownership_values }
        (applier, inference_info)

instance MemberOwner InferenceInfo where
    getMembers inference_info = inference_info.members

buildFilterInfoFromInferenceInfo :: Config -> InferenceInfo -> (InferenceInfo, FilterInfo)
buildFilterInfoFromInferenceInfo config inference_info = do
    ownershipinfos <- M.toOwnershipInfo inference_info.ownership_values
    sources <- Map2.fold List2.empty inference_info.function_infos (\sources, (_, function_info) -> do
        sources <- List2.push sources function_info.result
        sources <- sources + function_info.args
        sources)
    sources <- Map2.fold sources inference_info.expr_type_variables (\sources, (_, info) -> List2.push sources info)
    sources <- Map2.fold sources inference_info.var_type_variables (\sources, (_, info) -> List2.push sources info)
    (members, ownershipinfos, filter_info) <- buildFilterInfo config inference_info.members ownershipinfos sources
    (inference_info { members = members }, filter_info)

checkInitials :: InferenceInfo -> String -> InferenceInfo
checkInitials inference_info phase = do
    Map2.fold inference_info inference_info.initials (\inference_info, (var, kind) -> do
        (inference_info, current) <- getOwnership inference_info var
        case current of
            Some current -> do
                if current != kind
                then do
                    println inference_info
                    panic "Initial {} changed ownership {} ! {} => {}" % (var, phase, kind, current)
                else inference_info
            None -> do
                println inference_info
                panic "Initial {} has no ownership {} ! {}" % (var, phase, kind))
