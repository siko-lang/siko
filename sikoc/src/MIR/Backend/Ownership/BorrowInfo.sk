module Siko.MIR.Backend.Ownership.BorrowInfo where

import Map2
import Siko.MIR.Expr as E

import List2

data BorrowInfo = {  borrows :: List2 E.ExprId,
                     invalidations :: Map2 E.ExprId (List2 E.ExprId),
                  } deriving (Show)

isBorrow :: BorrowInfo -> E.ExprId -> (BorrowInfo, Bool)
isBorrow borrow_info expr_id = do
    r <- List2.contains borrow_info.borrows expr_id
    (borrow_info, r)
