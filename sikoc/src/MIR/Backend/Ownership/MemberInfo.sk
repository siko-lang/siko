module Siko.MIR.Backend.Ownership.MemberInfo where

import Set

import Siko.MIR.Backend.Ownership.TypeVariableInfo
import Siko.MIR.Backend.Ownership.BorrowId

import Map2
import List2 as List2
import List2 (List2)

data MemberInfo = Variant Int TypeVariable TypeVariableInfo
                | Member String TypeVariable TypeVariableInfo
                | Extern Int TypeVariable TypeVariableInfo
                deriving (PartialEq, Eq, PartialOrd, Ord, Show)

data OwnershipInfo = Unknown TypeVariable
                   | Owner TypeVariable
                   | Borrower TypeVariable BorrowId
                   deriving (PartialEq, Eq, PartialOrd, Ord, Show)

collect :: List2 MemberInfo -> List2 TypeVariable -> (List2 MemberInfo, List2 TypeVariable)
collect sources result =
    loop (sources, result) <- (sources, result) do
        start_size <- List2.getLength result
        (sources, result) <- List2.foldLinear result sources collectMember
        if List2.getLength result != start_size
        then (sources, result)
        else break (sources, result)

collectMember :: List2 TypeVariable -> MemberInfo -> List2 TypeVariable
collectMember vars constraint =
    case constraint of
        Variant index root info -> addMember vars root info
        Member name root info -> addMember vars root info
        Extern index root info -> addMember vars root info
    where
        addMember :: List2 TypeVariable -> TypeVariable -> TypeVariableInfo -> List2 TypeVariable
        addMember vars root info =
            if List2.contains vars root
            then do
                vars <- List2.push vars info.arg_group_var
                List2.dedup (List2.sort vars)
            else vars

isSubMember :: List2 TypeVariable -> MemberInfo -> (List2 TypeVariable, Bool)
isSubMember vars constraint =
    case constraint of
        Variant index root info -> do
            r <- List2.contains vars root
            (vars, r)
        Member name root info -> do
            r <- List2.contains vars root
            (vars, r)
        Extern index root info -> do
            r <- List2.contains vars root
            (vars, r)

filterOwnershipInfo :: List2 TypeVariable -> OwnershipInfo -> (List2 TypeVariable, Bool)
filterOwnershipInfo vars ownershipinfo =
    case ownershipinfo of
        Unknown v -> List2.foldLinear False vars (\found, var -> found || var == v)
        Owner v -> List2.foldLinear False vars (\found, var -> found || var == v)
        Borrower v _ -> List2.foldLinear False vars (\found, var -> found || var == v)

getDependencyMap2 :: List2 MemberInfo -> (List2 MemberInfo, Map2 TypeVariable (List2 TypeVariable))
getDependencyMap2 members = do
        deps_map <- Map2.empty
        (members, deps_map) <- List2.foldLinear deps_map members (\deps_map, member -> case member of
                Variant index root info -> Map2.put deps_map info.arg_group_var List2.empty
                Member name root info -> Map2.put deps_map info.arg_group_var List2.empty
                Extern index root info -> Map2.put deps_map info.arg_group_var List2.empty
            )
        (members, deps_map) <- List2.foldLinear deps_map members (\deps_map, member -> case member of
                Variant index root info -> addDep deps_map root info.arg_group_var
                Member name root info -> addDep deps_map root info.arg_group_var
                Extern index root info -> addDep deps_map root info.arg_group_var
            )
        (members, deps_map)
    where
        addDep :: Map2 TypeVariable (List2 TypeVariable) -> TypeVariable -> TypeVariable -> Map2 TypeVariable (List2 TypeVariable)
        addDep deps_map root dep = do
            (deps_map, _) <- alter (\old -> case old of
                Some deps -> Some (List2.push deps dep)
                None -> Some (List2.single dep)) root deps_map
            deps_map

getDependencyMap :: List2 TypeVariableInfo -> List2 MemberInfo -> Map2 TypeVariableInfo (List2 TypeVariableInfo)
getDependencyMap sources members = do
        deps_map <- Map2.empty
        deps_map <- List2.fold deps_map sources (\deps_map, info -> addInfo deps_map info)
        deps_map <- List2.fold deps_map members (\deps_map, member -> case member of
            Variant index root info -> addInfo deps_map info
            Member name root info -> addInfo deps_map info
            Extern index root info -> addInfo deps_map info)
        processMembers members deps_map
    where
        processMembers :: List2 MemberInfo -> Map2 TypeVariableInfo (List2 TypeVariableInfo) -> Map2 TypeVariableInfo (List2 TypeVariableInfo)
        processMembers members deps_map =
            List2.fold deps_map members (\deps_map, member ->
                case member of
                    Variant index root info -> addDependency deps_map root info
                    Member name root info -> addDependency deps_map root info
                    Extern index root info -> addDependency deps_map root info)

        addInfo :: Map2 TypeVariableInfo (List2 TypeVariableInfo) -> TypeVariableInfo -> Map2 TypeVariableInfo (List2 TypeVariableInfo)
        addInfo deps_map info = do
            (deps_map, _) <- alter (\old -> case old of
                Some deps -> Some deps
                None -> Some (List2.empty)) info deps_map
            deps_map

        addDependency :: Map2 TypeVariableInfo (List2 TypeVariableInfo) -> TypeVariable -> TypeVariableInfo -> Map2 TypeVariableInfo (List2 TypeVariableInfo)
        addDependency deps_map root info = do
            Map2.update deps_map (\(key, deps) ->
                if key.arg_group_var == root
                then List2.push deps info
                else deps)
