module Siko.MIR.Backend.Ownership.V3.BorrowInfo where

import Map
import Siko.MIR.Expr as E

data BorrowInfo = {  borrows :: [E.ExprId],
                     invalidations :: Map E.ExprId [E.ExprId],
                  }

isBorrow :: BorrowInfo -> E.ExprId -> Bool
isBorrow borrow_info expr_id = List.contains borrow_info.borrows expr_id
