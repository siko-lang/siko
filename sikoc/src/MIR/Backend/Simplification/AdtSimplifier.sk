module Siko.MIR.Backend.Simplification.AdtSimplifier where

import Siko.MIR.Program as P
import Siko.MIR.Expr as E
import Siko.MIR.Data as D
import Siko.MIR.Type as T
import Siko.MIR.Function as F
import Siko.Util.Counter
import Siko.MIR.Backend.Traversal
import Map

data SpecifiedVarInfo = { wrapper_call :: E.Expr, variant_index :: Int }

data Context = { program :: P.Program,
                 expr_id_gen :: Counter E.ExprId,
                 temp_var_gen :: Counter E.Var,
                 replaced_vars :: Map E.Var E.Var,
                 specified_vars :: Map E.Var SpecifiedVarInfo }

getNextExprId :: Context -> (Context, E.ExprId)
getNextExprId context = do
    (expr_id_gen, next_id) <- getNext context.expr_id_gen
    (context { expr_id_gen = expr_id_gen }, next_id)

getNextTempVar :: Context -> (Context, E.Var)
getNextTempVar context = do
    (temp_var_gen, v) <- getNext context.temp_var_gen
    (context { temp_var_gen = temp_var_gen }, v)

replaceVar :: Context -> E.Var -> E.Var -> Context
replaceVar context old new = do
    (replaced_vars, _) <- Map.insert context.replaced_vars old new
    context <- context { replaced_vars = replaced_vars }
    context

processVar :: Context -> E.Var -> E.Var
processVar context var = do
        v <- getVar context var
        if v == var
        then v
        else processVar context v
    where
        getVar :: Context -> E.Var -> E.Var
        getVar context var = case get context.replaced_vars var of
            Some v -> v
            None -> var

processExpr :: Context -> E.Expr -> (Context, E.Expr)
processExpr context expr = do
    E.Expr s_expr type id <- expr
    case s_expr of
        E.Do items -> do
            (context, items) <- List.mapS context items processExpr
            (context, E.Expr (E.Do items) type id)
        E.Multi _ -> panic "Multi expr found in adt simplifier"
        E.StaticFunctionCall f_id args -> do
            (context, args) <- List.mapS context args processExpr
            (context, E.Expr (E.StaticFunctionCall f_id args) type id)
        E.IntegerLiteral lit -> (context, E.Expr (E.IntegerLiteral lit) type id)
        E.StringLiteral lit -> (context, E.Expr (E.StringLiteral lit) type id)
        E.FloatLiteral lit -> (context, E.Expr (E.FloatLiteral lit) type id)
        E.CharLiteral lit -> (context, E.Expr (E.CharLiteral lit) type id)
        E.VarDecl v rhs -> do
            (context, rhs) <- processExpr context rhs
            E.Expr rhs_s_expr rhs_type rhs_id <- rhs
            (context, rhs) <- case rhs_s_expr of
                    E.StaticFunctionCall f_id f_args -> do
                        program <- context.program
                        (program, function) <- P.getFunction program f_id
                        case function.kind of
                            F.VariantCtor index -> do
                                adt_id <- T.getIdentity function.type.result
                                (program, adt) <- P.getAdt program adt_id
                                variant <- atIndex adt.variants index
                                record_id <- T.getIdentity variant.type
                                (program, record) <- P.getRecord program record_id
                                (program, ctor) <- P.getRecordCtor program record_id
                                new_rhs_type <- T.Record record_id
                                new_rhs <- E.Expr (E.StaticFunctionCall ctor f_args) new_rhs_type rhs_id
                                (context, expr_id) <- getNextExprId context
                                (context, wrapper_args) <- List.mapS context record.fields (\context, field -> do
                                    (context, expr_id) <- getNextExprId context
                                    var_ref <- E.Expr (E.VarRef v) new_rhs_type expr_id
                                    (context, expr_id) <- getNextExprId context
                                    field_access <- E.Expr (E.FieldAccess field.name var_ref) field.type expr_id
                                    (context, field_access))
                                wrapper_call <- E.Expr (E.StaticFunctionCall f_id wrapper_args) rhs_type expr_id
                                info <- SpecifiedVarInfo wrapper_call index
                                (specified_vars, _) <- insert context.specified_vars v info
                                context <- context { specified_vars = specified_vars }
                                (context, new_rhs)
                            _ -> (context, rhs)
                    _ -> (context, rhs)
            (context, E.Expr (E.VarDecl v rhs) type id)
        E.VarRef v -> do
            v <- processVar context v
            case get context.specified_vars v of
                Some info -> do
                    info :: SpecifiedVarInfo <- info // FIXME
                    (context, info.wrapper_call)
                None -> (context, E.Expr (E.VarRef v) type id)
        E.FieldAccess name arg -> do
            (context, arg) <- processExpr context arg
            (context, E.Expr (E.FieldAccess name arg) type id)
        E.If cond true_branch false_branch -> do
            (context, cond) <- processExpr context cond
            (context, true_branch) <- processExpr context true_branch
            (context, false_branch) <- processExpr context false_branch
            (context, E.Expr (E.If cond true_branch false_branch) type id)
        E.List args -> do
            (context, args) <- List.mapS context args processExpr
            (context, E.Expr (E.List args) type id)
        E.Return arg -> do
            (context, arg) <- processExpr context arg
            (context, E.Expr (E.Return arg) type id)
        E.Continue arg -> do
            (context, arg) <- processExpr context arg
            (context, E.Expr (E.Continue arg) type id)
        E.Break arg -> do
            (context, arg) <- processExpr context arg
            (context, E.Expr (E.Break arg) type id)
        E.RecordUpdate v updates -> do
            v <- processVar context v
            (context, updates) <- List.mapS context updates (\context, update -> do
                update :: E.RecordUpdateItem <- update // FIXME
                (context, updated_body) <- processExpr context update.body
                (context, update { body = updated_body }))
            (context, E.Expr (E.RecordUpdate v updates) type id)
        E.Loop v initializer body continues breaks -> do
            (context, initializer) <- processExpr context initializer
            (context, body) <- processExpr context body
            (context, E.Expr (E.Loop v initializer body continues breaks) type id)
        E.CaseOf body cases -> do
            E.Expr body_s_expr _ _ <- body
            case body_s_expr of
                E.VarRef body_var -> do
                    v <- processVar context body_var
                    case get context.specified_vars v of
                        Some info -> do
                            info :: SpecifiedVarInfo <- info // FIXME
                            matching_cases <- List.filterMap cases (\c -> case c.checker of
                                E.VariantChecker i v _ -> if i == info.variant_index
                                                          then Some (v, c.body)
                                                          else None
                                _ -> None)
                            if getLength matching_cases == 1
                            then do
                                (case_variant, case_body) <- atIndex matching_cases 0
                                context <- replaceVar context case_variant v
                                (specified_vars, _) <- remove context.specified_vars v
                                block_context <- context { specified_vars = specified_vars }
                                (_, case_body) <- processExpr block_context case_body
                                return (context, case_body)
                            else ()
                        None -> do
                            if getLength cases == 1
                            then do
                                c :: E.Case <- atIndex cases 0 // FIXME: type annotation
                                case c.checker of
                                    E.WildcardChecker -> do
                                        (context, c_body) <- processExpr context c.body
                                        return (context, c_body)
                                    E.VariantChecker index v v_type -> do
                                        case v_type of
                                            T.Record _ -> do
                                                context <- replaceVar context v body_var
                                                (context, c_body) <- processExpr context c.body
                                                return (context, c_body)
                                            _ -> ()
                                    _ -> ()
                            else ()
                _ -> ()
            (context, new_body) <- processExpr context body
            (context, cases) <- List.mapS context cases (\context, case_branch -> do
                (context, updated_body) <- processExpr context case_branch.body
                case_branch <- case_branch { body = updated_body }
                (context, case_branch))
            (context, E.Expr (E.CaseOf new_body cases) type id)
        E.Clone arg -> do
            (context, arg) <- processExpr context arg
            (context, E.Expr (E.Clone arg) type id)
        E.Deref arg -> do
            (context, arg) <- processExpr context arg
            (context, E.Expr (E.Deref arg) type id)
        E.Ref arg -> do
            (context, arg) <- processExpr context arg
            (context, E.Expr (E.Ref arg) type id)
        E.Move arg -> do
            (context, arg) <- processExpr context arg
            (context, E.Expr (E.Move arg) type id)
        E.Box arg -> do
            (context, arg) <- processExpr context arg
            (context, E.Expr (E.Box arg) type id)
        E.Converter arg kind -> do
            (context, arg) <- processExpr context arg
            (context, E.Expr (E.Converter arg kind) type id)

createContext :: P.Program -> Counter E.ExprId -> Counter E.Var -> Context
createContext program expr_id_gen temp_var_gen =
    Context program expr_id_gen temp_var_gen Map.empty Map.empty

processFunction :: P.Program -> F.Function -> F.Function
processFunction program function = case function.kind of
    F.Normal info -> do
        context <- createContext program info.expr_id_gen info.temp_var_gen
        (context, body) <- processExpr context info.body
        info <- info { body = body, expr_id_gen = context.expr_id_gen, temp_var_gen = context.temp_var_gen }
        new_kind <- F.Normal info
        function { kind = new_kind}
    _ -> function

processProgram :: P.Program -> P.Program
processProgram program = do
    functions <- program.functions |> Map.iter |> Iterator.map (\(id, function) -> (id, processFunction program function)) |> toMap
    program { functions = functions }
