module Main where

import Hack

data Foo = Foo

data Rec = { foo :: Foo }

test1 = do
    a <- Foo
    r <- Rec a
    sink r.foo
    sink r.foo

test2 = do
    a <- Foo
    r <- Rec a
    p <- r.foo
    sink r.foo
    sink p

test3 = do
    a <- Foo
    r <- Rec a
    p <- r
    sink r
    sink p

test a b = sink a

test4 = do
    a <- Foo
    b <- Rec a
    r <- Rec a
    f <- test b
    f r
    f r
    sink r.foo

main = do
    test1
    test2
    test3
    test4
