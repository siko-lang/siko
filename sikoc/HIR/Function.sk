module Siko.HIR.Function where

import Siko.HIR.Type
import Siko.HIR.Expr

data Function = {
                    name :: String,
                    module_name :: String,
                    type :: Option Type,
                    body :: Option Expr,
                }

instance Show Function where
    show f = do
        ty <- case f.type of
            Some t -> toString t
            None -> "<unknown>"
        "{}.{} - {} :: {}" % (f.module_name, f.name, ty, f.body)
