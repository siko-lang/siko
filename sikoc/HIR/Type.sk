module Siko.HIR.Type(Type(..),
                     TypeVar(..),
                     Constraint(..),
                     RowKind(..),
                     toString,
                     toLongString,
                     collectVars,
                     getArgCount,
                     getArgs,
                     getResultType,
                     fixedType,
                     collectClassesFromClassConstraints,
                     isConcreteType) where

import Siko.Constants
import Siko.HIR.Program as HP
import Map

data TypeVar = TypeVar Int deriving (Show, PartialEq, Eq, PartialOrd, Ord)

data RowKind = NamedRow String
               | IndexedRow Int
               deriving (Show, PartialEq, Eq, PartialOrd, Ord)

data Constraint = ClassConstraint HP.FullyQualifiedName
                  | RowConstraint RowKind Type
                  deriving (Show, PartialEq, Eq, PartialOrd, Ord)

data Type = Var TypeVar [Constraint]
            | FixedTypeArg String TypeVar [Constraint]
            | Named HP.FullyQualifiedName [Type]
            | Function Type Type
            | Never TypeVar
            | Ref Type
            | Tuple [Type]
            deriving (Show, PartialEq, Eq, PartialOrd, Ord)

isSimple :: Type -> Bool
isSimple type = case type of
    Var _  _ -> True
    FixedTypeArg _ _ _ -> True
    Named n args -> getLength args == 0
    Function _ _ -> False
    Never _ -> True
    Ref _ -> True
    Tuple _ -> True

isFunction :: Type -> Bool
isFunction type = case type of
    Function _ _ -> True
    _ -> False

toStringComplex :: Type -> Map String Bool -> String
toStringComplex type names = if isSimple type then convertType type names else "({})" % (convertType type names)

addConstraint :: String -> [Constraint] -> Map String [Constraint] -> Map String [Constraint]
addConstraint n constraints constraint_map = do
    (constraint_map, _) <- insert constraint_map n constraints
    constraint_map

collectNamesFromConstraints :: [Constraint] -> [String]
collectNamesFromConstraints constraints = constraints |> List.iter |> map (\c -> case c of
                ClassConstraint s -> HP.getResolvableName s
                RowConstraint (NamedRow name) row_type -> name
                RowConstraint (IndexedRow i) row_type -> "{}"  % i) |> toList

collectVarsFromConstraints :: [Constraint] -> [TypeVar]
collectVarsFromConstraints constraints = constraints |> List.iter |> fold (\all, c -> case c of
                ClassConstraint _ -> all
                RowConstraint _ row_type -> all + collectVars row_type) []

collectVars :: Type -> [TypeVar]
collectVars type = case type of
    Var var constraints -> [var] + collectVarsFromConstraints constraints
    FixedTypeArg _ var constraints -> [var] + collectVarsFromConstraints constraints
    Named _ args -> args |> List.iter |> fold (\vars, arg -> do
        vs <- collectVars arg
        vars + vs) []
    Function from to -> collectVars from + collectVars to
    Never var -> [var]
    Ref t -> collectVars t
    Tuple args -> args |> List.iter |> fold (\vars, arg -> do
        vs <- collectVars arg
        vars + vs) []

collectnames :: Type -> Map String [Constraint] -> ([String], Map String [Constraint])
collectnames type constraint_map = case type of
    Var (TypeVar v)  constraints -> (collectNamesFromConstraints constraints, addConstraint ("t{}" % v) constraints constraint_map)
    FixedTypeArg n _ constraints -> (collectNamesFromConstraints constraints, addConstraint n constraints constraint_map)
    Named n args -> do
                n <- HP.getResolvableName n
                args |> List.iter |> fold (\(all, constraint_map), arg -> do
                (args, constraint_map) <- collectnames arg constraint_map
                (all + args, constraint_map)) ([n], constraint_map)
    Function from to -> do
        (args_from, constraint_map) <- collectnames from constraint_map
        (args_to, constraint_map) <- collectnames to constraint_map
        (args_from + args_to, constraint_map)
    Never _ -> ([], constraint_map)
    Ref t -> collectnames t constraint_map
    Tuple args -> args |> List.iter |> fold (\(all, constraint_map), arg -> do
                (args, constraint_map) <- collectnames arg constraint_map
                (all + args, constraint_map)) ([], constraint_map)

getShortName :: String -> String
getShortName name = do
    parts <- split name "."
    atIndex parts ((getLength parts) - 1)

addShortName :: String -> Option [String] -> Option [String]
addShortName name names = case names of
    Some names -> if contains names name then Some names else Some (names + [name])
    None -> Some [name]

formatType :: Type -> Bool -> String
formatType type short = do
    limit <- if short then 1 else 0
    (names, constraint_map) <- collectnames type empty
    conflicting_names <- names |> List.iter |> fold (\short_names, name -> do
                short <- getShortName name
                (short_names, _) <- alter (addShortName name) short short_names
                short_names) empty
    conflicting_names <- conflicting_names |> Map.iter |> map (\(short, names) -> if getLength names > limit then (short, True) else (short, False)) |> toMap
    constraints <- constraint_map |> Map.iter |> map (\(name, constraints) -> do
                                constraints <- constraints |> List.iter |> map (\c -> case c of
                                                    ClassConstraint s -> "{} {}" % (getNiceName (HP.getResolvableName s) conflicting_names, name)
                                                    RowConstraint (NamedRow row_name) row_type -> "#{} :: {} {}" % (row_name, toString row_type, name)
                                                    RowConstraint (IndexedRow index) row_type -> "#{} :: {} {}" % (index, toString row_type, name)) |> toList
                                constraints) |> fold (\all, constraints -> all + constraints) []
    string_type <- convertType type conflicting_names
    if isEmpty constraints
        then string_type
        else "({}) => {}" % (join constraints ", ", string_type)

toString :: Type -> String
toString type = formatType type True

toLongString :: Type -> String
toLongString type = formatType type False

getNiceName :: String -> Map String Bool -> String
getNiceName full_name conflicting_names = do
    short <- getShortName full_name
    case get conflicting_names short of
        Some True -> full_name
        _ -> short

convertType :: Type -> Map String Bool -> String
convertType type names = case type of
    Var var _ -> do
        TypeVar v <- var
        "tv{}" % v
    FixedTypeArg n _ _ -> n
    Named n args -> do
        n <- HP.getResolvableName n
        if n == getFullListTypeName
            then "[{}]" % (convertType (atIndex args 0) names)
            else if isEmpty args
                then getNiceName n names
                else do
                    args <- args |> List.iter |> map (\arg -> toStringComplex arg names) |> toList
                    "{} {}" % (getNiceName n names, join args " ")
    Function from to -> do
        from <- if isFunction from then "({})" % (convertType from names) else convertType from names
        to <- convertType to names
        "{} -> {}" % (from, to)
    Never _ -> "!"
    Ref t -> "&{}" % (toStringComplex t names)
    Tuple args -> do
        args <- args |> List.iter |> map (\arg -> convertType arg names) |> toList
        if getLength args == 1
            then "({},)" % (join args ", ")
            else "({})" % (join args ", ")

getArgCount :: Type -> Int
getArgCount type =
    case type of
        Function _ to -> 1 + getArgCount to
        _ -> 0

getArgs :: Type -> [Type]
getArgs type =
    case type of
        Function from to -> [from] + getArgs to
        _ -> []

getResultType :: Type -> Int -> Type
getResultType type arg_count =
    case type of
        Function from to -> if arg_count == 0 then type else getResultType to (arg_count - 1)
        _ -> type

fixedType :: Type -> Type
fixedType type = do
    vars <- collectVars type |> sort |> dedup
    (var_map, index) <- vars |> List.iter |> fold (\(var_map, index), v -> do
                 new_var <- (("t{}" % index), v)
                 (var_map, _) <- Map.insert var_map v new_var
                 (var_map, index + 1)) (Map.empty, 0)
    convertToFixed var_map type

convertConstraintsToFixed :: [Constraint] -> Map TypeVar (String, TypeVar) -> [Constraint]
convertConstraintsToFixed constraints var_map = constraints |> List.iter |> map (\c -> case c of
    ClassConstraint s -> c
    RowConstraint row_name row_type -> RowConstraint row_name (convertToFixed var_map row_type)) |> toList

convertToFixed :: Map TypeVar (String, TypeVar) -> Type -> Type
convertToFixed var_map type =
    case type of
        Var var constraints -> case get var_map var of
            Some (name, new_var) -> FixedTypeArg name new_var (convertConstraintsToFixed constraints var_map)
            None -> panic "old var {} not found" % var
        FixedTypeArg _ var constraints -> case get var_map var of
            Some (name, new_var) -> FixedTypeArg name new_var (convertConstraintsToFixed constraints var_map)
            None -> panic "old var {} not found" % var
        Named n args -> do
            args <- args |> List.iter |> map (\arg -> convertToFixed var_map arg) |> toList
            Named n args
        Function from to -> do
            from <- convertToFixed var_map from
            to <- convertToFixed var_map to
            Function from to
        Never var -> case get var_map var of
            Some (_, new_var) -> Never new_var
            None -> panic "old var {} not found" % var
        Ref t -> Ref (convertToFixed var_map t)
        Tuple args -> do
            args <- args |> List.iter |> map (\arg -> convertToFixed var_map arg) |> toList
            Tuple args

collectClassesFromClassConstraints :: [Constraint] -> [HP.FullyQualifiedName]
collectClassesFromClassConstraints constraints = constraints |> List.iter |> filter (\c -> case c of
        ClassConstraint _ -> True
        _ -> False) |> map (\c -> case c of
            ClassConstraint n -> n
            _ -> panic "RowConstraint found while collecting classes") |> toList

isConcreteType :: Type -> Bool
isConcreteType type = case type of
    Var _ _ -> False
    FixedTypeArg _ _ _ -> False
    Named _ args -> args |> List.iter |> fold (\concrete, arg -> do
        concrete && isConcreteType arg) True
    Function from to -> isConcreteType from && isConcreteType to
    Never var -> True
    Ref t -> isConcreteType t
    Tuple args -> args |> List.iter |> fold (\concrete, arg -> do
        concrete && isConcreteType arg) True