module Siko.HIR.Class where

import Siko.HIR.Program
import Siko.HIR.Function
import Siko.HIR.Type

data Class = { name :: String,
               module_name :: String,
               class_constraints :: [FullyQualifiedName],
               members :: [Function],
             } deriving (Show)

data Instance = { class_name :: FullyQualifiedName,
                  type :: Type,
                  members :: [Function],
                } deriving (Show)

