module Siko.HIR.ClassDependencyStore where

import Siko.HIR.Program as P

import Siko.HIR.Unification as U
import Siko.HIR.TypeIsomorphism as HTI

import Map

data ClassDependencyStore = { dependencies :: Map P.FullyQualifiedName [P.FullyQualifiedName] }

createClassDependencyStore :: ClassDependencyStore
createClassDependencyStore = ClassDependencyStore Map.empty

addClassDependency :: ClassDependencyStore -> P.FullyQualifiedName -> [P.FullyQualifiedName] -> ClassDependencyStore
addClassDependency store class_name dependencies = do
    (dependencies, _) <- Map.insert store.dependencies class_name dependencies
    store { dependencies = dependencies }

getDependencies :: ClassDependencyStore -> P.FullyQualifiedName -> [P.FullyQualifiedName]
getDependencies store class_name = case get store.dependencies class_name of
    Some dependencies -> dependencies
    None -> panic "Class {} not found in class dependency store" % class_name

instance U.ClassProvider ClassDependencyStore where
    getAllClassDependencies store qn = getDependencies store qn

instance HTI.DependencyProvider ClassDependencyStore where
    getAllDependencies store qn = getDependencies store qn
