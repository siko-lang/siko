module Siko.HIR.Module where

import Siko.HIR.Function as F
import Siko.HIR.Data as D
import Siko.HIR.Class as C
import Map

data Item = Function F.Function
            | Adt D.AbstractDataType
            | Record D.Record
            | Class C.Class
            | Instance C.Instance
            deriving (Show)

data Module = {
                    name :: String,
                    items :: Map String Item
            }
