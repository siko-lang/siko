module Main where

foo1 = do
    List.fold 1 [1, 2] (\x, y -> x + y)
    foo2

foo2 = do
    List.fold 1 [1, 2] (\x, y -> x + y)
    foo3

foo3 = do
    List.fold 1 [1, 2] (\x, y -> x + y)

main = do
    println "module Main where"
    println ""
    loop i <- 0 do
        if i < 1000
        then do
            println "foo{} = do" % i
            println "   List.fold 1 [1, 2] (\\x, y -> x + y)"
            println "   foo{}" % (i+1)
            println ""
            i + 1
        else do
            println "foo{} = do" % i
            println "   List.fold 1 [1, 2] (\\x, y -> x + y)"
            println ""
            break ()
    println "main = do"
    println "     foo1"
    println "     ()"
