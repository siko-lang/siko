module Main where

import Siko.HIR.Program as HPO
import Map

data Location = Location

data Ident = Ident String

getString :: Ident -> String
getString _ = "a"

data Type = Type

data RecordField = RecordField String Type

data PProgram = PProgram

data Context = { state :: ResolverState, program :: HPO.Program () }

data Pattern = Pattern SimplePattern Location

data RecordFieldPattern = {
                            name :: Ident,
                            pattern :: Pattern,
                          }

data SimplePattern = Wildcard

data HPattern a = HPattern (HSimplePattern a) PatternId a Location

data PatternId = PatternId Int 

data HSimplePattern a = Tuple [HPattern a]

data ResolverState = { pattern_id_gen :: Int }

emptyState :: ResolverState
emptyState = ResolverState 0

getNextPatternId :: ResolverState -> (ResolverState, PatternId)
getNextPatternId state = do
    id <- state.pattern_id_gen
    state <- state { pattern_id_gen = state.pattern_id_gen  + 1}
    (state, PatternId id)

processRecordFieldPattern :: [RecordFieldPattern] -> (Context, [HPattern ()]) -> RecordField -> (Context, [HPattern ()])
processRecordFieldPattern field_patterns (context, args) (RecordField field_name _) = do
    field_pattern <- field_patterns |> List.iter |> Iterator.filter (\(RecordFieldPattern name _) -> getString name == field_name) |> toList
    (RecordFieldPattern name pattern) <- atIndex field_pattern 0
    (context, hir_pattern) <- processPattern context pattern
    args <- push args hir_pattern
    (context, args)

processPattern :: Context -> Pattern -> (Context, HPattern ())
processPattern context (Pattern pattern location) = do
    (state, pattern_id) <- getNextPatternId context.state
    context <- context { state = state }
    (context, HPattern (Tuple []) pattern_id () location)

main = do
    field_patterns <- []
    state <- emptyState
    program <- HPO.Program Map.empty Map.empty
    context <- Context state program
    record_field <- RecordField "a" Type
    args <- []
    processRecordFieldPattern field_patterns (context, args) record_field
    ()