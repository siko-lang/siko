module Hack where

sink a :: ~a -> ~()
sink item = extern

module Main where

import Hack

data Outer = Outer Inner

data Inner = Inner
data Season = Spring | Summer | Fall | Winter

id a = a

main = do
    b <- Inner
    c <- Inner
    a <- Outer b
    d <- Outer c
    sink (id a)
    sink (id a)
    sink (id a)
    sink (id d)
    sink (id d)
    sink (id d)
    b
    ()
