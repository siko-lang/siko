module Siko.Backend.OwnershipVarGenerator where

import Siko.MIR.Type as T

data OwnershipVarGenerator = { next_var :: Int }

getNextOwnershipVar :: OwnershipVarGenerator -> (OwnershipVarGenerator, T.OwnershipVar)
getNextOwnershipVar var_gen = do
    v <- var_gen.next_var
    o <- T.OwnershipVar v
    var_gen <- var_gen { next_var = v + 1}
    (var_gen, o)