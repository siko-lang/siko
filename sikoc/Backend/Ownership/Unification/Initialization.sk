module Siko.Backend.Ownership.Initialization where

import Siko.MIR.Program as P
import Siko.MIR.Type as T
import Siko.MIR.Data
import Siko.MIR.Expr
import Siko.MIR.Function as F
import Siko.Util.DependencyProcessor
import Siko.Backend.Traversal
import Siko.Backend.Ownership.Unification as U
import Map

data Context = { arg_count_map :: Map P.Identity Int,
                 var_gen :: U.OwnershipVarGenerator }

getNextOwnershipKind :: Context -> (Context, T.OwnershipKind)
getNextOwnershipKind context = do
    (var_gen, v) <- U.getNextOwnershipVar context.var_gen
    context <- context { var_gen = var_gen }
    (context, T.VarKind v)

addOwnershipVarsToDataType :: Context -> Bool -> [P.Identity] -> [T.OwnershipKind] -> [T.OwnershipKind] -> T.Type -> ([T.OwnershipKind], T.Type)
addOwnershipVarsToDataType context is_adt group all_ownership_vars ownership_vars type = do
    id <- T.getIdentity type
    if contains group id
        then do
            type <- case type of
                T.Box t -> do
                        t <- case t of
                            T.Record id _ -> T.Record id all_ownership_vars
                            T.Adt id _ -> T.Adt id all_ownership_vars
                            _ -> panic "Boxed data is not data!"
                        T.Box t
                T.Record id _ -> T.Record id all_ownership_vars
                T.Adt id _ -> T.Adt id all_ownership_vars
                _ -> panic "Data is not data!"
            (ownership_vars, type)
        else do
            c <- getArgCount context id
            if is_adt
                then
                    do
                    (args, ownership_vars) <- List.split ownership_vars c
                    type <- case type of
                        T.Record id _ -> T.Owner (T.Record id args)
                        T.Adt id _ -> T.Owner (T.Adt id args)
                        t -> t
                    (ownership_vars, type)
                else do
                    (var, ownership_vars) <- List.split ownership_vars 1
                    var <- atIndex var 0
                    (args, ownership_vars) <- List.split ownership_vars c
                    type <- case type of
                        T.Record id _ -> T.Var var (T.Record id args)
                        T.Adt id _ -> T.Var var (T.Adt id args)
                        t -> t
                    (ownership_vars, type)

addOwnershipVarsToRecord :: Context -> [T.OwnershipKind] -> [P.Identity] -> [T.OwnershipKind] -> Option Record -> ([T.OwnershipKind], Option Record)
addOwnershipVarsToRecord context all_ownership_vars group ownership_vars record = case record of
    Some record -> do
        record :: Record <- record
        record <- record { ownership_vars = all_ownership_vars }
        (ownership_vars, fields) <- List.mapS ownership_vars record.fields (\ownership_vars, field -> do
            (ownership_vars, type) <- addOwnershipVarsToDataType context False group all_ownership_vars ownership_vars field.type
            field <- field { type = type }
            (ownership_vars, field))
        (ownership_vars, external_info) <- case record.external_info of
            Some external_info -> do
                external_info :: ExternalRecordInfo <- external_info // FIXME
                (ownership_vars, type_args) <- List.mapS ownership_vars external_info.type_args (\ownership_vars, type_arg -> do
                    addOwnershipVarsToDataType context False group all_ownership_vars ownership_vars type_arg)
                (ownership_vars, Some (ExternalRecordInfo type_args))
            None -> (ownership_vars, None)
        record <- record { fields = fields, external_info = external_info }
        (ownership_vars, Some record)
    None -> (ownership_vars, None)

addOwnershipVarsToAdt :: Context -> [T.OwnershipKind] -> [P.Identity] -> [T.OwnershipKind] -> Option AlgebraicDataType -> ([T.OwnershipKind], Option AlgebraicDataType)
addOwnershipVarsToAdt context all_ownership_vars group ownership_vars adt = case adt of
    Some adt -> do
        adt :: AlgebraicDataType <- adt
        adt <- adt { ownership_vars = all_ownership_vars }
        (variants, ownership_vars) <- adt.variants |> List.iter |> fold (\(variants, ownership_vars), variant -> do
            (ownership_vars, type) <- addOwnershipVarsToDataType context True group all_ownership_vars ownership_vars variant.type
            variant <- variant { type = type }
            (variants + [variant], ownership_vars)) ([], ownership_vars)
        adt <- adt { variants = variants }
        (ownership_vars, Some adt)
    None -> (ownership_vars, None)

getArgCount :: Context -> P.Identity -> Int
getArgCount context id = do
    case get context.arg_count_map id of
        Some c -> c
        None -> panic "Could not find arg count for {}" % id

calculateArgCountForAdt :: Context -> [P.Identity] -> AlgebraicDataType -> Int
calculateArgCountForAdt context group adt = do
    adt.variants |> List.iter |> fold (\arg_count, variant -> do
        record_id <- T.getIdentity variant.type
        variant_arg_count <- if contains group record_id
            then 0
            else getArgCount context record_id
        arg_count + variant_arg_count) 0

calculateArgCountForRecord :: Context -> [P.Identity] -> Record -> Int
calculateArgCountForRecord context group record = do
    arg_count <- record.fields |> List.iter |> fold (\arg_count, field -> do
        id <- T.getIdentity field.type
        field_arg_count <- if contains group id
            then 0
            else 1 + getArgCount context id
        arg_count + field_arg_count) 0
    case record.external_info of
        Some external_info -> do
            external_info :: ExternalRecordInfo <- external_info // FIXME
            arg_count <- arg_count + getLength external_info.type_args
            external_info.type_args |> List.iter |> fold (\arg_count, type_arg -> do
                id <- T.getIdentity type_arg
                c <- getArgCount context id
                arg_count + c) arg_count
        None -> arg_count

calculateArgCount :: P.Program -> Context -> [P.Identity] -> P.Identity -> Int
calculateArgCount program context group id = do
    case get program.records id of
            Some record -> calculateArgCountForRecord context group record
            None -> case get program.adts id of
                Some adt -> calculateArgCountForAdt context group adt
                None -> panic "Could not find data def {}" % id

addOwnershipVarsToGroup :: Context -> [P.Identity] -> P.Program -> (Context, P.Program)
addOwnershipVarsToGroup context group program = do
    (context, arg_count) <- group |> List.iter |> fold (\(context, arg_count), id -> do
        c <- calculateArgCount program context group id
        (context, arg_count + c)) (context, 0)
    context <- group |> List.iter |> fold (\context, id -> do
        (arg_count_map, _) <- insert context.arg_count_map id arg_count
        context <- context { arg_count_map = arg_count_map }
        context) context
    (context, all_vars) <- getNextOwnershipKinds context arg_count
    (vars, program) <- group |> List.iter |> fold (\(vars, program), id -> do
        (vars, records, _) <- alterS (addOwnershipVarsToRecord context all_vars group) vars id program.records
        (vars, adts, _) <- alterS (addOwnershipVarsToAdt context all_vars group) vars id program.adts
        program <- program { records = records, adts = adts }
        (vars, program)) (all_vars, program)
    (context, program)

addOwnershipVarsToDataTypes :: Context -> P.Program -> [DependencyGroup P.Identity] -> (Context, P.Program)
addOwnershipVarsToDataTypes context program groups = do
    (context, program) <- groups |> List.iter |> fold (\(context, program), group -> addOwnershipVarsToGroup context group.items program
        ) (context, program)
    (context, program)

getNextOwnershipKinds :: Context -> Int -> (Context, [T.OwnershipKind])
getNextOwnershipKinds context count = repeatS context (\context -> getNextOwnershipKind context) count

addOwnershipVarsToType :: Context -> T.Type -> (Context, T.Type)
addOwnershipVarsToType context type = case type of
    T.Adt id args -> do
        c <- getArgCount context id
        (context, args) <- getNextOwnershipKinds context c
        (context, kind) <- getNextOwnershipKind context
        t <- T.Var kind (T.Adt id args)
        (context, t)
    T.Record id args -> do
        c <- getArgCount context id
        (context, args) <- getNextOwnershipKinds context c
        (context, kind) <- getNextOwnershipKind context
        t <- T.Var kind (T.Record id args)
        (context, t)
    T.Ref index type -> do
        (context, t) <- addOwnershipVarsToType context type
        t <- case t of
            T.Var _ t -> t
            _ -> panic "Ref type is not T.Var {}" % t
        (context, T.Ref index t)
    T.Owner type -> do
        (context, t) <- addOwnershipVarsToType context type
        t <- case t of
            T.Var _ t -> t
            _ -> panic "Ref type is not T.Var {}" % t
        (context, T.Owner t)
    T.Never -> (context, T.Never)
    type -> do
        (context, kind) <- getNextOwnershipKind context
        t <- T.Var kind type
        (context, t)

addOwnershipVarsToBody :: Context -> Expr -> (Context, Expr)
addOwnershipVarsToBody context expr = do
    traverse context expr None (Some (addOwnershipVarsToType))

kindsToIndices :: [T.OwnershipKind] -> [T.OwnershipKind] -> [Int]
kindsToIndices all subs = subs |> List.iter |> map (\kind -> Option.unwrap (containsAtIndex all kind)) |> toList

processIndices :: [Int] -> T.Type -> [T.OwnershipKind] -> [Int]
processIndices sub sub_type all = do
    if getLength sub == 0
        then do
            ownership_args <- T.collectOwnershipArgs sub_type
            indices <- kindsToIndices all ownership_args
            indices
        else do
            ownership_args <- T.collectOwnershipArgs sub_type
            ownership_vars <- sub |> List.iter |> map (\index -> atIndex ownership_args index) |> toList
            indices <- kindsToIndices all ownership_vars
            indices

processSteps :: P.Program -> [F.Step] -> T.Type -> [Int]
processSteps program steps type = do
    if getLength steps == 0
        then return []
        else do
            (first, rest) <- Option.unwrap (pop steps)
            case first of
                F.External index -> do
                    record_id <- T.getIdentity type
                    record <- P.getRecord program record_id
                    case record.external_info of
                        Some external_info -> do
                            external_info :: ExternalRecordInfo <- external_info // FIXME
                            ext_type <- atIndex external_info.type_args index
                            indices <- processSteps program rest ext_type
                            processIndices indices ext_type record.ownership_vars
                        None -> panic "Record {} is not external in type mapping processing!" % record_id
                F.Variant index -> do
                    adt_id <- T.getIdentity type
                    adt <- P.getAdt program adt_id
                    variant <- atIndex adt.variants index
                    indices <- processSteps program rest variant.type
                    processIndices indices variant.type adt.ownership_vars
                F.Field index -> do
                    record_id <- T.getIdentity type
                    record <- P.getRecord program record_id
                    field <- atIndex record.fields index
                    indices <- processSteps program rest field.type
                    processIndices indices field.type record.ownership_vars
                _ -> panic "Incorrect step in type mapping!"

getKinds :: P.Program -> [F.Step] -> T.Type -> [T.OwnershipKind]
getKinds program steps type = do
    indices <- if getLength steps == 0
        then [0]
        else do
            indices <- processSteps program steps type
            indices <- indices |> List.iter |> map (\i -> i + 1) |> toList
            indices
    ownership_kinds <- T.collectOwnershipKinds type
    kinds <- indices |> List.iter |> map (\index -> atIndex ownership_kinds index) |> toList
    kinds

applyPosition :: P.Program -> F.Position -> F.FunctionType -> [T.OwnershipKind]
applyPosition program position function_type = do
    F.Position steps <- position
    (first, rest) <- Option.unwrap (pop steps)
    case first of
        F.FunctionArg index -> do
            type <- atIndex function_type.args index
            getKinds program rest type
        F.FunctionResult -> do
            type <- function_type.result
            getKinds program rest type
        _ -> panic "Invalid first step in type mapping!"

unifyTypePositions :: P.Program -> Context -> [F.Position] -> F.FunctionType -> (Context, F.FunctionType)
unifyTypePositions program context positions function_type = do
    kinds <- positions |> List.iter |> fold (\kinds, position -> do
            vars <- applyPosition program position function_type
            kinds + vars
        ) []
    (context, new_kind) <- getNextOwnershipKind context
    new_kinds <- repeat new_kind (getLength kinds)
    sub <- U.batch kinds new_kinds
    function_type <- U.apply function_type sub
    (context, function_type)

applyTypeMappings :: P.Program -> Context -> F.TypeMapping -> F.FunctionType -> (Context, F.FunctionType)
applyTypeMappings program context type_mappings function_type = do
    (context, function_type) <- type_mappings.var_mappings |> Map.iter |> fold (\(context, function_type), (_, positions) -> do
        unifyTypePositions program context positions function_type) (context, function_type)
    (context, function_type) <- type_mappings.owner_positions |> List.iter |> fold (\(context, function_type), owner_position -> do
            vars <- applyPosition program owner_position function_type
            new_kinds <- repeat T.OwnerKind (getLength vars)
            sub <- U.batch vars new_kinds
            function_type <- U.apply function_type sub
            (context, function_type)
        ) (context, function_type)
    (context, function_type) <- type_mappings.ref_positions |> List.iter |> fold (\(context, function_type), ref_position -> do
            vars <- applyPosition program ref_position function_type
            new_kinds <- repeat (T.BorrowKind 0) (getLength vars)
            sub <- U.batch vars new_kinds
            function_type <- U.apply function_type sub
            (context, function_type)
        ) (context, function_type)
    (context, function_type)

processFunction :: P.Program -> Context -> F.Function -> (Context, F.Function)
processFunction program context function = case function.kind of
    F.Normal body expr_id_gen temp_var_gen -> do
        (context, updated_body) <- addOwnershipVarsToBody context body
        (context, args) <- function.type.args |> List.iter |> fold (\(context, args), arg -> do
            (context, arg) <- addOwnershipVarsToType context arg
            (context, args + [arg])) (context, [])
        (context, result) <- addOwnershipVarsToType context function.type.result
        function_type <- F.FunctionType args result
        (context, function { kind = F.Normal updated_body expr_id_gen temp_var_gen, type = function_type })
    F.RecordCtor -> do
        id <- T.getIdentity function.type.result
        record <- P.getRecord program id
        args <- record.fields |> List.iter |> map (\f -> f.type) |> toList
        result <- T.Record id record.ownership_vars
        owned_result <- T.Owner result
        function_type <- F.FunctionType args owned_result
        (context, function { type = function_type })
    F.VariantCtor index -> do
        id <- T.getIdentity function.type.result
        adt <- P.getAdt program id
        variant <- atIndex adt.variants index
        variant_ownership_vars <- T.collectOwnershipArgs variant.type
        variant_record_id <- T.getIdentity variant.type
        variant_record <- P.getRecord program variant_record_id
        sub <- U.batch variant_record.ownership_vars variant_ownership_vars
        variant_record <- U.apply variant_record sub
        args <- variant_record.fields |> List.iter |> map (\f -> T.debox f.type) |> toList
        result <- T.Adt id adt.ownership_vars
        owned_result <- T.Owner result
        function_type <- F.FunctionType args owned_result
        (context, function { type = function_type })
    F.Extern type_mappings -> do
        (context, args) <- function.type.args |> List.iter |> fold (\(context, args), arg -> do
            (context, arg) <- addOwnershipVarsToType context arg
            (context, args + [arg])) (context, [])
        (context, result) <- addOwnershipVarsToType context function.type.result
        function_type <- F.FunctionType args result
        (context, function_type) <- applyTypeMappings program context type_mappings function_type
        (context, function { type = function_type })
    _ -> (context, function)

initializeOwnership :: P.Program -> [DependencyGroup P.Identity] -> (U.OwnershipVarGenerator, P.Program)
initializeOwnership program groups = do
    context <- Context empty U.createOwnershipVarGenerator
    (context, program) <- addOwnershipVarsToDataTypes context program groups
    (context, functions) <- program.functions |> Map.iter |> fold (\(context, functions), (id, function) -> do
        (context, function) <- processFunction program context function // FIXME: program should not be copied here!
        (functions, _) <- insert functions id function
        (context, functions)) (context, empty)
    program <- program { functions = functions }
    (context.var_gen, program)
