module Siko.Typechecker.Pattern where

import Siko.Syntax.Location
import Siko.Typechecker
import Siko.Typechecker.Expr
import Siko.Typechecker.TypeStore as TS
import Siko.Typechecker.DataStore as DS
import Siko.Typechecker.Unification as U
import Siko.Typechecker.Util as UT
import Siko.HIR.Pattern as P
import Siko.HIR.Type as T
import Siko.HIR.Expr as E

addPatternType :: Context -> P.PatternId -> TS.PatternTypeState -> Context
addPatternType context pattern_id pattern_type = do
    type_store <- TS.addPatternType context.type_store pattern_id pattern_type
    context { type_store = type_store }

getPatternType :: Context -> P.PatternId -> T.Type
getPatternType context pattern_id = TS.getPatternType context.type_store pattern_id

matchPatternWith :: Context -> P.PatternId -> T.Type -> Location -> (Context, U.Substitution)
matchPatternWith context pattern_id type location = do
    pattern_type <- getPatternType context pattern_id
    unify context type pattern_type location

matchPatterns :: Context -> P.PatternId -> P.PatternId -> Location -> (Context, U.Substitution)
matchPatterns context pattern_id1 pattern_id2 location = do
    pattern_type1 <- getPatternType context pattern_id1
    pattern_type2 <- getPatternType context pattern_id2
    unify context pattern_type1 pattern_type2 location

initializePatternType :: Context -> P.Pattern -> Context
initializePatternType context (P.Pattern pattern id location) = do
    //println "InitializePatternType: pattern {} {}" % (pattern, id)
    type_store <- TS.addPatternLocation context.type_store id location
    context <- context { type_store = type_store }
    case pattern of
        P.Binding bind_ref -> do
            (context, var) <- getNewVar context
            context <- addPatternType context id (TS.PatternType var)
            context
        P.Tuple args -> do
            (context, vars) <- args |> List.iter |> Iterator.fold (\(context, vars), arg -> do
                (context, var) <- getNewVar context
                vars <- vars + [var]
                (context, vars)) (context, [])
            context <- addPatternType context id (TS.PatternType (T.Tuple vars))
            context
        P.Guarded pattern expr -> do
            (context, var) <- getNewVar context
            context <- addPatternType context id (TS.PatternType var)
            context
        P.Wildcard -> do
            (context, var) <- getNewVar context
            context <- addPatternType context id (TS.PatternType var)
            context
        P.IntegerLiteral lit -> do
            context <- addPatternType context id (TS.PatternType UT.getIntType)
            context
        P.StringLiteral lit -> do
            context <- addPatternType context id (TS.PatternType UT.getStringType)
            context
        P.CharLiteral lit -> do
            context <- addPatternType context id (TS.PatternType UT.getCharType)
            context
        P.CharRange _ _ _ -> do
            context <- addPatternType context id (TS.PatternType UT.getCharType)
            context
        P.Typed pattern type -> do
            context <- addPatternType context id (TS.PatternType type)
            context
        P.Record qn args -> do
            data_type_info <- DS.getDataTypeInfo context.state.data_store qn
            (data_type_info, var_gen) <- DS.remapDataTypeInfo data_type_info context.state.var_gen
            state <- context.state // FIXME
            state <- state { var_gen = var_gen }
            context <- context { state = state }
            record_type_info <- case data_type_info of
                DS.Record record -> record
                _ -> panic "Record_type_info is not a record_type_info!"
            context <- addPatternType context id (TS.PatternWithRecordType record_type_info)
            context
        P.Variant qn _ _ -> do
            data_type_info <- DS.getDataTypeInfo context.state.data_store qn
            (data_type_info, var_gen) <- DS.remapDataTypeInfo data_type_info context.state.var_gen
            state <- context.state // FIXME
            state <- state { var_gen = var_gen }
            context <- context { state = state }
            adt_type_info <- case data_type_info of
                DS.Adt adt -> adt
                _ -> panic "Adt_type_info is not an adt_type_info!"
            context <- addPatternType context id (TS.PatternWithAdtType adt_type_info)
            context

checkPatternType :: Context -> P.Pattern -> Context
checkPatternType context (P.Pattern pattern id location) = do
    //println "checkPatternType: pattern {} {} {}" % (pattern, id, T.toString (getPatternType context id))
    case pattern of
        P.Binding _ -> context
        P.Tuple args -> do
            arg_types <- args |> List.iter |> Iterator.map (\(P.Pattern _ arg _) -> getPatternType context arg) |> toList
            (context, _) <- matchPatternWith context id (T.Tuple arg_types) location
            context
        P.Guarded p expr -> do
            P.Pattern _ sub_pattern_id _ <- p
            E.Expr _ expr_id expr_location <- expr
            bool_ty <- UT.getBoolType
            (context, _) <- matchExprWith context expr_id bool_ty expr_location
            (context, _) <- matchPatterns context id sub_pattern_id location
            context
        P.Wildcard -> context
        P.IntegerLiteral lit -> context
        P.StringLiteral lit -> context
        P.CharLiteral lit -> context
        P.CharRange _ _ _ -> context
        P.Typed p _ -> do
            P.Pattern _ sub_pattern_id location <- p
            (context, _) <- matchPatterns context id sub_pattern_id location
            context
        P.Record _ args -> do
            record_type_info <- TS.getRecordTypeInfo context.type_store id
            (context, record_type_info, _) <- args |> List.iter |> Iterator.fold (\(context, record_type_info, index), (P.Pattern _ arg_id arg_location) -> do
                    field <- atIndex record_type_info.fields index
                    (context, sub) <- matchPatternWith context arg_id field.type arg_location
                    record_type_info <- U.apply record_type_info sub
                    (context, record_type_info, index + 1)
                ) (context, record_type_info, 0)
            context
        P.Variant _ index args -> do
            adt_type_info <- TS.getAdtTypeInfo context.type_store id
            (context, adt_type_info, _) <- args |> List.iter |> Iterator.fold (\(context, adt_type_info, arg_index), (P.Pattern _ arg_id arg_location) -> do
                    variant <- atIndex adt_type_info.variants index
                    item_type <- atIndex variant.items arg_index
                    (context, sub) <- matchPatternWith context arg_id item_type arg_location
                    adt_type_info <- U.apply adt_type_info sub
                    (context, adt_type_info, arg_index + 1)
                ) (context, adt_type_info, 0)
            context

checkMissingTypeInPattern :: [T.TypeVar] -> (Context, [T.TypeVar]) -> P.Pattern -> (Context, [T.TypeVar])
checkMissingTypeInPattern signature_vars (context, undefined_vars) (P.Pattern pattern id location) = do
    //println "Checking pattern {} {}" % (pattern, id)
    type <- getPatternType context id
    checkUndefinedVars context undefined_vars type signature_vars location