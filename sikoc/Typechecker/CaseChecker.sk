module Siko.Typechecker.CaseChecker where

import Siko.Syntax.Location
import Siko.HIR.Expr as E
import Siko.HIR.Pattern as P
import Siko.HIR.Program as PO
import Siko.Typechecker
import Siko.Typechecker.Error
import Siko.Typechecker.Expr
import Map

data ValuePath = ItemIndex ValuePath Int
                 | VariantPath ValuePath String Int Int
                 | Root
                 deriving (PartialEq, Eq, PartialOrd, Ord)

instance Show ValuePath where
    show a = case a of
        Root -> "p"
        ItemIndex p i -> "{}.{}" % (p, i)
        VariantPath p n vi i -> "{}.{}/{}.{}" % (p, n, vi, i)

data PendingPattern = { path :: ValuePath,
                        pattern :: P.Pattern
                      }

data Check = Check ValuePath Condition deriving (Show, PartialEq, Eq, PartialOrd, Ord)

data Condition = IntegerCondition String
                 | VariantCondition Int
                 | WildcardCondition
                 deriving (Show, PartialEq, Eq, PartialOrd, Ord)

processPattern :: [PendingPattern] -> [Check]
processPattern pendingPatterns = do
    pending_pattern <- case head pendingPatterns of
        Some first -> first
        None -> return []
    pendingPatterns <- case tail pendingPatterns of
        Some p -> p
        None -> []
    path <- pending_pattern.path
    (P.Pattern pattern _ _) <- pending_pattern.pattern
    checks <- case pattern of
        P.Tuple args -> do
            (args, _) <- args |> List.iter |> fold (\(args, index), arg -> do
                    p <- ItemIndex path index
                    arg <- PendingPattern p arg
                    args <- args + [arg]
                    (args, index + 1)) ([], 0)
            checks <- processPattern (args + pendingPatterns)
            [Check path WildcardCondition] + checks
        P.Wildcard -> do
            checks <- processPattern pendingPatterns
            [Check path WildcardCondition] + checks
        P.IntegerLiteral lit -> do
            checks <- processPattern pendingPatterns
            [Check path (IntegerCondition lit)] + checks
        P.Binding _ -> do
            checks <- processPattern pendingPatterns
            [Check path (WildcardCondition)] + checks
        P.Variant qn variant_index args -> do
            (args, _) <- args |> List.iter |> fold (\(args, index), arg -> do
                    p <- VariantPath path (show qn) variant_index index
                    arg <- PendingPattern p arg
                    args <- args + [arg]
                    (args, index + 1)) ([], 0)
            checks <- processPattern (args + pendingPatterns)
            [Check path (VariantCondition variant_index)] + checks
        _ -> panic "Unimplemented"
    checks

addUnreachablePatternError :: Context -> Location -> Context
addUnreachablePatternError context location = do
    //state <- addError context.state (UnreachablePattern location)
    //context <- context { state = state }
    context

data Choice = Choice ValuePath (Map Condition Choice)
              | CaseEnd Int

mergeChecks :: [Check] -> Int -> Option Choice
mergeChecks checks case_index = do
    (first, rest) <- case head checks of
        Some first -> do
            rest <- Option.unwrap (tail checks)
            (first, rest)
        None -> return None
    Check path condition <- first
    next <- case mergeChecks rest case_index of
        Some next -> next
        None -> CaseEnd case_index
    (branches, _) <- Map.insert Map.empty condition next
    choice <- Choice path branches
    Some choice

checkCase :: Context -> E.Expr -> [E.Case] -> Context
checkCase context case_body cases = do
    (context, _) <- cases |> List.iter |> fold (\(context, index), c -> do
            (P.Pattern p _ location) <- c.pattern
            //println "Processing case {}" % index
            //checks <- processPattern [PendingPattern Root c.pattern]
            //println "Checks {}" % checks
            (context, index + 1)
        ) (context, 0)
    context

checkCases :: Context -> E.Expr -> Context
checkCases context (E.Expr expr _ _) = do
    context <- case expr of
        E.CaseOf body cases -> do
            checkCase context body cases
        _ -> context
    context