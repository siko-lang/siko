module Siko.Typechecker.Lowering.TypedHIR.Expr where

import Siko.Typechecker.Lowering.TypedHIR.Program as LP
import Siko.Typechecker.Lowering.TypedHIR.Pattern as LPat
import Siko.Typechecker.Lowering.TypedHIR.Type as LT
import Siko.Typechecker.Lowering.TypedHIR.Class as LC
import Siko.HIR.Expr as HE
import Siko.HIR.Type as HT
import Siko.HIR.Pattern as HPat
import Siko.TypedHIR.Expr as THE
import Siko.TypedHIR.Type as THT

class TypeProvider a where
    getExprType a :: a -> HE.ExprId -> HT.Type
    getPatternType a :: a -> HPat.PatternId -> HT.Type

lowerCase a :: (TypeProvider a) => a -> HE.Case -> THE.Case
lowerCase type_provider hir_case =
    THE.Case {
        pattern = LPat.lowerPattern type_provider hir_case.pattern,
        body = lowerExpr type_provider hir_case.body
     }

lowerExprRef :: HE.ExprRef -> THE.ExprRef
lowerExprRef hir_expr_ref =
    THE.ExprRef {
        source = lowerExprId hir_expr_ref.source,
        location = hir_expr_ref.location
     }

lowerRecordConstructionItem a :: (TypeProvider a) => a -> HE.RecordConstructionItem -> THE.RecordConstructionItem
lowerRecordConstructionItem type_provider hir_rc_item =
    THE.RecordConstructionItem {
        field_name = hir_rc_item.field_name,
        body = lowerExpr type_provider hir_rc_item.body
     }

lowerExprId :: HE.ExprId -> THE.ExprId
lowerExprId (HE.ExprId i) = THE.ExprId i

lowerExpr a :: (TypeProvider a) => a -> HE.Expr -> THE.Expr
lowerExpr type_provider (HE.Expr s_expr id location) = do
    hir_type <- getExprType type_provider id
    THE.Expr (lowerSimpleExpr type_provider s_expr) (lowerExprId id) (LT.lowerType hir_type) location

lowerSimpleExpr a :: (TypeProvider a) => a -> HE.SimpleExpr -> THE.SimpleExpr
lowerSimpleExpr type_provider hir_simple_expr = case hir_simple_expr of
    HE.StaticFunctionCall qn args -> THE.StaticFunctionCall (LP.lowerFullyQualifiedName qn) (List.map args (lowerExpr type_provider))
    HE.DynamicFunctionCall receiver args -> THE.DynamicFunctionCall (lowerExpr type_provider receiver) (List.map args (lowerExpr type_provider))
    HE.ClassMemberCall qn args -> THE.ClassMemberCall (LP.lowerFullyQualifiedName qn) (List.map args (lowerExpr type_provider))
    HE.VariantConstructorCall qn args -> THE.VariantConstructorCall (LP.lowerFullyQualifiedName qn) (List.map args (lowerExpr type_provider))
    HE.RecordConstructorCall qn args -> THE.RecordConstructorCall (LP.lowerFullyQualifiedName qn) (List.map args (lowerExpr type_provider))
    HE.If cond true_branch false_branch -> THE.If (lowerExpr type_provider cond) (lowerExpr type_provider true_branch) (lowerExpr type_provider false_branch)
    HE.Tuple args -> THE.Tuple (List.map args (lowerExpr type_provider))
    HE.List args -> THE.List (List.map args (lowerExpr type_provider))
    HE.IntegerLiteral lit -> THE.IntegerLiteral lit
    HE.FloatLiteral lit -> THE.FloatLiteral lit
    HE.StringLiteral lit -> THE.StringLiteral lit
    HE.CharLiteral lit -> THE.CharLiteral lit
    HE.Do items -> THE.Do (List.map items (lowerExpr type_provider))
    HE.Bind pattern rhs -> THE.Bind (LPat.lowerPattern type_provider pattern) (lowerExpr type_provider rhs)
    HE.FieldAccess name receiver -> THE.FieldAccess name (lowerExpr type_provider receiver)
    HE.TupleFieldAccess index receiver -> THE.TupleFieldAccess index (lowerExpr type_provider receiver)
    HE.Formatter fmt args -> THE.Formatter fmt (List.map args (lowerExpr type_provider))
    HE.CaseOf body cases bind_group -> THE.CaseOf (lowerExpr type_provider body) (List.map cases (lowerCase type_provider))
    HE.RecordUpdate ref items -> THE.RecordUpdate (LPat.lowerBindRef ref) (List.map items (lowerRecordConstructionItem type_provider))
    HE.Return arg -> THE.Return (lowerExpr type_provider arg)
    HE.Continue arg -> THE.Continue (lowerExpr type_provider arg)
    HE.Break arg -> THE.Break (lowerExpr type_provider arg)
    HE.Loop pattern initializer body continues breaks ->
        THE.Loop (LPat.lowerPattern type_provider pattern) (lowerExpr type_provider initializer)
                 (lowerExpr type_provider body) (List.map continues lowerExprRef) (List.map breaks lowerExprRef)
    HE.ArgRef i -> THE.ArgRef i
    HE.ValueRef ref -> THE.ValueRef (LPat.lowerBindRef ref)