module Siko.Typechecker.Util where

import Siko.HIR.Type
import Siko.HIR.Program
import Siko.Constants

getIntType :: Type
getIntType = Named (FullPath getIntModuleName getIntTypeName) []

getFloatType :: Type
getFloatType = Named (FullPath getFloatModuleName getFloatTypeName) []

getStringType :: Type
getStringType = Named (FullPath getStringModuleName getStringTypeName) []

getCharType :: Type
getCharType = Named (FullPath getCharModuleName getCharTypeName) []

getBoolType :: Type
getBoolType = Named (FullPath getBoolModuleName getBoolTypeName) []