module Siko.Typechecker.FunctionStore where

import Siko.HIR.Type
import Siko.HIR.Program
import Map

data FunctionTypeInfo = { name :: FullyQualifiedName,
                          args :: [Type],
                          function_type :: Type,
                        } deriving (Show)

data FunctionStore = {  functions :: Map FullyQualifiedName FunctionTypeInfo,
                     } deriving (Show)
