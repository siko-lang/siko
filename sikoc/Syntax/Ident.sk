module Siko.Syntax.Ident where

import Siko.Syntax.Location

data Ident = Ident String.String Location deriving (Show)

getString :: Ident -> String
getString (Ident s _) = s

mergeIdent :: Ident -> String -> Location -> Ident
mergeIdent (Ident n1 l1) n2 l2 =
    Ident (n1 + n2) (mergeLocation l1 l2)
