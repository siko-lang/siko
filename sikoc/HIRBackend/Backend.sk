module Siko.HIRBackend.Backend where

import Siko.HIRBackend.AutoDerive as AutoDerive
import Siko.HIR.Program as P

import Siko.Config
import Hack
import Siko.Trace

dumpProgram :: Config -> P.Program -> OutputFileType -> ()
dumpProgram config program type =
    if config.dump
    then do
        //s <- P.dump program
        //writeTextFile (getOutputFileName config type) s
        ()
    else ()

processProgram :: Config -> P.Program -> P.Program
processProgram config program = do
    program <- AutoDerive.processProgram config program
    program