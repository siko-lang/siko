module Siko.HIRBackend.AutoDerive where

import Siko.HIRBackend.Backend
import Siko.HIR.Program as P

import Siko.Config
import Hack
import Siko.Trace

processProgram :: Config -> P.Program () -> P.Program ()
processProgram config program = do
    trace config "processing auto derives"
    dumpProgram config program (HIR "autoderive")
    program