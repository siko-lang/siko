module Siko.MIR.Type where

data Type = Adt String
            | Record String
            | Function Type Type
            | Ref Type
            | Never

instance Show Type where
    show t = case t of
        Adt n -> n
        Record n -> n
        Function from to -> "{} -> {}" % (from, to)
        Ref t -> "&{}" % t
        Never -> "!"
