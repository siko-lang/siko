module Siko.MIR.Backend.Ownership.ValueGraph where

import Map
import Siko.MIR.Expr as E

data ValueGraphs = { nodes :: Map E.Var ValueGraphNode } deriving (Show)

data ValueGraphNode = ValueDecl String
                    | ValueRef E.ExprId
                    | Block [ValueGraphNode]
                    | ValueFieldAccess E.ExprId [String]
                    | Branches [ValueGraphNode]
                    | Loop ValueGraphNode
                    | Empty
                    | End
                    deriving (Show)

addNode :: ValueGraphs -> E.Var -> ValueGraphNode -> ValueGraphs
addNode graphs var node = do
    (nodes, _) <- insert graphs.nodes var node
    graphs { nodes = nodes }

createValueGraphs :: ValueGraphs
createValueGraphs = ValueGraphs empty

createBlock :: E.Var -> [ValueGraphs]  -> ValueGraphNode
createBlock var graphs = do
    merged <- graphs |> List.iter |> Iterator.fold (\merged, graph -> do
        l <- case get graph.nodes var of
            Some (Block n) -> n
            Some n -> [n]
            None -> []
        merged + l) []
    if getLength merged == 1
        then atIndex merged 0
        else Block merged

createBranch :: E.Var -> [ValueGraphs] -> ValueGraphNode
createBranch var branch_graphs = do
    nodes <- branch_graphs |> List.iter |> Iterator.fold (\nodes, graphs -> do
        case get graphs.nodes var of
            Some n -> nodes + [n]
            None -> nodes + [Empty]) []
    Branches nodes

createLoop :: E.Var -> [ValueGraphs]  -> ValueGraphNode
createLoop var graphs = do
    n <- createBlock var graphs
    Loop n

after :: [ValueGraphs] -> ValueGraphs
after graphs = do
    merge graphs (\v -> createBlock v graphs)

choice :: [ValueGraphs] -> ValueGraphs
choice branch_graphs = do
    merge branch_graphs (\v -> createBranch v branch_graphs)

mergeLoop :: [ValueGraphs] -> ValueGraphs
mergeLoop graphs = do
    merge graphs (\v -> createLoop v graphs)

merge :: [ValueGraphs] -> (E.Var -> ValueGraphNode) -> ValueGraphs
merge input_graphs factory_fn = do
    keys <- input_graphs |> List.iter |> Iterator.fold (\keys, g -> getKeys g.nodes + keys) []
    keys <- keys |> sort |> dedup
    nodes <- keys |> List.iter |> Iterator.map (\k -> do
        node <- factory_fn k
        (k, node)) |> toList
    graphs <- createValueGraphs
    nodes |> List.iter |> Iterator.fold (\graphs, (k, node) -> addNode graphs k node) graphs

unpack :: ValueGraphNode -> ValueGraphNode
unpack node = case node of
    Block nodes -> if getLength nodes == 1
        then unpack (atIndex nodes 0)
        else node
    Branches nodes -> do
        non_empty_nodes <- nodes |> List.iter |> Iterator.filter (\n -> case n of
            Empty -> False
            _ -> True) |> toList
        if getLength non_empty_nodes == 1
            then unpack (atIndex non_empty_nodes 0)
            else node
    Loop node -> node
    _ -> node

unpackGraphs :: ValueGraphs -> ValueGraphs
unpackGraphs graphs = do
    nodes <- graphs.nodes |> Map.iter |> Iterator.map (\(var, n) -> (var, unpack n)) |> toMap
    graphs { nodes = nodes }
