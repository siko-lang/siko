module Siko.MIR.Data where

import Siko.MIR.Type
import Siko.MIR.Program
import Siko.MIR.Expr

data ExternalClassImpl = Show
                       | PartialEq
                       | Eq
                       | PartialOrd
                       | Ord
                       deriving (Show, PartialEq, Eq, PartialOrd, Ord)

instance Show Identity where
    show (Identity m n i) = "{}.{}_{}" % (m, n, i)

data Variant = { name :: String,
                 type :: Type,
               } deriving (Show)

data AlgebraicDataType = { id :: Identity,
                           variants :: [Variant],
                           external_class_impls :: [(ExternalClassImpl, Option Expr)],
                           ownership_vars :: [OwnershipVar],
                         }

data RecordField = { name :: String,
                     type :: Type,
                   }

data ExternalRecordInfo = { type_args :: [Type] }

data Record = { id :: Identity,
                fields :: [RecordField],
                external_info :: Option ExternalRecordInfo,
                external_class_impls :: [(ExternalClassImpl, Option Expr)],
                ownership_vars :: [OwnershipVar],
              }

dumpAdt :: AlgebraicDataType -> String
dumpAdt adt = do
    variants <- adt.variants |> List.iter |> map (\v -> "{} {}" % (v.name, v.type)) |> toList
    "adt {} {} = {}" % (adt.id, adt.ownership_vars, join variants " | ")

dumpRecord :: Record -> String
dumpRecord record = do
    fields <- record.fields |> List.iter |> map (\field -> "{} :: {}" % (field.name, field.type)) |> toList
    if isEmpty fields
        then if isSome record.external_info
            then "record {} {} = extern" % (record.id, record.ownership_vars)
            else "record {} {}" % (record.id, record.ownership_vars)
        else ("record {} {}" % (record.id, record.ownership_vars)) + " = { " + (join fields ", ") + " }"