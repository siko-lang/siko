@extern("C")
@rename("ERR_clear_error")
fn err_clear_error() -> void

@extern("C")
@rename("ERR_get_error")
fn err_get_error() -> U64

@extern("C")
@rename("ERR_error_string_n")
fn err_error_string_n(code: U64, buffer: *U8, size: U64) -> void

