module TlsExperiment.Tls {

import Std.Error as E
import Std.IO.Error as IO
import Std.IO.Reader
import Std.IO.Writer
import Std.IO.Closer
import Std.Libc.String as LibcString
import Std.Net.TcpStream
import Std.Net.TcpListener
import Std.Ptr
import Std.Slice
import Std.Vec

// OpenSSL types are intentionally opaque. This experiment is LP64-only.
@extern("C")
@rename("TLS_client_method")
fn tls_client_method() -> void*

@extern("C")
@rename("TLS_server_method")
fn tls_server_method() -> void*

@extern("C")
@rename("SSL_CTX_new")
fn ssl_ctx_new(method: void*) -> void*

@extern("C")
@rename("SSL_CTX_free")
fn ssl_ctx_free(ctx: void*) -> void

@extern("C")
@rename("SSL_CTX_ctrl")
fn ssl_ctx_ctrl(ctx: void*, command: I32, value: I64, argument: void*) -> I64

@extern("C")
@rename("SSL_CTX_set_verify")
fn ssl_ctx_set_verify(ctx: void*, mode: I32, callback: void*) -> void

@extern("C")
@rename("SSL_CTX_set_default_verify_paths")
fn ssl_ctx_set_default_verify_paths(ctx: void*) -> I32

@extern("C")
@rename("SSL_CTX_use_certificate_chain_file")
fn ssl_ctx_use_certificate_chain_file(ctx: void*, path: *I8) -> I32

@extern("C")
@rename("SSL_CTX_use_PrivateKey_file")
fn ssl_ctx_use_private_key_file(ctx: void*, path: *I8, file_type: I32) -> I32

