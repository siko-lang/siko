@extern("C")
@rename("SSL_set0_wbio")
fn ssl_set0_wbio(ssl: void*, bio: void*) -> void

@extern("C")
@rename("SSL_set_connect_state")
fn ssl_set_connect_state(ssl: void*) -> void

@extern("C")
@rename("SSL_set_accept_state")
fn ssl_set_accept_state(ssl: void*) -> void

