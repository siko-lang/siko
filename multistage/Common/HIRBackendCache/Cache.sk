module Siko.HIR.Backend.Cache where

import Siko.Cache

getHIRBackendFunctionCachePath :: String
getHIRBackendFunctionCachePath = getCachePath + "/hirbackend_functions"

getHIRBackendRecordCachePath :: String
getHIRBackendRecordCachePath = getCachePath + "/hirbackend_records"

getHIRBackendAdtCachePath :: String
getHIRBackendAdtCachePath = getCachePath + "/hirbackend_adts"
