module Siko.Resolver.Cache where

import Json
import Json.Parser
import Json.Serialize
import Json.Writer
import Siko.Cache
import Siko.HIR.Class as HC
import Siko.HIR.Data as HD
import Siko.HIR.Effect as HE
import Siko.HIR.Function as HF

instance (FromJson a, ToJson a) => CacheEntry HF.Function a where
    getCacheFileName f = "{}.json" % f.name

instance CacheEntry HC.Class where
    getCacheFileName c = "{}.json" % c.name

instance CacheEntry HC.Instance where
    getCacheFileName i = "{}.json" % i.name

instance CacheEntry HE.Effect where
    getCacheFileName e = "{}.json" % e.name

instance CacheEntry HD.AlgebraicDataType where
    getCacheFileName adt = "{}.json" % adt.name

instance CacheEntry HD.Record where
    getCacheFileName record = "{}.json" % record.name

getResolvedFunctionCachePath :: String
getResolvedFunctionCachePath = getCachePath + "/resolved_functions"

getResolvedClassCachePath :: String
getResolvedClassCachePath = getCachePath + "/resolved_classes"

getResolvedInstanceCachePath :: String
getResolvedInstanceCachePath = getCachePath + "/resolved_instances"

getResolvedEffectCachePath :: String
getResolvedEffectCachePath = getCachePath + "/resolved_effects"

getResolvedAdtCachePath :: String
getResolvedAdtCachePath = getCachePath + "/resolved_adt"

getResolvedRecordCachePath :: String
getResolvedRecordCachePath = getCachePath + "/resolved_record"
