FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        bash \
        ca-certificates \
        clang \
        coreutils \
        libgc-dev \
        make \
        pkg-config \
        tar \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /work
