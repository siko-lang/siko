module Main where

import Hack

data Foo = Foo

data Rec = { foo :: Foo }

test1 = do
    a <- Foo
    r <- Rec a
    sink r.foo
    sink r.foo

test2 = do
    a <- Foo
    r <- Rec a
    p <- r.foo
    sink r.foo
    sink p

test3 = do
    a <- Foo
    r <- Rec a
    p <- r
    sink r
    sink p

main = do
    test1
    test2
    test3