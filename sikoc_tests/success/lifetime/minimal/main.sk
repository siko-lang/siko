module Main where

import Std.Util

nextInt :: Int -> Option (Int, Int)
nextInt s = if s < 10 then Some (s + 1, s) else None

sum s i = s + i

getNNext :: Iter -> Option (Iter, Int)
getNNext (Iter f i) = do
    case f i of
        Some (s, i) -> Some (Iter f s, i)
        None -> None

fold :: (Int -> Int -> Int) -> Int -> Iter -> Int
fold f s iter = do
    loop (s, iter) <- (s, iter) do
        case getNNext iter of
            Some (iter, n) -> do
                s <- f s n
                (s, iter)
            None -> break s

data Foo = Foo

instance Add Foo where
    opAdd a b = a

nextFoo :: Foo -> Option (Foo, Foo)
nextFoo f = Some (f, f)

data Iter = Iter (Int -> Option (Int, Int)) Int

main = do
    iter <- Iter nextInt 4
    a <- fold sum 0 iter
