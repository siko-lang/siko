module Main where

import Hack

data Double = { one :: Inner, two :: Nested }

id :: Double -> Inner
id d = d.one

one a = do
    other a

other a = if True then a else one a

data Inner = Inner

data Nested = { inner :: Inner }

data NextNested = { nested :: Nested }

data Data = Data Inner

trick = do
    a <- Inner
    ref a

main2 = do
    double <- Double Inner (Nested Inner)
    a <- id double
    sink a
    b <- id double
    borrower b
    sink (one Inner)
    do
        a <- trick
    sink stuff
    borrower stuff

stuff :: [String]
stuff = ["a"]

data OneTwo = One | Two

func = do
    next <- NextNested (Nested Inner)
    sink next.nested
    sink next.nested.inner
    loop a <- One do
        case One of
            One -> do
                next.nested
                break ()
            _ -> do
                case One of
                    One -> do
                        next.nested.inner
                        a
                    Two -> do
                        next.nested.inner
                        a
    next.nested.inner

main = do
    d <- Double Inner (Nested Inner)
    sink d
    sink d.one
    sink d
    sink d.two
    sink d.one
    sink d.two.inner