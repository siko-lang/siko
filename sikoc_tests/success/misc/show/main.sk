module Main where

import Std.Util

data Foo = Foo Int deriving (Show)
data Foo2 = Foo2 deriving (Show)
data Foo3 = Foo3 | Bar deriving (Show)

main = do
    assert (show 1.0 == "1")
    assert (show 1 == "1")
    assert (show ["1", "2"] == "[1, 2]")
    assert (show [Foo 1] == "[Foo 1]")
    assert (show [Foo2] == "[Foo2]")
    assert (show [Foo3] == "[Foo3]")