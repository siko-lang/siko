module Main where

import Std.Util
import Map

create :: Map Int Int
create = empty

main = do
    m <- create
    assert (show m == "{}")
    assert (getSize m == 0)
    (m, _) <- insert m 1 2
    (m, _) <- insert m 3 4
    assert (show m == "{1: 2, 3: 4}")
    assert (getSize m == 2)
    assert (get m 1 == Some 2)
    assert (get m 3 == Some 4)
    assert (get m 5 == None)
    (m, _) <- remove m 3
    assert (get m 3 == None)
    m <- m |> Map.iter |> map (\(k, v) -> (k, v * 2)) |> toMap
    sum <- m |> Map.iter |> fold (\sum, (k, v) -> sum + v) 0
    assert (sum == 4)
    (m, _) <- alter (\v -> case v of
                    Some v -> panic "5 found"
                    None -> Some 6) 5 m
    assert (get m 5 == Some 6)
    ()