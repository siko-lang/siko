module Main where

import Std.Util

main = do
    list <- ["apple", "banana", "banana"]
    apple <- atIndex list 0
    assert (apple == "apple")
    len <- getLength list
    assert (len == 3)
    d <- dedup list
    assert (d == ["apple", "banana"])
    empty :: [Int] <- []
    assert (isEmpty empty)
    sorted <- sort [3, 2]
    assert (sorted == [2, 3])
