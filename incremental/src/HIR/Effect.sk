module Siko.HIR.Effect where

import Siko.HIR.FullyQualifiedName
import Siko.HIR.Type
import Siko.Syntax.Location

data Effect = { name :: FullyQualifiedName,
                location :: Location,
                type :: Type,
                members :: [FullyQualifiedName],
              } deriving (Show, PartialEq, Eq)
