module Std.Util.Basic where

@Inline
println a :: (Show a) => a -> ()
println msg = printStr "{}\n" % msg

printStr :: String -> ~()
printStr msg = extern

abort :: !
abort = extern (result == *)

panic a :: (Show a) => a -> !
panic msg = do
    println msg
    abort

unreachable :: !
unreachable = panic "foo"

module Std.Ops where

class Show a where
    show a :: a -> String

class Add a where
    opAdd a :: a -> a -> a

class Mul a where
    opMul a :: a -> a -> a

class PartialEq a where
    opEq a :: a -> a -> Bool

    opNotEq a :: a -> a -> Bool
    opNotEq a b = (opEq a b)

class (PartialEq a) => Eq a

module String where

data String = extern

split :: ~String -> ~String -> ~[~String]
split input sep = extern

endsWith :: String -> String -> ~Bool
endsWith self end = extern

instance Add String where
    opAdd a b = addString a b

instance Show String where
    show s = s

instance PartialEq String where
    opEq a b = False

instance Eq String

addString :: ~String -> ~String -> ~String
addString a b = extern

module Bool where

data Bool = True | False

module Std.Util where

assert :: ~Bool -> ~()
assert value = extern

module Int where

data Int = extern

instance Show Int where
    show _ = "0"

instance Add Int where
    opAdd a b = addInt a b

instance Mul Int where
    opMul a b = mulInt a b

instance PartialEq Int where
    opEq a b = True

addInt :: ~Int -> ~Int -> ~Int
addInt a b = extern

mulInt :: ~Int -> ~Int -> ~Int
mulInt a b = extern

module Option where

data Option a = Some a | None

module Result where

data Result ok err = Ok ok | Err err

module IO where

listDir :: String -> ~[~String]
listDir path = extern

isDir :: String -> ~Bool
isDir path = extern

module List where

data List a = extern

instance Add [a] where
    opAdd a b = addList a b

addList a :: [a] -> [a] -> ~[a]
addList a b = extern

push a :: [a] -> a -> ~[a]
push l item = extern (arg[1] -> result.e[0],
                      arg[0].e[0] == result.e[0])

@Inline
fold s a :: s -> [a] -> (s -> a -> s) -> s
fold init list f = list |> List.iter |> Iterator.fold f init

data ListIter a = { inner :: ListIterator a }

instance Iterator (ListIter a) > a where
    next iter = do
        (inner, item) <- List.nextItem iter.inner
        iter <- iter { inner = inner }
        case item of
            Some a -> (iter, Some a)
            None -> (iter, None)

atIndex a :: [a] -> Int -> a
atIndex index l = extern (arg[0].e[0] -> result)

@Inline
last a :: [a] -> a
last list = do
    i <- getLength list
    atIndex list 0

getLength a :: [a] -> ~Int
getLength l = extern

@Inline
iter it a :: [a] -> ListIter a
iter l = ListIter (List.intoIter l)

data ListIterator a = extern (implicit)

intoIter a :: [a] -> ~ListIterator a
intoIter list = extern (arg[0] -> result.i[0])

nextItem a :: ListIterator a -> ~(~ListIterator a, ~Option a)
nextItem iter = extern (arg[0].i[0].e[0] -> result.f[1].v[0].f[0],
                        arg[0].i[0] == result.f[0].i[0],
                        arg[0].i[0].e[0] == result.f[0].i[0].e[0])
module Iterator where

class Iterator a > b where
    next a b :: a -> (a, Option b)

@Inline
fold a b i1 :: (Iterator i1 > b) => (a -> b -> a) -> a -> i1 -> a
fold f s iter = do
    loop (s, iter) <- (s, iter) do
        (iter, value) <- next iter
        case value of
            Some n -> do
                s <- f s n
                (s, iter)
            None -> break s

module Main where

import Std.Util

data Value = IntegerValue Int
    | StringValue String.String

data Expr = Integer Int
    | String String.String
    | Sum Expr Expr
    | Mul Expr Expr

toInt :: Value -> Int
toInt v = case v of
    IntegerValue v -> v
    StringValue v -> 0

eval :: Expr -> Value
eval expr = case expr of
    Integer value -> IntegerValue value
    String value -> StringValue value
    Sum lhs rhs -> IntegerValue (toInt (eval lhs) + toInt (eval rhs))
    Mul lhs rhs -> IntegerValue (toInt (eval lhs) * toInt (eval rhs))

main = do
    expr <- Mul (Sum (Integer 4) (Integer 4)) (Integer 2)
    assert ((toInt (eval expr)) == 16)


