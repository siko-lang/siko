module Siko.LLVM.Emit {

import Std.Sync.Thread as T
import Siko.LLVM.CApi

pub struct LLVMModule {
    ctx: Context,
    m: Module,
    target_triple: String,

    pub fn new(ctx: Context, m: Module, target_triple: String) -> LLVMModule {
        LLVMModule(ctx, m, target_triple)
    }

    pub fn ir(llvm_module: LLVMModule) -> String {
        llvm_module.m.print_to_string()
    }
}

pub fn emit_modules(modules: Vec[LLVMModule]) -> String {
    let text = "";
    let first = True;
    for llvm_module in modules {
        if !first {
            text = text + "\n";
        }
        text = text + llvm_module.ir();
        first = False;
    }
    text
}

pub struct ObjectModule {
    ctx: Context,
    m: Module,
    tm: TargetMachine,

    pub fn ir(o: ObjectModule) -> String {
        o.m.print_to_string()
    }

    pub fn emit_object(o: ObjectModule, path: String) {
        o.tm.emit_object(o.m, path);
    }

    pub fn dispose(o: ObjectModule) {
        o.tm.dispose();
        o.m.dispose();
        o.ctx.dispose();
    }
}

pub fn emit_object_modules(object_modules: Vec[ObjectModule], paths: Vec[String]) {
    if object_modules.len() != paths.len() {
        panic("llvm emit: object module/path count mismatch");
    }
    let handles: Vec[T.JoinHandle] = Vec.new(object_modules.len());
    let i = 0;
    while i < object_modules.len() {
        let object_module = object_modules[i];
        let path = paths[i];
        handles.push(T.spawn(|| {
            object_module.emit_object(path);
            object_module.dispose();
        }));
        i += 1;
    }
    for handle in handles {
        handle.join();
    }
}

fn optimize_initialized(llvm_module: LLVMModule, optimize: Bool) -> ObjectModule {
    let tm = Target.from_triple(llvm_module.target_triple).create_machine(llvm_module.target_triple, optimize);
    tm.apply_data_layout(llvm_module.m);
    if optimize {
        llvm_module.m.run_passes("default<O3>", tm);
    }
    ObjectModule(llvm_module.ctx, llvm_module.m, tm)
}

pub fn optimize_modules(modules: Vec[LLVMModule], optimize: Bool) -> Vec[ObjectModule] {
    initialize_targets();
    let slots: Vec[Option[ObjectModule]] = Vec.with_value(modules.len(), None);
    let handles: Vec[T.JoinHandle] = Vec.new(modules.len());
    let i = 0;
    while i < modules.len() {
        let index = i;
        let llvm_module = modules[i];
        handles.push(T.spawn(|| {
            slots[index] = Some(optimize_initialized(llvm_module, optimize));
        }));
        i += 1;
    }
    for handle in handles {
        handle.join();
    }
    let object_modules: Vec[ObjectModule] = Vec.new(slots.len());
    for slot in slots {
        object_modules.push(slot.expect("llvm emit: worker did not produce object module"));
    }
    object_modules
}

}
