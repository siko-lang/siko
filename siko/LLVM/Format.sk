module Siko.LLVM.Format {

import Siko.LLVM.AST
import Std.StringBuilder

// ─── Formatter state ─────────────────────────────────────────────────────────

struct Formatter {
    buf: StringBuilder,
    indent: Int,

    fn new() -> Formatter {
        Formatter(StringBuilder.new(), 0)
    }

    fn push(f: Formatter, s: String) {
        f.buf.push(s)
    }

    fn emit_indent(f: Formatter) {
        for _ in 0..f.indent {
            f.buf.push("  ")
        }
    }

    fn finish(f: Formatter) -> String {
        f.buf.to_string()
    }
}

// ─── Escaping ────────────────────────────────────────────────────────────────

fn hex_digit(n: Int) -> String {
    let chars = "0123456789ABCDEF".as_slice();
    String.from_byte(chars[n])
}

fn hex_byte(b: U8) -> String {
    let v = b.as_int();
    "\\" + hex_digit(v / 16) + hex_digit(v % 16)
}

fn is_ident_start(c: U8) -> Bool {
    (c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || c == '_' || c == '$' || c == '.'
}

fn is_ident_char(c: U8) -> Bool {
    is_ident_start(c) || (c >= '0' && c <= '9') || c == '-'
}

fn escape_quoted(s: String) -> String {
    let out = "";
    for c in s.chars() {
        if c == '"' || c == '\\' || c < ' ' || c > '~' {
            out = out + hex_byte(c);
        } else {
            out = out + String.from_byte(c);
        }
    }
    out
}

fn ident(s: String) -> String {
    let first = True;
    let simple = !s.is_empty();
    for c in s.chars() {
        if first {
            if !is_ident_start(c) {
                simple = False;
            }
            first = False;
        } else if !is_ident_char(c) {
            simple = False;
        }
    }
    if simple {
        s
    } else {
        "\"" + escape_quoted(s) + "\""
    }
}

fn local_name(name: String) -> String {
    "%" + ident(name)
}

fn global_name(name: String) -> String {
    "@" + ident(name)
}

fn type_name(name: String) -> String {
    "%" + ident(name)
}

fn escape_llvm_string(s: String) -> String {
    let out = "";
    for c in s.chars() {
        if c >= ' ' && c <= '~' && c != '"' && c != '\\' {
            out = out + String.from_byte(c);
        } else {
            out = out + hex_byte(c);
        }
    }
    out
}

// ─── Small printers ──────────────────────────────────────────────────────────

fn linkage_str(linkage: LLVMLinkage) -> Option[String] {
    match linkage {
        LLVMLinkage.External => None,
        LLVMLinkage.Internal => Some("internal"),
        LLVMLinkage.Private => Some("private"),
        LLVMLinkage.Appending => Some("appending"),
        LLVMLinkage.LinkOnceODR => Some("linkonce_odr"),
        LLVMLinkage.WeakODR => Some("weak_odr"),
    }
}

fn unnamed_addr_str(ua: LLVMUnnamedAddr) -> Option[String] {
    match ua {
        LLVMUnnamedAddr.NoUnnamedAddr => None,
        LLVMUnnamedAddr.UnnamedAddr => Some("unnamed_addr"),
        LLVMUnnamedAddr.LocalUnnamedAddr => Some("local_unnamed_addr"),
    }
}

fn binary_op_str(op: LLVMBinaryOp) -> String {
    match op {
        LLVMBinaryOp.Add => "add",
        LLVMBinaryOp.Sub => "sub",
        LLVMBinaryOp.Mul => "mul",
        LLVMBinaryOp.UDiv => "udiv",
        LLVMBinaryOp.SDiv => "sdiv",
        LLVMBinaryOp.URem => "urem",
        LLVMBinaryOp.SRem => "srem",
        LLVMBinaryOp.And => "and",
        LLVMBinaryOp.Or => "or",
        LLVMBinaryOp.Xor => "xor",
        LLVMBinaryOp.Shl => "shl",
        LLVMBinaryOp.LShr => "lshr",
        LLVMBinaryOp.AShr => "ashr",
    }
}

fn pred_str(pred: LLVMIntPredicate) -> String {
    match pred {
        LLVMIntPredicate.Eq => "eq",
        LLVMIntPredicate.Ne => "ne",
        LLVMIntPredicate.Ugt => "ugt",
        LLVMIntPredicate.Uge => "uge",
        LLVMIntPredicate.Ult => "ult",
        LLVMIntPredicate.Ule => "ule",
        LLVMIntPredicate.Sgt => "sgt",
        LLVMIntPredicate.Sge => "sge",
        LLVMIntPredicate.Slt => "slt",
        LLVMIntPredicate.Sle => "sle",
    }
}

fn cast_op_str(op: LLVMCastOp) -> String {
    match op {
        LLVMCastOp.Trunc => "trunc",
        LLVMCastOp.ZExt => "zext",
        LLVMCastOp.SExt => "sext",
        LLVMCastOp.BitCast => "bitcast",
        LLVMCastOp.PtrToInt => "ptrtoint",
        LLVMCastOp.IntToPtr => "inttoptr",
    }
}

fn format_string_attr(f: Formatter, key: String, value: String) {
    f.push(key);
    f.push(" = \"");
    f.push(escape_quoted(value));
    f.push("\"\n");
}

fn format_attrs(f: Formatter, attrs: Vec[String]) {
    for attr in attrs {
        f.push(" ");
        f.push(attr);
    }
}

// ─── Types and values ────────────────────────────────────────────────────────

fn format_type(f: Formatter, ty: LLVMType) {
    match ty {
        LLVMType.Void => f.push("void"),
        LLVMType.Label => f.push("label"),
        LLVMType.Int(bits) => f.push("i${bits}"),
        LLVMType.Ptr => f.push("ptr"),
        LLVMType.Array(n, elem) => {
            f.push("[${n} x ");
            format_type(f, elem);
            f.push("]");
        }
        LLVMType.Vector(n, elem) => {
            f.push("<${n} x ");
            format_type(f, elem);
            f.push(">");
        }
        LLVMType.Named(name) => f.push(type_name(name)),
        LLVMType.Struct(fields, packed) => {
            if fields.is_empty() {
                if packed {
                    f.push("<{}>");
                } else {
                    f.push("{}");
                }
                return;
            }
            if packed {
                f.push("<{ ");
            } else {
                f.push("{ ");
            }
            for (i, field) in fields.iter().enumerate() {
                if i > 0 { f.push(", "); }
                format_type(f, field);
            }
            if packed {
                f.push(" }>");
            } else {
                f.push(" }");
            }
        }
        LLVMType.Function(ret, params, varargs) => {
            format_type(f, ret);
            f.push(" (");
            for (i, param) in params.iter().enumerate() {
                if i > 0 { f.push(", "); }
                format_type(f, param);
            }
            if varargs {
                if !params.is_empty() { f.push(", "); }
                f.push("...");
            }
            f.push(")");
        }
    }
}

fn format_value(f: Formatter, value: LLVMValue) {
    match value {
        LLVMValue.Local(name) => f.push(local_name(name)),
        LLVMValue.Global(name) => f.push(global_name(name)),
        LLVMValue.Int(v) => f.push(v),
        LLVMValue.Bool(v) => {
            if v { f.push("true"); } else { f.push("false"); }
        }
        LLVMValue.Null => f.push("null"),
        LLVMValue.Undef => f.push("undef"),
        LLVMValue.Poison => f.push("poison"),
        LLVMValue.ZeroInitializer => f.push("zeroinitializer"),
        LLVMValue.StringLiteral(s) => {
            f.push("c\"");
            f.push(escape_llvm_string(s));
            f.push("\"");
        }
        LLVMValue.Array(values) => {
            f.push("[");
            for (i, value) in values.iter().enumerate() {
                if i > 0 { f.push(", "); }
                format_typed_value(f, value);
            }
            f.push("]");
        }
        LLVMValue.Vector(values) => {
            f.push("<");
            for (i, value) in values.iter().enumerate() {
                if i > 0 { f.push(", "); }
                format_typed_value(f, value);
            }
            f.push(">");
        }
        LLVMValue.Struct(values, packed) => {
            if values.is_empty() {
                if packed {
                    f.push("<{}>");
                } else {
                    f.push("{}");
                }
                return;
            }
            if packed {
                f.push("<{ ");
            } else {
                f.push("{ ");
            }
            for (i, value) in values.iter().enumerate() {
                if i > 0 { f.push(", "); }
                format_typed_value(f, value);
            }
            if packed {
                f.push(" }>");
            } else {
                f.push(" }");
            }
        }
        LLVMValue.Raw(s) => f.push(s),
    }
}

fn format_typed_value(f: Formatter, value: LLVMTypedValue) {
    format_type(f, value.ty);
    f.push(" ");
    format_value(f, value.value);
}

fn format_indices(f: Formatter, indices: Vec[Int]) {
    for index in indices {
        f.push(", ${index}");
    }
}

fn format_gep_indices(f: Formatter, indices: Vec[LLVMTypedValue]) {
    for index in indices {
        f.push(", ");
        format_typed_value(f, index);
    }
}

// ─── Globals and signatures ──────────────────────────────────────────────────

fn format_type_def(f: Formatter, def: LLVMTypeDef) {
    f.push(type_name(def.name));
    f.push(" = type ");
    match def.ty {
        Some(ty) => format_type(f, ty),
        None => f.push("opaque"),
    }
    f.push("\n");
}

fn format_global(f: Formatter, g: LLVMGlobal) {
    f.push(global_name(g.name));
    f.push(" = ");
    let has_init = g.init.is_some();
    if !has_init && g.linkage == LLVMLinkage.External {
        f.push("external ");
    } else {
        if let Some(linkage) = linkage_str(g.linkage) {
            f.push(linkage);
            f.push(" ");
        }
    }
    if let Some(ua) = unnamed_addr_str(g.unnamed_addr) {
        f.push(ua);
        f.push(" ");
    }
    if g.constant {
        f.push("constant ");
    } else {
        f.push("global ");
    }
    format_type(f, g.ty);
    if let Some(init) = g.init {
        f.push(" ");
        format_value(f, init);
    }
    if let Some(align) = g.align {
        f.push(", align ${align}");
    }
    for attr in g.attrs {
        f.push(", ");
        f.push(attr);
    }
    f.push("\n");
}

fn format_param(f: Formatter, param: LLVMParam, include_name: Bool) {
    for attr in param.attrs {
        f.push(attr);
        f.push(" ");
    }
    format_type(f, param.ty);
    if include_name {
        if let Some(name) = param.name {
            f.push(" ");
            f.push(local_name(name));
        }
    }
}

fn format_sig(f: Formatter, sig: LLVMFunctionSig, include_param_names: Bool) {
    if let Some(linkage) = linkage_str(sig.linkage) {
        f.push(linkage);
        f.push(" ");
    }
    if let Some(cc) = sig.calling_conv {
        f.push(cc);
        f.push(" ");
    }
    format_type(f, sig.ret);
    f.push(" ");
    f.push(global_name(sig.name));
    f.push("(");
    for (i, param) in sig.params.iter().enumerate() {
        if i > 0 { f.push(", "); }
        format_param(f, param, include_param_names);
    }
    if sig.varargs {
        if !sig.params.is_empty() { f.push(", "); }
        f.push("...");
    }
    f.push(")");
    format_attrs(f, sig.attrs);
}

fn format_decl(f: Formatter, decl: LLVMFunctionDecl) {
    f.push("declare ");
    format_sig(f, decl.sig, False);
    f.push("\n");
}

// ─── Instructions and terminators ────────────────────────────────────────────

fn format_instruction_kind(f: Formatter, kind: LLVMInstructionKind) {
    match kind {
        LLVMInstructionKind.Alloca(ty, align) => {
            f.push("alloca ");
            format_type(f, ty);
            if let Some(a) = align {
                f.push(", align ${a}");
            }
        }
        LLVMInstructionKind.Load(ty, ptr, align) => {
            f.push("load ");
            format_type(f, ty);
            f.push(", ptr ");
            format_value(f, ptr);
            if let Some(a) = align {
                f.push(", align ${a}");
            }
        }
        LLVMInstructionKind.Store(value, ptr, align) => {
            f.push("store ");
            format_typed_value(f, value);
            f.push(", ptr ");
            format_value(f, ptr);
            if let Some(a) = align {
                f.push(", align ${a}");
            }
        }
        LLVMInstructionKind.Binary(op, ty, lhs, rhs) => {
            f.push(binary_op_str(op));
            f.push(" ");
            format_type(f, ty);
            f.push(" ");
            format_value(f, lhs);
            f.push(", ");
            format_value(f, rhs);
        }
        LLVMInstructionKind.ICmp(pred, ty, lhs, rhs) => {
            f.push("icmp ");
            f.push(pred_str(pred));
            f.push(" ");
            format_type(f, ty);
            f.push(" ");
            format_value(f, lhs);
            f.push(", ");
            format_value(f, rhs);
        }
        LLVMInstructionKind.GetElementPtr(ty, ptr, indices, inbounds) => {
            if inbounds {
                f.push("getelementptr inbounds ");
            } else {
                f.push("getelementptr ");
            }
            format_type(f, ty);
            f.push(", ptr ");
            format_value(f, ptr);
            format_gep_indices(f, indices);
        }
        LLVMInstructionKind.ExtractValue(ty, aggregate, indices) => {
            f.push("extractvalue ");
            format_type(f, ty);
            f.push(" ");
            format_value(f, aggregate);
            format_indices(f, indices);
        }
        LLVMInstructionKind.InsertValue(ty, aggregate, value, indices) => {
            f.push("insertvalue ");
            format_type(f, ty);
            f.push(" ");
            format_value(f, aggregate);
            f.push(", ");
            format_typed_value(f, value);
            format_indices(f, indices);
        }
        LLVMInstructionKind.Cast(op, value, dest_ty) => {
            f.push(cast_op_str(op));
            f.push(" ");
            format_typed_value(f, value);
            f.push(" to ");
            format_type(f, dest_ty);
        }
        LLVMInstructionKind.Call(ret_ty, callee, args, attrs) => {
            f.push("call");
            format_attrs(f, attrs);
            f.push(" ");
            format_type(f, ret_ty);
            f.push(" ");
            format_value(f, callee);
            f.push("(");
            for (i, arg) in args.iter().enumerate() {
                if i > 0 { f.push(", "); }
                format_typed_value(f, arg);
            }
            f.push(")");
        }
        LLVMInstructionKind.Phi(ty, incoming) => {
            f.push("phi ");
            format_type(f, ty);
            f.push(" ");
            for (i, inc) in incoming.iter().enumerate() {
                if i > 0 { f.push(", "); }
                f.push("[ ");
                format_value(f, inc.value);
                f.push(", ");
                f.push(local_name(inc.label));
                f.push(" ]");
            }
        }
        LLVMInstructionKind.Comment(text) => {
            f.push("; ");
            f.push(text);
        }
        LLVMInstructionKind.Raw(text) => f.push(text),
    }
}

fn format_instruction(f: Formatter, instr: LLVMInstruction) {
    f.emit_indent();
    if let Some(result) = instr.result {
        f.push(local_name(result));
        f.push(" = ");
    }
    format_instruction_kind(f, instr.kind);
    f.push("\n");
}

fn format_terminator(f: Formatter, term: LLVMTerminator) {
    f.emit_indent();
    match term {
        LLVMTerminator.Ret(value) => {
            match value {
                Some(v) => {
                    f.push("ret ");
                    format_typed_value(f, v);
                }
                None => f.push("ret void"),
            }
        }
        LLVMTerminator.Br(label) => {
            f.push("br label ");
            f.push(local_name(label));
        }
        LLVMTerminator.CondBr(cond, then_label, else_label) => {
            f.push("br ");
            format_typed_value(f, cond);
            f.push(", label ");
            f.push(local_name(then_label));
            f.push(", label ");
            f.push(local_name(else_label));
        }
        LLVMTerminator.Switch(value, default_label, cases) => {
            f.push("switch ");
            let switch_ty = value.ty.clone();
            format_typed_value(f, value);
            f.push(", label ");
            f.push(local_name(default_label));
            f.push(" [");
            if !cases.is_empty() {
                f.push("\n");
                f.indent = f.indent + 1;
                for case in cases {
                    f.emit_indent();
                    format_type(f, switch_ty.clone());
                    f.push(" ");
                    format_value(f, case.value);
                    f.push(", label ");
                    f.push(local_name(case.label));
                    f.push("\n");
                }
                f.indent = f.indent - 1;
                f.emit_indent();
            }
            f.push("]");
        }
        LLVMTerminator.Unreachable => f.push("unreachable"),
    }
    f.push("\n");
}

fn format_block(f: Formatter, block: LLVMBasicBlock) {
    f.push(ident(block.label));
    f.push(":\n");
    f.indent = 1;
    for instr in block.instrs {
        format_instruction(f, instr);
    }
    format_terminator(f, block.term);
    f.indent = 0;
}

fn format_function(f: Formatter, func: LLVMFunctionDef) {
    f.push("define ");
    format_sig(f, func.sig, True);
    f.push(" {\n");
    for block in func.blocks {
        format_block(f, block);
    }
    f.push("}\n");
}

// ─── Entry point ─────────────────────────────────────────────────────────────

pub fn format(llvm_module: LLVMModule) -> String {
    let f = Formatter.new();

    let has_header =
        llvm_module.source_filename.is_some() ||
        llvm_module.data_layout.is_some() ||
        llvm_module.target_triple.is_some();
    let has_types = !llvm_module.types.is_empty();
    let has_globals = !llvm_module.globals.is_empty();
    let has_declarations = !llvm_module.declarations.is_empty();

    if let Some(source) = llvm_module.source_filename {
        format_string_attr(f, "source_filename", source);
    }
    if let Some(layout) = llvm_module.data_layout {
        format_string_attr(f, "target datalayout", layout);
    }
    if let Some(triple) = llvm_module.target_triple {
        format_string_attr(f, "target triple", triple);
    }
    if has_header {
        f.push("\n");
    }

    for tdef in llvm_module.types {
        format_type_def(f, tdef);
    }
    if has_types {
        f.push("\n");
    }

    for global in llvm_module.globals {
        format_global(f, global);
    }
    if has_globals {
        f.push("\n");
    }

    for decl in llvm_module.declarations {
        format_decl(f, decl);
    }
    if has_declarations {
        f.push("\n");
    }

    for func in llvm_module.functions {
        format_function(f, func);
        f.push("\n");
    }

    f.finish()
}

}
