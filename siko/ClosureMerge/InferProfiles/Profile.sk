module Siko.ClosureMerge.InferProfiles.Profile {

import Std.Set
import Siko.AST.QualifiedName
import Siko.AST.Type

// ── Flow graph domain ────────────────────────────────────────────────────────
// Closure infer vars are numbered per function (GeneralizeFunctions), so a
// graph node must carry its owner to be unique across an SCC.

@derive(PartialEq, Std.Ops.Eq, PartialOrd, Ord, Clone)
pub struct FlowNode {
    pub owner: QualifiedName,
    pub var: TypeVar,
}

// One equivalence class of slots, as seen from a specific function's
// profile: the function's own boundary vars that are in the class, plus the
// lambda literals known to inhabit it. Vars of other SCC members are
// dropped — flows only realizable through those members are covered by
// their own profiles.
@derive(Clone)
pub struct ClassRef {
    pub vars: Vec[TypeVar],
    pub lambdas: Set[QualifiedName],

    pub fn is_empty(c: ClassRef) -> Bool {
        c.vars.is_empty() && c.lambdas.is_empty()
    }
}

pub struct ApplySummary {
    pub callee: ClassRef,
    pub args: Vec[ClassRef],
    pub results: Vec[ClassRef],
}

pub struct CreationSummary {
    pub lambda: QualifiedName,
    pub captures: Vec[ClassRef],
}

// The data-flow profile of one function: a partition of its boundary vars
// (the closure infer vars appearing in its arg/result/yield types) into
// equivalence classes, with the lambda literals inhabiting each class.
// Only interesting groups are recorded: a class is omitted when it contains
// a single var and no lambdas.
pub struct Profile {
    pub groups: Vec[ClassRef],
    pub applies: Vec[ApplySummary],
    pub creations: Vec[CreationSummary],

    pub fn is_empty(p: Profile) -> Bool {
        p.groups.is_empty() && p.applies.is_empty() && p.creations.is_empty()
    }
}

}
