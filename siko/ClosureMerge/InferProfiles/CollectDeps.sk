module Siko.ClosureMerge.InferProfiles.CollectDeps {

import Std.Map
import Std.Set
import Siko.AST.Annotations
import Siko.AST.Expr as E
import Siko.AST.Function
import Siko.AST.Generics
import Siko.AST.Identifier
import Siko.AST.Name
import Siko.AST.Pattern
import Siko.AST.QualifiedName
import Siko.AST.Statement as S
import Siko.AST.Type
import Siko.HIR.Program
import Siko.Interner as I
import Siko.Location
import Siko.Package.Collector as PC
import Siko.Utils.SCC as SCC
import Siko.Utils.VarAllocator

// ── Call graph ───────────────────────────────────────────────────────────────
// Static call dependencies for SCC ordering. Lambda functions are included
// as dependencies of their creator so their profiles are available when the
// creation site is processed.

struct DepCollector {
    deps: Set[QualifiedName],
}

trait CollectDeps[T] {
    fn collect_deps(t: T, c: DepCollector)
}

instance CollectDeps[Location]            = auto(Fold, =)
instance CollectDeps[TypeDef]             = auto(Fold, =)
instance CollectDeps[I.String]            = auto(Fold, =)
instance CollectDeps[String]              = auto(Fold, =)
instance CollectDeps[Int]                 = auto(Fold, =)
instance CollectDeps[U8]                  = auto(Fold, =)
instance CollectDeps[Bool]                = auto(Fold, =)
instance CollectDeps[QualifiedName]       = auto(Fold, =)
instance CollectDeps[E.VariableName]      = auto(Fold, =)
instance CollectDeps[Name]                = auto(Fold, =)
instance CollectDeps[Identifier]          = auto(Fold, =)
instance CollectDeps[E.WitnessInfo]       = auto(Fold, =)
instance CollectDeps[E.FunctionKind]      = auto(Fold, =)
instance CollectDeps[E.BinaryOp]          = auto(Fold, =)
instance CollectDeps[E.UnaryOp]           = auto(Fold, =)
instance CollectDeps[E.LambdaArg]         = auto(Fold, =)
instance CollectDeps[E.ImplicitRefInfo]   = auto(Fold, =)
instance CollectDeps[E.FunctionPtrInfo]   = auto(Fold, =)
instance CollectDeps[E.NamedArgument]     = auto(Fold, =)
instance CollectDeps[NamedPatternArg]     = auto(Fold, =)
instance CollectDeps[E.HandlerSelection]  = auto(Fold, =)
instance CollectDeps[Annotation]          = auto(Fold, =)
instance CollectDeps[FunctionDefKind]     = auto(Fold, =)
instance CollectDeps[TypeArgDefs]         = auto(Fold, =)
instance CollectDeps[VarAllocator]        = auto(Fold, =)
instance CollectDeps[DefaultValueInfo]    = auto(Fold, =)
instance CollectDeps[PC.SourcePackage]    = auto(Fold, =)
instance CollectDeps[E.TypeAssociatedCallInfo] = auto(Fold, !)
instance CollectDeps[NamedPatternInfo]    = auto(Fold)
instance CollectDeps[E.MethodCallInfo]    = auto(Fold)
instance CollectDeps[E.CallInfo]          = auto(Fold)
instance CollectDeps[E.WithInfo]          = auto(Fold)
instance CollectDeps[E.MatchArm]          = auto(Fold)
instance CollectDeps[E.MatchInfo]         = auto(Fold)
instance CollectDeps[E.YieldInfo]         = auto(Fold)
instance CollectDeps[E.ExprKind]          = auto(Fold)
instance CollectDeps[E.Expr]              = auto(Fold)
instance CollectDeps[S.LetInfo]           = auto(Fold)
instance CollectDeps[S.DeclareInfo]       = auto(Fold)
instance CollectDeps[E.BlockInfo]         = auto(Fold)
instance CollectDeps[S.Statement]         = auto(Fold)
instance CollectDeps[Pattern]             = auto(Fold)
instance CollectDeps[PatternKind]         = auto(Fold)
instance CollectDeps[FunctionArg]         = auto(Fold)
instance CollectDeps[FunctionDef]         = auto(Fold)

instance CollectDeps[E.FunctionCallInfo] {
    fn collect_deps(info: E.FunctionCallInfo, c: DepCollector) {
        if let E.FunctionKind.UserDefined = info.kind {
            c.deps.insert(info.qname);
        }
        collect_deps(info.args, c);
    }
}

instance CollectDeps[E.CreateClosureInfo] {
    fn collect_deps(info: E.CreateClosureInfo, c: DepCollector) {
        c.deps.insert(info.name);
    }
}

instance[T: CollectDeps[T]] CollectDeps[Option[T]] {
    fn collect_deps(opt: Option[T], c: DepCollector) {
        if let Some(t) = opt {
            collect_deps(t, c);
        }
    }
}

instance[T: CollectDeps[T]] CollectDeps[Vec[T]] {
    fn collect_deps(vec: Vec[T], c: DepCollector) {
        for t in vec {
            collect_deps(t, c);
        }
    }
}

pub fn build_groups(program: Program) -> Vec[Vec[QualifiedName]] {
    let graph: Map[QualifiedName, Vec[QualifiedName]] = Map.new();
    for (qname, func) in program.functions {
        let collector = DepCollector(Set.new());
        collect_deps(func, collector);
        let deps: Vec[QualifiedName] = collector.deps
            .into_iter()
            .filter(|d| program.functions.contains_key(d))
            .collect();
        graph.insert(qname, deps);
    }
    SCC.compute(graph)
}

}
