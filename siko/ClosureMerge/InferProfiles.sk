module Siko.ClosureMerge.InferProfiles {

import Std.Map
import Std.Set
import Siko.AST.QualifiedName
import Siko.AST.Type
import Siko.ClosureMerge.InferProfiles.CollectDeps
import Siko.ClosureMerge.InferProfiles.Debug
import Siko.ClosureMerge.InferProfiles.Flow
import Siko.ClosureMerge.InferProfiles.Profile
import Siko.Config
import Siko.HIR.Program

// ── Summarization ────────────────────────────────────────────────────────────

// The class of a set of nodes, expressed in one member function's profile
// vocabulary: that member's boundary vars sharing a class with the nodes,
// plus the lambdas inhabiting those classes.
fn class_ref_of(ctx: FlowCtx, class_vars: Map[FlowNode, Vec[TypeVar]], nodes: Vec[FlowNode]) -> ClassRef {
    let vars: Vec[TypeVar] = Vec.new();
    let lambdas: Set[QualifiedName] = Set.new();
    let seen: Set[FlowNode] = Set.new();
    for n in nodes {
        let root = ctx.uf.find(n);
        if seen.contains(root) {
            continue;
        }
        seen.insert(root.clone());
        vars.extend(class_vars.get(root.clone()).unwrap_or(Vec.new()));
        for l in ctx.uf.lambdas.get(root).unwrap_or(Set.new()) {
            lambdas.insert(l);
        }
    }
    ClassRef(vars, lambdas)
}

fn summarize(ctx: FlowCtx, scc: Vec[QualifiedName]) {
    if get_config().debug_closure {
        debug_dump_classes(ctx, scc);
    }

    // per-member profiles: a member's profile only speaks about its own
    // boundary vars; other members' vars are internal from this member's
    // callers' point of view
    for q in scc.iter() {
        let func = ctx.program.functions.get(q).unwrap();
        if func.body.is_none() {
            continue;
        }

        // partition this member's boundary vars by class
        let class_vars: Map[FlowNode, Vec[TypeVar]] = Map.new();
        for v in boundary_vars(func) {
            let root = ctx.uf.find(FlowNode(q.clone(), v.clone()));
            let vars = class_vars.get(root.clone()).unwrap_or(Vec.new());
            vars.push(v);
            class_vars.insert(root, vars);
        }

        let groups: Vec[ClassRef] = Vec.new();
        for (root, vars) in class_vars.iter() {
            let lambdas = ctx.uf.lambdas.get(root).unwrap_or(Set.new());
            if vars.len() > 1 || !lambdas.is_empty() {
                groups.push(ClassRef(vars, lambdas));
            }
        }

        let applies: Vec[ApplySummary] = Vec.new();
        for record in ctx.applies.iter() {
            if record.owner == q {
                let arg_refs: Vec[ClassRef] = record.args.iter().map(|ns| class_ref_of(ctx, class_vars, ns.clone())).collect();
                let result_refs: Vec[ClassRef] = record.result.iter().map(|n| class_ref_of(ctx, class_vars, [n.clone()])).collect();
                applies.push(ApplySummary(class_ref_of(ctx, class_vars, record.callee.clone()), arg_refs, result_refs));
            }
        }

        let creations: Vec[CreationSummary] = Vec.new();
        for record in ctx.creations.iter() {
            if record.owner == q {
                let capture_refs: Vec[ClassRef] = record.captures.iter().map(|ns| class_ref_of(ctx, class_vars, ns.clone())).collect();
                creations.push(CreationSummary(record.lambda.clone(), capture_refs));
            }
        }

        ctx.profiles.insert(q.clone(), Profile(groups, applies, creations));
    }
}

// ── Entry point ──────────────────────────────────────────────────────────────

// Compute a data-flow profile for every function with a body. Expects the
// program to have been through generalize_datatypes and
// generalize_functions already. Read-only on `program`.
pub fn infer_profiles(program: Program) -> Map[QualifiedName, Profile] {
    let tables = build_tables(program);
    let sccs = build_groups(program);

    let ctx = FlowCtx(
        program: program,
        tables: tables,
        scc_members: Set.new(),
        profiles: Map.new(),
        uf: UnionFind.new(),
        applies: Vec.new(),
        creations: Vec.new(),
        calls: Vec.new(),
        current_fn: QualifiedName.new_closure_enum(0),
        env: Map.new(),
        result_vars: Vec.new(),
        yield_vars: Vec.new(),
    );

    for scc in sccs {
        let members: Set[QualifiedName] = Set.new();
        for q in scc.iter() {
            members.insert(q);
        }
        ctx.scc_members = members;
        ctx.uf = UnionFind.new();
        ctx.applies = Vec.new();
        ctx.creations = Vec.new();
        ctx.calls = Vec.new();

        for q in scc.iter() {
            let func = ctx.program.functions.get(q).unwrap();
            let body = match func.body {
                Some(b) => b,
                None => continue,
            };
            ctx.current_fn = q.clone();
            ctx.env = Map.new();
            for arg in func.args.iter() {
                ctx.env.insert(arg.name.clone(), ty_vars(arg.type_def.clone()));
            }
            ctx.result_vars = opt_ty_vars(func.result_type.clone());
            ctx.yield_vars = opt_ty_vars(func.yield_type.clone());

            if func.is_closure_alias() {
                apply_closure_alias(ctx, func.clone());
            }

            flow(body.clone(), ctx);
            ctx.unify(ctx.nodes(evars(body)), ctx.nodes(ctx.result_vars.clone()));
        }

        summarize(ctx, scc);
    }

    ctx.profiles
}

}
