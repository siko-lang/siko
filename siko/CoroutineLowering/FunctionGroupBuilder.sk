module Siko.CoroutineLowering.FunctionGroupBuilder {

import Std.Map
import Std.Set
import Siko.AST.Annotations
import Siko.AST.Expr as E
import Siko.Instances.FunctionInstanceResolver
import Siko.AST.Function
import Siko.AST.Generics
import Siko.AST.Identifier
import Siko.AST.Name
import Siko.AST.Pattern
import Siko.AST.QualifiedName
import Siko.AST.Statement as S
import Siko.AST.Type
import Siko.HIR.Program
import Siko.Interner as I
import Siko.Location
import Siko.Package.Collector as PC
import Siko.Utils.SCC as SCC
import Siko.Utils.VarAllocator

pub struct CallCollector {
    pub deps: Set[QualifiedName],
    pub handler_deps: Set[QualifiedName],
    pub program: Program,
}

trait Collect[T] {
    fn walk(t: T, c: CallCollector)
}

instance Collect[Location]           = auto(Fold, =)
instance Collect[TypeDef]            = auto(Fold, =)
instance Collect[I.String]           = auto(Fold, =)
instance Collect[String]             = auto(Fold, =)
instance Collect[Int]                = auto(Fold, =)
instance Collect[U8]                 = auto(Fold, =)
instance Collect[Bool]               = auto(Fold, =)
instance Collect[QualifiedName]      = auto(Fold, =)
instance Collect[E.VariableName]     = auto(Fold, =)
instance Collect[Name]               = auto(Fold, =)
instance Collect[Identifier]         = auto(Fold, =)
instance Collect[E.WitnessInfo]      = auto(Fold)
instance Collect[BoundWitness]       = auto(Fold)
instance Collect[E.FunctionKind]     = auto(Fold, =)
instance Collect[E.BinaryOp]         = auto(Fold, =)
instance Collect[E.UnaryOp]          = auto(Fold, =)
instance Collect[E.LambdaArg]        = auto(Fold, =)
instance Collect[E.ImplicitRefInfo]  = auto(Fold, =)
instance Collect[E.FunctionPtrInfo]  = auto(Fold, =)
instance Collect[E.NamedArgument]    = auto(Fold, =)
instance Collect[NamedPatternArg]    = auto(Fold, =)
instance Collect[NamedPatternInfo]   = auto(Fold)
instance Collect[E.MethodCallInfo]   = auto(Fold)
instance Collect[E.CallInfo]         = auto(Fold)
instance Collect[E.WithInfo]         = auto(Fold)
instance Collect[E.MatchArm]         = auto(Fold)
instance Collect[E.MatchInfo]        = auto(Fold)
instance Collect[E.YieldInfo]        = auto(Fold)
instance Collect[E.ExprKind]         = auto(Fold)
instance Collect[E.Expr]             = auto(Fold)
instance Collect[S.LetInfo]          = auto(Fold)
instance Collect[S.DeclareInfo]      = auto(Fold)
instance Collect[E.BlockInfo]        = auto(Fold)
instance Collect[S.Statement]        = auto(Fold)
instance Collect[Pattern]            = auto(Fold)
instance Collect[PatternKind]        = auto(Fold)
instance Collect[FunctionArg]        = auto(Fold)
instance Collect[FunctionDef]        = auto(Fold)
instance Collect[E.HandlerSelection] = auto(Fold, !)
instance Collect[Annotation]         = auto(Fold, =)
instance Collect[FunctionDefKind]    = auto(Fold, =)
instance Collect[TypeArgDefs]        = auto(Fold, =)
instance Collect[VarAllocator]       = auto(Fold, =)
instance Collect[DefaultValueInfo]   = auto(Fold, =)
instance Collect[PC.SourcePackage]   = auto(Fold, =)
instance Collect[E.TypeAssociatedCallInfo] = auto(Fold, !)
instance Collect[E.CreateClosureInfo] = auto(Fold, !)

instance[T: Collect[T]] Collect[Option[T]] {
    fn walk(opt: Option[T], c: CallCollector) {
        if let Some(t) = opt {
            walk(t, c);
        }
    }
}

instance[T: Collect[T]] Collect[Vec[T]] {
    fn walk(vec: Vec[T], c: CallCollector) {
        for t in vec {
            walk(t, c);
        }
    }
}

instance Collect[E.FunctionCallInfo] {
    fn walk(info: E.FunctionCallInfo, c: CallCollector) {
        // Exclude co-create calls: those only construct a coroutine object and
        // do not cause the caller to become a coroutine.
        if !info.is_coroutine_create {
            c.deps.insert(info.qname);
        }
        walk(info.args, c);
        walk(info.witnesses, c);
        walk(info.named_args, c);
    }
}

// Prepass: classify every function as coroutine or not, propagating along the
// call graph. Tarjan emits SCCs in reverse topological order (callees before
// callers), so by the time we reach an SCC all of its dependencies already have
// their final classification. An SCC is a coroutine if any of its members is an
// intrinsic coroutine (has a yield type) or depends on a function already known
// to be a coroutine.
pub fn build_coroutine_map(program: Program) -> Map[QualifiedName, Bool] {
    let (sccs, graph, _) = build_groups(program);

    let is_coroutine: Map[QualifiedName, Bool] = Map.new();

    for scc in sccs {
        let group_is_co = False;
        for qname in scc.iter() {
            let func = program.functions.get(qname).unwrap();
            if func.yield_type.is_some() && func.body.is_some() {
                group_is_co = True;
            }
        }
        if !group_is_co {
            for qname in scc.iter() {
                let deps = graph.get(qname).unwrap_or([]);
                for d in deps {
                    if is_coroutine.get(d).unwrap_or(False) {
                        group_is_co = True;
                    }
                }
            }
        }
        for qname in scc {
            is_coroutine.insert(qname, group_is_co);
        }
    }

    // for (qname, is_co) in is_coroutine.iter() {
    //     let tag = if is_co { "coroutine" } else { "plain" };
    //     println("${I.resolve(qname.name())} -> ${tag}");
    // }

    is_coroutine
}

pub fn build_groups(program: Program) -> (Vec[Vec[QualifiedName]], Map[QualifiedName, Vec[QualifiedName]], Map[QualifiedName, Set[QualifiedName]]) {
    let graph: Map[QualifiedName, Vec[QualifiedName]] = Map.new();
    let handler_map: Map[QualifiedName, Set[QualifiedName]] = Map.new();

    for (qname, func) in program.functions {
        let collector = CallCollector(Set.new(), Set.new(), program);
        walk(func, collector);
        let deps: Vec[QualifiedName] = collector.deps
            .into_iter()
            .filter(|d| program.functions.contains_key(d))
            .collect();
        graph.insert(qname, deps);
        if !collector.handler_deps.is_empty() {
            handler_map.insert(qname, collector.handler_deps);
        }
    }

    (SCC.compute(graph), graph, handler_map)
}

}


