module Siko.Constants.Builtins {

import Siko.Interner as I
import Siko.AST.QualifiedName

pub struct BuiltinNameCache {
    bool_type_qn: QualifiedName,
    bool_true_qn: QualifiedName,
    bool_false_qn: QualifiedName,
    int_type_qn: QualifiedName,
    i8_type_qn: QualifiedName,
    i16_type_qn: QualifiedName,
    i32_type_qn: QualifiedName,
    i64_type_qn: QualifiedName,
    u8_type_qn: QualifiedName,
    u16_type_qn: QualifiedName,
    u32_type_qn: QualifiedName,
    u64_type_qn: QualifiedName,
    string_type_qn: QualifiedName,
    array_type_qn: QualifiedName,
    option_type_qn: QualifiedName,
    option_some_qn: QualifiedName,
    option_none_qn: QualifiedName,
    result_type_qn: QualifiedName,
    result_ok_qn: QualifiedName,
    result_err_qn: QualifiedName,
    ordering_type_qn: QualifiedName,
    ordering_less_qn: QualifiedName,
    ordering_equal_qn: QualifiedName,
    ordering_greater_qn: QualifiedName,
    trait_partial_eq_qn: QualifiedName,
    trait_eq_qn: QualifiedName,
    trait_partial_ord_qn: QualifiedName,
    trait_ord_qn: QualifiedName,
    trait_clone_qn: QualifiedName,
    trait_from_int_qn: QualifiedName,
    op_eq_qn: QualifiedName,
    op_not_eq_qn: QualifiedName,
    op_partial_cmp_qn: QualifiedName,
    op_less_qn: QualifiedName,
    op_greater_qn: QualifiedName,
    op_less_eq_qn: QualifiedName,
    op_greater_eq_qn: QualifiedName,
    op_cmp_qn: QualifiedName,
    op_clone_qn: QualifiedName,
    op_from_int_qn: QualifiedName,
    op_add_qn: QualifiedName,
    op_sub_qn: QualifiedName,
    op_mul_qn: QualifiedName,
    op_div_qn: QualifiedName,
    op_neg_qn: QualifiedName,
    op_not_qn: QualifiedName,
    op_mod_qn: QualifiedName,
    op_band_qn: QualifiedName,
    op_bor_qn: QualifiedName,
    op_bxor_qn: QualifiedName,
    op_bnot_qn: QualifiedName,
    op_shl_qn: QualifiedName,
    op_shr_qn: QualifiedName,
    index_index_qn: QualifiedName,
    index_assign_index_assign_qn: QualifiedName,
    convert_into_qn: QualifiedName,
    string_eq_qn: QualifiedName,
    vec_new_qn: QualifiedName,
    vec_push_qn: QualifiedName,
    range_range_qn: QualifiedName,
    util_panic_qn: QualifiedName,
    util_discriminator_qn: QualifiedName,
    util_uninitialized_qn: QualifiedName,
    transmute_qn: QualifiedName,
    array_as_ptr_qn: QualifiedName,
    ptr_offset_of_qn: QualifiedName,
    main_entry_qn: QualifiedName,
    console_print_qn: QualifiedName,
    console_println_qn: QualifiedName,
    console_flush_qn: QualifiedName,
    co_result_type_qn: QualifiedName,
    co_result_yielded_qn: QualifiedName,
    co_result_returned_qn: QualifiedName,
    co_result_completed_qn: QualifiedName,
    resume_qn: QualifiedName,
    into_iter_qn: QualifiedName,
    iterator_next_qn: QualifiedName,
}

fn m(s: String) -> I.String { I.intern(s) }

pub fn build_cache() -> BuiltinNameCache {
    let n_partial_eq = m("Std.Ops.PartialEq");
    let n_partial_ord = m("Std.Ops.PartialOrd");
    let n_ord = m("Std.Ops.Ord");
    let n_clone = m("Std.Ops.Clone");
    let n_from_int = m("Std.Ops.FromInt");
    let n_string = m("Std.String.String");
    let n_vec = m("Std.Vec.Vec");

    BuiltinNameCache(
        bool_type_qn: QualifiedName.new_enum(m("Std.Bool"), m("Bool")),
        bool_true_qn: QualifiedName.new_variant(m("Std.Bool"), m("Bool"), m("True")),
        bool_false_qn: QualifiedName.new_variant(m("Std.Bool"), m("Bool"), m("False")),
        int_type_qn: QualifiedName.new_struct(m("Std.Int"), m("Int")),
        i8_type_qn: QualifiedName.new_struct(m("Std.Int.I8"), m("I8")),
        i16_type_qn: QualifiedName.new_struct(m("Std.Int.I16"), m("I16")),
        i32_type_qn: QualifiedName.new_struct(m("Std.Int.I32"), m("I32")),
        i64_type_qn: QualifiedName.new_struct(m("Std.Int.I64"), m("I64")),
        u8_type_qn: QualifiedName.new_struct(m("Std.Int.U8"), m("U8")),
        u16_type_qn: QualifiedName.new_struct(m("Std.Int.U16"), m("U16")),
        u32_type_qn: QualifiedName.new_struct(m("Std.Int.U32"), m("U32")),
        u64_type_qn: QualifiedName.new_struct(m("Std.Int.U64"), m("U64")),
        string_type_qn: QualifiedName.new_struct(m("Std.String"), m("String")),
        array_type_qn: QualifiedName.new_struct(m("Std.Array"), m("Array")),
        option_type_qn: QualifiedName.new_enum(m("Std.Option"), m("Option")),
        option_some_qn: QualifiedName.new_variant(m("Std.Option"), m("Option"), m("Some")),
        option_none_qn: QualifiedName.new_variant(m("Std.Option"), m("Option"), m("None")),
        result_type_qn: QualifiedName.new_enum(m("Std.Result"), m("Result")),
        result_ok_qn: QualifiedName.new_variant(m("Std.Result"), m("Result"), m("Ok")),
        result_err_qn: QualifiedName.new_variant(m("Std.Result"), m("Result"), m("Err")),
        ordering_type_qn: QualifiedName.new_enum(m("Std.Ordering"), m("Ordering")),
        ordering_less_qn: QualifiedName.new_variant(m("Std.Ordering"), m("Ordering"), m("Less")),
        ordering_equal_qn: QualifiedName.new_variant(m("Std.Ordering"), m("Ordering"), m("Equal")),
        ordering_greater_qn: QualifiedName.new_variant(m("Std.Ordering"), m("Ordering"), m("Greater")),
        trait_partial_eq_qn: QualifiedName.new_trait(m("Std.Ops"), m("PartialEq")),
        trait_eq_qn: QualifiedName.new_trait(m("Std.Ops"), m("Eq")),
        trait_partial_ord_qn: QualifiedName.new_trait(m("Std.Ops"), m("PartialOrd")),
        trait_ord_qn: QualifiedName.new_trait(m("Std.Ops"), m("Ord")),
        trait_clone_qn: QualifiedName.new_trait(m("Std.Ops"), m("Clone")),
        trait_from_int_qn: QualifiedName.new_trait(m("Std.Ops"), m("FromInt")),
        op_eq_qn: QualifiedName.new_method(n_partial_eq, m("eq")),
        op_not_eq_qn: QualifiedName.new_method(n_partial_eq, m("not_eq")),
        op_partial_cmp_qn: QualifiedName.new_method(n_partial_ord, m("partial_cmp")),
        op_less_qn: QualifiedName.new_method(n_partial_ord, m("less_than")),
        op_greater_qn: QualifiedName.new_method(n_partial_ord, m("greater_than")),
        op_less_eq_qn: QualifiedName.new_method(n_partial_ord, m("less_than_or_equal")),
        op_greater_eq_qn: QualifiedName.new_method(n_partial_ord, m("greater_than_or_equal")),
        op_cmp_qn: QualifiedName.new_method(n_ord, m("cmp")),
        op_clone_qn: QualifiedName.new_method(n_clone, m("clone")),
        op_from_int_qn: QualifiedName.new_method(n_from_int, m("from_int")),
        op_add_qn: QualifiedName.new_method(m("Std.Ops.Add"), m("add")),
        op_sub_qn: QualifiedName.new_method(m("Std.Ops.Sub"), m("sub")),
        op_mul_qn: QualifiedName.new_method(m("Std.Ops.Mul"), m("mul")),
        op_div_qn: QualifiedName.new_method(m("Std.Ops.Div"), m("div")),
        op_neg_qn: QualifiedName.new_method(m("Std.Ops.Neg"), m("neg")),
        op_not_qn: QualifiedName.new_method(m("Std.Ops.Not"), m("not")),
        op_mod_qn: QualifiedName.new_method(m("Std.Ops.Mod"), m("mod")),
        op_band_qn: QualifiedName.new_method(m("Std.Ops.BitAnd"), m("band")),
        op_bor_qn: QualifiedName.new_method(m("Std.Ops.BitOr"), m("bor")),
        op_bxor_qn: QualifiedName.new_method(m("Std.Ops.BitXor"), m("bxor")),
        op_bnot_qn: QualifiedName.new_method(m("Std.Ops.BNot"), m("bnot")),
        op_shl_qn: QualifiedName.new_method(m("Std.Ops.Shl"), m("shl")),
        op_shr_qn: QualifiedName.new_method(m("Std.Ops.Shr"), m("shr")),
        index_index_qn: QualifiedName.new_method(m("Std.Ops.Index"), m("index")),
        index_assign_index_assign_qn: QualifiedName.new_method(m("Std.Ops.IndexAssign"), m("index_assign")),
        convert_into_qn: QualifiedName.new_method(m("Std.Convert.Into"), m("into")),
        string_eq_qn: QualifiedName.new_method(n_string, m("eq")),
        vec_new_qn: QualifiedName.new_method(n_vec, m("new")),
        vec_push_qn: QualifiedName.new_method(n_vec, m("push")),
        range_range_qn: QualifiedName.new_method(m("Std.Range.Range"), m("range")),
        util_panic_qn: QualifiedName.new_function(m("Std.Util"), m("panic")),
        util_discriminator_qn: QualifiedName.new_function(m("Std.Util"), m("discriminator")),
        util_uninitialized_qn: QualifiedName.new_function(m("Std.Util"), m("uninitialized")),
        transmute_qn: QualifiedName.new_function(m("Std.Intrinsics"), m("transmute")),
        array_as_ptr_qn: QualifiedName.new_function(m("Std.Array"), m("as_ptr")),
        ptr_offset_of_qn: QualifiedName.new_function(m("Std.Ptr"), m("offset_of")),
        main_entry_qn: QualifiedName.new_function(m("Main"), m("main")),
        console_print_qn: QualifiedName.new_function(m("Std.Console"), m("print")),
        console_println_qn: QualifiedName.new_function(m("Std.Console"), m("println")),
        console_flush_qn: QualifiedName.new_function(m("Std.Console"), m("flush")),
        co_result_type_qn: QualifiedName.new_enum(m("Std.Coroutine"), m("CoResult")),
        co_result_yielded_qn: QualifiedName.new_variant(m("Std.Coroutine"), m("CoResult"), m("Yielded")),
        co_result_returned_qn: QualifiedName.new_variant(m("Std.Coroutine"), m("CoResult"), m("Returned")),
        co_result_completed_qn: QualifiedName.new_variant(m("Std.Coroutine"), m("CoResult"), m("Completed")),
        resume_qn: QualifiedName.new_function(m("Std.Coroutine"), m("resume")),
        into_iter_qn: QualifiedName.new_method(m("Std.Iterator.IntoIterator"), m("into_iter")),
        iterator_next_qn: QualifiedName.new_method(m("Std.Iterator.Iterator"), m("next")),
    )
}

pub implicit name_cache: BuiltinNameCache

// Primitive types
pub fn get_bool_type_qn() -> QualifiedName { name_cache.bool_type_qn }
pub fn get_bool_true_qn() -> QualifiedName { name_cache.bool_true_qn }
pub fn get_bool_false_qn() -> QualifiedName { name_cache.bool_false_qn }
pub fn get_int_type_qn() -> QualifiedName { name_cache.int_type_qn }
