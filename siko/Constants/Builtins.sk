    ordering_greater: I.String,
    trait_partial_eq: I.String,
    trait_eq: I.String,
    trait_partial_ord: I.String,
    trait_ord: I.String,
    trait_clone: I.String,
    op_clone: I.String,
    op_cmp: I.String,
    op_band: I.String,
    op_bor: I.String,
    op_bxor: I.String,
    op_mod: I.String,
    op_shl: I.String,
    op_shr: I.String,
    op_bnot: I.String,
    op_add: I.String,
    op_sub: I.String,
    op_mul: I.String,
    op_div: I.String,
    op_neg: I.String,
    op_not: I.String,
    op_eq: I.String,
    op_not_eq: I.String,
    op_partial_cmp: I.String,
    op_less: I.String,
    op_greater: I.String,
    op_less_eq: I.String,
    op_greater_eq: I.String,
    string_eq: I.String,
    util_panic: I.String,
    vec_new: I.String,
    vec_push: I.String,
    index_index: I.String,
    index_assign_index_assign: I.String,
    siko_tuple: I.String,
    siko_closure: I.String,
    transmute: I.String,
    util_discriminator: I.String,
    util_uninitialized: I.String,
    array_type: I.String,
    trait_from_int: I.String,
    op_from_int: I.String,
    range_range: I.String,
    convert_into: I.String,
}

pub fn build_cache() -> BuiltinNameCache {
    BuiltinNameCache(
        bool_type: I.intern(get_bool_type_str()),
        bool_true: I.intern(get_bool_true_str()),
        bool_false: I.intern(get_bool_false_str()),
        int_type: I.intern(get_int_type_str()),
        i8_type: I.intern(get_i8_type_str()),
        i16_type: I.intern(get_i16_type_str()),
        i32_type: I.intern(get_i32_type_str()),
        i64_type: I.intern(get_i64_type_str()),
        u8_type: I.intern(get_u8_type_str()),
        u16_type: I.intern(get_u16_type_str()),
        u32_type: I.intern(get_u32_type_str()),
        u64_type: I.intern(get_u64_type_str()),
        string_type: I.intern(get_string_type_str()),
        option_type: I.intern(get_option_type_str()),
        option_some: I.intern(get_option_some_str()),
        option_none: I.intern(get_option_none_str()),
        result_type: I.intern(get_result_type_str()),
        result_ok: I.intern(get_result_ok_str()),
        result_err: I.intern(get_result_err_str()),
        ordering_type: I.intern(get_ordering_type_str()),
        ordering_less: I.intern(get_ordering_less_str()),
        ordering_equal: I.intern(get_ordering_equal_str()),
        ordering_greater: I.intern(get_ordering_greater_str()),
        trait_partial_eq: I.intern(get_trait_partial_eq_str()),
        trait_eq: I.intern(get_trait_eq_str()),
        trait_partial_ord: I.intern(get_trait_partial_ord_str()),
        trait_ord: I.intern(get_trait_ord_str()),
        trait_clone: I.intern(get_trait_clone_str()),
        op_clone: I.intern(get_op_clone_str()),
        op_cmp: I.intern(get_op_cmp_str()),
        op_band: I.intern(get_op_band_str()),
        op_bor: I.intern(get_op_bor_str()),
        op_bxor: I.intern(get_op_bxor_str()),
        op_mod: I.intern(get_op_mod_str()),
        op_shl: I.intern(get_op_shl_str()),
        op_shr: I.intern(get_op_shr_str()),
        op_bnot: I.intern(get_op_bnot_str()),
        op_add: I.intern(get_op_add_str()),
        op_sub: I.intern(get_op_sub_str()),
        op_mul: I.intern(get_op_mul_str()),
        op_div: I.intern(get_op_div_str()),
        op_neg: I.intern(get_op_neg_str()),
        op_not: I.intern(get_op_not_str()),
        op_eq: I.intern(get_op_eq_str()),
        op_not_eq: I.intern(get_op_not_eq_str()),
        op_partial_cmp: I.intern(get_op_partial_cmp_str()),
        op_less: I.intern(get_op_less_str()),
        op_greater: I.intern(get_op_greater_str()),
        op_less_eq: I.intern(get_op_less_eq_str()),
        op_greater_eq: I.intern(get_op_greater_eq_str()),
        string_eq: I.intern(get_string_eq_str()),
        util_panic: I.intern(get_util_panic_str()),
        vec_new: I.intern(get_vec_new_str()),
        vec_push: I.intern(get_vec_push_str()),
        index_index: I.intern(get_index_index_str()),
        index_assign_index_assign: I.intern(get_index_assign_index_assign_str()),
        siko_tuple: I.intern(get_siko_tuple_str()),
        siko_closure: I.intern(get_siko_closure_str()),
        transmute: I.intern(get_transmute_str()),
        util_discriminator: I.intern(get_util_discriminator_str()),
        util_uninitialized: I.intern(get_util_uninitialized_str()),
        array_type: I.intern(get_array_type_str()),
        trait_from_int: I.intern(get_trait_from_int_str()),
        op_from_int: I.intern(get_op_from_int_str()),
        range_range: I.intern(get_range_range_str()),
        convert_into: I.intern(get_convert_into_str()),
    )
}

