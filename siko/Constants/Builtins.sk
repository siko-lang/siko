module Siko.Constants.Builtins {

import Siko.Interner as I

pub struct BuiltinNameCache {
    bool_type: I.String,
    bool_true: I.String,
    bool_false: I.String,
    int_type: I.String,
    i8_type: I.String,
    i16_type: I.String,
