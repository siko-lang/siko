pub fn get_u32_type_qn() -> QualifiedName { name_cache.u32_type_qn }
pub fn get_u64_type_qn() -> QualifiedName { name_cache.u64_type_qn }
pub fn get_string_type_qn() -> QualifiedName { name_cache.string_type_qn }
pub fn get_array_type_qn() -> QualifiedName { name_cache.array_type_qn }

// Option
pub fn get_option_type_qn() -> QualifiedName { name_cache.option_type_qn }
