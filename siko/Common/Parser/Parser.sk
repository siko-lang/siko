module Siko.Parser.Parser {

import Siko.Parser.Token
import Siko.Parser.Lexer
import Siko.Location
import Siko.AST.Module
import Siko.Parser.Module
import Siko.AST.Identifier
import Siko.FileManager
import Std.Fs.File
import Siko.Package.Collector as PC

pub struct ParseError {
    pub message: String,
    pub pos: Int,

    pub fn new(message: String, pos: Int) -> ParseError {
        ParseError(message, pos)
    }
}

pub struct Parser {
    pub tokens: Vec[Token],
    pub pos: Int,
    pub file_id: Int,
    pub source_package: PC.SourcePackage,

    pub fn new(tokens: Vec[Token], file_id: Int, source_package: PC.SourcePackage) -> Parser {
        Parser(tokens, 0, file_id, source_package)
    }

    pub fn current(parser: Parser) -> Token {
        parser.tokens[parser.pos]
    }

    pub fn peek(parser: Parser) -> TokenKind {
        parser.tokens[parser.pos].kind
    }

    pub fn peek_next(parser: Parser) -> TokenKind {
        let next = parser.pos + 1;
        if next < parser.tokens.len() {
            parser.tokens[next].kind
        } else {
            TokenKind.Eof
        }
    }

    pub fn advance(parser: Parser) {
        if parser.pos + 1 < parser.tokens.len() {
            parser.pos += 1;
        }
    }

    pub fn cur_pos(parser: Parser) -> Int {
        parser.tokens[parser.pos].start
    }

    pub fn loc(parser: Parser, start: Int, end: Int) -> Location {
        Location.new(parser.file_id, Span(start, end))
    }

    pub fn expect(parser: Parser, kind: TokenKind) -> Result[(), ParseError] {
        if parser.peek() == kind {
            parser.advance();
            Ok(())
        } else {
            Err(ParseError.new(
                "expected ${kind}, got ${parser.peek()}",
                parser.cur_pos(),
            ))
        }
    }

    pub fn expect_type_ident(parser: Parser) -> Result[Identifier, ParseError] {
        match parser.peek() {
            TokenKind.TypeIdentifier(name) => {
                let start = parser.current().start;
                let end = parser.current().end;
                parser.advance();
                let location = parser.loc(start, end);
                Ok(Identifier.new(name, location))
            }
            _ => Err(ParseError.new(
                "expected type identifier, got ${parser.peek()}",
                parser.cur_pos(),
            )),
        }
    }

    pub fn expect_var_ident(parser: Parser) -> Result[Identifier, ParseError] {
        match parser.peek() {
            TokenKind.VarIdentifier(name) => {
                let start = parser.current().start;
                let end = parser.current().end;
                parser.advance();
                let location = parser.loc(start, end);
                Ok(Identifier.new(name, location))
            }
            _ => Err(ParseError.new(
                "expected variable identifier, got ${parser.peek()}",
                parser.cur_pos(),
            )),
        }
    }

    pub fn expect_ident(parser: Parser) -> Result[Identifier, ParseError] {
        match parser.peek() {
            TokenKind.TypeIdentifier(name) | TokenKind.VarIdentifier(name) => {
                let start = parser.current().start;
                let end = parser.current().end;
                parser.advance();
                let location = parser.loc(start, end);
                Ok(Identifier.new(name, location))
            }
            _ => Err(ParseError.new(
                "expected identifier, got ${parser.peek()}",
                parser.cur_pos(),
            )),
        }
    }

    pub fn parse_dotted_name(parser: Parser) -> Result[Identifier, ParseError] {
        let ident = parser.expect_type_ident()?;
        while parser.peek() == TokenKind.Dot {
            parser.advance();
            let next = parser.expect_type_ident()?;
            ident = ident.merge(next);
        }
        Ok(ident)
    }

    pub fn parse_expr_dotted_name(parser: Parser) -> Result[Identifier, ParseError] {
        let ident = parser.expect_ident()?;
        while parser.peek() == TokenKind.Dot {
            parser.advance();
            let next = parser.expect_ident()?;
            ident = ident.merge(next);
        }
        Ok(ident)
    }
}

pub struct ParserError {
    pub message: String,
    pub location: Location,
}

pub fn parse_files(packages: Vec[PC.SourcePackage]) -> (Vec[Module], Vec[ParserError]) {
    let all_modules = Vec.new();
    let errors = Vec.new();
    for pkg in packages {
        for path in pkg.files {
            match read_file(path) {
                Err(_) => {
                    println("error: could not read file: " + path);
                }
                Ok(contents) => {
                    let file_id = Siko.FileManager.add(path, contents);
                    match tokenize(contents) {
                        Err(e) => {
                            errors.push(ParserError(message: e.message, location: Location.new(file_id, Span(e.pos, e.pos+1))));
                        }
                        Ok(tokens) => {
                            let parser = Parser.new(tokens, file_id, pkg);
                            match parser.parse_program() {
                                Err(e) => {
                                    errors.push(ParserError(message: e.message, location: Location.new(file_id, Span(e.pos, e.pos+1))));
                                }
                                Ok(program) => {
                                    for m in program.modules {
                                        all_modules.push(m);
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
    (all_modules, errors)
}

}