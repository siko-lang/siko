module Siko.Typechecker.Sanity {

import Std.Set
import Siko.AST.Expr
import Siko.AST.Function
import Siko.AST.Identifier
import Siko.AST.Name
import Siko.AST.Pattern
import Siko.AST.QualifiedName
import Siko.AST.Statement as S
import Siko.AST.Type
import Siko.Interner as I
import Siko.Location
import Siko.Typechecker.Error
import Siko.Unification.Utils

// ── Check trait ───────────────────────────────────────────────────────────────

trait Check[T] {
    fn check(t: T, ctx: SanityChecker)
}

instance Check[Location]          = auto2(Fold, =)
instance Check[TypeDef]           = auto2(Fold, =)
instance Check[I.String]          = auto2(Fold, =)
instance Check[String]            = auto2(Fold, =)
instance Check[Int]               = auto2(Fold, =)
instance Check[AtomicOrdering]    = auto2(Fold, =)
instance Check[AtomicRmwOp]       = auto2(Fold, =)
instance Check[U8]                = auto2(Fold, =)
instance Check[QualifiedName]     = auto2(Fold, =)
instance Check[VariableName]      = auto2(Fold, =)
instance Check[Name]              = auto2(Fold, =)
instance Check[Identifier]        = auto2(Fold, =)
instance Check[FunctionKind]      = auto2(Fold, =)
instance Check[BinaryOp]          = auto2(Fold, =)
instance Check[UnaryOp]           = auto2(Fold, =)
instance Check[WitnessInfo]       = auto2(Fold, =)
instance Check[HandlerSelection]  = auto2(Fold, =)
instance Check[ImplicitRefInfo]   = auto2(Fold, =)
instance Check[CreateClosureInfo] = auto2(Fold, =)
instance Check[FunctionPtrInfo]   = auto2(Fold, =)
instance Check[LambdaArg]         = auto2(Fold, =)

instance Check[FunctionCallInfo]        = auto2(Fold)
instance Check[TypeAssociatedCallInfo]  = auto2(Fold)
instance Check[NamedArgument]           = auto2(Fold, =)
instance Check[Bool]                 = auto2(Fold, =)
instance Check[NamedPatternArg]      = auto2(Fold, =)
instance Check[NamedPatternInfo]     = auto2(Fold)
instance Check[MethodCallInfo]    = auto2(Fold)
instance Check[CallInfo]          = auto2(Fold)
instance Check[MatchInfo]         = auto2(Fold)
instance Check[YieldInfo]         = auto2(Fold)
instance Check[BlockInfo]         = auto2(Fold)
instance Check[MatchArm]          = auto2(Fold)
instance Check[WithInfo]          = auto2(Fold)
instance Check[ExprKind]          = auto2(Fold)
instance Check[PatternKind]       = auto2(Fold)

instance[T: Check[T]] Check[Option[T]] {
    fn check(opt: Option[T], ctx: SanityChecker) {
        if let Some(t) = opt { check(t, ctx); }
    }
}

instance[T: Check[T]] Check[Vec[T]] {
    fn check(vec: Vec[T], ctx: SanityChecker) {
        for t in vec { check(t, ctx); }
    }
}

instance Check[Expr] {
    fn check(expr: Expr, ctx: SanityChecker) {
        match expr.ty {
            Some(ty) => ctx.check_ty(ty, expr.location),
            None => ctx.errors.push(TypeError.AmbiguousType(expr.location)),
        }
        check(expr.kind, ctx);
    }
}

instance Check[Pattern] {
    fn check(pattern: Pattern, ctx: SanityChecker) {
        match pattern.kind {
            PatternKind.Typed(inner, ty) => {
                check(inner, ctx);
                ctx.check_ty(ty, pattern.location);
            }
            other => check(other, ctx),
        }
    }
}

instance Check[S.LetInfo] {
    fn check(info: S.LetInfo, ctx: SanityChecker) {
        if let Some(ty) = info.ty {
            ctx.check_ty(ty, info.rhs.location);
        }
        check(info.rhs, ctx);
    }
}

instance Check[S.DeclareInfo] {
    fn check(info: S.DeclareInfo, ctx: SanityChecker) {
        if let Some(ty) = info.ty {
            ctx.check_ty(ty, ctx.fallback_loc);
        }
    }
}

instance Check[S.Statement] = auto2(Fold)

// ── SanityChecker ─────────────────────────────────────────────────────────────

struct SanityChecker {
    valid: Set[I.String],
    errors: Vec[TypeError],
    fallback_loc: Location,

    fn check_ty(ctx: SanityChecker, ty: TypeDef, loc: Location) {
        let fail = False;
        let vars = collect_type_vars(ty);
        for v in vars {
            match v {
                TypeVar.Named(n) => {
                    if !ctx.valid.contains(n) {
                        fail = True;
                    }
                }
                TypeVar.Var(_) => {
                    fail = True;
                }
            }
        }
        if fail {
            ctx.errors.push(TypeError.AmbiguousType(loc));
        }
    }
}

pub fn sanity_check(func: FunctionDef) -> Vec[TypeError] {
    let params = match func.type_arg_defs {
        Some(tad) => tad.type_params(),
        None => Vec.new(),
    };
    let valid: Set[I.String] = params.iter().collect();
    let errors = Vec.new();
    match func.body {
        Some(body) => {
            let ctx = SanityChecker(valid, errors, body.location);
            check(body, ctx);
        }
        None => {}
    }
    errors
}

}
