module Siko.Typechecker.Finalize {

import Std.Map
import Siko.AST.Expr
import Siko.AST.Function
import Siko.AST.Identifier
import Siko.AST.Name
import Siko.AST.Pattern
import Siko.AST.QualifiedName
import Siko.AST.Statement as S
import Siko.AST.Type
import Siko.HIR.Program
import Siko.Instances.FunctionInstanceResolver
import Siko.Interner as I
import Siko.Location
import Siko.Typechecker.Constraints
import Siko.Unification.Sub
import Siko.Constants.Builtins as B

pub struct CallResolution {
    pub result_var: Int,
    pub qname: QualifiedName,
    pub kind: FunctionKind,
    pub trait_object: Option[QualifiedName],
}

// ── Finalize trait ────────────────────────────────────────────────────────────

trait Finalize[T] {
    fn finalize(t: T, f: Finalizer) -> T
}

instance Finalize[TypeDef] {
    fn finalize(ty: TypeDef, f: Finalizer) -> TypeDef {
        f.sub.apply(ty)
    }
}

instance Finalize[Location]      = auto2(Map, =)
instance Finalize[I.String]      = auto2(Map, =)
instance Finalize[String]        = auto2(Map, =)
instance Finalize[Int]           = auto2(Map, =)
instance Finalize[AtomicOrdering] = auto2(Map, =)
instance Finalize[AtomicRmwOp]   = auto2(Map, =)
instance Finalize[U8]            = auto2(Map, =)
instance Finalize[QualifiedName] = auto2(Map, =)
instance Finalize[VariableName]  = auto2(Map, =)
instance Finalize[Name]          = auto2(Map, =)
instance Finalize[Identifier]    = auto2(Map, =)
instance Finalize[FunctionKind]  = auto2(Map, =)
instance Finalize[BinaryOp]      = auto2(Map, =)
instance Finalize[UnaryOp]       = auto2(Map, =)
instance Finalize[WitnessInfo]   = auto2(Map, =)
instance Finalize[ImplicitRefInfo]  = auto2(Map, =)
instance Finalize[CreateClosureInfo] = auto2(Map, =)
instance Finalize[FunctionPtrInfo]   = auto2(Map, =)

instance Finalize[LambdaArg]    = auto2(Map)
instance Finalize[FunctionCallInfo]        = auto2(Map)
instance Finalize[TypeAssociatedCallInfo]  = auto2(Map)
instance Finalize[NamedArgument]           = auto2(Map, =)
instance Finalize[Bool]              = auto2(Map, =)
instance Finalize[NamedPatternArg]   = auto2(Map, =)
instance Finalize[NamedPatternInfo]  = auto2(Map)
instance Finalize[MethodCallInfo]   = auto2(Map)
instance Finalize[CallInfo]         = auto2(Map)
instance Finalize[MatchInfo]    = auto2(Map)
instance Finalize[YieldInfo]    = auto2(Map)
instance Finalize[MatchArm]     = auto2(Map)
instance Finalize[WithInfo]     = auto2(Map)
instance Finalize[Pattern]      = auto2(Map)
instance Finalize[PatternKind]  = auto2(Map)
instance Finalize[BlockInfo]    = auto2(Map)
instance Finalize[ExprKind]     = auto2(Map)

instance Finalize[Expr] {
    fn finalize(expr: Expr, f: Finalizer) -> Expr {
        f.finalize_expr(expr)
    }
}

instance Finalize[HandlerSelection] {
    fn finalize(sel: HandlerSelection, f: Finalizer) -> HandlerSelection {
        match sel {
            // Attach the witnesses resolved at typecheck for the handler's
            // bounds (anchored to the handler's location).
            HandlerSelection.EffectFunction(method, handler, location, _) => {
                let witnesses = f.collect_witnesses(WitnessKey.Handler(location, 0));
                HandlerSelection.EffectFunction(method, handler, location, witnesses)
            }
            // Attach the witnesses resolved at typecheck for the EAT's bounds.
            HandlerSelection.TypeAssociation(assoc, ty, location, _) => {
                let witnesses = f.collect_witnesses(WitnessKey.Handler(location, 0));
                HandlerSelection.TypeAssociation(assoc, ty, location, witnesses)
            }
            other => other,
        }
    }
}

instance[T: Finalize[T]] Finalize[Option[T]] {
    fn finalize(opt: Option[T], f: Finalizer) -> Option[T] {
        opt.map(|t| finalize(t, f))
    }
}

instance[T: Finalize[T]] Finalize[Vec[T]] {
    fn finalize(vec: Vec[T], f: Finalizer) -> Vec[T] {
        vec.into_iter().map(|t| finalize(t, f)).collect()
    }
}

instance Finalize[S.LetInfo] {
    fn finalize(info: S.LetInfo, f: Finalizer) -> S.LetInfo {
        let new_rhs = finalize(info.rhs, f);
        S.LetInfo(info.name, new_rhs.ty, new_rhs)
    }
}

instance Finalize[S.DeclareInfo] = auto2(Map)

instance Finalize[S.Statement] {
    fn finalize(stmt: S.Statement, f: Finalizer) -> S.Statement {
        f.finalize_stmt(stmt)
    }
}

// ── Helpers ───────────────────────────────────────────────────────────────────

fn build_array_elem_ptr(container: Expr, idx: Expr, container_ty: TypeDef, elem_ty: TypeDef) -> Expr {
    let loc = container.location;
    let ptr_array_ty = TypeDef.Ptr(container_ty);
    let ptr_elem_ty = TypeDef.Ptr(elem_ty);
    let addr_of = Expr(ExprKind.AddrOf(container), loc, Some(ptr_array_ty));
    let as_ptr_call = Expr(ExprKind.FunctionCall(FunctionCallInfo(
        B.get_array_as_ptr_qn(),
        FunctionKind.UserDefined,
        [addr_of],
        WitnessInfo.new(),
        Vec.new(),
        False,
    )), loc, Some(ptr_elem_ty));
    Expr(ExprKind.FunctionCall(FunctionCallInfo(
        B.get_ptr_offset_of_qn(),
        FunctionKind.UserDefined,
        [as_ptr_call, idx],
        WitnessInfo.new(),
        Vec.new(),
        False,
    )), loc, Some(ptr_elem_ty))
}

// ── Finalizer ─────────────────────────────────────────────────────────────────

pub struct Finalizer {
    pub sub: Substitution,
    pub program: Program,
    pub method_resolutions: Map[Int, CallResolution],
    pub field_resolutions: Map[Int, Int],
    pub witness_map: Map[WitnessKey, BoundWitness],

    pub fn new(
        sub: Substitution,
        program: Program,
        method_resolutions: Map[Int, CallResolution],
        field_resolutions: Map[Int, Int],
        witness_map: Map[WitnessKey, BoundWitness],
    ) -> Finalizer {
        Finalizer(
            sub: sub,
            program: program,
            method_resolutions: method_resolutions,
            field_resolutions: field_resolutions,
            witness_map: witness_map,
        )
    }

    fn never_return_ty(f: Finalizer, qname: QualifiedName) -> Option[TypeDef] {
        match f.program.functions.get(qname) {
            None => None,
            Some(func) => match func.result_type {
                Some(TypeDef.Never(explicit)) => Some(TypeDef.Never(explicit)),
                _ => None,
            }
        }
    }

    pub fn finalize_function(f: Finalizer, func: FunctionDef) -> FunctionDef {
        let body = match func.body {
            None => return func,
            Some(b) => b,
        };
        let result = func;
        result.body = Some(f.finalize_expr(body));
        result
    }

    fn apply_ty(f: Finalizer, ty: Option[TypeDef]) -> Option[TypeDef] {
        match ty {
            Some(t) => Some(f.sub.apply(t)),
            None => None,
        }
    }

    fn result_var(f: Finalizer, expr: Expr) -> Int {
        match expr.ty {
            Some(TypeDef.Var(TypeVar.Var(n))) => n,
            _ => panic("finalize: expr.ty is not a bare flex var"),
        }
    }

    fn build_witnesses(f: Finalizer, result_var: Int) -> WitnessInfo {
        f.collect_witnesses(WitnessKey.Call(result_var, 0))
    }

    // Collect the consecutive witnesses for a key, starting at bound_index 0.
    // `start` supplies the key shape (Call or Handler); we walk bound_index up.
    fn collect_witnesses(f: Finalizer, start: WitnessKey) -> WitnessInfo {
        let witnesses = Vec.new();
        let idx = 0;
        while True {
            let key = match start {
                WitnessKey.Call(v, _) => WitnessKey.Call(v, idx),
                WitnessKey.Handler(loc, _) => WitnessKey.Handler(loc, idx),
            };
            match f.witness_map.get(key) {
                Some(bw) => {
                    witnesses.push(bw);
                    idx = idx + 1;
                }
                None => break,
            }
        }
        WitnessInfo(witnesses)
    }

    fn inject_default_args(f: Finalizer, qname: QualifiedName, args: Vec[Expr], loc: Location) -> Vec[Expr] {
        if let Some(func) = f.program.functions.get(qname) {
            for i in args.len() .. func.args.len() {
                let dv = func.default_value_names.iter().find(|dv| dv.index == i).unwrap();
                let default_func = f.program.functions.get(dv.name).unwrap();
                let default_ty = f.sub.apply(default_func.result_type.unwrap());
                args.push(Expr(
                    ExprKind.FunctionCall(FunctionCallInfo(
                        dv.name,
                        FunctionKind.UserDefined,
                        Vec.new(),
                        WitnessInfo.new(),
                        Vec.new(),
                        False,
                    )),
                    loc,
                    Some(default_ty),
                ));
            }
        }
        args
    }

    fn inject_ctor_default_args(f: Finalizer, qname: QualifiedName, args: Vec[Expr], loc: Location) -> Vec[Expr] {
        if let Some(struct_def) = f.program.structs.get(qname) {
            for i in args.len() .. struct_def.fields.len() {
                let dv = struct_def.default_value_names.iter().find(|dv| dv.index == i).unwrap();
                let default_func = f.program.functions.get(dv.name).unwrap();
                let default_ty = f.sub.apply(default_func.result_type.unwrap());
                args.push(Expr(
                    ExprKind.FunctionCall(FunctionCallInfo(
                        dv.name,
                        FunctionKind.UserDefined,
                        Vec.new(),
                        WitnessInfo.new(),
                        Vec.new(),
                        False,
                    )),
                    loc,
                    Some(default_ty),
                ));
            }
        }
        args
    }

    fn finalize_expr(f: Finalizer, expr: Expr) -> Expr {
        let ty = f.apply_ty(expr.ty);
        let loc = expr.location;

        match expr.kind {
            ExprKind.FieldAccess(receiver, field_name, _) => {
                let result_var = f.result_var(expr);
                let receiver = f.finalize_expr(receiver);
                let field_index = f.field_resolutions.get(result_var).expect("finalize: field access has no solver resolution");
                Expr(ExprKind.FieldAccess(receiver, field_name, Some(field_index)), loc, ty)
            }

            ExprKind.MethodCall(MethodCallInfo(receiver, _method, args, _named_args)) => {
                let result_var = f.result_var(expr);
                let cr = f.method_resolutions.get(result_var).unwrap();
                let witnesses = f.build_witnesses(result_var);
                let new_args = Vec.new();
                new_args.push(f.finalize_expr(receiver));
                for a in args { new_args.push(f.finalize_expr(a)); }
                let new_args = f.inject_default_args(cr.qname, new_args, loc);
                let call_ty = match f.never_return_ty(cr.qname) {
                    Some(t) => Some(t),
                    None => ty,
                };
                let call = FunctionCallInfo(cr.qname, cr.kind, new_args, witnesses, Vec.new(), False);
                match cr.trait_object {
                    Some(trait_qname) => Expr(ExprKind.TraitObjectCall(trait_qname, call), loc, call_ty),
                    None => Expr(ExprKind.FunctionCall(call), loc, call_ty),
                }
            }

            ExprKind.FunctionCall(FunctionCallInfo(qname, kind, args, _, named_args, is_co)) => {
                let new_args = finalize(args, f);
                if qname.base_name() == B.get_util_downcast_qn() {
                    let value = new_args[0];
                    let trait_qname = match value.ty.unwrap() {
                        TypeDef.Named(NamedInfo(Name.Resolved(name: trait_qname, ..), _)) => trait_qname,
                        _ => panic("finalize: validated downcast receiver is not a trait object"),
                    };
                    let target_ty = match ty.unwrap() {
                        TypeDef.Named(NamedInfo(Name.Resolved(name: option_qname, ..), args))
                            if option_qname.base_name() == B.get_option_type_qn() => args[0],
                        _ => panic("finalize: downcast result is not Option[T]"),
                    };
                    return Expr(
                        ExprKind.TraitObjectDowncast(trait_qname, value, target_ty),
                        loc,
                        ty,
                    );
                }
                match kind {
                    FunctionKind.UserDefined | FunctionKind.Extern(_) | FunctionKind.Builtin => {
                        let new_args = f.inject_default_args(qname, new_args, loc);
                        let result_var = f.result_var(expr);
                        let witnesses = f.build_witnesses(result_var);
                        // Trait calls are left intact for the monomorphizer, which
                        // performs trait -> concrete instance dispatch uniformly
                        // (and fills the instance's context-bound witnesses).
                        let call_ty = match f.never_return_ty(qname) {
                            Some(t) => Some(t),
                            None => ty,
                        };
                        let call = FunctionCallInfo(qname, kind, new_args, witnesses, named_args, is_co);
                        match f.method_resolutions.get(result_var).and_then(|cr| cr.trait_object) {
                            Some(trait_qname) => Expr(ExprKind.TraitObjectCall(trait_qname, call), loc, call_ty),
                            None => Expr(ExprKind.FunctionCall(call), loc, call_ty),
                        }
                    }
                    FunctionKind.StructCtor => {
                        let new_args = f.inject_ctor_default_args(qname, new_args, loc);
                        Expr(ExprKind.FunctionCall(FunctionCallInfo(qname, kind, new_args, WitnessInfo.new(), named_args, is_co)), loc, ty)
                    }
                    FunctionKind.VariantCtor =>
                        Expr(ExprKind.FunctionCall(FunctionCallInfo(qname, kind, new_args, WitnessInfo.new(), named_args, is_co)), loc, ty),
                }
            }

            ExprKind.Index(container, idx) => {
                let result_var = f.result_var(expr);
                let finalized_container = f.finalize_expr(container);
                let finalized_idx = f.finalize_expr(idx);
                let container_ty = finalized_container.ty.unwrap();
                match container_ty {
                    TypeDef.Named(NamedInfo(Name.Resolved(name: qname, ..), type_args)) if qname.base_name() == B.get_array_type_qn() => {
                        let elem_ty = type_args[0];
                        let ptr = build_array_elem_ptr(finalized_container, finalized_idx, container_ty, elem_ty);
                        Expr(ExprKind.Deref(ptr), loc, Some(elem_ty))
                    }
                    _ => {
                        let witnesses = f.build_witnesses(result_var);
                        Expr(ExprKind.FunctionCall(FunctionCallInfo(
                            B.get_index_index_qn(),
                            FunctionKind.UserDefined,
                            [finalized_container, finalized_idx],
                            witnesses,
                            Vec.new(),
                            False,
                        )), loc, ty)
                    }
                }
            }

            ExprKind.FunctionPtr(info) => {
                let result_var = f.result_var(expr);
                let witnesses = f.build_witnesses(result_var);
                Expr(ExprKind.FunctionPtr(FunctionPtrInfo(info.name, witnesses)), loc, ty)
            }

            ExprKind.DynamicCall(callee, args) => {
                let new_callee = f.finalize_expr(callee);
                let new_args: Vec[_] = args.into_iter().map(|a| f.finalize_expr(a)).collect();
                match new_callee.ty {
                    Some(TypeDef.FnPtr(_, _)) =>
                        Expr(ExprKind.FunctionPtrCall(new_callee, new_args), loc, ty),
                    _ =>
                        Expr(ExprKind.DynamicCall(new_callee, new_args), loc, ty),
                }
            }

            ExprKind.TypeAssociatedCall(TypeAssociatedCallInfo(type_def, fn_name, args, _, named_args)) => {
                let result_var = f.result_var(expr);
                let witnesses = f.build_witnesses(result_var);
                let new_args = Vec.new();
                for a in args { new_args.push(f.finalize_expr(a)); }
                let new_args = f.inject_default_args(fn_name, new_args, loc);
                let type_def = finalize(type_def, f);
                Expr(ExprKind.TypeAssociatedCall(TypeAssociatedCallInfo(type_def, fn_name, new_args, witnesses, named_args)), loc, ty)
            }

            ExprKind.TraitObjectPack(trait_qname, value, _) => {
                let result_var = f.result_var(expr);
                let witnesses = f.build_witnesses(result_var);
                Expr(
                    ExprKind.TraitObjectPack(trait_qname, f.finalize_expr(value), witnesses),
                    loc,
                    ty,
                )
            }

            ExprKind.TraitObjectCall(_, _) =>
                panic("finalize: TraitObjectCall before finalization"),

            ExprKind.TraitObjectCarrierPack(_, _) | ExprKind.TraitObjectDowncast(_, _, _) =>
                panic("finalize: lowered trait-object carrier node before finalization"),

            kind => Expr(kind.finalize(f), loc, ty),
        }
    }

    fn finalize_stmt(f: Finalizer, stmt: S.Statement) -> S.Statement {
        match stmt {
            S.Let(info) => S.Let(finalize(info, f)),
            S.Declare(info) => S.Declare(finalize(info, f)),
            S.Assign(lhs, rhs) => {
                match lhs.kind {
                    ExprKind.Index(container, idx) => {
                        let assign_var = match lhs.ty {
                            Some(TypeDef.Var(TypeVar.Var(n))) => n,
                            _ => panic("finalize: index-assign lhs must have flex var ty"),
                        };
                        let finalized_container = f.finalize_expr(container);
                        let finalized_idx = f.finalize_expr(idx);
                        let finalized_rhs = f.finalize_expr(rhs);
                        let container_ty = finalized_container.ty.unwrap();
                        match container_ty {
                            TypeDef.Named(NamedInfo(Name.Resolved(name: qname, ..), type_args)) if qname.base_name() == B.get_array_type_qn() => {
                                let elem_ty = type_args[0];
                                let ptr = build_array_elem_ptr(finalized_container, finalized_idx, container_ty, elem_ty);
                                S.Assign(Expr(ExprKind.Deref(ptr), lhs.location, Some(elem_ty)), finalized_rhs)
                            }
                            _ => {
                                let witnesses = f.build_witnesses(assign_var);
                                S.Expr(Expr(ExprKind.FunctionCall(FunctionCallInfo(
                                    B.get_index_assign_index_assign_qn(),
                                    FunctionKind.UserDefined,
                                    [finalized_container, finalized_idx, finalized_rhs],
                                    witnesses,
                                    Vec.new(),
                                    False,
                                )), lhs.location, Some(TypeDef.Tuple(Vec.new()))))
                            }
                        }
                    }
                    _ => S.Assign(f.finalize_expr(lhs), f.finalize_expr(rhs)),
                }
            }
            S.Expr(e) => S.Expr(finalize(e, f)),
            S.TrailingExpr(e) => S.TrailingExpr(finalize(e, f)),
            S.Loop(block) => S.Loop(finalize(block, f)),
            _ => panic("finalize: unexpected statement kind"),
        }
    }
}

}
