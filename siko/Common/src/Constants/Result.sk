module Siko.Constants.Result {

import Siko.AST.QualifiedName
import Siko.Constants.Util

pub struct ResultNames {
    pub type_qn: QualifiedName,
    pub ok_qn: QualifiedName,
    pub err_qn: QualifiedName,
}

pub fn build_result_names() -> ResultNames {
    ResultNames(
        type_qn: QualifiedName.new_enum(m("Std.Result"), m("Result")),
        ok_qn: QualifiedName.new_variant(m("Std.Result"), m("Result"), m("Ok")),
        err_qn: QualifiedName.new_variant(m("Std.Result"), m("Result"), m("Err")),
    )
}

}
