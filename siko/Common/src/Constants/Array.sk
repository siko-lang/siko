module Siko.Constants.Array {

import Siko.AST.QualifiedName
import Siko.Constants.Util

pub struct ArrayNames {
    pub type_qn: QualifiedName,
    pub as_ptr_qn: QualifiedName,
}

pub fn build_array_names() -> ArrayNames {
    ArrayNames(
        type_qn: QualifiedName.new_struct(m("Std.Array"), m("Array")),
        as_ptr_qn: QualifiedName.new_function(m("Std.Array"), m("as_ptr")),
    )
}

}
