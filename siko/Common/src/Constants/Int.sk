module Siko.Constants.Int {

import Siko.AST.QualifiedName
import Siko.Constants.Util

pub struct IntegerNames {
    pub int_: IntegerTypeNames,
    pub i8: IntegerTypeNames,
    pub i16: IntegerTypeNames,
    pub i32: IntegerTypeNames,
    pub i64: IntegerTypeNames,
    pub u8: IntegerTypeNames,
    pub u16: IntegerTypeNames,
    pub u32: IntegerTypeNames,
    pub u64: IntegerTypeNames,
}

pub struct IntegerTypeNames {
    pub type_qn: QualifiedName,
    pub eq_qn: QualifiedName,
}

fn build_integer_type_names(module_name: String, type_name: String, parent_name: String) -> IntegerTypeNames {
    IntegerTypeNames(
        type_qn: QualifiedName.new_struct(m(module_name), m(type_name)),
        eq_qn: QualifiedName.new_method(m(parent_name), m("eq")),
    )
}

pub fn build_integer_names() -> IntegerNames {
    IntegerNames(
        int_: build_integer_type_names("Std.Int", "Int", "Std.Int.Int"),
        i8: build_integer_type_names("Std.Int.I8", "I8", "Std.Int.I8.I8"),
        i16: build_integer_type_names("Std.Int.I16", "I16", "Std.Int.I16.I16"),
        i32: build_integer_type_names("Std.Int.I32", "I32", "Std.Int.I32.I32"),
        i64: build_integer_type_names("Std.Int.I64", "I64", "Std.Int.I64.I64"),
        u8: build_integer_type_names("Std.Int.U8", "U8", "Std.Int.U8.U8"),
        u16: build_integer_type_names("Std.Int.U16", "U16", "Std.Int.U16.U16"),
        u32: build_integer_type_names("Std.Int.U32", "U32", "Std.Int.U32.U32"),
        u64: build_integer_type_names("Std.Int.U64", "U64", "Std.Int.U64.U64"),
    )
}

}
