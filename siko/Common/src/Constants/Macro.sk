module Siko.Constants.Macro {

import Siko.AST.QualifiedName
import Siko.Constants.Util
import Siko.Interner as I

pub struct MacroNames {
    pub debug_println_qn: QualifiedName,
    pub resolve_trait_builtin_qn: QualifiedName,
    pub resolve_function_builtin_qn: QualifiedName,
    pub resolve_variant_builtin_qn: QualifiedName,
    pub resolve_type_builtin_qn: QualifiedName,
    pub struct_def_qn: QualifiedName,
    pub enum_def_qn: QualifiedName,
    pub trait_def_qn: QualifiedName,
    pub trait_method_def_qn: QualifiedName,
    pub qualified_name_qn: QualifiedName,
    pub type_def_qn: QualifiedName,
    pub type_parameter_qn: QualifiedName,
    pub field_def_qn: QualifiedName,
    pub variant_item_def_qn: QualifiedName,
    pub variant_def_qn: QualifiedName,
    pub instance_header_qn: QualifiedName,
    pub instance_body_qn: QualifiedName,
    pub instance_def_qn: QualifiedName,
    pub instance_bound_qn: QualifiedName,
    pub function_variable_qn: QualifiedName,
    pub function_expr_kind_qn: QualifiedName,
    pub function_expr_variable_qn: QualifiedName,
    pub function_expr_field_access_qn: QualifiedName,
    pub function_expr_call_qn: QualifiedName,
    pub function_expr_tuple_qn: QualifiedName,
    pub function_expr_if_qn: QualifiedName,
    pub function_expr_match_qn: QualifiedName,
    pub function_expr_sequence_qn: QualifiedName,
    pub function_expr_string_literal_qn: QualifiedName,
    pub function_expr_integer_literal_qn: QualifiedName,
    pub function_expr_return_qn: QualifiedName,
    pub function_expr_let_qn: QualifiedName,
    pub function_expr_qn: QualifiedName,
    pub function_argument_qn: QualifiedName,
    pub function_def_qn: QualifiedName,
    pub function_pattern_kind_qn: QualifiedName,
    pub function_pattern_binding_qn: QualifiedName,
    pub function_pattern_tuple_qn: QualifiedName,
    pub function_pattern_variant_qn: QualifiedName,
    pub function_pattern_integer_qn: QualifiedName,
    pub function_pattern_wildcard_qn: QualifiedName,
    pub function_pattern_string_literal_qn: QualifiedName,
    pub function_pattern_qn: QualifiedName,
    pub function_match_arm_qn: QualifiedName,
    pub context_qn: QualifiedName,
    pub target_qn: QualifiedName,
    pub target_struct_qn: QualifiedName,
    pub target_enum_qn: QualifiedName,
    pub symbol_qn: QualifiedName,
    pub symbol_equals_qn: QualifiedName,
    pub symbol_bang_qn: QualifiedName,
    pub arg_qn: QualifiedName,
    pub arg_name_qn: QualifiedName,
    pub arg_text_qn: QualifiedName,
    pub arg_integer_qn: QualifiedName,
    pub arg_symbol_qn: QualifiedName,
    pub error_qn: QualifiedName,
    pub error_not_supported_qn: QualifiedName,
    pub derive_struct_name: I.String,
    pub derive_enum_name: I.String,
    pub external_derive_struct_name: I.String,
    pub external_derive_enum_name: I.String,
    pub generated_variable_name: I.String,
}

pub fn build_macro_names() -> MacroNames {
    let module_name = m("Std.Macro");
    let reflection_module = m("Std.Macro.Reflection");
    let function_builder_module = m("Std.Macro.FunctionBuilder");
    let context_qn = QualifiedName.new_struct(module_name, m("MacroContext"));
    MacroNames(
        debug_println_qn: QualifiedName.new_function(m("Std.Macro.Debug"), m("println")),
        resolve_trait_builtin_qn: QualifiedName.new_function(module_name, m("resolve_trait_builtin")),
        resolve_function_builtin_qn: QualifiedName.new_function(module_name, m("resolve_function_builtin")),
        resolve_variant_builtin_qn: QualifiedName.new_function(module_name, m("resolve_variant_builtin")),
        resolve_type_builtin_qn: QualifiedName.new_function(module_name, m("resolve_type_builtin")),
        struct_def_qn: QualifiedName.new_struct(reflection_module, m("StructDef")),
        enum_def_qn: QualifiedName.new_struct(reflection_module, m("EnumDef")),
        trait_def_qn: QualifiedName.new_struct(reflection_module, m("TraitDef")),
        trait_method_def_qn: QualifiedName.new_struct(reflection_module, m("TraitMethodDef")),
        qualified_name_qn: QualifiedName.new_struct(reflection_module, m("QualifiedName")),
        type_def_qn: QualifiedName.new_struct(reflection_module, m("TypeDef")),
        type_parameter_qn: QualifiedName.new_struct(reflection_module, m("TypeParameter")),
        field_def_qn: QualifiedName.new_struct(reflection_module, m("FieldDef")),
        variant_item_def_qn: QualifiedName.new_struct(reflection_module, m("VariantItemDef")),
        variant_def_qn: QualifiedName.new_struct(reflection_module, m("VariantDef")),
        instance_header_qn: QualifiedName.new_struct(module_name, m("InstanceHeader")),
        instance_body_qn: QualifiedName.new_struct(module_name, m("InstanceBody")),
        instance_def_qn: QualifiedName.new_struct(module_name, m("InstanceDef")),
        instance_bound_qn: QualifiedName.new_struct(module_name, m("InstanceBound")),
        function_variable_qn: QualifiedName.new_struct(function_builder_module, m("VariableRef")),
        function_expr_kind_qn: QualifiedName.new_enum(function_builder_module, m("ExprKind")),
        function_expr_variable_qn: QualifiedName.new_variant(function_builder_module, m("ExprKind"), m("Variable")),
        function_expr_field_access_qn: QualifiedName.new_variant(function_builder_module, m("ExprKind"), m("FieldAccess")),
        function_expr_call_qn: QualifiedName.new_variant(function_builder_module, m("ExprKind"), m("Call")),
        function_expr_tuple_qn: QualifiedName.new_variant(function_builder_module, m("ExprKind"), m("Tuple")),
        function_expr_if_qn: QualifiedName.new_variant(function_builder_module, m("ExprKind"), m("If")),
        function_expr_match_qn: QualifiedName.new_variant(function_builder_module, m("ExprKind"), m("Match")),
        function_expr_sequence_qn: QualifiedName.new_variant(function_builder_module, m("ExprKind"), m("Sequence")),
        function_expr_string_literal_qn: QualifiedName.new_variant(function_builder_module, m("ExprKind"), m("StringLiteral")),
        function_expr_integer_literal_qn: QualifiedName.new_variant(function_builder_module, m("ExprKind"), m("IntegerLiteral")),
        function_expr_return_qn: QualifiedName.new_variant(function_builder_module, m("ExprKind"), m("Return")),
        function_expr_let_qn: QualifiedName.new_variant(function_builder_module, m("ExprKind"), m("Let")),
        function_expr_qn: QualifiedName.new_struct(function_builder_module, m("Expr")),
        function_argument_qn: QualifiedName.new_struct(function_builder_module, m("FunctionArgument")),
        function_def_qn: QualifiedName.new_struct(function_builder_module, m("FunctionDef")),
        function_pattern_kind_qn: QualifiedName.new_enum(function_builder_module, m("PatternKind")),
        function_pattern_binding_qn: QualifiedName.new_variant(function_builder_module, m("PatternKind"), m("Binding")),
        function_pattern_tuple_qn: QualifiedName.new_variant(function_builder_module, m("PatternKind"), m("Tuple")),
        function_pattern_variant_qn: QualifiedName.new_variant(function_builder_module, m("PatternKind"), m("Variant")),
        function_pattern_integer_qn: QualifiedName.new_variant(function_builder_module, m("PatternKind"), m("Integer")),
        function_pattern_wildcard_qn: QualifiedName.new_variant(function_builder_module, m("PatternKind"), m("Wildcard")),
        function_pattern_string_literal_qn: QualifiedName.new_variant(function_builder_module, m("PatternKind"), m("StringLiteral")),
        function_pattern_qn: QualifiedName.new_struct(function_builder_module, m("Pattern")),
        function_match_arm_qn: QualifiedName.new_struct(function_builder_module, m("MatchArm")),
        context_qn: context_qn,
        target_qn: QualifiedName.new_enum(module_name, m("MacroTarget")),
        target_struct_qn: QualifiedName.new_variant(module_name, m("MacroTarget"), m("Struct")),
        target_enum_qn: QualifiedName.new_variant(module_name, m("MacroTarget"), m("Enum")),
        symbol_qn: QualifiedName.new_enum(module_name, m("MacroSymbol")),
        symbol_equals_qn: QualifiedName.new_variant(module_name, m("MacroSymbol"), m("Equals")),
        symbol_bang_qn: QualifiedName.new_variant(module_name, m("MacroSymbol"), m("Bang")),
        arg_qn: QualifiedName.new_enum(module_name, m("MacroArg")),
        arg_name_qn: QualifiedName.new_variant(module_name, m("MacroArg"), m("Name")),
        arg_text_qn: QualifiedName.new_variant(module_name, m("MacroArg"), m("Text")),
        arg_integer_qn: QualifiedName.new_variant(module_name, m("MacroArg"), m("Integer")),
        arg_symbol_qn: QualifiedName.new_variant(module_name, m("MacroArg"), m("Symbol")),
        error_qn: QualifiedName.new_enum(module_name, m("MacroError")),
        error_not_supported_qn: QualifiedName.new_variant(module_name, m("MacroError"), m("NotSupported")),
        derive_struct_name: m("derive_struct"),
        derive_enum_name: m("derive_enum"),
        external_derive_struct_name: m("external_derive_struct"),
        external_derive_enum_name: m("external_derive_enum"),
        generated_variable_name: m("macro_var"),
    )
}

}
