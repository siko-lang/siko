module Siko.HIR.Program {

import Std.Map
import Std.Set
import Siko.AST.QualifiedName
import Siko.AST.Data
import Siko.AST.Traits
import Siko.AST.Instances
import Siko.AST.Function
import Siko.AST.Effects
import Siko.AST.Implicits
import Siko.AST.Type
import Siko.Format.Utils
import Siko.Interner as I
import Siko.Instances.InstanceResolver
import Std.StringBuilder

@derive(Clone)
pub struct Program {
    pub structs: Map[QualifiedName, StructDef],
    pub enums: Map[QualifiedName, EnumDef],
    pub variant_enum_map: Map[QualifiedName, QualifiedName],
    pub traits: Map[QualifiedName, TraitDef],
    pub named_instances: Map[QualifiedName, InstanceDef],
    pub canonical_instances: Vec[InstanceDef],
    pub all_instances: Map[QualifiedName, InstanceDef],
    pub functions: Map[QualifiedName, FunctionDef],
    pub effects: Map[QualifiedName, EffectDef],
    pub effect_associated_types: Map[QualifiedName, AssociatedTypeDef],
    pub implicits: Map[QualifiedName, ImplicitDef],
    pub entry_points: Vec[QualifiedName],
    pub module_names: Vec[I.String],
    pub module_instance_imports: Map[I.String, Vec[QualifiedName]],
    pub module_trait_method_map: Map[I.String, Map[I.String, Vec[QualifiedName]]],
    pub instance_resolver: InstanceResolver,

    pub fn new() -> Program {
        Program(
            structs: Map.new(),
            enums: Map.new(),
            variant_enum_map: Map.new(),
            traits: Map.new(),
            named_instances: Map.new(),
            canonical_instances: Vec.new(),
            all_instances: Map.new(),
            functions: Map.new(),
            effects: Map.new(),
            effect_associated_types: Map.new(),
            implicits: Map.new(),
            entry_points: Vec.new(),
            module_names: Vec.new(),
            module_instance_imports: Map.new(),
            module_trait_method_map: Map.new(),
            instance_resolver: InstanceResolver.empty(),
        )
    }

    pub fn struct_def(program: Program, qname: QualifiedName) -> StructDef {
        program.structs.get(qname).unwrap()
    }

    pub fn enum_def(program: Program, qname: QualifiedName) -> EnumDef {
        program.enums.get(qname).unwrap()
    }

    pub fn variant(program: Program, variant_qname: QualifiedName) -> VariantDef {
        let enum_qname = program.variant_enum_map.get(variant_qname).expect("variant enum not found");
        let enum_def = program.enums.get(enum_qname).expect("enum not found");
        for variant in enum_def.variants {
            if variant.qualified_name.unwrap() == variant_qname {
                return variant;
            }
        }
        panic("variant not found")
    }

    pub fn find_variant(program: Program, variant_qname: QualifiedName) -> (QualifiedName, Vec[TypeDef], Vec[I.String]) {
        let enum_qname = program.variant_enum_map.get(variant_qname).expect("variant enum not found");
        let enum_def = program.enums.get(enum_qname).expect("enum not found");
        let type_params = match enum_def.type_arg_defs {
            Some(tad) => tad.type_params(),
            None => Vec.new(),
        };
        for variant in enum_def.variants {
            if variant.qualified_name.unwrap() == variant_qname {
                return (enum_qname, variant.items.iter().map(|i| i.ty).collect(), type_params);
            }
        }
        panic("variant not found")
    }

    pub fn format(program: Program) -> String {
        let out = StringBuilder.new();
        for def in program.structs.values() {
            out.push(format_struct(def));
            out.push("\n");
        }
        for def in program.enums.values() {
            out.push(format_enum(def));
            out.push("\n");
        }
        for def in program.traits.values() {
            out.push(format_trait(def));
            out.push("\n");
        }
        for def in program.named_instances.values() {
            out.push(format_instance(def));
            out.push("\n");
        }
        for def in program.canonical_instances {
            out.push(format_instance(def));
            out.push("\n");
        }
        for def in program.functions.values() {
            out.push(format_fn(def));
            out.push("\n");
        }
        for def in program.effects.values() {
            out.push(format_effect(def));
            out.push("\n");
        }
        out.push(program.instance_resolver.format());
        out.to_string()
    }

    pub fn get_divergent_functions(program: Program) -> Set[QualifiedName] {
        let div_fns: Set[QualifiedName] = Set.new();
        for (name, func) in program.functions {
            match func.result_type {
                Some(TypeDef.Never(_)) => { div_fns.insert(name); }
                _ => {}
            }
        }
        div_fns
    }
}

}
