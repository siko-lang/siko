module Siko.AST.Instances {

import Siko.Location
import Siko.AST.Function
import Siko.AST.Generics
import Siko.AST.Identifier
import Siko.AST.Name
import Siko.AST.Type
import Siko.AST.QualifiedName
import Siko.AST.Annotations
import Siko.Interner as I
import Siko.Resolver.Error
import Siko.Format.Utils

@derive(Clone, PartialEq, Eq)
pub enum InstanceKind {
    Unresolved(Name),
    Trait(Name),
    Effect(Name),

    pub fn trait_name(kind: InstanceKind) -> Name {
        match kind {
            InstanceKind.Trait(name) => name,
            _ => panic("expected Trait InstanceKind"),
        }
    }

    pub fn try_trait_name(kind: InstanceKind) -> Result[Name, ResolveError] {
        match kind {
            InstanceKind.Trait(name) => Ok(name),
            InstanceKind.Effect(name) => Err(ResolveError.NotATraitInstance(name.name(), name.location())),
            InstanceKind.Unresolved(name) => Err(ResolveError.NotATraitInstance(name.name(), name.location())),
        }
    }

    pub fn try_effect_name(kind: InstanceKind) -> Option[Name] {
        match kind {
            InstanceKind.Effect(name) => Some(name),
            _ => None,
        }
    }
}

@derive(Clone, PartialEq, Eq)
pub struct TypeAssignment {
    pub name: Identifier,
    pub ty: TypeDef,
}

@derive(Clone, PartialEq, Eq)
pub enum ExternalDeriveMode {
    Map,
    Fold,
}

@derive(Clone, PartialEq, Eq)
pub enum FnName {
    Inferred,
    Explicit(Name),
}

@derive(Clone, PartialEq, Eq)
pub enum BodyStrategy {
    Generate,
    Identity,
    Unreachable,
}

@derive(Clone, PartialEq, Eq)
pub struct ExternalDeriveParams {
    pub mode: ExternalDeriveMode,
    pub fn_name: FnName,
    pub body: BodyStrategy,
}

@derive(Clone, PartialEq, Eq)
pub struct ExternalDerivedInstanceInfo {
    pub params: Option[ExternalDeriveParams],
}

@derive(Clone, PartialEq, Eq)
pub struct InstanceDef {
    pub annotations: Vec[Annotation],
    pub public: Bool,
    pub name: Option[Identifier],
    pub qualified_name: Option[QualifiedName],
    pub type_arg_defs: Option[TypeArgDefs],
    pub subject: InstanceKind,
    pub args: Vec[TypeDef],
    pub type_assignments: Vec[TypeAssignment],
    pub methods: Vec[FunctionDef],
    pub module_name: I.String,
    pub method_names: Vec[Identifier],
    pub location: Location,
    pub external_derived_instance_info: Option[ExternalDerivedInstanceInfo],

    pub fn synth_name(instance_def: InstanceDef) -> Result[Identifier, ResolveError] {
        let trait_name = instance_def.subject.try_trait_name()?;
        let trait_fqn = I.resolve(trait_name.name());
        let args_rendered = format_types(instance_def.args);
        Ok(Identifier.new(I.intern("${trait_fqn}#[${args_rendered}]"), instance_def.location))
    }

    pub fn get_instance_name(instance_def: InstanceDef) -> Result[Identifier, ResolveError] {
        match instance_def.name {
            Some(name) => Ok(name),
            None => instance_def.synth_name(),
        }
    }
}

}
