module Siko.AST.Annotations {

import Siko.AST.Expr as E
import Siko.Interner as I
import Siko.AST.Macros

@derive(Clone, PartialEq, Eq)
pub enum OpKind {
    BinaryOp(E.BinaryOp)
    UnaryOp(E.UnaryOp)
}

@derive(Clone, PartialEq, Eq)
pub enum Annotation {
    ExternC,
    Rename(I.String),
    Prelude,
    Generic(I.String),
    Builtin,
    Op(OpKind),
    ValueType,
    Packed,
    Safe,
    Unsafe,
    Pure,
    CCallback,
    Test,
    // The function's signature types that are structurally identical alias
    // each other's closure content (used for functions whose bodies launder
    // pointers through integers, where closure flow is uninferable).
    ClosureAlias,
    // @interpreter_test(foo) on a struct: compile function `foo` (resolved in
    // the annotating module) through lowering and execute it with Interpreter.
    InterpreterTest(I.String),
    Derive(AttachedMacroApplication),

    pub fn is_extern(a: Annotation) -> Bool {
        match a {
            Annotation.ExternC => True,
            _ => False,
        }
    }

    pub fn rename(a: Annotation) -> Option[I.String] {
        match a {
            Annotation.Rename(name) => Some(name),
            _ => None,
        }
    }

    pub fn is_prelude(a: Annotation) -> Bool {
        match a {
            Annotation.Prelude => True,
            _ => False,
        }
    }

    pub fn is_builtin(a: Annotation) -> Bool {
        match a {
            Annotation.Builtin => True,
            _ => False,
        }
    }

    pub fn is_binary_op(a: Annotation) -> Option[E.BinaryOp] {
        match a {
            Annotation.Op(OpKind.BinaryOp(op)) => Some(op),
            _ => None,
        }
    }

    pub fn is_unary_op(a: Annotation) -> Option[E.UnaryOp] {
        match a {
            Annotation.Op(OpKind.UnaryOp(op)) => Some(op),
            _ => None,
        }
    }

    pub fn is_value_type(a: Annotation) -> Bool {
        match a {
            Annotation.ValueType => True,
            _ => False,
        }
    }

    pub fn is_packed(a: Annotation) -> Bool {
        match a {
            Annotation.Packed => True,
            _ => False,
        }
    }

    pub fn is_safe(a: Annotation) -> Bool {
        match a {
            Annotation.Safe => True,
            _ => False,
        }
    }

    pub fn is_unsafe(a: Annotation) -> Bool {
        match a {
            Annotation.Unsafe => True,
            _ => False,
        }
    }

    pub fn is_pure(a: Annotation) -> Bool {
        match a {
            Annotation.Pure => True,
            _ => False,
        }
    }

    pub fn is_c_callback(a: Annotation) -> Bool {
        match a {
            Annotation.CCallback => True,
            _ => False,
        }
    }

    pub fn is_test(a: Annotation) -> Bool {
        match a {
            Annotation.Test => True,
            _ => False,
        }
    }

    pub fn is_closure_alias(a: Annotation) -> Bool {
        match a {
            Annotation.ClosureAlias => True,
            _ => False,
        }
    }

    pub fn interpreter_test_name(a: Annotation) -> Option[I.String] {
        match a {
            Annotation.InterpreterTest(name) => Some(name),
            _ => None,
        }
    }
}

}
