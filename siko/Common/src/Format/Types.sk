module Siko.Format.Types {

import Siko.AST.Type
import Siko.Format.Formatter
import Siko.Interner as I

pub fn format_type_var(f: Formatter, var: TypeVar) {
    match var {
        TypeVar.Named(n) => f.push(I.resolve(n)),
        TypeVar.Var(n) => {
            f.push("$");
            f.push(n.to_string());
        }
    }
}

pub fn format_type_def(f: Formatter, ty: TypeDef) {
    match ty {
        TypeDef.Named(NamedInfo(name, args)) => {
            f.push(I.resolve(name.name()));
            if !args.is_empty() {
                f.push("[");
                let i = 0;
                for arg in args {
                    if i > 0 {
                        f.push(", ");
                    }
                    format_type_def(f, arg);
                    i = i + 1;
                }
                f.push("]");
            }
        }
        TypeDef.Tuple(types) => {
            f.push("(");
            let i = 0;
            for ty in types {
                if i > 0 {
                    f.push(", ");
                }
                format_type_def(f, ty);
                i = i + 1;
            }
            f.push(")");
        }
        TypeDef.Paren(inner) => {
            f.push("(");
            format_type_def(f, inner);
            f.push(")");
        }
        TypeDef.Var(v) => {
            format_type_var(f, v);
        }
        TypeDef.Fn(ClosureInfo(args, result, var)) => {
            let needs_paren = var.is_some();
            if needs_paren {
                f.push("(");
            }
            f.push("fn(");
            let i = 0;
            for arg in args {
                if i > 0 {
                    f.push(", ");
                }
                format_type_def(f, arg);
                i = i + 1;
            }
            f.push(") -> ");
            format_type_def(f, result);
            if let Some(var) = var {
                f.push("/");
                format_type_var(f, var);
            }
            if needs_paren {
                f.push(")");
            }
        }
        TypeDef.FnPtr(args, result) => {
            f.push("fn*(");
            let i = 0;
            for arg in args {
                if i > 0 {
                    f.push(", ");
                }
                format_type_def(f, arg);
                i = i + 1;
            }
            f.push(") -> ");
            format_type_def(f, result);
        }
        TypeDef.Ptr(inner) => {
            f.push("*");
            format_type_def(f, inner);
        }
        TypeDef.Never(_) => {
            f.push("!");
        }
        TypeDef.Wildcard => {
            f.push("_");
        }
        TypeDef.Void => {
            f.push("void");
        }
        TypeDef.VoidPtr => {
            f.push("void*");
        }
        TypeDef.Array(inner, n) => {
            f.push("[");
            format_type_def(f, inner);
            f.push("; ${n}]");
        }
        TypeDef.Numeric(n) => {
            f.push("${n}");
        }
        TypeDef.Co(CoroutineInfo(yield_ty, return_ty)) => {
            f.push("co(");
            format_type_def(f, yield_ty);
            f.push(") -> ");
            format_type_def(f, return_ty);
        }
    }
}

}
