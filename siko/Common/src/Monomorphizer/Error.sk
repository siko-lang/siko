module Siko.Monomorphizer.Error {

import Siko.Location
import Siko.Interner as I
import Siko.AST.QualifiedName

@derive(Clone)
pub enum MonoError {
    EntryPointNotFound(QualifiedName),
    UnresolvedEffectHandler(I.String, Location),
    UnsetImplicit(I.String, Location),
    UnboundEffectAssociatedType(I.String, Location),
}

}
