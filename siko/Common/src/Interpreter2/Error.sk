module Siko.Interpreter2.Error {

import Siko.Location

pub struct FrameInfo {
    pub name: String,
    pub location: Location,
}

pub enum ErrorKind {
    Panic(String),
    WrongArgCount(String, Int, Int),
    UninitializedRead,
    DivisionByZero,
    NullDeref,
    StackOverflow,
    Internal(String),
}

pub struct InterpreterError {
    pub kind: ErrorKind,
    pub location: Location,
    pub backtrace: Vec[FrameInfo],
}

pub fn error(kind: ErrorKind, location: Location) -> InterpreterError {
    InterpreterError(kind, location, Vec.new())
}

pub fn format_error(e: InterpreterError) -> String {
    let message = match e.kind {
        ErrorKind.Panic(msg) => "compile-time code panicked: ${msg}",
        ErrorKind.WrongArgCount(name, expected, got) =>
            "compile-time execution failed: `${name}` expects ${expected} arguments, got ${got}",
        ErrorKind.UninitializedRead =>
            "compile-time execution failed: read of uninitialized value",
        ErrorKind.DivisionByZero =>
            "compile-time execution failed: division by zero",
        ErrorKind.NullDeref =>
            "compile-time execution failed: null pointer dereference",
        ErrorKind.StackOverflow =>
            "compile-time execution failed: interpreter call depth limit exceeded",
        ErrorKind.Internal(msg) =>
            "compile-time execution failed: internal interpreter error: ${msg}",
    };
    let i = e.backtrace.len() - 1;
    while i >= 0 {
        message = message + "\n  in ${e.backtrace[i].name}";
        i -= 1;
    }
    message
}

}
