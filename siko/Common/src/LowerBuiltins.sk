// ── Rewrite trait ─────────────────────────────────────────────────────────────

trait Rewrite[T] {
    fn rewrite(t: T, ctx: BuiltinLowerer) -> T
}

instance Rewrite[TypeDef] {
    fn rewrite(ty: TypeDef, ctx: BuiltinLowerer) -> TypeDef { ty }
}

instance Rewrite[Location]      = auto2(Map, =)
instance Rewrite[I.String]      = auto2(Map, =)
instance Rewrite[String]        = auto2(Map, =)
instance Rewrite[Int]           = auto2(Map, =)
instance Rewrite[U8]            = auto2(Map, =)
instance Rewrite[Bool]          = auto2(Map, =)
instance Rewrite[QualifiedName] = auto2(Map, =)
instance Rewrite[VariableName]  = auto2(Map, =)
instance Rewrite[Name]          = auto2(Map, =)
instance Rewrite[Identifier]    = auto2(Map, =)
instance Rewrite[FunctionKind]  = auto2(Map, =)
instance Rewrite[BinaryOp]      = auto2(Map, =)
instance Rewrite[UnaryOp]       = auto2(Map, =)
instance Rewrite[AtomicOrdering] = auto2(Map, =)
instance Rewrite[AtomicRmwOp]    = auto2(Map, =)
instance Rewrite[WitnessInfo]   = auto2(Map, =)
instance Rewrite[HandlerSelection] = auto2(Map, =)
instance Rewrite[ImplicitRefInfo]  = auto2(Map, =)
instance Rewrite[CreateClosureInfo] = auto2(Map, =)
instance Rewrite[FunctionPtrInfo]   = auto2(Map, =)
instance Rewrite[LambdaArg]     = auto2(Map, =)
instance Rewrite[TypeArgDefs]   = auto2(Map, =)
instance Rewrite[MethodMap]     = auto2(Map, =)
instance Rewrite[FunctionArg]   = auto2(Map)
instance Rewrite[Pattern]       = auto2(Map)
instance Rewrite[PatternKind]   = auto2(Map)
instance Rewrite[FunctionCallInfo]         = auto2(Map)
instance Rewrite[TypeAssociatedCallInfo]   = auto2(Map, !)
instance Rewrite[NamedArgument]            = auto2(Map, =)
instance Rewrite[NamedPatternArg]    = auto2(Map, =)
instance Rewrite[NamedPatternInfo]   = auto2(Map)
instance Rewrite[MethodCallInfo]   = auto2(Map)
instance Rewrite[CallInfo]         = auto2(Map)
instance Rewrite[WithInfo]      = auto2(Map)
instance Rewrite[MatchArm]      = auto2(Map)
instance Rewrite[S.LetInfo]     = auto2(Map)
instance Rewrite[S.DeclareInfo] = auto2(Map)
instance Rewrite[S.Statement]   = auto2(Map)
instance Rewrite[MatchInfo]     = auto2(Map)
instance Rewrite[YieldInfo]     = auto2(Map)
instance Rewrite[ExprKind]      = auto2(Map)

instance Rewrite[BlockInfo] {
    fn rewrite(block: BlockInfo, ctx: BuiltinLowerer) -> BlockInfo {
        let out = Vec.new();
        for stmt in block.stmts {
            if let S.Statement.Let(S.LetInfo(name, ty, Expr(ExprKind.FunctionCall(FunctionCallInfo(qn, FunctionKind.Builtin, args, _, _, _)), loc, expr_ty))) = stmt {
                if qn.base_name() == B.get_util_uninitialized_qn() {
                    out.push(S.Statement.Declare(S.DeclareInfo(name, ty.or(expr_ty))));
                    continue;
                }
                if let Some(op) = ctx.comparison_op(qn) {
                    ctx.emit_comparison(out, name, ty.or(expr_ty), op, args.rewrite(ctx), loc);
                    continue;
                }
            }
            out.push(stmt.rewrite(ctx));
        }
        BlockInfo(out)
    }
}


instance[T: Rewrite[T]] Rewrite[Option[T]] {
    fn rewrite(opt: Option[T], ctx: BuiltinLowerer) -> Option[T] {
        opt.map(|t| rewrite(t, ctx))
    }
}

instance[T: Rewrite[T]] Rewrite[Vec[T]] {
    fn rewrite(vec: Vec[T], ctx: BuiltinLowerer) -> Vec[T] {
        vec.into_iter().map(|t| rewrite(t, ctx)).collect()
    }
}

instance Rewrite[Expr] {
    fn rewrite(expr: Expr, ctx: BuiltinLowerer) -> Expr {
        let loc = expr.location.clone();
        let ty = expr.ty.clone();
        match expr.kind {
            ExprKind.FunctionCall(FunctionCallInfo(qn, FunctionKind.Builtin, args, _, _, is_co)) => {
                let args = args.rewrite(ctx);
                if qn.base_name() == B.get_macro_debug_println_qn() {
                    report("Std.Macro.Debug.println is only available in compile-time interpreted code", Some(loc));
                    return Expr(ExprKind.FunctionCall(FunctionCallInfo(
                        qname: qn,
                        kind: FunctionKind.Builtin,
                        args: args,
                        witnesses: WitnessInfo.new(),
                        named_args: Vec.new(),
                        is_coroutine_create: is_co,
                    )), loc, ty);
                }
                if let Some(kind) = ctx.lower_atomic_intrinsic(qn, args) {
                    return Expr(kind, loc, ty);
                }
                if qn.base_name() == B.get_transmute_qn() {
                    let arg = args[0];
                    return Expr(ExprKind.Transmute(arg), loc, ty);
                }
                if qn.base_name() == B.get_util_discriminator_qn() {
                    let arg = args[0];
                    return Expr(ExprKind.Discriminator(arg), loc, ty);
                }
                if let Some(fdef) = ctx.program.functions.get(qn) {
                    if let Some(op) = fdef.is_binary_op() {
                        // Comparisons produce a Bool from the raw 0/1 and are
                        // handled in statement position (Rewrite[BlockInfo]);
                        // post-normalizer they cannot appear anywhere else.
                        match op {
                            BinaryOp.Eq | BinaryOp.Less =>
                                panic("lower-builtins: builtin comparison in value position"),
                            _ => {}
                        }
                        let lhs = args[0];
                        let rhs = args[1];
                        return Expr(ExprKind.BinaryOp(op, lhs, rhs), loc, ty);
                    }
                    if let Some(op) = fdef.is_unary_op() {
                        let operand = args[0];
                        return Expr(ExprKind.UnaryOp(op, operand), loc, ty);
                    }
                }
                Expr(ExprKind.FunctionCall(FunctionCallInfo(
                    qname: qn,
                    kind: FunctionKind.Builtin,
                    args: args,
                    witnesses: WitnessInfo.new(),
                    named_args: Vec.new(),
                    is_coroutine_create: is_co,
                )), loc, ty)
            }
            kind => Expr(kind.rewrite(ctx), loc, ty)
        }
    }
}

// ── BuiltinLowerer ────────────────────────────────────────────────────────────

struct BuiltinLowerer {
    program: Program,
    label_alloc: LabelAllocator,
    int_ty: TypeDef,

    fn lower_atomic_intrinsic(ctx: BuiltinLowerer, qn: QualifiedName, args: Vec[Expr]) -> Option[ExprKind] {
        let qn = qn.base_name();
        if qn == B.get_atomic_load_relaxed_qn() { return Some(ExprKind.AtomicLoad(args[0], AtomicOrdering.Relaxed)); }
        if qn == B.get_atomic_load_acquire_qn() { return Some(ExprKind.AtomicLoad(args[0], AtomicOrdering.Acquire)); }
        if qn == B.get_atomic_load_seqcst_qn() { return Some(ExprKind.AtomicLoad(args[0], AtomicOrdering.SeqCst)); }

        if qn == B.get_atomic_store_relaxed_qn() { return Some(ExprKind.AtomicStore(args[0], args[1], AtomicOrdering.Relaxed)); }
        if qn == B.get_atomic_store_release_qn() { return Some(ExprKind.AtomicStore(args[0], args[1], AtomicOrdering.Release)); }
        if qn == B.get_atomic_store_seqcst_qn() { return Some(ExprKind.AtomicStore(args[0], args[1], AtomicOrdering.SeqCst)); }

        if qn == B.get_atomic_swap_relaxed_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Xchg, AtomicOrdering.Relaxed)); }
        if qn == B.get_atomic_swap_release_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Xchg, AtomicOrdering.Release)); }
        if qn == B.get_atomic_swap_acquire_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Xchg, AtomicOrdering.Acquire)); }
        if qn == B.get_atomic_swap_acqrel_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Xchg, AtomicOrdering.AcqRel)); }
        if qn == B.get_atomic_swap_seqcst_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Xchg, AtomicOrdering.SeqCst)); }

        if qn == B.get_atomic_fetch_add_relaxed_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Add, AtomicOrdering.Relaxed)); }
        if qn == B.get_atomic_fetch_add_release_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Add, AtomicOrdering.Release)); }
        if qn == B.get_atomic_fetch_add_acquire_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Add, AtomicOrdering.Acquire)); }
        if qn == B.get_atomic_fetch_add_acqrel_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Add, AtomicOrdering.AcqRel)); }
        if qn == B.get_atomic_fetch_add_seqcst_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Add, AtomicOrdering.SeqCst)); }

        if qn == B.get_atomic_fetch_sub_relaxed_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Sub, AtomicOrdering.Relaxed)); }
        if qn == B.get_atomic_fetch_sub_release_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Sub, AtomicOrdering.Release)); }
        if qn == B.get_atomic_fetch_sub_acquire_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Sub, AtomicOrdering.Acquire)); }
        if qn == B.get_atomic_fetch_sub_acqrel_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Sub, AtomicOrdering.AcqRel)); }
        if qn == B.get_atomic_fetch_sub_seqcst_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Sub, AtomicOrdering.SeqCst)); }

        if qn == B.get_atomic_fetch_and_relaxed_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.And, AtomicOrdering.Relaxed)); }
        if qn == B.get_atomic_fetch_and_release_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.And, AtomicOrdering.Release)); }
        if qn == B.get_atomic_fetch_and_acquire_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.And, AtomicOrdering.Acquire)); }
        if qn == B.get_atomic_fetch_and_acqrel_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.And, AtomicOrdering.AcqRel)); }
        if qn == B.get_atomic_fetch_and_seqcst_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.And, AtomicOrdering.SeqCst)); }

        if qn == B.get_atomic_fetch_or_relaxed_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Or, AtomicOrdering.Relaxed)); }
        if qn == B.get_atomic_fetch_or_release_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Or, AtomicOrdering.Release)); }
        if qn == B.get_atomic_fetch_or_acquire_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Or, AtomicOrdering.Acquire)); }
        if qn == B.get_atomic_fetch_or_acqrel_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Or, AtomicOrdering.AcqRel)); }
        if qn == B.get_atomic_fetch_or_seqcst_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Or, AtomicOrdering.SeqCst)); }

        if qn == B.get_atomic_fetch_xor_relaxed_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Xor, AtomicOrdering.Relaxed)); }
        if qn == B.get_atomic_fetch_xor_release_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Xor, AtomicOrdering.Release)); }
        if qn == B.get_atomic_fetch_xor_acquire_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Xor, AtomicOrdering.Acquire)); }
        if qn == B.get_atomic_fetch_xor_acqrel_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Xor, AtomicOrdering.AcqRel)); }
        if qn == B.get_atomic_fetch_xor_seqcst_qn() { return Some(ctx.atomic_rmw(args, AtomicRmwOp.Xor, AtomicOrdering.SeqCst)); }

        if qn == B.get_atomic_compare_exchange_relaxed_relaxed_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.Relaxed, AtomicOrdering.Relaxed, False)); }
        if qn == B.get_atomic_compare_exchange_relaxed_acquire_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.Relaxed, AtomicOrdering.Acquire, False)); }
        if qn == B.get_atomic_compare_exchange_relaxed_seqcst_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.Relaxed, AtomicOrdering.SeqCst, False)); }
        if qn == B.get_atomic_compare_exchange_release_relaxed_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.Release, AtomicOrdering.Relaxed, False)); }
        if qn == B.get_atomic_compare_exchange_release_acquire_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.Release, AtomicOrdering.Acquire, False)); }
        if qn == B.get_atomic_compare_exchange_release_seqcst_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.Release, AtomicOrdering.SeqCst, False)); }
        if qn == B.get_atomic_compare_exchange_acquire_relaxed_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.Acquire, AtomicOrdering.Relaxed, False)); }
        if qn == B.get_atomic_compare_exchange_acquire_acquire_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.Acquire, AtomicOrdering.Acquire, False)); }
        if qn == B.get_atomic_compare_exchange_acquire_seqcst_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.Acquire, AtomicOrdering.SeqCst, False)); }
        if qn == B.get_atomic_compare_exchange_acqrel_relaxed_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.AcqRel, AtomicOrdering.Relaxed, False)); }
        if qn == B.get_atomic_compare_exchange_acqrel_acquire_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.AcqRel, AtomicOrdering.Acquire, False)); }
        if qn == B.get_atomic_compare_exchange_acqrel_seqcst_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.AcqRel, AtomicOrdering.SeqCst, False)); }
        if qn == B.get_atomic_compare_exchange_seqcst_relaxed_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.SeqCst, AtomicOrdering.Relaxed, False)); }
        if qn == B.get_atomic_compare_exchange_seqcst_acquire_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.SeqCst, AtomicOrdering.Acquire, False)); }
        if qn == B.get_atomic_compare_exchange_seqcst_seqcst_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.SeqCst, AtomicOrdering.SeqCst, False)); }

        if qn == B.get_atomic_compare_exchange_weak_relaxed_relaxed_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.Relaxed, AtomicOrdering.Relaxed, True)); }
        if qn == B.get_atomic_compare_exchange_weak_relaxed_acquire_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.Relaxed, AtomicOrdering.Acquire, True)); }
        if qn == B.get_atomic_compare_exchange_weak_relaxed_seqcst_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.Relaxed, AtomicOrdering.SeqCst, True)); }
        if qn == B.get_atomic_compare_exchange_weak_release_relaxed_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.Release, AtomicOrdering.Relaxed, True)); }
        if qn == B.get_atomic_compare_exchange_weak_release_acquire_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.Release, AtomicOrdering.Acquire, True)); }
        if qn == B.get_atomic_compare_exchange_weak_release_seqcst_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.Release, AtomicOrdering.SeqCst, True)); }
        if qn == B.get_atomic_compare_exchange_weak_acquire_relaxed_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.Acquire, AtomicOrdering.Relaxed, True)); }
        if qn == B.get_atomic_compare_exchange_weak_acquire_acquire_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.Acquire, AtomicOrdering.Acquire, True)); }
        if qn == B.get_atomic_compare_exchange_weak_acquire_seqcst_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.Acquire, AtomicOrdering.SeqCst, True)); }
        if qn == B.get_atomic_compare_exchange_weak_acqrel_relaxed_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.AcqRel, AtomicOrdering.Relaxed, True)); }
        if qn == B.get_atomic_compare_exchange_weak_acqrel_acquire_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.AcqRel, AtomicOrdering.Acquire, True)); }
        if qn == B.get_atomic_compare_exchange_weak_acqrel_seqcst_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.AcqRel, AtomicOrdering.SeqCst, True)); }
        if qn == B.get_atomic_compare_exchange_weak_seqcst_relaxed_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.SeqCst, AtomicOrdering.Relaxed, True)); }
        if qn == B.get_atomic_compare_exchange_weak_seqcst_acquire_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.SeqCst, AtomicOrdering.Acquire, True)); }
        if qn == B.get_atomic_compare_exchange_weak_seqcst_seqcst_qn() { return Some(ctx.atomic_compare_exchange(args, AtomicOrdering.SeqCst, AtomicOrdering.SeqCst, True)); }

        if qn == B.get_atomic_fence_acquire_qn() { return Some(ExprKind.AtomicFence(AtomicOrdering.Acquire)); }
        if qn == B.get_atomic_fence_release_qn() { return Some(ExprKind.AtomicFence(AtomicOrdering.Release)); }
        if qn == B.get_atomic_fence_acqrel_qn() { return Some(ExprKind.AtomicFence(AtomicOrdering.AcqRel)); }
        if qn == B.get_atomic_fence_seqcst_qn() { return Some(ExprKind.AtomicFence(AtomicOrdering.SeqCst)); }
        None
    }

    fn atomic_rmw(ctx: BuiltinLowerer, args: Vec[Expr], op: AtomicRmwOp, order: AtomicOrdering) -> ExprKind {
        ExprKind.AtomicRmw(op, args[0], args[1], order)
    }

    fn atomic_compare_exchange(
        ctx: BuiltinLowerer,
        args: Vec[Expr],
        success: AtomicOrdering,
        failure: AtomicOrdering,
        weak: Bool,
    ) -> ExprKind {
        ExprKind.AtomicCompareExchange(
            pointer: args[0],
            current: args[1],
            new: args[2],
            success: success,
            failure: failure,
            weak: weak,
        )
    }

    // The op of a builtin comparison function; None for every other builtin.
    fn comparison_op(ctx: BuiltinLowerer, qn: QualifiedName) -> Option[BinaryOp] {
        if let Some(fdef) = ctx.program.functions.get(qn) {
            if let Some(op) = fdef.is_binary_op() {
                match op {
                    BinaryOp.Eq | BinaryOp.Less => return Some(op),
                    _ => {}
                }
            }
        }
        None
    }

    fn void_stmt(ctx: BuiltinLowerer, kind: ExprKind, loc: Location) -> S.Statement {
        S.Statement.Expr(Expr(kind, loc, Some(TypeDef.Void)))
    }

    fn bool_ctor(ctx: BuiltinLowerer, qn: QualifiedName, ty: Option[TypeDef], loc: Location) -> Expr {
        Expr(ExprKind.FunctionCall(FunctionCallInfo(
            qname: qn.as_mono(),
            kind: FunctionKind.VariantCtor,
            args: Vec.new(),
        )), loc, ty)
    }

    // `let t = eq(a, b)` becomes a raw comparison (0/1, exactly what the C
    // backend's ==/< produce) switched into the Bool variants. The arm order
    // relies on the tags matching the C truth values (False = 0, True = 1).
    //
    //   declare t
    //   switch a == b { 0 => goto f, 1 => goto t }
    //   f: t = False; goto join
    //   t: t = True
    //   join:
    fn emit_comparison(ctx: BuiltinLowerer, out: Vec[S.Statement], name: VariableName, ty: Option[TypeDef], op: BinaryOp, args: Vec[Expr], loc: Location) {
        let cmp = Expr(ExprKind.BinaryOp(op, args[0], args[1]), loc.clone(), Some(ctx.int_ty.clone()));
        let false_label = ctx.label_alloc.allocate("cmp_false");
        let true_label = ctx.label_alloc.allocate("cmp_true");
        let join_label = ctx.label_alloc.allocate("cmp_join");
        let arms: Vec[Expr] = Vec.new();
        arms.push(Expr(ExprKind.Goto(false_label.clone()), loc.clone(), Some(TypeDef.Void)));
        arms.push(Expr(ExprKind.Goto(true_label.clone()), loc.clone(), Some(TypeDef.Void)));
        out.push(S.Statement.Declare(S.DeclareInfo(name.clone(), ty.clone())));
        out.push(ctx.void_stmt(ExprKind.Switch(cmp, arms), loc.clone()));
        out.push(ctx.void_stmt(ExprKind.Label(false_label), loc.clone()));
        out.push(S.Statement.Assign(
            Expr(ExprKind.Var(name.clone()), loc.clone(), ty.clone()),
            ctx.bool_ctor(B.get_bool_false_qn(), ty.clone(), loc.clone()),
        ));
        out.push(ctx.void_stmt(ExprKind.Goto(join_label.clone()), loc.clone()));
        out.push(ctx.void_stmt(ExprKind.Label(true_label), loc.clone()));
        out.push(S.Statement.Assign(
            Expr(ExprKind.Var(name), loc.clone(), ty.clone()),
            ctx.bool_ctor(B.get_bool_true_qn(), ty, loc.clone()),
        ));
        out.push(ctx.void_stmt(ExprKind.Label(join_label), loc));
    }
}

// ── Entry point ───────────────────────────────────────────────────────────────

pub fn lower_builtins(program: Program) {
    let int_ty = TypeDef.Named(NamedInfo(Name.inner(B.get_int_type_qn().as_mono()), []));
    let func_keys: Vec[QualifiedName] = program.functions.keys().cloned().collect();
    for key in func_keys {
        let func = program.functions.remove(key).unwrap();
        if func.kind == FunctionDefKind.Builtin {
            program.functions.remove(key);
        }
        let ctx = BuiltinLowerer(program, func.label_allocator, int_ty.clone());
        func.body = rewrite(func.body, ctx);
        program.functions.insert(key, func);
    }
}

}
