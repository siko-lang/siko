module Siko.Resolver.Macros.Bridge.Input {

import Siko.AST.Macros
import Siko.Constants.Builtins as B
import Siko.Interner as I
import Siko.Interpreter.Strings
import Siko.Interpreter.Types
import Siko.Interpreter.Value
import Siko.Resolver.Macros.Bridge.Value
import Siko.Resolver.Macros.Request

fn struct_def() -> Value { empty_struct(B.get_macro_struct_def_qn()) }
fn enum_def() -> Value { empty_struct(B.get_macro_enum_def_qn()) }
fn instance_header() -> Value { empty_struct(B.get_macro_instance_header_qn()) }

fn macro_target(target: MacroTarget) -> Value {
    match target {
        MacroTarget.Struct(_) => variant_value(
            B.get_macro_target_qn(),
            B.get_macro_target_struct_qn(),
            0,
            [struct_def()],
        ),
        MacroTarget.Enum(_) => variant_value(
            B.get_macro_target_qn(),
            B.get_macro_target_enum_qn(),
            1,
            [enum_def()],
        ),
        MacroTarget.Invalid => panic("invalid macro target reached bridge"),
    }
}

fn macro_symbol(symbol: MacroSymbol) -> Value {
    match symbol {
        MacroSymbol.Equals => variant_value(
            B.get_macro_symbol_qn(),
            B.get_macro_symbol_equals_qn(),
            0,
            Vec.new(),
        ),
        MacroSymbol.Bang => variant_value(
            B.get_macro_symbol_qn(),
            B.get_macro_symbol_bang_qn(),
            1,
            Vec.new(),
        ),
    }
}

fn macro_arg(arg: MacroArg) -> Value {
    match arg {
        MacroArg.Name(name) => variant_value(
            B.get_macro_arg_qn(),
            B.get_macro_arg_name_qn(),
            0,
            [make_string(I.resolve(name.name()))],
        ),
        MacroArg.Text(text) => variant_value(
            B.get_macro_arg_qn(),
            B.get_macro_arg_text_qn(),
            1,
            [make_string(text)],
        ),
        MacroArg.Integer(value) => variant_value(
            B.get_macro_arg_qn(),
            B.get_macro_arg_integer_qn(),
            2,
            [Value(int_type(), ValueKind.Int(value))],
        ),
        MacroArg.Symbol(symbol) => variant_value(
            B.get_macro_arg_qn(),
            B.get_macro_arg_symbol_qn(),
            3,
            [macro_symbol(symbol)],
        ),
    }
}

pub fn macro_context(target: MacroTarget, external: Bool, args: Vec[MacroArg]) -> Value {
    let qname = B.get_macro_context_qn();
    let header_type = named_type(B.get_macro_instance_header_qn());
    let header = if external {
        option_value(header_type, Some(instance_header()))
    } else {
        option_value(header_type, None)
    };
    let arg_type = named_type(B.get_macro_arg_qn());
    let args = vec_value(args.iter().map(|arg| macro_arg(arg)).collect(), arg_type);
    Value(
        named_type(qname),
        ValueKind.Struct(StructBox(qname, [macro_target(target), header, args])),
    )
}

pub fn is_macro_context(value: Value) -> Bool {
    match value.kind {
        ValueKind.Struct(sbox) => sbox.qname == B.get_macro_context_qn() && sbox.fields.len() == 3,
        _ => False,
    }
}

}
