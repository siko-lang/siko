module Siko.Interpreter.Extensions {

import Siko.Interpreter.Value

pub struct InterpreterExtensions {
    functions: Vec[fn(Vec[Value]) -> Value],

    pub fn new(
        functions: Vec[fn(Vec[Value]) -> Value],
    ) -> InterpreterExtensions {
        InterpreterExtensions(functions)
    }

    pub fn call(
        extensions: InterpreterExtensions,
        index: Int,
        args: Vec[Value],
    ) -> Value {
        (extensions.functions[index])(args)
    }
}

}
