module Siko.Interpreter.TypeHints {

import Siko.AST.Function
import Siko.AST.Name
import Siko.AST.QualifiedName
import Siko.AST.Type
import Siko.HIR.Program
import Siko.Interpreter.Types
import Siko.Interpreter.Witnesses
import Siko.Unification.Apply
import Siko.Unification.Sub

// Expected types flow from an expression's context toward its children. A
// call uses its declared result type to turn that expectation into type
// parameter bindings, then applies those bindings to its argument types.
// Only concrete hints are propagated: unresolved HIR type variables are not
// runtime evidence and must not be mistaken for concrete instance arguments.
pub struct CallTypeHints {
    params: Vec[TypeDef],
    result: Option[TypeDef],
    sub: Substitution,

    pub fn empty() -> CallTypeHints {
        CallTypeHints(Vec.new(), None, Substitution.new())
    }

    pub fn new(
        params: Vec[TypeDef],
        result: Option[TypeDef],
        expected: Option[TypeDef],
    ) -> CallTypeHints {
        let hints = CallTypeHints(params, result, Substitution.new());
        match (result, concrete_hint(expected)) {
            (Some(pattern), Some(concrete)) =>
                extract_named_bindings(pattern, concrete, hints.sub),
            _ => {}
        }
        hints
    }

    pub fn arg(hints: CallTypeHints, index: Int) -> Option[TypeDef] {
        match hints.params.get_opt(index) {
            Some(pattern) => concrete_type(hints.sub.apply(pattern)),
            None => None,
        }
    }

    pub fn observe_arg(hints: CallTypeHints, index: Int, actual: TypeDef) {
        if let Some(pattern) = hints.params.get_opt(index) {
            extract_named_bindings(pattern, actual, hints.sub);
        }
    }

    pub fn specialized_result(hints: CallTypeHints) -> Option[TypeDef] {
        match hints.result {
            Some(result) => concrete_type(hints.sub.apply(result)),
            None => None,
        }
    }
}

pub fn function_call_hints(
    program: Program,
    qname: QualifiedName,
    expected: Option[TypeDef],
) -> CallTypeHints {
    match program.functions.get(qname) {
        Some(fdef) => CallTypeHints.new(
            fdef.args.iter().map(|arg| arg.type_def).collect(),
            fdef.result_type,
            expected,
        ),
        None => CallTypeHints.empty(),
    }
}

pub fn struct_call_hints(
    program: Program,
    qname: QualifiedName,
    expected: Option[TypeDef],
) -> CallTypeHints {
    let def = match program.structs.get(qname) {
        Some(def) => def,
        None => return CallTypeHints.empty(),
    };
    let params = match def.type_arg_defs {
        Some(tad) => tad.type_params(),
        None => Vec.new(),
    };
    let result_args = params
        .iter()
        .map(|name| TypeDef.Var(TypeVar.Named(name)))
        .collect();
    CallTypeHints.new(
        def.fields.iter().map(|field| field.ty).collect(),
        Some(TypeDef.Named(NamedInfo(Name.inner(qname), result_args))),
        expected,
    )
}

pub fn variant_call_hints(
    program: Program,
    qname: QualifiedName,
    expected: Option[TypeDef],
) -> CallTypeHints {
    let enum_qname = match program.variant_enum_map.get(qname) {
        Some(name) => name,
        None => return CallTypeHints.empty(),
    };
    let def = match program.enums.get(enum_qname) {
        Some(def) => def,
        None => return CallTypeHints.empty(),
    };
    let params = match def.type_arg_defs {
        Some(tad) => tad.type_params(),
        None => Vec.new(),
    };
    let item_types = Vec.new();
    for variant in def.variants {
        if variant.qualified_name.unwrap_or(qname) == qname {
            item_types = variant.items.iter().map(|item| item.ty).collect();
            break;
        }
    }
    let result_args = params
        .iter()
        .map(|name| TypeDef.Var(TypeVar.Named(name)))
        .collect();
    CallTypeHints.new(
        item_types,
        Some(TypeDef.Named(NamedInfo(Name.inner(enum_qname), result_args))),
        expected,
    )
}

pub fn function_result_hint(
    program: Program,
    fdef: FunctionDef,
    args: Vec[CallArg],
    expected: Option[TypeDef],
) -> Option[TypeDef] {
    let hints = CallTypeHints.new(
        fdef.args.iter().map(|arg| arg.type_def).collect(),
        fdef.result_type,
        expected,
    );
    for (index, arg) in args.iter().enumerate() {
        hints.observe_arg(index, dispatch_type(program, arg.value));
    }
    hints.specialized_result()
}

pub fn tuple_item_hint(expected: Option[TypeDef], index: Int) -> Option[TypeDef] {
    match concrete_hint(expected) {
        Some(TypeDef.Tuple(items)) => items.get_opt(index),
        _ => None,
    }
}

pub fn concrete_hint(expected: Option[TypeDef]) -> Option[TypeDef] {
    match expected {
        Some(ty) => concrete_type(ty),
        None => None,
    }
}

fn concrete_type(ty: TypeDef) -> Option[TypeDef] {
    if is_concrete_type(ty) {
        Some(ty)
    } else {
        None
    }
}

}
