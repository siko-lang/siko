module Siko.Interpreter.Memory {

import Siko.Interpreter.Value

pub struct ArrayBox {
    pub slots: Vec[Option[Value]],

    pub fn new(count: Int) -> ArrayBox {
        ArrayBox(Vec.with_value(count, None))
    }
}

pub enum PtrValue {
    Null,
    Slot(ArrayBox, Int),
    Field(StructBox, Int),
}

}
