module Siko.Interpreter.InstanceCache {

import Std.Map
import Siko.AST.QualifiedName
import Siko.AST.Type
import Siko.Instances.FunctionInstanceResolver
import Siko.Interner as I

// The compiler's shared bound cache must reject allocator-scoped generic
// resolutions. Interpreter queries are different: this cache lives for one
// invocation and only stores fully concrete queries, so their substitutions
// and captured child witnesses are safe to reuse.
@derive2(PartialEq, Eq, PartialOrd, Ord, Clone)
struct BoundKey {
    module_name: I.String,
    trait_name: I.String,
    args: Vec[TypeDef],
}

// Replaying an already selected witness still reconstructs its generic type
// substitution and associated types. Cache that reconstruction separately
// from module-table lookup.
@derive2(PartialEq, Eq, PartialOrd, Ord, Clone)
struct KnownKey {
    witness: ResolvedWitness,
    args: Vec[TypeDef],
}

pub struct InstanceCache {
    bounds: Map[BoundKey, BoundResolution],
    known: Map[KnownKey, BoundResolution],

    pub fn new() -> InstanceCache {
        InstanceCache(Map.new(), Map.new())
    }

    pub fn get_bound(
        cache: InstanceCache,
        module_name: I.String,
        trait_name: I.String,
        args: Vec[TypeDef],
    ) -> Option[BoundResolution] {
        cache.bounds.get(BoundKey(module_name, trait_name, args))
    }

    pub fn insert_bound(
        cache: InstanceCache,
        module_name: I.String,
        trait_name: I.String,
        args: Vec[TypeDef],
        resolution: BoundResolution,
    ) {
        cache.bounds.insert(BoundKey(module_name, trait_name, args), resolution);
    }

    pub fn get_known(
        cache: InstanceCache,
        witness: ResolvedWitness,
        args: Vec[TypeDef],
    ) -> Option[BoundResolution] {
        cache.known.get(KnownKey(witness, args))
    }

    pub fn insert_known(
        cache: InstanceCache,
        witness: ResolvedWitness,
        args: Vec[TypeDef],
        resolution: BoundResolution,
    ) {
        cache.known.insert(KnownKey(witness, args), resolution);
    }
}

}
