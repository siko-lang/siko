module Siko.Interpreter.Interpreter {

import Std.Map
import Siko.AST.Expr
import Siko.AST.Function
import Siko.AST.Name
import Siko.AST.Pattern
import Siko.AST.QualifiedName
import Siko.AST.Statement as S
import Siko.AST.Type
import Siko.Constants.Builtins as B
import Siko.HIR.Program
import Siko.Interner as I
import Siko.Interpreter.Builtins
import Siko.Interpreter.Dispatch
import Siko.Interpreter.Error
import Siko.Interpreter.Extensions
import Siko.Interpreter.Memory
import Siko.Interpreter.Strings
import Siko.Interpreter.SymbolicTypes
import Siko.Interpreter.TypeHints
import Siko.Interpreter.Types
import Siko.Interpreter.Value
import Siko.Interpreter.Witnesses
import Siko.Location

// Tree-walking interpreter over post-resolve (untyped) HIR. The input program
// may be arbitrarily wrong (it has not been typechecked), so every failure
// mode is a Result error; the interpreter itself never panics.

// Run a zero-argument function and throw away its result.
pub fn run(program: Program, entry: QualifiedName, location: Location) -> Result[(), InterpreterError] {
    invoke(program, entry, Vec.new(), location)?;
    Ok(())
}

// Invoke a resolved function with compiler-provided values. This is the call
// boundary used by the macro bridge as well as future compile-time clients.
pub fn invoke(program: Program, entry: QualifiedName, args: Vec[Value], location: Location) -> Result[Value, InterpreterError] {
    invoke_with_extensions(program, entry, args, location, InterpreterExtensions.new())
}

// Invoke with caller-supplied extension closures. A closure registered for a
// function qualified name is called instead of interpreting that function.
pub fn invoke_with_extensions(
    program: Program,
    entry: QualifiedName,
    args: Vec[Value],
    location: Location,
    extensions: InterpreterExtensions,
) -> Result[Value, InterpreterError] {
    let interp = Interpreter(
        program: program,
        call_stack: Vec.new(),
        depth_limit: 500,
        extensions: extensions,
    );
    let fdef = match program.functions.get(entry) {
        Some(f) => f,
        None => return Err(error(ErrorKind.MissingFunction(I.resolve(entry.name())), location)),
    };
    let call_args = args.iter().map(|value| CallArg.concrete(program, value)).collect();
    match call_function(interp, CallContext.empty(fdef.module_name), entry, call_args, location) {
        Ok(value) => Ok(value),
        Err(e) => {
            // The stack is not unwound on the error path, so it still
            // describes the failure point.
            e.backtrace = interp.call_stack;
            Err(e)
        }
    }
}

struct Interpreter {
    program: Program,
    call_stack: Vec[FrameInfo],
    depth_limit: Int,
    extensions: InterpreterExtensions,
}

// One function invocation. The resolver alpha-renames every variable to be
// unique per function, so a single flat map serves all nested blocks.
struct Frame {
    vars: Map[VariableName, Value],
    var_types: Map[VariableName, TypeDef],
    module_name: I.String,
    context: CallContext,
    return_type: Option[TypeDef],
}

// The result of evaluating an expression: either a value, or control flow
// that propagates upward until something catches it (a loop for
// Break/Continue, the function-call boundary for Return).
enum Flow {
    Val(Value),
    Return(Value),
    Break,
    Continue,
}

fn display(qname: QualifiedName) -> String {
    I.resolve(qname.name())
}

// ── Calls ─────────────────────────────────────────────────────────────────────

fn call_function(interp: Interpreter, caller: CallContext, qname: QualifiedName, args: Vec[CallArg], location: Location) -> Result[Value, InterpreterError] {
    call_function_expected(interp, caller, qname, args, None, location)
}

fn call_function_expected(
    interp: Interpreter,
    caller: CallContext,
    qname: QualifiedName,
    args: Vec[CallArg],
    expected: Option[TypeDef],
    location: Location,
) -> Result[Value, InterpreterError] {
    call_function_with_bounds(interp, caller, qname, args, Vec.new(), expected, location)
}

// `provided` is aligned with the callee's declared bounds. Trait dispatch uses
// it to install the selected self dictionary and instance-context children.
fn call_function_with_bounds(
    interp: Interpreter,
    caller: CallContext,
    qname: QualifiedName,
    args: Vec[CallArg],
    provided: Vec[Option[ResolvedWitness]],
    expected: Option[TypeDef],
    location: Location,
) -> Result[Value, InterpreterError] {
    if interp.call_stack.len() >= interp.depth_limit {
        return Err(error(ErrorKind.StackOverflow, location));
    }
    let arg_values = call_arg_values(args);
    if let Some(closure) = interp.extensions.get(qname) {
        return closure(arg_values, location);
    }
    if let Some(result) = try_special(interp.program, qname, arg_values, location) {
        return result;
    }
    let fdef = match interp.program.functions.get(qname) {
        Some(f) => f,
        None => return Err(error(ErrorKind.MissingFunction(display(qname)), location)),
    };
    if fdef.is_builtin() {
        return run_builtin(interp.program, fdef, qname, arg_values, location);
    }
    if fdef.is_extern() {
        return Err(error(ErrorKind.ExternCall(display(qname)), location));
    }
    match fdef.kind {
        FunctionDefKind.Regular => execute_body(interp, caller, fdef, qname, args, provided, expected, location),
        FunctionDefKind.TraitMethod => {
            let dispatched = dispatch_trait_call(interp.program, qname, fdef, args, expected, caller, location)?;
            match dispatched.target {
                CallTarget.Concrete(target) => {
                    let target_def = match interp.program.functions.get(target) {
                        Some(f) => f,
                        None => return Err(error(ErrorKind.MissingFunction(display(target)), location)),
                    };
                    let target_bounds = instance_method_bounds(target_def, dispatched.self_witness, location)?;
                    call_function_with_bounds(interp, caller, target, args, target_bounds, expected, location)
                }
                CallTarget.DefaultBody(_) => {
                    let default_bounds = default_method_bounds(fdef, dispatched.self_witness);
                    execute_body(interp, caller, fdef, qname, args, default_bounds, expected, location)
                }
            }
        }
        FunctionDefKind.Extern => Err(error(ErrorKind.ExternCall(display(qname)), location)),
        FunctionDefKind.Builtin => run_builtin(interp.program, fdef, qname, arg_values, location),
        FunctionDefKind.EffectMethod => Err(error(ErrorKind.UnsupportedFunction("effect method ${display(qname)}"), location)),
        FunctionDefKind.Closure(_) => Err(error(ErrorKind.UnsupportedFunction("closure ${display(qname)}"), location)),
    }
}

fn execute_body(
    interp: Interpreter,
    caller: CallContext,
    fdef: FunctionDef,
    qname: QualifiedName,
    args: Vec[CallArg],
    provided: Vec[Option[ResolvedWitness]],
    expected: Option[TypeDef],
    location: Location,
) -> Result[Value, InterpreterError] {
    let args = fill_defaults(interp, caller, fdef, qname, args, location)?;
    if args.len() != fdef.args.len() {
        return Err(error(ErrorKind.WrongArgCount(display(qname), fdef.args.len(), args.len()), location));
    }
    let body = match fdef.body {
        Some(b) => b,
        None => return Err(error(ErrorKind.MissingBody(display(qname)), location)),
    };
    let result_hint = function_result_hint(interp.program, fdef, args, expected);
    let context = build_call_context(interp.program, caller, fdef, args, result_hint, provided, location)?;
    let frame = Frame(
        vars: Map.new(),
        var_types: Map.new(),
        module_name: fdef.module_name,
        context: context,
        return_type: result_hint,
    );
    for (i, arg_def) in fdef.args.iter().enumerate() {
        if is_concrete_type(arg_def.type_def) {
            args[i].value.ty = arg_def.type_def;
        }
        frame.vars.insert(arg_def.name, pass_value(interp.program, args[i].value));
        frame.var_types.insert(arg_def.name, arg_def.type_def);
    }
    interp.call_stack.push(FrameInfo(name: display(qname), location: location));
    // An Err propagates without popping: the stack must describe the failure.
    let flow = eval_expr_expected(interp, frame, body, result_hint)?;
    interp.call_stack.pop();
    let result = match flow {
        Flow.Val(v) => v,
        Flow.Return(v) => v,
        Flow.Break => return Err(error(ErrorKind.Internal("break escaped function body"), body.location)),
        Flow.Continue => return Err(error(ErrorKind.Internal("continue escaped function body"), body.location)),
    };
    // A concrete declared result type overrides the value's tracked type:
    // this is what gives transmute-based casts (as_int, as_u8, ...) and
    // returned literals their real type.
    if let Some(declared) = result_hint {
        return Ok(Value(declared, result.kind));
    }
    Ok(result)
}

// Missing trailing arguments are filled by calling the callee's generated
// default-value functions (mirrors the typechecker's inject_default_args).
fn fill_defaults(interp: Interpreter, caller: CallContext, fdef: FunctionDef, qname: QualifiedName, args: Vec[CallArg], location: Location) -> Result[Vec[CallArg], InterpreterError] {
    for i in args.len()..fdef.args.len() {
        let dv = match fdef.default_value_names.iter().find(|dv| dv.index == i) {
            Some(dv) => dv,
            None => return Err(error(ErrorKind.MissingDefaultArg(display(qname), i), location)),
        };
        let value = call_function(interp, caller, dv.name, Vec.new(), location)?;
        args.push(CallArg(value, fdef.args[i].type_def));
    }
    Ok(args)
}

fn call_closure(
    interp: Interpreter,
    caller: CallContext,
    cbox: ClosureBox,
    args: Vec[CallArg],
    expected: Option[TypeDef],
    location: Location,
) -> Result[Value, InterpreterError] {
    if interp.call_stack.len() >= interp.depth_limit {
        return Err(error(ErrorKind.StackOverflow, location));
    }
    let user_count = cbox.args.len() - cbox.capture_count;
    if args.len() != user_count {
        return Err(error(ErrorKind.WrongArgCount("<closure>", user_count, args.len()), location));
    }
    let context = CallContext(module_name: cbox.module_name, bounds: caller.bounds);
    let frame = Frame(
        vars: Map.new(),
        var_types: Map.new(),
        module_name: cbox.module_name,
        context: context,
        return_type: concrete_hint(expected),
    );
    for (i, arg_def) in cbox.args.iter().enumerate() {
        let value = if i < cbox.capture_count {
            cbox.captured[i]
        } else {
            pass_value(interp.program, args[i - cbox.capture_count].value)
        };
        frame.vars.insert(arg_def.name, value);
        let symbolic_ty = match arg_def.ty {
            Some(ty) => ty,
            None => if i < cbox.capture_count {
                dispatch_type(interp.program, value)
            } else {
                args[i - cbox.capture_count].symbolic_ty
            },
        };
        frame.var_types.insert(arg_def.name, symbolic_ty);
    }
    interp.call_stack.push(FrameInfo(name: "<closure>", location: location));
    let flow = eval_expr_expected(interp, frame, cbox.body, frame.return_type)?;
    interp.call_stack.pop();
    match flow {
        Flow.Val(v) => Ok(v),
        Flow.Return(v) => Ok(v),
        Flow.Break => Err(error(ErrorKind.Internal("break escaped closure body"), location)),
        Flow.Continue => Err(error(ErrorKind.Internal("continue escaped closure body"), location)),
    }
}

// ── Constructors ──────────────────────────────────────────────────────────────

fn construct_struct(interp: Interpreter, caller: CallContext, qname: QualifiedName, args: Vec[Value], location: Location) -> Result[Value, InterpreterError] {
    let struct_def = match interp.program.structs.get(qname) {
        Some(sd) => sd,
        None => return Err(error(ErrorKind.Internal("struct not found: ${display(qname)}"), location)),
    };
    for i in args.len()..struct_def.fields.len() {
        let dv = match struct_def.default_value_names.iter().find(|dv| dv.index == i) {
            Some(dv) => dv,
            None => return Err(error(ErrorKind.WrongArgCount(display(qname), struct_def.fields.len(), args.len()), location)),
        };
        args.push(call_function(interp, caller, dv.name, Vec.new(), location)?);
    }
    if args.len() != struct_def.fields.len() {
        return Err(error(ErrorKind.WrongArgCount(display(qname), struct_def.fields.len(), args.len()), location));
    }
    let fields = Vec.new();
    for arg in args {
        fields.push(pass_value(interp.program, arg));
    }
    let value = Value(TypeDef.Wildcard, ValueKind.Struct(StructBox(qname: qname, fields: fields)));
    value.ty = runtime_type(interp.program, value);
    Ok(value)
}

fn construct_variant(interp: Interpreter, qname: QualifiedName, args: Vec[Value], location: Location) -> Result[Value, InterpreterError] {
    let enum_qname = match interp.program.variant_enum_map.get(qname) {
        Some(e) => e,
        None => return Err(error(ErrorKind.Internal("variant not found: ${display(qname)}"), location)),
    };
    let enum_def = match interp.program.enums.get(enum_qname) {
        Some(ed) => ed,
        None => return Err(error(ErrorKind.Internal("enum not found: ${display(enum_qname)}"), location)),
    };
    let tag = 0;
    let found = False;
    let item_count = 0;
    for (i, variant) in enum_def.variants.iter().enumerate() {
        if variant.qualified_name.unwrap_or(qname) == qname {
            tag = i;
            item_count = variant.items.len();
            found = True;
            break;
        }
    }
    if !found {
        return Err(error(ErrorKind.Internal("variant ${display(qname)} not in enum ${display(enum_qname)}"), location));
    }
    if args.len() != item_count {
        return Err(error(ErrorKind.WrongArgCount(display(qname), item_count, args.len()), location));
    }
    let items = Vec.new();
    for arg in args {
        items.push(pass_value(interp.program, arg));
    }
    let value = Value(TypeDef.Wildcard, ValueKind.Variant(VariantBox(
        enum_qname: enum_qname,
        variant_qname: qname,
        tag: tag,
        items: items,
    )));
    value.ty = runtime_type(interp.program, value);
    Ok(value)
}

// ── Expressions ───────────────────────────────────────────────────────────────

fn eval_expr(interp: Interpreter, frame: Frame, expr: Expr) -> Result[Flow, InterpreterError] {
    eval_expr_expected(interp, frame, expr, None)
}

fn eval_expr_expected(
    interp: Interpreter,
    frame: Frame,
    expr: Expr,
    expected: Option[TypeDef],
) -> Result[Flow, InterpreterError] {
    let flow = eval_expr_inner(interp, frame, expr, concrete_hint(expected))?;
    match flow {
        Flow.Val(value) => {
            if let Some(ty) = concrete_hint(expected) {
                return Ok(Flow.Val(Value(ty, value.kind)));
            }
            Ok(Flow.Val(value))
        }
        other => Ok(other),
    }
}

fn eval_expr_inner(
    interp: Interpreter,
    frame: Frame,
    expr: Expr,
    expected: Option[TypeDef],
) -> Result[Flow, InterpreterError] {
    let location = expr.location;
    match expr.kind {
        ExprKind.IntLiteral(s) => {
            match parse_int_literal(s) {
                Some(n) => Ok(Flow.Val(Value(literal_int_type(), ValueKind.Int(n)))),
                None => Err(error(ErrorKind.InvalidLiteral(s), location)),
            }
        }
        ExprKind.FloatLiteral(s) => {
            match parse_float_literal(s) {
                Some(f) => Ok(Flow.Val(Value(named_type(B.get_f64_type_qn()), ValueKind.Float(f)))),
                None => Err(error(ErrorKind.InvalidLiteral(s), location)),
            }
        }
        ExprKind.CharLiteral(b) => {
            Ok(Flow.Val(Value(named_type(B.get_u8_type_qn()), ValueKind.Int(b.as_int()))))
        }
        ExprKind.StringLiteral(s) => Ok(Flow.Val(make_string(s))),
        ExprKind.Var(name) => {
            match frame.vars.get(name) {
                Some(value) => {
                    match value.kind {
                        ValueKind.Uninitialized => Err(error(ErrorKind.UninitializedRead, location)),
                        _ => Ok(Flow.Val(value)),
                    }
                }
                None => Err(error(ErrorKind.Internal("unbound variable ${name.format()}"), location)),
            }
        }
        ExprKind.Paren(inner) => eval_expr_expected(interp, frame, inner, expected),
        ExprKind.Block(BlockInfo(stmts)) => eval_block_expected(interp, frame, stmts, expected),
        ExprKind.Tuple(items) => {
            let values = Vec.new();
            for (index, item) in items.iter().enumerate() {
                match eval_expr_expected(interp, frame, item, tuple_item_hint(expected, index))? {
                    Flow.Val(v) => values.push(v),
                    other => return Ok(other),
                }
            }
            let types = values.iter().map(|v| v.ty).collect();
            Ok(Flow.Val(Value(TypeDef.Tuple(types), ValueKind.Tuple(values))))
        }
        ExprKind.Return(inner) => {
            match eval_expr_expected(interp, frame, inner, frame.return_type)? {
                Flow.Val(v) => Ok(Flow.Return(v)),
                other => Ok(other),
            }
        }
        ExprKind.Break => Ok(Flow.Break),
        ExprKind.Continue => Ok(Flow.Continue),
        ExprKind.If(cond, then_body, else_body) => {
            let cond_value = match eval_expr(interp, frame, cond)? {
                Flow.Val(v) => v,
                other => return Ok(other),
            };
            match read_bool(cond_value) {
                Some(True) => eval_expr_expected(interp, frame, then_body, expected),
                Some(False) => match else_body {
                    Some(e) => eval_expr_expected(interp, frame, e, expected),
                    None => Ok(Flow.Val(Value.unit())),
                }
                None => Err(error(ErrorKind.TypeMismatch("Bool", describe(cond_value)), cond.location)),
            }
        }
        ExprKind.Match(MatchInfo(scrutinee, arms)) => {
            let value = match eval_expr(interp, frame, scrutinee)? {
                Flow.Val(v) => v,
                other => return Ok(other),
            };
            for arm in arms {
                if match_pattern(interp, frame, arm.pattern, value)? {
                    return eval_expr_expected(interp, frame, arm.body, expected);
                }
            }
            Err(error(ErrorKind.NoMatch, location))
        }
        ExprKind.FieldAccess(receiver, field) => {
            let recv = match eval_expr(interp, frame, receiver)? {
                Flow.Val(v) => v,
                other => return Ok(other),
            };
            match recv.kind {
                ValueKind.Struct(sbox) => {
                    let index = field_index(interp, sbox, field.name(), location)?;
                    Ok(Flow.Val(pass_value(interp.program, sbox.fields[index])))
                }
                _ => Err(error(ErrorKind.TypeMismatch("struct", describe(recv)), location)),
            }
        }
        ExprKind.TupleIndex(receiver, index) => {
            let recv = match eval_expr(interp, frame, receiver)? {
                Flow.Val(v) => v,
                other => return Ok(other),
            };
            match recv.kind {
                ValueKind.Tuple(items) => {
                    if index < 0 || index >= items.len() {
                        return Err(error(ErrorKind.OutOfBounds(index, items.len()), location));
                    }
                    Ok(Flow.Val(items[index]))
                }
                _ => Err(error(ErrorKind.TypeMismatch("tuple", describe(recv)), location)),
            }
        }
        ExprKind.FunctionCall(FunctionCallInfo(qname, kind, args, _, _, is_co)) => {
            if is_co {
                return Err(error(ErrorKind.UnsupportedExpr("coroutine creation"), location));
            }
            let hints = match kind {
                FunctionKind.StructCtor => struct_call_hints(interp.program, qname, expected),
                FunctionKind.VariantCtor => variant_call_hints(interp.program, qname, expected),
                _ => function_call_hints(interp.program, qname, expected),
            };
            let call_args: Vec[CallArg] = Vec.new();
            for (index, arg) in args.iter().enumerate() {
                match eval_expr_expected(interp, frame, arg, hints.arg(index))? {
                    Flow.Val(v) => {
                        let call_arg = make_call_arg(interp, frame, arg, v);
                        hints.observe_arg(index, dispatch_type(interp.program, v));
                        call_args.push(call_arg);
                    }
                    other => return Ok(other),
                }
            }
            let result = match kind {
                FunctionKind.StructCtor => construct_struct(interp, frame.context, qname, call_arg_values(call_args), location)?,
                FunctionKind.VariantCtor => construct_variant(interp, qname, call_arg_values(call_args), location)?,
                _ => call_function_expected(interp, frame.context, qname, call_args, expected, location)?,
            };
            Ok(Flow.Val(result))
        }
        ExprKind.MethodCall(MethodCallInfo(receiver, method, args, _)) => {
            let recv = match eval_expr(interp, frame, receiver)? {
                Flow.Val(v) => v,
                other => return Ok(other),
            };
            let call_args: Vec[CallArg] = [make_call_arg(interp, frame, receiver, recv)];
            let receiver_ty = dispatch_type(interp.program, recv);
            let target = resolve_method_call(interp.program, receiver_ty, method.name(), frame.module_name, location)?;
            let hints = function_call_hints(interp.program, target, expected);
            hints.observe_arg(0, receiver_ty);
            for (index, arg) in args.iter().enumerate() {
                match eval_expr_expected(interp, frame, arg, hints.arg(index + 1))? {
                    Flow.Val(v) => {
                        let call_arg = make_call_arg(interp, frame, arg, v);
                        hints.observe_arg(index + 1, dispatch_type(interp.program, v));
                        call_args.push(call_arg);
                    }
                    other => return Ok(other),
                }
            }
            let result = call_function_expected(interp, frame.context, target, call_args, expected, location)?;
            Ok(Flow.Val(result))
        }
        ExprKind.DynamicCall(callee, args) => {
            let callee_value = match eval_expr(interp, frame, callee)? {
                Flow.Val(v) => v,
                other => return Ok(other),
            };
            let call_args: Vec[CallArg] = Vec.new();
            for arg in args {
                match eval_expr(interp, frame, arg)? {
                    Flow.Val(v) => call_args.push(make_call_arg(interp, frame, arg, v)),
                    other => return Ok(other),
                }
            }
            let result = match callee_value.kind {
                ValueKind.Closure(cbox) => call_closure(interp, frame.context, cbox, call_args, expected, location)?,
                ValueKind.FnRef(qname) => call_function_expected(interp, frame.context, qname, call_args, expected, location)?,
                _ => return Err(error(ErrorKind.NotCallable(describe(callee_value)), location)),
            };
            Ok(Flow.Val(result))
        }
        ExprKind.ResolvedLambda(args, body, capture_count) => {
            let captured = Vec.new();
            for i in 0..capture_count {
                match frame.vars.get(args[i].name) {
                    Some(v) => captured.push(v),
                    None => return Err(error(ErrorKind.Internal("unbound capture ${args[i].name.format()}"), location)),
                }
            }
            Ok(Flow.Val(Value(TypeDef.Wildcard, ValueKind.Closure(ClosureBox(
                args: args,
                capture_count: capture_count,
                captured: captured,
                body: body,
                module_name: frame.module_name,
            )))))
        }
        ExprKind.FunctionPtr(info) => Ok(Flow.Val(Value(TypeDef.Wildcard, ValueKind.FnRef(info.name)))),
        ExprKind.Index(container, idx) => {
            let container_value = match eval_expr(interp, frame, container)? {
                Flow.Val(v) => v,
                other => return Ok(other),
            };
            let idx_value = match eval_expr(interp, frame, idx)? {
                Flow.Val(v) => v,
                other => return Ok(other),
            };
            let call_args = [
                make_call_arg(interp, frame, container, container_value),
                make_call_arg(interp, frame, idx, idx_value),
            ];
            let result = call_function_expected(interp, frame.context, B.get_index_index_qn(), call_args, expected, location)?;
            Ok(Flow.Val(result))
        }
        ExprKind.Deref(inner) => {
            let ptr = match eval_expr(interp, frame, inner)? {
                Flow.Val(v) => v,
                other => return Ok(other),
            };
            Ok(Flow.Val(read_ptr(interp, ptr, location)?))
        }
        ExprKind.AddrOf(inner) => {
            match inner.kind {
                ExprKind.FieldAccess(receiver, field) => {
                    let recv = match eval_expr(interp, frame, receiver)? {
                        Flow.Val(v) => v,
                        other => return Ok(other),
                    };
                    match recv.kind {
                        ValueKind.Struct(sbox) => {
                            let index = field_index(interp, sbox, field.name(), location)?;
                            Ok(Flow.Val(Value(TypeDef.Ptr(TypeDef.Wildcard), ValueKind.Ptr(PtrValue.Field(sbox, index)))))
                        }
                        _ => Err(error(ErrorKind.TypeMismatch("struct", describe(recv)), location)),
                    }
                }
                ExprKind.Deref(ptr_expr) => eval_expr(interp, frame, ptr_expr),
                _ => Err(error(ErrorKind.NotAPlace(expr_kind_name(inner.kind)), location)),
            }
        }
        // A transmute changes the result type; its target is not evidence for
        // the source expression's type.
        ExprKind.Transmute(inner) => eval_expr(interp, frame, inner),
        ExprKind.TypeAssociatedCall(TypeAssociatedCallInfo(type_def, fn_name, args, _, _)) => {
            let hints = function_call_hints(interp.program, fn_name, expected);
            let call_args: Vec[CallArg] = Vec.new();
            for (index, arg) in args.iter().enumerate() {
                match eval_expr_expected(interp, frame, arg, hints.arg(index))? {
                    Flow.Val(v) => {
                        let call_arg = make_call_arg(interp, frame, arg, v);
                        hints.observe_arg(index, dispatch_type(interp.program, v));
                        call_args.push(call_arg);
                    }
                    other => return Ok(other),
                }
            }
            let result = call_type_associated(interp, frame, type_def, fn_name, call_args, expected, location)?;
            Ok(Flow.Val(result))
        }
        kind => Err(error(ErrorKind.UnsupportedExpr(expr_kind_name(kind)), location)),
    }
}

// `SomeType.method(args)`: a trait method with an explicitly named self type.
// Pre-bind the trait's primary type param to that type, then dispatch.
fn call_type_associated(
    interp: Interpreter,
    frame: Frame,
    type_def: TypeDef,
    fn_name: QualifiedName,
    args: Vec[CallArg],
    expected: Option[TypeDef],
    location: Location,
) -> Result[Value, InterpreterError] {
    let fdef = match interp.program.functions.get(fn_name) {
        Some(f) => f,
        None => return Err(error(ErrorKind.MissingFunction(display(fn_name)), location)),
    };
    match fdef.kind {
        FunctionDefKind.TraitMethod => {
            let dispatched = dispatch_type_associated_call(interp.program, fn_name, fdef, type_def, args, expected, frame.context, location)?;
            match dispatched.target {
                CallTarget.Concrete(target) => {
                    let target_def = match interp.program.functions.get(target) {
                        Some(f) => f,
                        None => return Err(error(ErrorKind.MissingFunction(display(target)), location)),
                    };
                    let target_bounds = instance_method_bounds(target_def, dispatched.self_witness, location)?;
                    call_function_with_bounds(interp, frame.context, target, args, target_bounds, expected, location)
                }
                CallTarget.DefaultBody(_) => {
                    let default_bounds = default_method_bounds(fdef, dispatched.self_witness);
                    execute_body(interp, frame.context, fdef, fn_name, args, default_bounds, expected, location)
                }
            }
        }
        _ => call_function_expected(interp, frame.context, fn_name, args, expected, location),
    }
}

// ── Statements & defer ────────────────────────────────────────────────────────

fn eval_block(interp: Interpreter, frame: Frame, stmts: Vec[S.Statement]) -> Result[Flow, InterpreterError] {
    eval_block_expected(interp, frame, stmts, None)
}

fn eval_block_expected(
    interp: Interpreter,
    frame: Frame,
    stmts: Vec[S.Statement],
    expected: Option[TypeDef],
) -> Result[Flow, InterpreterError] {
    let defers: Vec[Expr] = Vec.new();
    // An Err skips the defers (an interpreter-test error aborts the run).
    let flow = eval_stmts(interp, frame, stmts, defers, expected)?;
    run_defers(interp, frame, defers)?;
    Ok(flow)
}

fn eval_stmts(
    interp: Interpreter,
    frame: Frame,
    stmts: Vec[S.Statement],
    defers: Vec[Expr],
    expected: Option[TypeDef],
) -> Result[Flow, InterpreterError] {
    for stmt in stmts {
        match stmt {
            S.Statement.Let(S.LetInfo(name, declared_ty, rhs)) => {
                match eval_expr(interp, frame, rhs)? {
                    Flow.Val(v) => {
                        let symbolic_ty = match declared_ty {
                            Some(ty) => {
                                if is_concrete_type(ty) {
                                    v.ty = ty;
                                }
                                ty
                            }
                            None => expression_type(interp.program, frame.var_types, rhs, v),
                        };
                        frame.vars.insert(name, pass_value(interp.program, v));
                        frame.var_types.insert(name, symbolic_ty);
                    }
                    other => return Ok(other),
                }
            }
            S.Statement.Declare(S.DeclareInfo(name, declared_ty)) => {
                frame.vars.insert(name, Value.uninitialized());
                frame.var_types.insert(name, declared_ty.unwrap_or(TypeDef.Wildcard));
            }
            S.Statement.Assign(lhs, rhs) => {
                let value = match eval_expr(interp, frame, rhs)? {
                    Flow.Val(v) => v,
                    other => return Ok(other),
                };
                match eval_assign(interp, frame, lhs, value)? {
                    Flow.Val(_) => {}
                    other => return Ok(other),
                }
            }
            S.Statement.Expr(e) => {
                match eval_expr(interp, frame, e)? {
                    Flow.Val(_) => {}
                    other => return Ok(other),
                }
            }
            S.Statement.TrailingExpr(e) => {
                return eval_expr_expected(interp, frame, e, expected);
            }
            S.Statement.Loop(BlockInfo(body)) => {
                loop {
                    // A fresh block scope per iteration: the body's defers run
                    // every iteration.
                    match eval_block(interp, frame, body)? {
                        Flow.Val(_) => {}
                        Flow.Continue => {}
                        Flow.Break => break,
                        Flow.Return(v) => return Ok(Flow.Return(v)),
                    }
                }
            }
            S.Statement.Defer(e) => {
                defers.push(e);
            }
            S.Statement.UnresolvedLet(_, _, rhs) => {
                return Err(error(ErrorKind.Internal("UnresolvedLet after resolution"), rhs.location));
            }
            S.Statement.ForLoop(_, iterable, _) => {
                return Err(error(ErrorKind.Internal("ForLoop after resolution"), iterable.location));
            }
            S.Statement.WhileLoop(cond, _) => {
                return Err(error(ErrorKind.Internal("WhileLoop after resolution"), cond.location));
            }
        }
    }
    Ok(Flow.Val(Value.unit()))
}

// Block defers, reverse declaration order. A deferred expression is its own
// control-flow context: return/break/continue may not escape it.
fn run_defers(interp: Interpreter, frame: Frame, defers: Vec[Expr]) -> Result[(), InterpreterError] {
    let i = defers.len() - 1;
    while i >= 0 {
        match eval_expr(interp, frame, defers[i])? {
            Flow.Val(_) => {}
            Flow.Return(_) => return Err(error(ErrorKind.DeferEscape("return"), defers[i].location)),
            Flow.Break => return Err(error(ErrorKind.DeferEscape("break"), defers[i].location)),
            Flow.Continue => return Err(error(ErrorKind.DeferEscape("continue"), defers[i].location)),
        }
        i -= 1;
    }
    Ok(())
}

// ── Assignment targets ────────────────────────────────────────────────────────

fn eval_assign(interp: Interpreter, frame: Frame, lhs: Expr, value: Value) -> Result[Flow, InterpreterError] {
    let location = lhs.location;
    match lhs.kind {
        ExprKind.Var(name) => {
            frame.vars.insert(name, pass_value(interp.program, value));
            if frame.var_types.get(name).is_none() {
                frame.var_types.insert(name, dispatch_type(interp.program, value));
            }
            Ok(Flow.Val(Value.unit()))
        }
        ExprKind.Paren(inner) => eval_assign(interp, frame, inner, value),
        ExprKind.FieldAccess(receiver, field) => {
            let recv = match eval_expr(interp, frame, receiver)? {
                Flow.Val(v) => v,
                other => return Ok(other),
            };
            match recv.kind {
                ValueKind.Struct(sbox) => {
                    let index = field_index(interp, sbox, field.name(), location)?;
                    sbox.fields[index] = pass_value(interp.program, value);
                    Ok(Flow.Val(Value.unit()))
                }
                _ => Err(error(ErrorKind.TypeMismatch("struct", describe(recv)), location)),
            }
        }
        ExprKind.TupleIndex(receiver, index) => {
            let recv = match eval_expr(interp, frame, receiver)? {
                Flow.Val(v) => v,
                other => return Ok(other),
            };
            match recv.kind {
                ValueKind.Tuple(items) => {
                    if index < 0 || index >= items.len() {
                        return Err(error(ErrorKind.OutOfBounds(index, items.len()), location));
                    }
                    items[index] = pass_value(interp.program, value);
                    Ok(Flow.Val(Value.unit()))
                }
                _ => Err(error(ErrorKind.TypeMismatch("tuple", describe(recv)), location)),
            }
        }
        ExprKind.Deref(ptr_expr) => {
            let ptr = match eval_expr(interp, frame, ptr_expr)? {
                Flow.Val(v) => v,
                other => return Ok(other),
            };
            write_ptr(interp, ptr, value, location)?;
            Ok(Flow.Val(Value.unit()))
        }
        ExprKind.Index(container, idx) => {
            let container_value = match eval_expr(interp, frame, container)? {
                Flow.Val(v) => v,
                other => return Ok(other),
            };
            let idx_value = match eval_expr(interp, frame, idx)? {
                Flow.Val(v) => v,
                other => return Ok(other),
            };
            let call_args = [
                make_call_arg(interp, frame, container, container_value),
                make_call_arg(interp, frame, idx, idx_value),
                CallArg.concrete(interp.program, value),
            ];
            call_function(interp, frame.context, B.get_index_assign_index_assign_qn(), call_args, location)?;
            Ok(Flow.Val(Value.unit()))
        }
        kind => Err(error(ErrorKind.NotAPlace(expr_kind_name(kind)), location)),
    }
}

// ── Pointer reads/writes ──────────────────────────────────────────────────────

fn read_ptr(interp: Interpreter, ptr: Value, location: Location) -> Result[Value, InterpreterError] {
    match ptr.kind {
        ValueKind.Ptr(PtrValue.Slot(array, index)) => {
            if index < 0 || index >= array.slots.len() {
                return Err(error(ErrorKind.OutOfBounds(index, array.slots.len()), location));
            }
            match array.slots[index] {
                Some(v) => Ok(pass_value(interp.program, v)),
                None => Err(error(ErrorKind.UninitializedRead, location)),
            }
        }
        ValueKind.Ptr(PtrValue.Field(sbox, index)) => {
            if index < 0 || index >= sbox.fields.len() {
                return Err(error(ErrorKind.OutOfBounds(index, sbox.fields.len()), location));
            }
            Ok(pass_value(interp.program, sbox.fields[index]))
        }
        ValueKind.Ptr(PtrValue.Null) => Err(error(ErrorKind.NullDeref, location)),
        _ => Err(error(ErrorKind.TypeMismatch("pointer", describe(ptr)), location)),
    }
}

fn write_ptr(interp: Interpreter, ptr: Value, value: Value, location: Location) -> Result[(), InterpreterError] {
    match ptr.kind {
        ValueKind.Ptr(PtrValue.Slot(array, index)) => {
            if index < 0 || index >= array.slots.len() {
                return Err(error(ErrorKind.OutOfBounds(index, array.slots.len()), location));
            }
            array.slots[index] = Some(pass_value(interp.program, value));
            if let TypeDef.Wildcard = array.elem_ty {
                array.elem_ty = dispatch_type(interp.program, value);
            }
            Ok(())
        }
        ValueKind.Ptr(PtrValue.Field(sbox, index)) => {
            if index < 0 || index >= sbox.fields.len() {
                return Err(error(ErrorKind.OutOfBounds(index, sbox.fields.len()), location));
            }
            sbox.fields[index] = pass_value(interp.program, value);
            Ok(())
        }
        ValueKind.Ptr(PtrValue.Null) => Err(error(ErrorKind.NullDeref, location)),
        _ => Err(error(ErrorKind.TypeMismatch("pointer", describe(ptr)), location)),
    }
}

// ── Patterns ──────────────────────────────────────────────────────────────────

fn match_pattern(interp: Interpreter, frame: Frame, pattern: Pattern, value: Value) -> Result[Bool, InterpreterError] {
    let location = pattern.location;
    match pattern.kind {
        PatternKind.Wildcard => Ok(True),
        PatternKind.Binding(name) => {
            frame.vars.insert(name, pass_value(interp.program, value));
            frame.var_types.insert(name, dispatch_type(interp.program, value));
            Ok(True)
        }
        PatternKind.Typed(inner, _) => match_pattern(interp, frame, inner, value),
        PatternKind.Tuple(pats) => {
            match value.kind {
                ValueKind.Tuple(items) => {
                    if items.len() != pats.len() {
                        return Err(error(ErrorKind.TypeMismatch("tuple of ${pats.len()}", describe(value)), location));
                    }
                    for (i, p) in pats.iter().enumerate() {
                        if !match_pattern(interp, frame, p, items[i])? {
                            return Ok(False);
                        }
                    }
                    Ok(True)
                }
                _ => Err(error(ErrorKind.TypeMismatch("tuple", describe(value)), location)),
            }
        }
        PatternKind.Named(info) => {
            let qname = match info.name {
                Name.Resolved(name: qn, ..) => qn,
                _ => return Err(error(ErrorKind.Internal("unresolved name in pattern"), location)),
            };
            if interp.program.variant_enum_map.contains_key(qname) {
                match value.kind {
                    ValueKind.Variant(vbox) => {
                        if vbox.variant_qname.base_name() != qname.base_name() {
                            return Ok(False);
                        }
                        if vbox.items.len() != info.args.len() {
                            return Err(error(ErrorKind.TypeMismatch("variant with ${info.args.len()} items", describe(value)), location));
                        }
                        for (i, p) in info.args.iter().enumerate() {
                            if !match_pattern(interp, frame, p, vbox.items[i])? {
                                return Ok(False);
                            }
                        }
                        Ok(True)
                    }
                    _ => Err(error(ErrorKind.TypeMismatch("enum value", describe(value)), location)),
                }
            } else {
                match value.kind {
                    ValueKind.Struct(sbox) => {
                        if sbox.fields.len() != info.args.len() {
                            return Err(error(ErrorKind.TypeMismatch("struct with ${info.args.len()} fields", describe(value)), location));
                        }
                        for (i, p) in info.args.iter().enumerate() {
                            if !match_pattern(interp, frame, p, sbox.fields[i])? {
                                return Ok(False);
                            }
                        }
                        Ok(True)
                    }
                    _ => Err(error(ErrorKind.TypeMismatch("struct", describe(value)), location)),
                }
            }
        }
        PatternKind.IntLiteral(s) => {
            let expected = match parse_int_literal(I.resolve(s)) {
                Some(n) => n,
                None => return Err(error(ErrorKind.InvalidLiteral(I.resolve(s)), location)),
            };
            match value.kind {
                ValueKind.Int(n) => Ok(n == expected),
                _ => Err(error(ErrorKind.TypeMismatch("integer", describe(value)), location)),
            }
        }
        PatternKind.CharLiteral(b) => {
            match value.kind {
                ValueKind.Int(n) => Ok(n == b.as_int()),
                _ => Err(error(ErrorKind.TypeMismatch("integer", describe(value)), location)),
            }
        }
        PatternKind.StringLiteral(s) => {
            match render_string(value) {
                Some(actual) => Ok(actual == I.resolve(s)),
                None => Err(error(ErrorKind.TypeMismatch("String", describe(value)), location)),
            }
        }
        PatternKind.Guard(inner, guard, guard_var) => {
            if !match_pattern(interp, frame, inner, value)? {
                return Ok(False);
            }
            match guard_var {
                None => eval_guard_bool(interp, frame, guard),
                Some(var_expr) => {
                    // Normalized form: the guard is a setup block, the result
                    // lives in var_expr.
                    match eval_expr(interp, frame, guard)? {
                        Flow.Val(_) => {}
                        _ => return Err(error(ErrorKind.UnsupportedStmt("control flow in match guard"), guard.location)),
                    }
                    eval_guard_bool(interp, frame, var_expr)
                }
            }
        }
    }
}

fn eval_guard_bool(interp: Interpreter, frame: Frame, expr: Expr) -> Result[Bool, InterpreterError] {
    match eval_expr(interp, frame, expr)? {
        Flow.Val(v) => match read_bool(v) {
            Some(b) => Ok(b),
            None => Err(error(ErrorKind.TypeMismatch("Bool", describe(v)), expr.location)),
        }
        _ => Err(error(ErrorKind.UnsupportedStmt("control flow in match guard"), expr.location)),
    }
}

// ── Helpers ───────────────────────────────────────────────────────────────────

fn make_call_arg(interp: Interpreter, frame: Frame, expr: Expr, value: Value) -> CallArg {
    CallArg(value, expression_type(interp.program, frame.var_types, expr, value))
}

fn field_index(interp: Interpreter, sbox: StructBox, field: I.String, location: Location) -> Result[Int, InterpreterError] {
    match interp.program.structs.get(sbox.qname) {
        Some(struct_def) => {
            for (i, f) in struct_def.fields.iter().enumerate() {
                if f.name.name() == field {
                    if i >= sbox.fields.len() {
                        return Err(error(ErrorKind.Internal("struct value is missing fields"), location));
                    }
                    return Ok(i);
                }
            }
            Err(error(ErrorKind.MissingField(display(sbox.qname), I.resolve(field)), location))
        }
        None => Err(error(ErrorKind.Internal("struct not found: ${display(sbox.qname)}"), location)),
    }
}

fn parse_int_literal(s: String) -> Option[Int] {
    let bytes = s.as_slice();
    let n = s.len();
    if n == 0 {
        return None;
    }
    let i = 0;
    let negative = False;
    if bytes[0] == '-' {
        negative = True;
        i = 1;
    }
    if i >= n {
        return None;
    }
    let value = 0;
    if n - i > 2 && bytes[i] == '0' && bytes[i + 1] == 'x' {
        i += 2;
        while i < n {
            let c = bytes[i];
            let digit = if c >= '0' && c <= '9' {
                c.as_int() - 48
            } else if c >= 'a' && c <= 'f' {
                c.as_int() - 87
            } else if c >= 'A' && c <= 'F' {
                c.as_int() - 55
            } else {
                return None;
            };
            value = value * 16 + digit;
            i += 1;
        }
    } else {
        while i < n {
            let c = bytes[i];
            if c < '0' || c > '9' {
                return None;
            }
            value = value * 10 + (c.as_int() - 48);
            i += 1;
        }
    }
    if negative {
        Some(0 - value)
    } else {
        Some(value)
    }
}

fn digit_to_f64(d: Int) -> F64 {
    match d {
        0 => 0.0,
        1 => 1.0,
        2 => 2.0,
        3 => 3.0,
        4 => 4.0,
        5 => 5.0,
        6 => 6.0,
        7 => 7.0,
        8 => 8.0,
        _ => 9.0,
    }
}

fn parse_float_literal(s: String) -> Option[F64] {
    let bytes = s.as_slice();
    let n = s.len();
    if n == 0 {
        return None;
    }
    let i = 0;
    let negative = False;
    if bytes[0] == '-' {
        negative = True;
        i = 1;
    }
    if i >= n {
        return None;
    }
    let value = 0.0;
    let seen_dot = False;
    let divisor = 1.0;
    while i < n {
        let c = bytes[i];
        if c == '.' {
            if seen_dot {
                return None;
            }
            seen_dot = True;
        } else if c >= '0' && c <= '9' {
            let digit = digit_to_f64(c.as_int() - 48);
            if seen_dot {
                divisor = divisor * 10.0;
                value = value + digit / divisor;
            } else {
                value = value * 10.0 + digit;
            }
        } else {
            return None;
        }
        i += 1;
    }
    if negative {
        Some(0.0 - value)
    } else {
        Some(value)
    }
}

// Names the node kind for unsupported-expression errors.
fn expr_kind_name(kind: ExprKind) -> String {
    match kind {
        ExprKind.IntLiteral(_) => "integer literal",
        ExprKind.FloatLiteral(_) => "float literal",
        ExprKind.StringLiteral(_) => "string literal",
        ExprKind.CharLiteral(_) => "char literal",
        ExprKind.Var(_) => "variable",
        ExprKind.Name(_) => "name",
        ExprKind.BinaryOp(_, _, _) => "binary operator",
        ExprKind.UnaryOp(_, _) => "unary operator",
        ExprKind.Call(_) => "call",
        ExprKind.MethodCall(_) => "method call",
        ExprKind.FieldAccess(_, _) => "field access",
        ExprKind.TupleIndex(_, _) => "tuple index",
        ExprKind.FunctionCall(_) => "function call",
        ExprKind.DynamicCall(_, _) => "dynamic call",
        ExprKind.FunctionPtr(_) => "function pointer",
        ExprKind.FunctionPtrCall(_, _) => "function pointer call",
        ExprKind.If(_, _, _) => "if",
        ExprKind.IfLet(_, _, _, _) => "if let",
        ExprKind.Is(_, _) => "is",
        ExprKind.Range(_, _) => "range",
        ExprKind.Block(_) => "block",
        ExprKind.Tuple(_) => "tuple",
        ExprKind.Paren(_) => "paren",
        ExprKind.Return(_) => "return",
        ExprKind.Break => "break",
        ExprKind.Continue => "continue",
        ExprKind.Match(_) => "match",
        ExprKind.With(_) => "with",
        ExprKind.ImplicitRef(_) => "implicit reference",
        ExprKind.UnresolvedLambda(_, _) => "unresolved lambda",
        ExprKind.ResolvedLambda(_, _, _) => "lambda",
        ExprKind.CreateClosure(_) => "closure creation",
        ExprKind.List(_) => "list literal",
        ExprKind.Index(_, _) => "index",
        ExprKind.Try(_) => "try",
        ExprKind.Transmute(_) => "transmute",
        ExprKind.SizeOf(_) => "sizeof",
        ExprKind.Discriminator(_) => "discriminator",
        ExprKind.Deref(_) => "dereference",
        ExprKind.AddrOf(_) => "address-of",
        ExprKind.TypeAssociatedCall(_) => "type associated call",
        ExprKind.TraitObjectPack(_, _, _) => "trait object pack",
        ExprKind.TraitObjectCall(_, _) => "trait object call",
        ExprKind.TraitObjectCarrierPack(_, _) => "trait object carrier pack",
        ExprKind.TraitObjectDowncast(_, _, _) => "trait object downcast",
        ExprKind.Yield(_) => "yield",
        ExprKind.EnumTag(_) => "enum tag",
        ExprKind.Switch(_, _) => "switch",
        ExprKind.ReadVariant(_, _) => "read variant",
        ExprKind.Goto(_) => "goto",
        ExprKind.Label(_) => "label",
        ExprKind.Alloc(_) => "alloc",
        ExprKind.AtomicLoad(_, _) => "atomic load",
        ExprKind.AtomicStore(_, _, _) => "atomic store",
        ExprKind.AtomicRmw(_, _, _, _) => "atomic rmw",
        ExprKind.AtomicCompareExchange(_, _, _, _, _, _) => "atomic compare exchange",
        ExprKind.AtomicFence(_) => "atomic fence",
    }
}

}
