module Siko.Interpreter.Dispatch {

import Siko.AST.Function
import Siko.AST.QualifiedName
import Siko.AST.Type
import Siko.Format.Utils
import Siko.HIR.Program
import Siko.Interner as I
import Siko.Interpreter.Error
import Siko.Interpreter.Types
import Siko.Interpreter.Witnesses
import Siko.Location
import Siko.Unification.Apply
import Siko.Unification.Sub

pub enum CallTarget {
    // A concrete function present in program.functions.
    Concrete(QualifiedName),
    // The trait method has no instance override; run its default body.
    DefaultBody(QualifiedName),
}

pub struct DispatchedCall {
    pub target: CallTarget,
    pub self_witness: ResolvedWitness,
}

// Dynamic version of the monomorphizer's dispatch_trait_call: bind the
// trait's type params by matching the method's declared parameter types
// against the runtime argument types, resolve the instance in the calling
// module's context, and map to the instance's method function
// (Method(instance_qname, method_name) in program.functions), falling back
// to the trait method's default body.
pub fn dispatch_trait_call(
    program: Program,
    callee: QualifiedName,
    fdef: FunctionDef,
    args: Vec[CallArg],
    context: CallContext,
    location: Location,
) -> Result[DispatchedCall, InterpreterError] {
    dispatch_with_self(program, callee, fdef, args, None, context, location)
}

// `SomeType.method(args)`: dispatch with the trait's primary type param
// pinned to the explicitly named type.
pub fn dispatch_type_associated_call(
    program: Program,
    callee: QualifiedName,
    fdef: FunctionDef,
    self_type: TypeDef,
    args: Vec[CallArg],
    context: CallContext,
    location: Location,
) -> Result[DispatchedCall, InterpreterError] {
    dispatch_with_self(program, callee, fdef, args, Some(self_type), context, location)
}

fn dispatch_with_self(
    program: Program,
    callee: QualifiedName,
    fdef: FunctionDef,
    args: Vec[CallArg],
    self_type: Option[TypeDef],
    context: CallContext,
    location: Location,
) -> Result[DispatchedCall, InterpreterError] {
    let tad = match fdef.type_arg_defs {
        Some(t) => t,
        None => return Err(error(ErrorKind.Internal("trait method without type args: ${I.resolve(callee.name())}"), location)),
    };
    if tad.bounds.is_empty() {
        return Err(error(ErrorKind.Internal("trait method without self bound: ${I.resolve(callee.name())}"), location));
    }
    let self_bound = tad.bounds[0];
    let symbolic_inst = Substitution.new();
    let concrete_inst = Substitution.new();
    for (i, arg_def) in fdef.args.iter().enumerate() {
        if i < args.len() {
            extract_named_bindings(arg_def.type_def, args[i].symbolic_ty, symbolic_inst);
            extract_named_bindings(arg_def.type_def, dispatch_type(program, args[i].value), concrete_inst);
        }
    }
    // The explicitly named self type wins over anything derived from the args.
    if let Some(ty) = self_type {
        if !self_bound.type_args.is_empty() {
            symbolic_inst.bind_named(self_bound.type_args[0].name(), ty);
            concrete_inst.bind_named(self_bound.type_args[0].name(), ty);
        }
    }
    let trait_name = self_bound.trait_name.name();
    let symbolic_query: Vec[TypeDef] = self_bound
        .type_args
        .iter()
        .map(|n| symbolic_inst.lookup_named(n.name()).unwrap_or(TypeDef.Var(TypeVar.Named(n.name()))))
        .collect();
    let concrete_query: Vec[TypeDef] = self_bound
        .type_args
        .iter()
        .map(|n| concrete_inst.lookup_named(n.name()).unwrap_or(TypeDef.Var(TypeVar.Named(n.name()))))
        .collect();
    let resolution = resolve_bound(
        program,
        context,
        trait_name,
        symbolic_query,
        concrete_query,
        self_bound.constraints,
        concrete_inst,
        location,
    )?;
    let instance_qname = resolution.witness.instance_qname;
    let method_name = match callee.base() {
        BaseName.Method(_, m) => m,
        _ => return Err(error(ErrorKind.Internal("trait method callee is not a method name: ${I.resolve(callee.name())}"), location)),
    };
    let concrete = QualifiedName.new_method(instance_qname.name(), method_name);
    let target = if program.functions.get(concrete).is_some() {
        CallTarget.Concrete(concrete)
    } else if fdef.body.is_some() {
        CallTarget.DefaultBody(callee)
    } else {
        return Err(error(ErrorKind.MissingMethod(I.resolve(instance_qname.name()), I.resolve(method_name)), location));
    };
    Ok(DispatchedCall(target, resolution.witness))
}

// Resolve `receiver.method(...)` to a callable function: inherent methods
// from the receiver type's method map first, then the module's imported
// trait methods (mirrors the typechecker's resolve_method /
// resolve_trait_method).
pub fn resolve_method_call(
    program: Program,
    receiver_ty: TypeDef,
    method: I.String,
    module_name: I.String,
    location: Location,
) -> Result[QualifiedName, InterpreterError] {
    let type_qname = match receiver_ty {
        TypeDef.Named(NamedInfo(name, _)) => name.resolved(),
        _ => return Err(error(ErrorKind.InvalidReceiver(format_type(receiver_ty)), location)),
    };
    if let Some(struct_def) = program.structs.get(type_qname) {
        if let Some(mq) = struct_def.method_map.names.get(method) {
            return Ok(mq);
        }
    } else if let Some(enum_def) = program.enums.get(type_qname) {
        if let Some(mq) = enum_def.method_map.names.get(method) {
            return Ok(mq);
        }
    }
    resolve_trait_method(program, type_qname, method, module_name, location)
}

fn resolve_trait_method(
    program: Program,
    type_qname: QualifiedName,
    method: I.String,
    module_name: I.String,
    location: Location,
) -> Result[QualifiedName, InterpreterError] {
    if let Some(methods) = program.module_trait_method_map.get(module_name) {
        if let Some(candidates) = methods.get(method) {
            if candidates.len() == 1 {
                return Ok(candidates[0]);
            }
            return Err(error(ErrorKind.AmbiguousMethod(I.resolve(method)), location));
        }
    }
    Err(error(ErrorKind.MissingMethod(I.resolve(type_qname.name()), I.resolve(method)), location))
}

}
