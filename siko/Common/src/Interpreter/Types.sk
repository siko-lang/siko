module Siko.Interpreter.Types {

import Siko.AST.Name
import Siko.AST.QualifiedName
import Siko.AST.Type
import Siko.Constants.Builtins as B
import Siko.HIR.Program
import Siko.Interpreter.Memory
import Siko.Interpreter.Value
import Siko.Unification.Apply
import Siko.Unification.Sub

let RUNTIME_TYPE_DEPTH_LIMIT: Int = 64;

pub fn named_type(qn: QualifiedName) -> TypeDef {
    TypeDef.Named(NamedInfo(Name.inner(qn), Vec.new()))
}

pub fn int_type() -> TypeDef {
    named_type(B.get_int_type_qn())
}

// The type used for integer literals until they adopt a concrete width; see
// dispatch_type.
pub fn literal_int_type() -> TypeDef {
    TypeDef.Numeric(0)
}

pub fn is_literal_int_type(ty: TypeDef) -> Bool {
    match ty {
        TypeDef.Numeric(_) => True,
        _ => False,
    }
}

// The runtime type of a value, recomputed from its current contents so that
// mutation-revealed type information (e.g. the first push into an empty Vec)
// is picked up. Type params that cannot be derived stay Wildcard.
pub fn runtime_type(program: Program, value: Value) -> TypeDef {
    runtime_type_at(program, value, 0)
}

// Struct graphs can be cyclic (Map nodes have parent pointers). Runtime type
// refinement is best-effort, so once the traversal gets deep, keep the type
// already recorded on the value instead of recursively walking host objects
// until the compiler process exhausts its own stack.
fn runtime_type_at(program: Program, value: Value, depth: Int) -> TypeDef {
    // Runtime type information only becomes more specific. Once a value has a
    // concrete type, mutation cannot change it, so recursive reconstruction is
    // both unnecessary and actively harmful for cyclic object graphs.
    if is_concrete_type(value.ty) {
        return value.ty;
    }
    if depth >= RUNTIME_TYPE_DEPTH_LIMIT {
        return value.ty;
    }
    let result = match value.kind {
        ValueKind.Struct(sbox) => struct_type(program, sbox, depth),
        ValueKind.Variant(vbox) => variant_type(program, vbox, depth),
        ValueKind.Tuple(items) => TypeDef.Tuple(items.iter().map(|i| runtime_type_at(program, i, depth + 1)).collect()),
        ValueKind.Ptr(ptr) => match ptr {
            PtrValue.Slot(array, _) => TypeDef.Ptr(array.elem_ty),
            PtrValue.Field(sbox, index) => {
                match program.structs.get(sbox.qname) {
                    Some(struct_def) => {
                        if index >= 0 && index < struct_def.fields.len() {
                            TypeDef.Ptr(struct_def.fields[index].ty)
                        } else {
                            TypeDef.Ptr(TypeDef.Wildcard)
                        }
                    }
                    None => TypeDef.Ptr(TypeDef.Wildcard),
                }
            }
            PtrValue.Null => value.ty,
        }
        _ => value.ty,
    };
    if is_concrete_type(result) {
        value.ty = result;
    }
    result
}

// runtime_type with literal-int markers replaced by Int: what instance
// resolution and method lookup dispatch on.
pub fn dispatch_type(program: Program, value: Value) -> TypeDef {
    concretize_numeric(runtime_type(program, value))
}

fn concretize_numeric(ty: TypeDef) -> TypeDef {
    match ty {
        TypeDef.Numeric(_) => int_type(),
        TypeDef.Named(NamedInfo(name, args)) =>
            TypeDef.Named(NamedInfo(name, args.iter().map(|a| concretize_numeric(a)).collect())),
        TypeDef.Tuple(items) => TypeDef.Tuple(items.iter().map(|i| concretize_numeric(i)).collect()),
        TypeDef.Ptr(inner) => TypeDef.Ptr(concretize_numeric(inner)),
        _ => ty,
    }
}

fn struct_type(program: Program, sbox: StructBox, depth: Int) -> TypeDef {
    let struct_def = match program.structs.get(sbox.qname) {
        Some(sd) => sd,
        None => return named_type(sbox.qname),
    };
    let params = match struct_def.type_arg_defs {
        Some(tad) => tad.type_params(),
        None => Vec.new(),
    };
    if params.is_empty() {
        return named_type(sbox.qname);
    }
    let sub = Substitution.new();
    for (i, field_def) in struct_def.fields.iter().enumerate() {
        if i < sbox.fields.len() {
            extract_named_bindings(field_def.ty, runtime_type_at(program, sbox.fields[i], depth + 1), sub);
        }
    }
    let args = params.iter().map(|p| sub.lookup_named(p).unwrap_or(TypeDef.Wildcard)).collect();
    TypeDef.Named(NamedInfo(Name.inner(sbox.qname), args))
}

fn variant_type(program: Program, vbox: VariantBox, depth: Int) -> TypeDef {
    let enum_def = match program.enums.get(vbox.enum_qname) {
        Some(ed) => ed,
        None => return named_type(vbox.enum_qname),
    };
    let params = match enum_def.type_arg_defs {
        Some(tad) => tad.type_params(),
        None => Vec.new(),
    };
    if params.is_empty() {
        return named_type(vbox.enum_qname);
    }
    let sub = Substitution.new();
    if vbox.tag >= 0 && vbox.tag < enum_def.variants.len() {
        let variant_def = enum_def.variants[vbox.tag];
        for (i, item) in variant_def.items.iter().enumerate() {
            if i < vbox.items.len() {
                extract_named_bindings(item.ty, runtime_type_at(program, vbox.items[i], depth + 1), sub);
            }
        }
    }
    let args = params.iter().map(|p| sub.lookup_named(p).unwrap_or(TypeDef.Wildcard)).collect();
    TypeDef.Named(NamedInfo(Name.inner(vbox.enum_qname), args))
}

// Bool values are ordinary Std.Bool variants.
pub fn make_bool(b: Bool) -> Value {
    let (variant_qn, tag) = if b {
        (B.get_bool_true_qn(), B.get_bool_true_variant_index())
    } else {
        (B.get_bool_false_qn(), B.get_bool_false_variant_index())
    };
    Value(
        named_type(B.get_bool_type_qn()),
        ValueKind.Variant(VariantBox(
            enum_qname: B.get_bool_type_qn(),
            variant_qname: variant_qn,
            tag: tag,
            items: Vec.new(),
        )),
    )
}

// Some(True/False) for a Bool variant value, None for anything else.
pub fn read_bool(value: Value) -> Option[Bool] {
    match value.kind {
        ValueKind.Variant(vbox) => {
            if vbox.variant_qname.base_name() == B.get_bool_true_qn() {
                Some(True)
            } else if vbox.variant_qname.base_name() == B.get_bool_false_qn() {
                Some(False)
            } else {
                None
            }
        }
        _ => None,
    }
}

// True when a type mentions no type vars, wildcards or literal markers —
// i.e. it can be trusted as a value's runtime type.
pub fn is_concrete_type(ty: TypeDef) -> Bool {
    match ty {
        TypeDef.Named(NamedInfo(_, args)) => args.iter().all(|a| is_concrete_type(a)),
        TypeDef.Tuple(items) => items.iter().all(|i| is_concrete_type(i)),
        TypeDef.Paren(inner) => is_concrete_type(inner),
        TypeDef.Ptr(inner) => is_concrete_type(inner),
        TypeDef.Fn(ClosureInfo(params, ret, _)) => params.iter().all(|p| is_concrete_type(p)) && is_concrete_type(ret),
        TypeDef.FnPtr(params, ret) => params.iter().all(|p| is_concrete_type(p)) && is_concrete_type(ret),
        TypeDef.Array(inner, _) => is_concrete_type(inner),
        TypeDef.Void | TypeDef.VoidPtr => True,
        TypeDef.Var(_) | TypeDef.Wildcard | TypeDef.Numeric(_) | TypeDef.Never(_) => False,
        TypeDef.Co(_) => False,
    }
}

// The binding/passing copy rule: @value_type structs are copied shallowly at
// every binding point (compiled value types have copy semantics); everything
// else shares its box (reference semantics).
pub fn pass_value(program: Program, value: Value) -> Value {
    match value.kind {
        ValueKind.Struct(sbox) => {
            let copy = match program.structs.get(sbox.qname) {
                Some(struct_def) => struct_def.is_value_type(),
                None => False,
            };
            if copy {
                let fields = Vec.new();
                for f in sbox.fields {
                    fields.push(f);
                }
                Value(value.ty, ValueKind.Struct(StructBox(qname: sbox.qname, fields: fields)))
            } else {
                value
            }
        }
        _ => value,
    }
}

}
