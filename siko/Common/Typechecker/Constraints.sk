module Siko.Typechecker.Constraints {

import Siko.AST.Expr as E
import Siko.AST.QualifiedName
import Siko.AST.Type
import Siko.Format.Utils
import Siko.Interner as I
import Siko.Location
import Siko.Unification.Sub

@derive(PartialEq, Std.Ops.Eq, PartialOrd, Ord, Clone)
pub enum WitnessKey {
    // Witnesses for a call's bounds, anchored to the call's result var.
    Call(call_result_var: Int, bound_index: Int),
    // Witnesses for an effect handler's bounds, anchored to the handler's
    // location in the `with` block (no fresh anchor var leaks into the AST).
    Handler(location: Location, bound_index: Int),
}

@derive(Clone)
pub enum ConstraintKind {
    Unify(lhs: TypeDef, rhs: TypeDef),
    // The type of an integer literal: must resolve to a builtin integer type.
    // Left pending while the type is a flex var; the solver defaults any still
    // unresolved literal type to Int once no other constraint makes progress.
    IntLiteral(ty: TypeDef),
    // The type of a floating-point literal: must resolve to F32 or F64.
    // Unresolved literals default to F64 once constraint solving stalls.
    FloatLiteral(ty: TypeDef),
    HasField(receiver: TypeDef, field: I.String, result: TypeDef),
    HasTupleIndex(receiver: TypeDef, index: Int, result: TypeDef),
    CallMethod(receiver: TypeDef, method: I.String, args: Vec[TypeDef], result: TypeDef, named_args: Vec[E.NamedArgument]),
    CallFunction(qname: QualifiedName, kind: E.FunctionKind, args: Vec[TypeDef], result: TypeDef, is_coroutine_create: Bool),
    CallTypeAssociated(ty: TypeDef, qname: QualifiedName, args: Vec[TypeDef], result: TypeDef),
    DynamicCall(callee: TypeDef, args: Vec[TypeDef], result: TypeDef),
    HasInstance(trait_name: I.String, args: Vec[TypeDef], assoc_constraints: Vec[(TypeDef, I.String)], witness_key: Option[WitnessKey]),
    MatchVariant(scrutinee: TypeDef, variant: QualifiedName, item_types: Vec[TypeDef]),
    MatchStruct(scrutinee: TypeDef, struct_qname: QualifiedName, item_types: Vec[TypeDef]),
    ResolveImplicit(qname: QualifiedName, result: TypeDef),
    HasIndex(container: TypeDef, idx: TypeDef, result: TypeDef),
    HasIndexAssign(container: TypeDef, idx: TypeDef, value: TypeDef, assign_result_ty: TypeDef),
    GetFunctionPtrType(qname: QualifiedName, result: TypeDef),
    ValidateTraitObjectDowncast(receiver: TypeDef),
    ValidateEffectHandler(effect_method: QualifiedName, instance_method: QualifiedName),
    ValidateEffectTypeAssociation(assoc: QualifiedName, ty: TypeDef),

    pub fn apply(kind: ConstraintKind, sub: Substitution) -> ConstraintKind {
        match kind {
            ConstraintKind.Unify(lhs, rhs) =>
                ConstraintKind.Unify(lhs: sub.apply(lhs), rhs: sub.apply(rhs)),
            ConstraintKind.IntLiteral(ty) =>
                ConstraintKind.IntLiteral(ty: sub.apply(ty)),
            ConstraintKind.FloatLiteral(ty) =>
                ConstraintKind.FloatLiteral(ty: sub.apply(ty)),
            ConstraintKind.HasField(receiver, field, result) =>
                ConstraintKind.HasField(receiver: sub.apply(receiver), field: field, result: sub.apply(result)),
            ConstraintKind.HasTupleIndex(receiver, index, result) =>
                ConstraintKind.HasTupleIndex(receiver: sub.apply(receiver), index: index, result: sub.apply(result)),
            ConstraintKind.CallMethod(receiver, method, args, result, named_args) =>
                ConstraintKind.CallMethod(
                    receiver: sub.apply(receiver),
                    method: method,
                    args: sub.apply_all(args),
                    result: sub.apply(result),
                    named_args: named_args,
                ),
            ConstraintKind.CallFunction(qname, kind, args, result, is_co) =>
                ConstraintKind.CallFunction(
                    qname: qname,
                    kind: kind,
                    args: sub.apply_all(args),
                    result: sub.apply(result),
                    is_coroutine_create: is_co,
                ),
            ConstraintKind.CallTypeAssociated(ty, qname, args, result) =>
                ConstraintKind.CallTypeAssociated(
                    ty: sub.apply(ty),
                    qname: qname,
                    args: sub.apply_all(args),
                    result: sub.apply(result),
                ),
            ConstraintKind.DynamicCall(callee, args, result) =>
                ConstraintKind.DynamicCall(
                    callee: sub.apply(callee),
                    args: sub.apply_all(args),
                    result: sub.apply(result),
                ),
            ConstraintKind.HasInstance(trait_name, args, assoc_constraints, witness_key) => {
                let new_assoc = assoc_constraints.iter().map(|(t, n)| (sub.apply(t), n)).collect();
                ConstraintKind.HasInstance(
                    trait_name: trait_name,
                    args: sub.apply_all(args),
                    assoc_constraints: new_assoc,
                    witness_key: witness_key,
                )
            }
            ConstraintKind.MatchVariant(scrutinee, variant, item_types) =>
                ConstraintKind.MatchVariant(
                    scrutinee: sub.apply(scrutinee),
                    variant: variant,
                    item_types: sub.apply_all(item_types),
                ),
            ConstraintKind.MatchStruct(scrutinee, struct_qname, item_types) =>
                ConstraintKind.MatchStruct(
                    scrutinee: sub.apply(scrutinee),
                    struct_qname: struct_qname,
                    item_types: sub.apply_all(item_types),
                ),
            ConstraintKind.ResolveImplicit(qname, result) =>
                ConstraintKind.ResolveImplicit(qname: qname, result: sub.apply(result)),
            ConstraintKind.HasIndex(container, idx, result) =>
                ConstraintKind.HasIndex(container: sub.apply(container), idx: sub.apply(idx), result: sub.apply(result)),
            ConstraintKind.HasIndexAssign(container, idx, value, assign_result_ty) =>
                ConstraintKind.HasIndexAssign(
                    container: sub.apply(container),
                    idx: sub.apply(idx),
                    value: sub.apply(value),
                    assign_result_ty: sub.apply(assign_result_ty),
                ),
            ConstraintKind.GetFunctionPtrType(qname, result) =>
                ConstraintKind.GetFunctionPtrType(qname: qname, result: sub.apply(result)),
            ConstraintKind.ValidateTraitObjectDowncast(receiver) =>
                ConstraintKind.ValidateTraitObjectDowncast(receiver: sub.apply(receiver)),
            ConstraintKind.ValidateEffectHandler(effect_method, instance_method) =>
                ConstraintKind.ValidateEffectHandler(effect_method: effect_method, instance_method: instance_method),
            ConstraintKind.ValidateEffectTypeAssociation(assoc, ty) =>
                ConstraintKind.ValidateEffectTypeAssociation(assoc: assoc, ty: sub.apply(ty)),
        }
    }

    pub fn describe(kind: ConstraintKind) -> String {
        match kind {
            ConstraintKind.Unify(t1, t2) =>
                "Unify(${format_type(t1)} = ${format_type(t2)})",
            ConstraintKind.IntLiteral(ty) =>
                "IntLiteral(${format_type(ty)})",
            ConstraintKind.FloatLiteral(ty) =>
                "FloatLiteral(${format_type(ty)})",
            ConstraintKind.HasField(receiver, field, result) =>
                "HasField(${format_type(receiver)}.${field} -> ${format_type(result)})",
            ConstraintKind.HasTupleIndex(receiver, index, result) =>
                "HasTupleIndex(${format_type(receiver)}.${index} -> ${format_type(result)})",
            ConstraintKind.CallMethod(receiver, method, args, result, _) =>
                "CallMethod(${format_type(receiver)}.${method}(${format_types(args)}) -> ${format_type(result)})",
            ConstraintKind.CallFunction(qname, kind, args, result, is_co) =>
                "CallFunction[${kind.to_string()}] ${qname.name()}(${format_types(args)}) -> ${format_type(result)}${if is_co { " [co]" } else { "" }}",
            ConstraintKind.CallTypeAssociated(ty, qname, args, result) =>
                "CallTypeAssociated(${format_type(ty)}.${qname.name()}(${format_types(args)}) -> ${format_type(result)})",
            ConstraintKind.DynamicCall(callee, args, result) =>
                "DynamicCall(${format_type(callee)}(${format_types(args)}) -> ${format_type(result)})",
            ConstraintKind.HasInstance(trait_name, args, _, _) =>
                "HasInstance(${I.resolve(trait_name)}[${format_types(args)}])",
            ConstraintKind.MatchVariant(scrutinee, variant, item_types) =>
                "MatchVariant(${format_type(scrutinee)} ~ ${variant.name()}(${format_types(item_types)}))",
            ConstraintKind.MatchStruct(scrutinee, struct_qname, item_types) =>
                "MatchStruct(${format_type(scrutinee)} ~ ${struct_qname.name()}(${format_types(item_types)}))",
            ConstraintKind.ResolveImplicit(qname, result) =>
                "ResolveImplicit(${qname.name()} -> ${format_type(result)})",
            ConstraintKind.HasIndex(container, idx, result) =>
                "HasIndex(${format_type(container)}[${format_type(idx)}] -> ${format_type(result)})",
            ConstraintKind.HasIndexAssign(container, idx, value, _) =>
                "HasIndexAssign(${format_type(container)}[${format_type(idx)}] = ${format_type(value)})",
            ConstraintKind.GetFunctionPtrType(qname, result) =>
                "GetFunctionPtrType(${qname.name()} -> ${format_type(result)})",
            ConstraintKind.ValidateTraitObjectDowncast(receiver) =>
                "ValidateTraitObjectDowncast(${format_type(receiver)})",
            ConstraintKind.ValidateEffectHandler(effect_method, instance_method) =>
                "ValidateEffectHandler(${effect_method.name()} ~ ${instance_method.name()})",
            ConstraintKind.ValidateEffectTypeAssociation(assoc, ty) =>
                "ValidateEffectTypeAssociation(${assoc.name()} = ${format_type(ty)})",
        }
    }
}

instance Apply[ConstraintKind] {
    fn apply(kind: ConstraintKind, sub: Substitution) -> ConstraintKind {
        kind.apply(sub)
    }
}

@derive(Clone, PartialEq, Eq)
pub enum ConstraintState {
    Pending,
    Satisfied,
}

@derive(Clone)
pub struct Constraint {
    pub id: Int,
    pub kind: ConstraintKind,
    pub state: ConstraintState,
    pub has_spawned: Bool,
    pub location: Location,

    pub fn new(id: Int, kind: ConstraintKind, location: Location) -> Constraint {
        Constraint(id, kind, ConstraintState.Pending, False, location)
    }
}

}
