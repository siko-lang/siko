module Siko.Constants.Float {

import Siko.AST.QualifiedName
import Siko.Constants.Util

pub struct FloatNames {
    pub f32: TypeNames,
    pub f64: TypeNames,
}

pub struct TypeNames {
    pub type_qn: QualifiedName,
}

pub fn build_float_names() -> FloatNames {
    FloatNames(
        f32: TypeNames(type_qn: QualifiedName.new_struct(m("Std.Float.F32"), m("F32"))),
        f64: TypeNames(type_qn: QualifiedName.new_struct(m("Std.Float.F64"), m("F64"))),
    )
}

}
