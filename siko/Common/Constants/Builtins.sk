pub struct BuiltinNameCache {
    bool_: Bool.BoolNames,
    integer: Int.IntegerNames,
    float: Float.FloatNames,
    string: String.StringNames,
    array: Array.ArrayNames,
    map: Map.MapNames,
    option: Option.OptionNames,
    result: Result.ResultNames,
    ordering: Ordering.OrderingNames,
    atomic: Atomic.AtomicNames,
    ops: Ops.OpsNames,
    index: Ops.IndexNames,
    convert: Ops.ConvertNames,
    vector: Vec.VectorNames,
    range: Range.RangeNames,
    json: Json.JsonNames,
    util: Runtime.UtilNames,
    libc: Runtime.LibcNames,
    intrinsics: Runtime.IntrinsicNames,
    ptr: Runtime.PtrNames,
    main: Runtime.MainNames,
    console: Runtime.ConsoleNames,
    coroutine: Coroutine.CoroutineNames,
    iterator: Iterator.IteratorNames,
}

pub fn build_cache() -> BuiltinNameCache {
    BuiltinNameCache(
        bool_: Bool.build_bool_names(),
        integer: Int.build_integer_names(),
        float: Float.build_float_names(),
        string: String.build_string_names(),
        array: Array.build_array_names(),
        map: Map.build_map_names(),
        option: Option.build_option_names(),
        result: Result.build_result_names(),
        ordering: Ordering.build_ordering_names(),
        atomic: Atomic.build_atomic_names(),
        ops: Ops.build_ops_names(),
        index: Ops.build_index_names(),
        convert: Ops.build_convert_names(),
        vector: Vec.build_vector_names(),
        range: Range.build_range_names(),
        json: Json.build_json_names(),
        util: Runtime.build_util_names(),
        libc: Runtime.build_libc_names(),
        intrinsics: Runtime.build_intrinsic_names(),
        ptr: Runtime.build_ptr_names(),
        main: Runtime.build_main_names(),
        console: Runtime.build_console_names(),
        coroutine: Coroutine.build_coroutine_names(),
        iterator: Iterator.build_iterator_names(),
    )
}

pub implicit name_cache: BuiltinNameCache

// Primitive types
pub fn get_bool_type_qn() -> QualifiedName { name_cache.bool_.type_qn }
pub fn get_bool_true_qn() -> QualifiedName { name_cache.bool_.true_qn }
pub fn get_bool_false_qn() -> QualifiedName { name_cache.bool_.false_qn }
// Bool's variant indices (= enum tags after lower-enums). These mirror the
// declaration order in std's Bool and must stay in sync with it; False is 0
// and True is 1 so a Bool tag matches the C/LLVM truth value of a comparison.
pub fn get_bool_false_variant_index() -> Int { 0 }
pub fn get_bool_true_variant_index() -> Int { 1 }
pub fn get_int_type_qn() -> QualifiedName { name_cache.integer.int_.type_qn }
