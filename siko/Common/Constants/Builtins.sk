// The builtin eq method for a builtin integer type, if `qn` is one.
pub fn get_eq_qn_for_int_type(qn: QualifiedName) -> Option[QualifiedName] {
    if qn == name_cache.int_type_qn { return Some(name_cache.int_eq_qn); }
    if qn == name_cache.i8_type_qn { return Some(name_cache.i8_eq_qn); }
    if qn == name_cache.i16_type_qn { return Some(name_cache.i16_eq_qn); }
    if qn == name_cache.i32_type_qn { return Some(name_cache.i32_eq_qn); }
    if qn == name_cache.i64_type_qn { return Some(name_cache.i64_eq_qn); }
    if qn == name_cache.u8_type_qn { return Some(name_cache.u8_eq_qn); }
    if qn == name_cache.u16_type_qn { return Some(name_cache.u16_eq_qn); }
    if qn == name_cache.u32_type_qn { return Some(name_cache.u32_eq_qn); }
    if qn == name_cache.u64_type_qn { return Some(name_cache.u64_eq_qn); }
    None
}
