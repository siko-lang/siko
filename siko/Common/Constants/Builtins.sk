fn m(s: String) -> I.String { I.intern(s) }

pub fn build_cache() -> BuiltinNameCache {
    let n_partial_eq = m("Std.Ops.PartialEq");
    let n_partial_ord = m("Std.Ops.PartialOrd");
    let n_ord = m("Std.Ops.Ord");
    let n_clone = m("Std.Ops.Clone");
    let n_from_int = m("Std.Ops.FromInt");
    let n_json_serialize = m("Std.Json.JsonSerialize");
    let n_json_deserialize = m("Std.Json.JsonDeserialize");
    let n_int = m("Std.Int.Int");
    let n_u8 = m("Std.Int.U8.U8");
    let n_string = m("Std.String.String");
    let n_vec = m("Std.Vec.Vec");
    let n_map = m("Std.Map.Map");
    let n_json = m("Std.Json.Json");
    let n_atomic = m("Std.Sync.Atomic.Intrinsics");

    BuiltinNameCache(
        bool_type_qn: QualifiedName.new_enum(m("Std.Bool"), m("Bool")),
        bool_true_qn: QualifiedName.new_variant(m("Std.Bool"), m("Bool"), m("True")),
        bool_false_qn: QualifiedName.new_variant(m("Std.Bool"), m("Bool"), m("False")),
        int_type_qn: QualifiedName.new_struct(m("Std.Int"), m("Int")),
        i8_type_qn: QualifiedName.new_struct(m("Std.Int.I8"), m("I8")),
        i16_type_qn: QualifiedName.new_struct(m("Std.Int.I16"), m("I16")),
        i32_type_qn: QualifiedName.new_struct(m("Std.Int.I32"), m("I32")),
        i64_type_qn: QualifiedName.new_struct(m("Std.Int.I64"), m("I64")),
        u8_type_qn: QualifiedName.new_struct(m("Std.Int.U8"), m("U8")),
        u16_type_qn: QualifiedName.new_struct(m("Std.Int.U16"), m("U16")),
        u32_type_qn: QualifiedName.new_struct(m("Std.Int.U32"), m("U32")),
        u64_type_qn: QualifiedName.new_struct(m("Std.Int.U64"), m("U64")),
        f32_type_qn: QualifiedName.new_struct(m("Std.Float.F32"), m("F32")),
        f64_type_qn: QualifiedName.new_struct(m("Std.Float.F64"), m("F64")),
        string_type_qn: QualifiedName.new_struct(m("Std.String"), m("String")),
