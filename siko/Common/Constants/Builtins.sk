pub fn get_int_eq_qn() -> QualifiedName { name_cache.integer.int_.eq_qn }
pub fn get_u8_eq_qn() -> QualifiedName { name_cache.integer.u8.eq_qn }

// The builtin eq method for a builtin integer type, if `qn` is one.
pub fn get_eq_qn_for_int_type(qn: QualifiedName) -> Option[QualifiedName] {
    if qn == name_cache.integer.int_.type_qn { return Some(name_cache.integer.int_.eq_qn); }
    if qn == name_cache.integer.i8.type_qn { return Some(name_cache.integer.i8.eq_qn); }
    if qn == name_cache.integer.i16.type_qn { return Some(name_cache.integer.i16.eq_qn); }
    if qn == name_cache.integer.i32.type_qn { return Some(name_cache.integer.i32.eq_qn); }
    if qn == name_cache.integer.i64.type_qn { return Some(name_cache.integer.i64.eq_qn); }
    if qn == name_cache.integer.u8.type_qn { return Some(name_cache.integer.u8.eq_qn); }
    if qn == name_cache.integer.u16.type_qn { return Some(name_cache.integer.u16.eq_qn); }
    if qn == name_cache.integer.u32.type_qn { return Some(name_cache.integer.u32.eq_qn); }
    if qn == name_cache.integer.u64.type_qn { return Some(name_cache.integer.u64.eq_qn); }
    None
}
