module Siko.Unification.Instantiate {

import Siko.Utils.TypeVarAllocator
import Siko.Unification.Sub
import Siko.Interner as I

pub fn instantiate(generic_params: Vec[I.String], allocator: TypeVarAllocator) -> Substitution {
    let s = Substitution.new();
    for name in generic_params {
        s.bind_named(name, allocator.allocate());
    }
    s
}

}
