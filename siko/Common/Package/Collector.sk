module Siko.Package.Collector {

import Std.IO.Error as IO
import Siko.Package.Info
import Siko.Package.Parser as P
import Std.Fs.Directory
import Std.Fs.Stat as S
import Std.Map
import Std.Set

pub enum CollectorError {
    IOError(IO.Error),
    ParseError(P.Error),
    MultipleRootPackages,
    MissingDependency(dep: String, requester: String, toml: String),
}

instance ToString[CollectorError] {
    fn to_string(e: CollectorError) -> String {
        match e {
            CollectorError.IOError(io) => "io error: ${io}",
            CollectorError.ParseError(pe) => "parse error: ${pe}",
            CollectorError.MultipleRootPackages => "multiple root packages given, at most one is allowed",
            CollectorError.MissingDependency(dep: dep, requester: requester, toml: toml) =>
                "dependency not found: `${dep}` (required by `${requester}` in ${toml})",
        }
    }
}

instance ToString[SourcePackage] {
    fn to_string(p: SourcePackage) -> String {
        let root = match p.root {
            Some(r) => r,
            None => "<implicit>",
        };
        let kind = if p.is_root { "root" } else { "dep" };
        "${kind} ${p.info} at ${root}"
    }
}

instance Into[IO.Error, CollectorError] {
    fn into(value: IO.Error) -> CollectorError {
        CollectorError.IOError(value)
    }
}

instance Into[P.Error, CollectorError] {
    fn into(value: P.Error) -> CollectorError {
        CollectorError.ParseError(value)
    }
}

@derive(Clone, PartialEq, Eq)
pub struct SourcePackage {
    pub root: Option[String],
    pub info: PackageInfo,
    pub files: Vec[String],
    pub is_root: Bool,
}

fn select_packages(
    name: String,
    by_name: Map[String, SourcePackage],
    visited: Map[String, Bool],
    result: Vec[SourcePackage],
) -> Result[(), CollectorError] {
    if visited.contains_key(name) {
        return Ok(());
    }
    visited.insert(name, True);
    let pkg = by_name.get(name).unwrap();
    let toml = match pkg.root {
        Some(r) => r + "/package.toml",
        None => "<unknown>",
    };
    for dep in pkg.info.dependencies {
        if !by_name.contains_key(dep.name) {
            return Err(CollectorError.MissingDependency(
                dep: dep.name,
                requester: pkg.info.name,
                toml: toml,
            ));
        }
        select_packages(dep.name, by_name, visited, result)?;
    }
    result.push(pkg);
    Ok(())
}

fn resolve_dependency_path(pkg_root: String, dep_path: String) -> String {
    if dep_path.starts_with("/") {
        dep_path
    } else {
        pkg_root + "/" + dep_path
    }
}

pub struct Collector {
    packages: Map[String, SourcePackage],
    bare_files: Vec[String],
    no_std: Bool,

    pub fn new(no_std: Bool) -> Collector {
        Collector(packages: Map.new(), bare_files: Vec.new(), no_std: no_std)
    }

    fn walk(c: Collector, dir: String, active_pkg: Option[String], is_root: Bool) -> Result[(), CollectorError] {
        let entries = Std.Fs.Directory.list_dir(dir)?;

        let subdirs: Vec[String] = Vec.new();
        let sk_files: Vec[String] = Vec.new();
        let has_toml = False;

        for entry_result in entries {
            let entry = entry_result?;
            if entry.name() == "." || entry.name() == ".." {
                continue;
            }
            let path = dir + "/" + entry.name();
            let is_dir = if entry.is_directory() {
                True
            } else if entry.file_type() == FileType.Symlink {
                match S.stat(path) {
                    Ok(s) => s.is_directory(),
                    Err(_) => False,
                }
            } else {
                False
            };
            if is_dir {
                subdirs.push(path);
            } else if entry.name() == "package.toml" {
                has_toml = True;
            } else if entry.name().ends_with(".sk") {
                sk_files.push(path);
            }
        }
        subdirs.sort();
        sk_files.sort();

        if has_toml && active_pkg.is_some() {
            return Ok(());
        }

        let pkg_key = if has_toml {
            let toml_path = dir + "/package.toml";
            let info = P.parse(toml_path)?;
            c.packages.insert(dir, SourcePackage(root: Some(dir), info: info, files: Vec.new(), is_root: is_root));
            Some(dir)
        } else {
            active_pkg
        };

        for path in sk_files {
            match pkg_key {
                Some(key) => c.packages.get(key).unwrap().files.push(path),
                None => c.bare_files.push(path),
            }
        }

        for subdir in subdirs {
            c.walk(subdir, pkg_key, False)?;
        }

        Ok(())
    }

    fn collect_pkg_path_dependencies(c: Collector, pkg: SourcePackage) -> Result[(), CollectorError] {
        let pkg_root = match pkg.root {
            Some(root) => root,
            None => return Ok(()),
        };
        for dep in pkg.info.dependencies {
            match dep.path {
                Some(dep_path) => {
                    let dep_root = resolve_dependency_path(pkg_root, dep_path);
                    if !c.packages.contains_key(dep_root) {
                        c.walk(dep_root, None, False)?;
                    }
                    match c.packages.get(dep_root) {
                        Some(dep_pkg) => c.collect_pkg_path_dependencies(dep_pkg)?,
                        None => {}
                    }
                }
                None => {}
            }
        }
        Ok(())
    }

    fn collect_path_dependencies(c: Collector) -> Result[(), CollectorError] {
        let packages: Vec[SourcePackage] = Vec.new();
        for (_, pkg) in c.packages {
            packages.push(pkg);
        }
        for pkg in packages {
            c.collect_pkg_path_dependencies(pkg)?;
        }
        Ok(())
    }

    pub fn collect(c: Collector, inputs: Vec[String], lib_paths: Vec[String]) -> Result[Vec[SourcePackage], CollectorError] {
        for lib in lib_paths {
            let s = S.stat(lib)?;
            if s.is_directory() {
                c.walk(lib, None, False)?;
            }
        }
        for input in inputs {
            let s = S.stat(input)?;
            if s.is_directory() {
                c.walk(input, None, True)?;
            } else if input.ends_with(".sk") {
                c.bare_files.push(input);
            }
        }
        c.collect_path_dependencies()?;

        let pkgs: Vec[SourcePackage] = Vec.new();
        let root_count = 0;
        for (_, pkg) in c.packages {
            if pkg.is_root {
                root_count += 1;
            }
            pkgs.push(pkg);
        }
        if root_count > 1 {
            return Err(CollectorError.MultipleRootPackages);
        }

        if root_count == 0 && !c.bare_files.is_empty() {
            let deps: Vec[Dependency] = Vec.new();
            if !c.no_std {
                deps.push(Dependency(name: "Std", version: "", path: None));
            }
            pkgs.push(SourcePackage(
                root: None,
                info: PackageInfo(name: "", version: "", dependencies: deps, pure: False),
                files: c.bare_files,
                is_root: True,
            ));
        }

        // build name -> package map for dep resolution
        let by_name: Map[String, SourcePackage] = Map.new();
        for pkg in pkgs {
            by_name.insert(pkg.info.name, pkg);
        }
        // for (name, pkg) in by_name {
        //     println("package: ${name}: ${pkg}");
        // }

        // dep-first walk from root
        let result: Vec[SourcePackage] = Vec.new();
        let visited: Map[String, Bool] = Map.new();
        for (_, pkg) in by_name {
            if pkg.is_root {
                select_packages(pkg.info.name, by_name, visited, result)?;
                break;
            }
        }

        Ok(result)
    }
}

// Returns a map from package name to the set of all package names it can reach
// (itself plus all transitive dependencies). Relies on `packages` being in
// dependency-first order, as produced by `Collector.collect`.
pub fn build_package_reachability(packages: Vec[SourcePackage]) -> Map[String, Set[String]] {
    let reachable: Map[String, Set[String]] = Map.new();
    for pkg in packages {
        let r: Set[String] = Set.new();
        r.insert(pkg.info.name);
        for dep in pkg.info.dependencies {
            r.insert(dep.name);
            if let Some(dep_r) = reachable.get(dep.name) {
                for name in dep_r {
                    r.insert(name);
                }
            }
        }
        reachable.insert(pkg.info.name, r);
    }
    reachable
}

}
