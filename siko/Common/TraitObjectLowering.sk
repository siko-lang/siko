instance Rewrite[NamedInfo] {
    fn rewrite(info: NamedInfo, lowerer: TraitObjectLowerer) -> NamedInfo {
        let args = rewrite(info.args, lowerer);
        match info.name {
            Name.Resolved(qname, loc) => match lowerer.object_types.get(qname) {
                Some(object_qname) => NamedInfo(
                    Name.Resolved(name: object_qname, location: loc),
                    Vec.new(),
                ),
                None => NamedInfo(info.name, args),
            },
            _ => NamedInfo(info.name, args),
        }
    }
}

instance Rewrite[Expr] {
    fn rewrite(expr: Expr, lowerer: TraitObjectLowerer) -> Expr {
        lowerer.rewrite_expr(expr)
    }
}

instance[T: Rewrite[T]] Rewrite[Option[T]] {
    fn rewrite(value: Option[T], lowerer: TraitObjectLowerer) -> Option[T] {
        value.map(|v| rewrite(v, lowerer))
    }
}

instance[T: Rewrite[T]] Rewrite[Vec[T]] {
    fn rewrite(values: Vec[T], lowerer: TraitObjectLowerer) -> Vec[T] {
        values.into_iter().map(|v| rewrite(v, lowerer)).collect()
    }
}

instance[K, V: Rewrite[V], Ord[K]] Rewrite[Map[K, V]] {
    fn rewrite(values: Map[K, V], lowerer: TraitObjectLowerer) -> Map[K, V] {
        values.iter().map(|(key, value)| (key, rewrite(value, lowerer))).collect()
    }
}

fn generated_qnames(trait_qname: QualifiedName) -> (QualifiedName, QualifiedName) {
    match trait_qname.base() {
        BaseName.Trait(_, _) => {}
        _ => panic("object-safe trait has a non-trait qualified name"),
    }
    (
        QualifiedName.new_trait_object(trait_qname.name()),
        QualifiedName.new_trait_object_variant(trait_qname.name()),
    )
}

pub fn lower_trait_objects(program: Program) -> Bool {
    let uses = ObjectUseCollector(Set.new());
    collect_object_uses(program.functions, uses);
    collect_object_uses(program.structs, uses);
    collect_object_uses(program.enums, uses);
    collect_object_uses(program.implicits, uses);

    let object_types: Map[QualifiedName, QualifiedName] = Map.new();
    for (trait_qname, trait_def) in program.traits {
        if trait_def.object_safe && uses.names.contains(trait_qname) {
            let (enum_qname, _) = generated_qnames(trait_qname);
            object_types.insert(trait_qname, enum_qname);
        }
    }
    if object_types.is_empty() {
        return False;
    }

    let lowerer = TraitObjectLowerer(object_types, Map.new(), VarAllocator.new());
    let new_enums: Vec[(QualifiedName, EnumDef, QualifiedName)] = Vec.new();
    for (trait_qname, trait_def) in program.traits {
        if !trait_def.object_safe || !uses.names.contains(trait_qname) {
            continue;
        }
        let (enum_qname, variant_qname) = generated_qnames(trait_qname);
        let trait_name = match trait_qname.base() {
            BaseName.Trait(_, trait_name) => trait_name,
            _ => panic("object-safe trait has a non-trait qualified name"),
        };
        let methods: Vec[ObjectMethod] = Vec.new();
        let items: Vec[ItemInfo] = Vec.new();
        for method_qname in trait_def.method_map.names.values() {
            let method = program.functions.get(method_qname).unwrap();
            let params: Vec[TypeDef] = method.args.iter().skip(1)
                .map(|arg| rewrite(arg.type_def, lowerer))
                .collect();
            let result = rewrite(method.result_type.unwrap_or(TypeDef.Tuple(Vec.new())), lowerer);
            let closure_ty = TypeDef.Fn(ClosureInfo(params, result, None));
            methods.push(ObjectMethod(method_qname, closure_ty));
            items.push(ItemInfo(name: None, ty: closure_ty));
        }
        let loc = trait_def.name.location;
        let variant = VariantDef(
            name: Identifier.new(trait_name, loc.clone()),
            qualified_name: Some(variant_qname),
            items: items,
        );
        let enum_def = EnumDef(
            annotations: Vec.new(),
            public: False,
            name: Identifier.new(trait_name, loc.clone()),
            qualified_name: Some(enum_qname),
            type_arg_defs: None,
            variants: [variant],
            methods: Vec.new(),
            method_map: MethodMap.new(),
            module_name: match trait_qname.base() {
                BaseName.Trait(module_name, _) => module_name,
                _ => panic("object-safe trait has a non-trait qualified name"),
            },
            value_type: False,
        );
        lowerer.infos.insert(trait_qname, ObjectInfo(variant_qname, methods));
        new_enums.push((enum_qname, enum_def, variant_qname));
    }

    program.structs = rewrite(program.structs, lowerer);
    program.enums = rewrite(program.enums, lowerer);
    for (enum_qname, enum_def, variant_qname) in new_enums {
        program.enums.insert(enum_qname, enum_def);
        program.variant_enum_map.insert(variant_qname, enum_qname);
    }

    let function_keys: Vec[QualifiedName] = program.functions.keys().collect();
    for key in function_keys {
        let func = program.functions.get(key).unwrap();
        lowerer.var_alloc = func.var_allocator;
        program.functions.insert(key, rewrite(func, lowerer));
    }

    program.implicits = rewrite(program.implicits, lowerer);
    program.effects = rewrite(program.effects, lowerer);

    program.all_instances = rewrite(program.all_instances, lowerer);
    program.named_instances = rewrite(program.named_instances, lowerer);
    program.canonical_instances = rewrite(program.canonical_instances, lowerer);
    program.instance_resolver = InstanceResolver.build(program);
    True
}

}
