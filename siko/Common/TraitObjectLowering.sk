instance CollectObjectUses[NamedInfo] {
    fn collect_object_uses(info: NamedInfo, collector: ObjectUseCollector) {
        if let Name.Resolved(qname, _) = info.name {
            collector.names.insert(qname);
        }
        collect_object_uses(info.args, collector);
    }
}

instance[T: CollectObjectUses[T]] CollectObjectUses[Option[T]] {
    fn collect_object_uses(value: Option[T], collector: ObjectUseCollector) {
        if let Some(v) = value {
            collect_object_uses(v, collector);
        }
    }
}

instance[T: CollectObjectUses[T]] CollectObjectUses[Vec[T]] {
    fn collect_object_uses(values: Vec[T], collector: ObjectUseCollector) {
        for value in values {
            collect_object_uses(value, collector);
        }
    }
}

instance[K, V: CollectObjectUses[V], Ord[K]] CollectObjectUses[Map[K, V]] {
    fn collect_object_uses(values: Map[K, V], collector: ObjectUseCollector) {
        for value in values.values() {
            collect_object_uses(value, collector);
        }
    }
}

struct ObjectMethod {
    qname: QualifiedName,
    closure_ty: TypeDef,
}

struct ObjectInfo {
    variant_qname: QualifiedName,
    methods: Vec[ObjectMethod],
}

struct TraitObjectLowerer {
    object_types: Map[QualifiedName, QualifiedName],
    infos: Map[QualifiedName, ObjectInfo],
    var_alloc: VarAllocator,

    fn rewrite_expr(l: TraitObjectLowerer, expr: Expr) -> Expr {
        let loc = expr.location.clone();
        let ty = rewrite(expr.ty, l);
        match expr.kind {
            ExprKind.TraitObjectPack(trait_qname, value, witnesses) =>
                l.lower_pack(trait_qname, rewrite(value, l), witnesses, loc, ty),
            ExprKind.TraitObjectCall(trait_qname, call) =>
                l.lower_call(trait_qname, rewrite(call, l), loc, ty),
            kind => Expr(rewrite(kind, l), loc, ty),
        }
    }

    fn lower_pack(
        l: TraitObjectLowerer,
        trait_qname: QualifiedName,
        value: Expr,
        witnesses: WitnessInfo,
        loc: Location,
        ty: Option[TypeDef],
    ) -> Expr {
        let info = l.infos.get(trait_qname).expect("trait-object info not found");
        let capture = match value.kind {
            ExprKind.Var(name) => name,
            _ => panic("trait-object pack value was not normalized to a variable"),
        };
        let capture_ty = value.ty.expect("trait-object pack value has no type");
        let closures: Vec[Expr] = Vec.new();
        for method in info.methods {
            let (param_tys, result_ty) = match method.closure_ty {
                TypeDef.Fn(ClosureInfo(params, result, _)) => (params, result),
                _ => panic("trait-object method field is not a closure"),
            };
            let lambda_args: Vec[LambdaArg] = [LambdaArg(capture, Some(capture_ty))];
            let call_args: Vec[Expr] = [Expr(ExprKind.Var(capture), loc.clone(), Some(capture_ty))];
            for param_ty in param_tys {
                let param = l.var_alloc.allocate_temp();
                lambda_args.push(LambdaArg(param, Some(param_ty)));
                call_args.push(Expr(ExprKind.Var(param), loc.clone(), Some(param_ty)));
            }
            let body = Expr(
                ExprKind.FunctionCall(FunctionCallInfo(
                    qname: method.qname,
                    kind: FunctionKind.UserDefined,
                    args: call_args,
                    witnesses: witnesses.clone(),
                )),
                loc.clone(),
                Some(result_ty),
            );
            closures.push(Expr(
                ExprKind.ResolvedLambda(lambda_args, body, 1),
                loc.clone(),
                Some(method.closure_ty),
            ));
        }
        Expr(
            ExprKind.FunctionCall(FunctionCallInfo(
                qname: info.variant_qname,
                kind: FunctionKind.VariantCtor,
                args: closures,
            )),
            loc,
            ty,
        )
    }

    fn lower_call(
        l: TraitObjectLowerer,
        trait_qname: QualifiedName,
        call: FunctionCallInfo,
        loc: Location,
        ty: Option[TypeDef],
    ) -> Expr {
        let info = l.infos.get(trait_qname).expect("trait-object info not found");
        let selected = info.methods.iter().position(|m| m.qname == call.qname)
            .expect("trait-object method not found");
        if call.args.is_empty() {
            panic("trait-object call has no receiver");
        }
        let receiver = call.args[0];
        let object_ty = receiver.ty.expect("trait-object receiver has no type");
        let bindings: Vec[VariableName] = Vec.new();
        let subpatterns: Vec[Pattern] = Vec.new();
        for method in info.methods {
            let binding = l.var_alloc.allocate_temp();
            bindings.push(binding);
            subpatterns.push(Pattern(
                PatternKind.Binding(binding),
                loc.clone(),
                Some(method.closure_ty),
            ));
        }
        let pattern = Pattern(
            PatternKind.Named(NamedPatternInfo(
                name: Name.inner(info.variant_qname),
                args: subpatterns,
                named_args: Vec.new(),
                has_rest: False,
            )),
            loc.clone(),
            Some(object_ty),
        );
        let callee_ty = info.methods[selected].closure_ty;
        let callee = Expr(ExprKind.Var(bindings[selected]), loc.clone(), Some(callee_ty));
        let exposed_args = call.args.iter().skip(1).collect();
        let body = Expr(ExprKind.DynamicCall(callee, exposed_args), loc.clone(), ty.clone());
        Expr(
            ExprKind.Match(MatchInfo(receiver, [MatchArm(pattern, body)])),
            loc,
            ty,
        )
    }
}

trait Rewrite[T] {
    fn rewrite(t: T, lowerer: TraitObjectLowerer) -> T
}

