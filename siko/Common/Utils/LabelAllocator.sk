module Siko.Utils.LabelAllocator {

@derive(Clone, PartialEq, Std.Ops.Eq)
pub struct LabelAllocator {
    pub next: Int,

    pub fn new() -> LabelAllocator {
        LabelAllocator(0)
    }

    pub fn allocate(l: LabelAllocator, hint: String) -> String {
        let name = "bb_${l.next}_${hint}";
        l.next += 1;
        name
    }
}

}
