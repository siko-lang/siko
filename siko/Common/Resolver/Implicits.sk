module Siko.Resolver.Implicit {

import Siko.Resolver
import Siko.Resolver.Error
import Siko.AST.Implicits

instance Resolvable[ImplicitDef] {
    fn resolve(i: ImplicitDef, ctx: ResolverContext) -> Result[ImplicitDef, ResolveError] {
        Ok(ImplicitDef(
            i.public,
            i.name.with_prefix(ctx.module_name()),
            i.ty.resolve(ctx)?,
        ))
    }
}

}