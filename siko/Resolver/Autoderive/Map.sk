module Siko.Resolver.Autoderive.Map {

import Siko.Resolver.Autoderive.Utils
import Siko.AST.Data
import Siko.AST.Instances
import Siko.AST.Name
import Siko.AST.Type
import Siko.AST.Identifier
import Siko.AST.Generics
import Siko.AST.Function
import Siko.AST.Expr
import Siko.AST.Pattern
import Siko.Utils.VarAllocator
import Siko.AST.QualifiedName
import Siko.Location
import Siko.Interner as I

pub fn build_map_method(
    enum_def: EnumDef,
    parent_qn: QualifiedName,
    type_arg_defs: Option[TypeArgDefs],
    self_type: TypeDef,
    fn_qname: QualifiedName,
    short_name: Identifier,
    module_name: I.String,
    extra_args: Vec[FunctionArg],
    body_strategy: BodyStrategy,
) -> (FunctionDef, Identifier) {
    let loc = enum_def.name.location;
    let var_alloc = VarAllocator.new();
    let var_a = var_alloc.allocate_user(I.intern("a"));
    let extra_arg_defs: Vec[FunctionArg] = extra_args.iter().map(|arg| {
        let v = var_alloc.allocate_user(arg.name.get_user_name());
        FunctionArg(v, arg.type_def, None)
    }).collect();
    let extra_arg_vars: Vec[VariableName] = extra_arg_defs.iter().map(|arg| arg.name).collect();
    let body = match body_strategy {
        BodyStrategy.Identity => Expr(ExprKind.Var(var_a), loc, None),
        BodyStrategy.Unreachable => build_unreachable(loc),
        BodyStrategy.Generate => build_map_body(enum_def, var_a, fn_qname, extra_arg_vars, var_alloc, loc),
    };
    let method = make_unary_method(
        parent_qn,
        short_name,
        type_arg_defs,
        self_type,
        Some(self_type),
        var_a,
        extra_arg_defs,
        body,
        module_name,
        var_alloc,
    );
    (method, short_name)
}

fn build_map_body(
    enum_def: EnumDef,
    var_a: VariableName,
    fn_qname: QualifiedName,
    extra_arg_vars: Vec[VariableName],
    var_alloc: VarAllocator,
    loc: Location,
) -> Expr {
    let scrutinee = Expr(
        ExprKind.Var(var_a),
        loc,
        None,
    );

    let arms: Vec[MatchArm] = enum_def
        .variants
        .iter()
        .map(|variant| {
            let n = variant.items.len();
            let field_vars = allocate_vars(n, I.intern("f"), var_alloc);
            let variant_qname = variant.qualified_name.unwrap();
            let pattern = Pattern(
                PatternKind.Named(NamedPatternInfo(
                    name: Name.inner(variant_qname),
                    args: binding_pats(field_vars, loc),
                    named_args: Vec.new(),
                    has_rest: False,
                )),
                loc,
                None,
            );
            let mapped_args: Vec[Expr] = field_vars
                .iter()
                .map(|v| call_fn(fn_qname, var_expr(v, loc), extra_arg_vars, loc))
                .collect();
            let body = Expr(
                ExprKind.FunctionCall(
                    FunctionCallInfo(
                        variant_qname,
                        FunctionKind.VariantCtor,
                        mapped_args,
                        WitnessInfo.new(),
                        Vec.new(),
                    )
                ),
                loc,
                None,
            );
            MatchArm(pattern, body)
        })
        .collect();

    Expr(
        ExprKind.Match(MatchInfo(scrutinee, arms)),
        loc,
        None,
    )
}

fn call_fn(fn_qname: QualifiedName, arg: Expr, extra_arg_vars: Vec[VariableName], loc: Location) -> Expr {
    let args: Vec[Expr] = [arg];
    for ev in extra_arg_vars {
        args.push(Expr(ExprKind.Var(ev), loc, None));
    }
    Expr(
        ExprKind.FunctionCall(FunctionCallInfo(fn_qname, FunctionKind.UserDefined, args, WitnessInfo.new(), Vec.new())),
        loc,
        None,
    )
}

fn var_expr(v: VariableName, loc: Location) -> Expr {
    Expr(
        ExprKind.Var(v),
        loc,
        None,
    )
}

pub fn build_map_method_struct(
    struct_def: StructDef,
    parent_qn: QualifiedName,
    type_arg_defs: Option[TypeArgDefs],
    self_type: TypeDef,
    fn_qname: QualifiedName,
    short_name: Identifier,
    module_name: I.String,
    extra_args: Vec[FunctionArg],
    body_strategy: BodyStrategy,
) -> (FunctionDef, Identifier) {
    let loc = struct_def.name.location;
    let var_alloc = VarAllocator.new();
    let var_a = var_alloc.allocate_user(I.intern("a"));
    let extra_arg_defs: Vec[FunctionArg] = extra_args.iter().map(|arg| {
        let v = var_alloc.allocate_user(arg.name.get_user_name());
        FunctionArg(v, arg.type_def, None)
    }).collect();
    let extra_arg_vars: Vec[VariableName] = extra_arg_defs.iter().map(|arg| arg.name).collect();
    let body = match body_strategy {
        BodyStrategy.Identity => Expr(ExprKind.Var(var_a), loc, None),
        BodyStrategy.Unreachable => build_unreachable(loc),
        BodyStrategy.Generate => {
            let struct_qname = struct_def.qualified_name.unwrap();
            let mapped: Vec[Expr] = field_exprs(struct_def.fields, var_a, loc)
                .into_iter()
                .map(|e| call_fn(fn_qname, e, extra_arg_vars, loc))
                .collect();
            Expr(
                ExprKind.FunctionCall(FunctionCallInfo(struct_qname, FunctionKind.StructCtor, mapped, WitnessInfo.new(), Vec.new())),
                loc,
                None,
            )
        }
    };
    let method = make_unary_method(
        parent_qn,
        short_name,
        type_arg_defs,
        self_type,
        Some(self_type),
        var_a,
        extra_arg_defs,
        body,
        module_name,
        var_alloc,
    );
    (method, short_name)
}

}
