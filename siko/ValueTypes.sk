module Siko.ValueTypes {

import Std.Map
import Siko.AST.QualifiedName
import Siko.HIR.Program
import Siko.Unification.Utils
import Siko.Utils.SCC as SCC

pub fn calculate_value_types(program: Program) -> Vec[QualifiedName] {
    let graph: Map[QualifiedName, Vec[QualifiedName]] = Map.new();

    for (qname, edef) in program.enums.iter() {
        let deps: Vec[QualifiedName] = Vec.new();
        for variant in edef.variants.iter() {
            for item in variant.items.iter() {
                collect_names(item.ty, deps);
            }
        }
        deps.dedup();
        graph.insert(qname, deps);
    }

    let ordered: Vec[QualifiedName] = Vec.new();

    for (qname, sdef) in program.structs.iter() {
        let deps: Vec[QualifiedName] = Vec.new();
        for field in sdef.fields.iter() {
            collect_names(field.ty, deps);
        }
        deps.dedup();
        graph.insert(qname, deps);
    }

    let sccs = SCC.compute(graph);

    for scc in sccs {
        if scc.len() == 1 {
            let node = scc[0];
            if let Some(s) = program.structs.get(node) {
                if s.is_value_type() || s.fields.len() == 0 {
                    s.value_type = True;
                    program.structs.insert(node, s);
                    ordered.push(node);
                    continue;
                }
            }
            if !program.enums.contains_key(node) {
                continue;
            }
            let deps = graph.get(node).unwrap_or([]);
            let has_self_loop = deps.iter().any(|d| d == node);
            if !has_self_loop {
                let e = program.enums.get(node).unwrap();
                e.value_type = True;
                program.enums.insert(node, e);
                ordered.push(node);
            }
        }
    }

    ordered
}

}
