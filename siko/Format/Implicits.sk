module Siko.Format.Implicits {

import Siko.AST.Implicits
import Siko.Interner as I
import Siko.Format.Formatter
import Siko.Format.Types

pub fn format_implicit_def(f: Formatter, def: ImplicitDef) {
    f.push_indent();
    if def.public {
        f.push("pub ");
    }
    f.push("implicit ");
    f.push(I.resolve(def.name.name));
    f.push(": ");
    format_type_def(f, def.ty);
    f.push("\n");
}

}
