module Siko.Config {

pub implicit current: Config

pub struct Config {
    pub check_only: Bool,
    pub pass: Option[String],
    pub debug_typecheck: Bool,
    pub debug_mono: Bool,
    pub closure_ptr: Bool,
    pub trace: Bool,
    pub paths: Vec[String],
    pub check_safety: Bool,
    pub output: Option[String],
    pub optimize: Bool,
    pub san: Bool,
    pub tsan: Bool,
    pub no_std: Bool,
    pub std_path: Option[String],
    pub test: Bool,

    pub fn new() -> Config {
        Config(
            check_only: False,
            pass: None,
            debug_typecheck: False,
            debug_mono: False,
            closure_ptr: False,
            trace: False,
            paths: Vec.new(),
            check_safety: False,
            output: None,
            optimize: False,
            san: False,
            tsan: False,
            no_std: False,
            std_path: None,
            test: False,
        )
    }
}

pub fn set_config(c: Config) {
    current = c;
}

pub fn get_config() -> Config {
    current
}

}
