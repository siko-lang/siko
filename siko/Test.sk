module Siko.Test {

import Siko.AST.Expr as E
import Siko.AST.Function
import Siko.AST.Identifier
import Siko.AST.QualifiedName
import Siko.AST.Statement as S
import Siko.AST.Type
import Siko.HIR.Program
import Siko.Interner as I
import Siko.Location
import Siko.Utils.VarAllocator
import Siko.Constants.Builtins as B

pub fn build_test_main(program: Program) {
    let test_fns: Vec[(QualifiedName, FunctionDef)] = Vec.new();
    for (key, f) in program.functions {
        let is_root = match f.source_package {
            Some(pkg) => pkg.is_root,
            None => False,
        };
        if is_root && f.is_test() {
            test_fns.push((key, f));
        }
    }

    let print_str_qname = B.get_console_print_qn();
    let println_str_qname = B.get_console_println_qn();
    let flush_qname = B.get_console_flush_qn();

    let stmts: Vec[S.Statement] = Vec.new();
    for (key, f) in test_fns {
        let loc = f.name.location;
        let fn_name = I.resolve(key.name());

        let print_call = E.Expr.new(
            E.ExprKind.FunctionCall(E.FunctionCallInfo(
                qname: print_str_qname,
                kind: E.FunctionKind.UserDefined,
                args: [E.Expr.new(E.ExprKind.StringLiteral("${fn_name}..."), loc)],
            )),
            loc,
        );
        let flush_before = E.Expr.new(
            E.ExprKind.FunctionCall(E.FunctionCallInfo(
                qname: flush_qname,
                kind: E.FunctionKind.UserDefined,
                args: Vec.new(),
            )),
            loc,
        );
        let test_call = E.Expr.new(
            E.ExprKind.FunctionCall(E.FunctionCallInfo(
                qname: key,
                kind: E.FunctionKind.UserDefined,
                args: Vec.new(),
            )),
            loc,
        );
        let done_call = E.Expr.new(
            E.ExprKind.FunctionCall(E.FunctionCallInfo(
                qname: println_str_qname,
                kind: E.FunctionKind.UserDefined,
                args: [E.Expr.new(E.ExprKind.StringLiteral("done"), loc)],
            )),
            loc,
        );
        let flush_after = E.Expr.new(
            E.ExprKind.FunctionCall(E.FunctionCallInfo(
                qname: flush_qname,
                kind: E.FunctionKind.UserDefined,
                args: Vec.new(),
            )),
            loc,
        );
        stmts.push(S.Statement.Expr(print_call));
        stmts.push(S.Statement.Expr(flush_before));
        stmts.push(S.Statement.Expr(test_call));
        stmts.push(S.Statement.Expr(done_call));
        stmts.push(S.Statement.Expr(flush_after));
    }

    let loc = Location.new(0, Span(0, 0));
    let body = E.Expr.new(E.ExprKind.Block(E.BlockInfo(stmts)), loc);
    let main_qname = B.get_main_entry_qn();
    let main_fn = FunctionDef(
        annotations: Vec.new(),
        public: True,
        name: Identifier.new(I.intern("Main.main"), loc),
        qualified_name: Some(main_qname),
        kind: FunctionDefKind.Regular,
        type_arg_defs: None,
        args: Vec.new(),
        yield_type: None,
        result_type: Some(TypeDef.Tuple(Vec.new())),
        body: Some(body),
        module_name: I.intern("Main"),
        var_allocator: VarAllocator.new(),
        is_varargs: False,
        default_value_names: Vec.new(),
        source_package: None,
    );
    program.functions.insert(main_qname, main_fn);
    program.module_names.push(I.intern("Main"));
}

}
