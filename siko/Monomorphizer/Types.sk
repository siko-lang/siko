module Siko.Monomorphizer.Types {

import Siko.AST.Type
import Siko.AST.Name
import Siko.Unification.Sub
import Siko.Interner as I
import Siko.Monomorphizer
import Siko.Monomorphizer.Specialize
import Siko.Monomorphizer.Error

pub fn specialize_type(ty: TypeDef, mono: Monomorphizer) -> TypeDef {
    match ty {
        TypeDef.Var(TypeVar.Named(s)) => {
            let t = match mono.sub.lookup_named(s) {
                Some(t) => t.clone(),
                None => panic("specialize_type: named type var '${I.resolve(s)}' not found in substitution\n${mono.sub.format()}"),
            };
            t.specialize(mono)
        }
        TypeDef.Var(TypeVar.Var(_)) => panic("type var in mono"),
        TypeDef.Named(NamedInfo(name, args)) if mono.source.effect_associated_types.contains_key(name.resolved()) => {
            match mono.current_effect_associated_type_ctx.get(name.resolved()) {
                Some(info) => info.ty.specialize(mono),
                None => {
                    mono.errors.push(MonoError.UnboundEffectAssociatedType(name.resolved().name(), mono.current_location.unwrap()));
                    TypeDef.Never(False)
                }
            }
        }
        TypeDef.Named(NamedInfo(name, args)) => {
            let spec_args: Vec[TypeDef] = args.specialize(mono)
            // Register the data type under EAT-resolved (but otherwise source-level)
            // args, so it lands under the same mono name it is referenced by — the
            // reference goes through spec_args, which renders identically.
            mono.enqueue_named_types(name.resolved(), eat_specialize_args(args.apply(mono.sub), mono));
            TypeDef.Named(NamedInfo(
                Name.inner(mono.data_mono_key(
                    name.resolved(),
                    spec_args,
                    mono.current_effect_associated_type_ctx.clone(),
                )),
                [],
            ))
        }
        TypeDef.Tuple(args) => TypeDef.Tuple(args.specialize(mono)),
        TypeDef.Fn(args, result) => TypeDef.Fn(
            args.specialize(mono),
            result.specialize(mono),
        ),
        TypeDef.FnPtr(args, result) => TypeDef.FnPtr(
            args.specialize(mono),
            result.specialize(mono),
        ),
        TypeDef.Paren(inner) => TypeDef.Paren(inner.specialize(mono)),
        TypeDef.Ptr(inner) => TypeDef.Ptr(inner.specialize(mono)),
        TypeDef.Array(inner, n) => TypeDef.Array(inner.specialize(mono), n),
        TypeDef.Numeric(n) => TypeDef.Numeric(n),
        TypeDef.Never(t) => TypeDef.Never(t),
        TypeDef.Void => TypeDef.Void,
        TypeDef.VoidPtr => TypeDef.VoidPtr,
        TypeDef.Co(CoroutineInfo(yield_ty, return_ty)) => TypeDef.Co(CoroutineInfo(yield_ty.specialize(mono), return_ty.specialize(mono))),
        TypeDef.Wildcard => panic("Wildcard in specialize_type"),
    }
}

pub fn eat_specialize_args(args: Vec[TypeDef], mono: Monomorphizer) -> Vec[TypeDef] {
    args.iter().map(|a| eat_specialize(a, mono)).collect()
}

// Resolve effect associated types to their bound concrete type, recursing through
// type arguments, without otherwise monomorphizing. Used to build data type args
// that are EAT-resolved yet still source-level — so a type registered for an EAT
// lands under the same mono name it is referenced by, while staying re-specializable
// by process_struct/enum. A nominal type that merely *contains* an EAT in a field
// (e.g. `struct Blah { f: Foo }`) is left as-is; its eat ctx rides along via
// data_eat_deps.
pub fn eat_specialize(ty: TypeDef, mono: Monomorphizer) -> TypeDef {
    match ty {
        TypeDef.Named(NamedInfo(name, _)) if mono.source.effect_associated_types.contains_key(name.resolved()) => {
            match mono.current_effect_associated_type_ctx.get(name.resolved()) {
                Some(info) => eat_specialize(info.ty, mono),
                None => {
                    mono.errors.push(MonoError.UnboundEffectAssociatedType(name.resolved().name(), mono.current_location.unwrap()));
                    TypeDef.Never(False)
                }
            }
        }
        TypeDef.Named(NamedInfo(name, args)) => TypeDef.Named(NamedInfo(name, eat_specialize_args(args, mono))),
        TypeDef.Tuple(args) => TypeDef.Tuple(eat_specialize_args(args, mono)),
        TypeDef.Fn(args, result) => TypeDef.Fn(eat_specialize_args(args, mono), eat_specialize(result, mono)),
        TypeDef.FnPtr(args, result) => TypeDef.FnPtr(eat_specialize_args(args, mono), eat_specialize(result, mono)),
        TypeDef.Paren(inner) => TypeDef.Paren(eat_specialize(inner, mono)),
        TypeDef.Ptr(inner) => TypeDef.Ptr(eat_specialize(inner, mono)),
        TypeDef.Array(inner, n) => TypeDef.Array(eat_specialize(inner, mono), n),
        _ => ty,
    }
}

}

