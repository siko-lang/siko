instance Specialize[ExprKind] = auto(Map)

instance Specialize[S.LetInfo]        = auto(Map)
instance Specialize[S.DeclareInfo]    = auto(Map)
instance Specialize[BlockInfo]        = auto(Map)
instance Specialize[S.Statement]      = auto(Map)

instance Specialize[ImplicitRefInfo] {
    fn specialize(info: ImplicitRefInfo, mono: Monomorphizer) -> ImplicitRefInfo {
        if !mono.current_implicit_ctx.contains(info.name) {
            mono.errors.push(MonoError.UnsetImplicit(info.name.name(), mono.current_location.unwrap()));
        }
        info
    }
}

instance Specialize[FunctionPtrInfo] {
    fn specialize(info: FunctionPtrInfo, mono: Monomorphizer) -> FunctionPtrInfo {
        let func = mono.source.functions.get(info.name).unwrap();
        let generic_params = func.type_arg_defs.type_params();
        let param_ann_tys: Vec[TypeDef] = func.args.iter().map(|a| a.type_def).collect();
        let result_ann_ty = func.result_type;
        let callee_bounds = func.type_arg_defs.map(|tad| tad.bounds).unwrap_or_else(|| Vec.new());

        let concrete_ty = mono.current_expr_ty.apply(mono.sub).unwrap();
        let (concrete_params, concrete_ret) = match concrete_ty {
            TypeDef.FnPtr(ps, r) => (ps, r),
            _ => panic("specialize FunctionPtrInfo: current_expr_ty is not FnPtr"),
        };

        let inst_map = Substitution.new();
        for (p, a) in param_ann_tys.iter().zip(concrete_params.iter()) {
            extract_named_bindings(p, a, inst_map);
        }
        if let Some(rt) = result_ann_ty {
            extract_named_bindings(rt, concrete_ret, inst_map);
        }

        let witness_list = info.witnesses.witnesses;
        for (bound_idx, bound) in callee_bounds.iter().enumerate() {
            if bound.constraints.is_empty() { continue; }
            let witness = match witness_list.get_opt(bound_idx) {
                Some(w) => w,
                None => continue,
            };
            let primary_args = bound_args(bound, inst_map, Substitution.new());
            // The witness already names the instance; bind its associated types
            // into inst_map without re-resolving.
            extract_from_known_instance(
                mono.source,
                mono.resolve_witness(witness),
                primary_args,
                bound.constraints,
                inst_map,
                TypeVarAllocator.new(),
            );
        }

        let callee_type_args: Vec[TypeDef] = generic_params.iter()
            .map(|p| inst_map.lookup_named(p).unwrap().clone())
            .collect();
        let callee_witnesses: Vec[ResolvedWitness] = witness_list.iter()
            .map(|w| mono.resolve_witness(w))
            .collect();

        let is_extern = func.is_extern();
        let is_c_callback = func.is_c_callback();
        let effect_ctx = if is_extern { EffectCtx.new() } else { mono.current_effect_ctx.clone() };
        let implicit_ctx = if is_extern || is_c_callback { ImplicitCtx.new() } else { mono.current_implicit_ctx.clone() };
        let effect_associated_type_ctx = if is_extern { EffectAssociatedTypeCtx.new() } else { mono.current_effect_associated_type_ctx.clone() };
        let mono_key = fn_mono_key(
            info.name,
            callee_type_args,
            callee_witnesses,
            effect_ctx.clone(),
            effect_associated_type_ctx.clone(),
            implicit_ctx.clone());
        if !mono.fn_done.contains(mono_key) {
            mono.fn_queue.push_back(FnWork(
                info.name,
                callee_type_args,
                callee_witnesses,
                effect_ctx,
                effect_associated_type_ctx,
                implicit_ctx,
            ));
        }
        FunctionPtrInfo(mono_key, WitnessInfo.new())
    }
}

instance Specialize[CreateClosureInfo] {
    fn specialize(info: CreateClosureInfo, mono: Monomorphizer) -> CreateClosureInfo {
        let lambda_func = mono.source.functions.get(info.name).unwrap();
        let generic_params = lambda_func.type_arg_defs.type_params();
        let callee_type_args: Vec[TypeDef] = generic_params
            .iter()
            .map(|p| mono.sub.lookup_named(p).unwrap().clone())
            .collect();
        let callee_witnesses: Vec[ResolvedWitness] = info.witnesses.witnesses
            .iter()
            .map(|w| mono.resolve_witness(w))
            .collect();
        let mono_callee = fn_mono_key(
            info.name,
            callee_type_args,
            callee_witnesses,
            mono.current_effect_ctx.clone(),
            mono.current_effect_associated_type_ctx.clone(),
            mono.current_implicit_ctx.clone(),
        );
        if !mono.fn_done.contains(mono_callee) {
            mono.fn_queue.push_back(FnWork(
                info.name.clone(),
                callee_type_args,
                callee_witnesses,
                mono.current_effect_ctx.clone(),
                mono.current_effect_associated_type_ctx.clone(),
                mono.current_implicit_ctx.clone(),
            ));
        }
        CreateClosureInfo(mono_callee, info.params.clone(), WitnessInfo.new())
    }
}

instance Specialize[NamedArgument]    = auto(Map, =)
instance Specialize[NamedPatternArg]  = auto(Map, =)
instance Specialize[NamedPatternInfo] = auto(Map)
instance Specialize[MethodCallInfo]          = auto(Map)
instance Specialize[CallInfo]                = auto(Map)
instance Specialize[TypeAssociatedCallInfo]  = auto(Map, !)

instance Specialize[FunctionCallInfo] {
    fn specialize(info: FunctionCallInfo, mono: Monomorphizer) -> FunctionCallInfo {
        let is_co = info.is_coroutine_create;
        match info.kind {
            FunctionKind.UserDefined => process_user_defined_fn(info.qname, info.args, mono, info.witnesses, is_co),
            FunctionKind.Extern(_)   => process_extern_fn(info.qname, info.args, info.kind, mono, is_co),
            FunctionKind.StructCtor  => process_struct_ctor(info.qname, info.args, mono, is_co),
            FunctionKind.VariantCtor => process_variant_ctor(info.qname, info.args, mono, is_co),
            FunctionKind.Builtin     => process_builtin_fn(info.qname, info.args, mono, is_co),
        }
    }
}

instance Specialize[WithInfo] {
    fn specialize(info: WithInfo, mono: Monomorphizer) -> WithInfo {
        let saved_effect_ctx = mono.current_effect_ctx.clone();
        let saved_effect_associated_type_ctx = mono.current_effect_associated_type_ctx.clone();
        let saved_implicit_ctx = mono.current_implicit_ctx.clone();
        let implicit_selections = [];
        for sel in info.selections {
            match sel {
                HandlerSelection.EffectFunction(method, handler, _, witness_info) => {
                    // Record the handler together with the witnesses for its bounds
                    // (computed at typecheck). Resolve those witnesses to modules
                    // here, at the `with` site, where the enclosing frame is known —
                    // a FunctionBound witness indexes the with-site's witness list,
                    // not the call site's. The handler itself is monomorphized later,
                    // at the effect call site, in the call-site dynamic context.
                    let handler_witnesses: Vec[ResolvedWitness] = witness_info.witnesses.iter().map(|w| mono.resolve_witness(w)).collect();
                    mono.current_effect_ctx.insert(method.clone(), HandlerInfo(handler.clone(), handler_witnesses));
                }
                HandlerSelection.Implicit(implicit_qn, var) => {
                    mono.current_implicit_ctx.insert(implicit_qn.clone());
                    implicit_selections.push(HandlerSelection.Implicit(implicit_qn.clone(), var.clone()));
                }
                HandlerSelection.TypeAssociation(assoc_qname, handler_type, _, witness_info) => {
                    // Store the bound type source-level (un-specialized). eat_specialize
                    // substitutes it into data type args, where it must stay source-level
                    // so process_struct can re-specialize fields and data_eat_deps lookups
                    // (keyed by source qname) still hit. specialize_type specializes it on
                    // read. Resolve the EAT's bound witnesses here, at the `with` site, so
                    // an EffectAssociatedTypeBound can later fetch them from this ctx.
                    let resolved: Vec[ResolvedWitness] = witness_info.witnesses.iter().map(|w| mono.resolve_witness(w)).collect();
                    mono.current_effect_associated_type_ctx.insert(assoc_qname.clone(), TypeHandlerInfo(handler_type, resolved));
                }
                HandlerSelection.Unresolved(_, _) |
                HandlerSelection.UnresolvedType(_, _) => panic("mono: unresolved HandlerSelection")
            }
        }
        let spec_body = info.body.specialize(mono);
        mono.current_effect_ctx = saved_effect_ctx;
        mono.current_effect_associated_type_ctx = saved_effect_associated_type_ctx;
        mono.current_implicit_ctx = saved_implicit_ctx;
        WithInfo(implicit_selections, spec_body)
    }
}

instance Specialize[MatchInfo] = auto(Map)

instance Specialize[Pattern] {
    fn specialize(pattern: Pattern, mono: Monomorphizer) -> Pattern {
        let spec_ty = pattern.ty.specialize(mono);
        match pattern.kind {
            PatternKind.Named(info) => {
                let qn = info.name.resolved();
                // Build the variant/struct mono name from the pattern's own specialized
                // type, so it can't diverge from the scrutinee (whose type is specialized
                // the same way). Recomputing from raw args would leave effect associated
                // types in the args unresolved and land on a parallel, unmatchable enum.
                let mono_data = match spec_ty {
                    Some(TypeDef.Named(NamedInfo(name, _))) => name.resolved(),
                    _ => panic("Specialize[Pattern]: named pattern without a Named type"),
                };
                let kind = if mono.source.variant_enum_map.contains_key(qn) {
                    let v = mono.source.variant(qn);
                    let mono_variant = Name.Resolved(get_mono_variant_qn(mono_data, v.qualified_name.unwrap()), info.name.location());
                    PatternKind.Named(NamedPatternInfo(name: mono_variant, args: info.args.specialize(mono), named_args: info.named_args, has_rest: False))
                } else {
                    PatternKind.Named(NamedPatternInfo(name: Name.inner(mono_data), args: info.args.specialize(mono), named_args: info.named_args, has_rest: False))
                };
                Pattern(kind, pattern.location.clone(), spec_ty)
            }
            PatternKind.Typed(_, _) => panic("typed pattern in mono"),
            kind => Pattern(kind.specialize(mono), pattern.location.clone(), spec_ty)
        }
    }
}

instance Specialize[FieldDef] {
    fn specialize(field: FieldDef, mono: Monomorphizer) -> FieldDef {
        mono.current_location = Some(field.name.location.clone());
        FieldDef(
            public: field.public,
            name: field.name.clone(),
            ty: field.ty.specialize(mono),
            default_value: None,
        )
    }
}

instance Specialize[TypeDef] {
    fn specialize(ty: TypeDef, mono: Monomorphizer) -> TypeDef {
        specialize_type(ty, mono)
    }
}

instance Specialize[ItemInfo] {
    fn specialize(item: ItemInfo, mono: Monomorphizer) -> ItemInfo {
        if let Some(name) = item.name {
            mono.current_location = Some(name.location.clone());
        }
        ItemInfo(name: item.name.clone(), ty: item.ty.specialize(mono))
    }
}

instance Specialize[VariantDef] {
    fn specialize(variant: VariantDef, mono: Monomorphizer) -> VariantDef {
        mono.current_location = Some(variant.name.location.clone());
        VariantDef(
            variant.name.clone(),
            variant.qualified_name.clone(),
            variant.items.specialize(mono),
        )
    }
}

instance Specialize[FunctionArg] {
    fn specialize(arg: FunctionArg, mono: Monomorphizer) -> FunctionArg {
        FunctionArg(
            arg.name.clone(),
            arg.type_def.specialize(mono),
            None,
        )
    }
}

instance Specialize[Expr] {
    fn specialize(expr: Expr, mono: Monomorphizer) -> Expr {
        mono.current_location = Some(expr.location.clone());
        mono.current_expr_ty = expr.ty.clone();
        match mono.current_expr_ty {
            Some(ty) if ty.is_mono(False) => {
                println("expr ${format_expr(expr)}");
                panic("current expr ty in Specialize[Expr] is not mono");
            }
            None => {
                println("expr ${format_expr(expr)}");
                panic("current expr ty is empty!");
            }
            _ => {}
        }
        match expr.kind {
            ExprKind.TypeAssociatedCall(info) => {
                let fn_call_info = process_type_associated_call(info, mono);
                Expr(ExprKind.FunctionCall(fn_call_info), expr.location.clone(), expr.ty.specialize(mono))
            }
            kind => Expr(kind.specialize(mono), expr.location.clone(), expr.ty.specialize(mono))
        }
    }
}

pub trait TypeParams[T] {
    fn type_params(t: T) -> Vec[I.String]
}

instance TypeParams[TypeArgDefs] {
    fn type_params(def: TypeArgDefs) -> Vec[I.String] {
        def.type_args.iter().map(|id| id.name.clone()).collect()
    }
}

instance[T: TypeParams[T]] TypeParams[Option[T]] {
    fn type_params(o: Option[T]) -> Vec[I.String] {
        o.map(|t| t.type_params()).unwrap_or_else(|| Vec.new())
    }
}

}
