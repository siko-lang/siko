pub trait Specialize[T] {
    fn specialize(t: T, mono: Monomorphizer) -> T
}

instance[T: Specialize[T]] Specialize[Vec[T]] {
    fn specialize(v: Vec[T], mono: Monomorphizer) -> Vec[T] {
        v.into_iter().map(|t| t.specialize(mono)).collect()
    }
}

instance[T: Specialize[T]] Specialize[Option[T]] {
    fn specialize(opt: Option[T], mono: Monomorphizer) -> Option[T] {
        opt.map(|t| t.specialize(mono))
    }
}

instance Specialize[Location]         = auto(Map, =)
instance Specialize[I.String]         = auto(Map, =)
instance Specialize[String]           = auto(Map, =)
instance Specialize[Int]              = auto(Map, =)
instance Specialize[U8]               = auto(Map, =)
