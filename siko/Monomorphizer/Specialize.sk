instance Specialize[QualifiedName]    = auto(Map, =)
instance Specialize[VariableName]     = auto(Map, =)
instance Specialize[Name]             = auto(Map, =)
instance Specialize[Identifier]       = auto(Map, =)
instance Specialize[FunctionKind]     = auto(Map, =)
instance Specialize[BinaryOp]         = auto(Map, =)
instance Specialize[UnaryOp]          = auto(Map, =)
instance Specialize[WitnessInfo]      = auto(Map, =)
instance Specialize[HandlerSelection] = auto(Map, =)

instance Specialize[MatchArm]         = auto(Map)

instance Specialize[LambdaArg]        = auto(Map, =)
