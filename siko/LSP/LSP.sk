module Siko.LSP {

import Siko.Driver
import Siko.Driver.Passes
import Siko.FileManager
import Siko.Diagnostics as D
import Siko.Diagnostics.Util as D
import Std.Effects.Console
import Std.Effects.Network
import Std.Effects.Spawn
import Std.Fs.Directory
import Std.Http
import Std.Http.Server
import Std.IO.Async.Scheduler as Async
import Std.Json
import Std.Json.Util as JsonUtil
import Std.Map
import Std.StringBuilder
import Std.Sys.Process as Sys

// A diagnostic resolved into a path and 0-based line/column range
struct FileDiagnostic {
    file: Option[String],
    line: Int,
    col: Int,
    end_line: Int,
    end_col: Int,
    severity: D.Severity,
    message: String,
}

// Serve the LSP protocol over local HTTP. The VS Code client sends one
// JSON-RPC-shaped message per POST and receives a JSON array of outbound
// messages to apply locally.
pub fn run_server() {
    let port = read_port();
    let s = Async.Scheduler.new();
    with Async.current = s,
         TcpNetwork = AsyncTcp,
         Spawn = AsyncSpawn,
         Console = StdConsole {
        spawn(|| { listen_and_serve(make_handler(), port).unwrap(); });
        s.run_tasks();
    }
}

fn read_port() -> U16 {
    match Sys.getenv("SIKO_LSP_PORT") {
        Some(port_str) => {
            match port_str.parse_int(10) {
                Ok(port) if port > 0 && port <= 65535 => port.as_u16(),
                _ => {
                    Std.Console.println("error: invalid SIKO_LSP_PORT: ${port_str}");
                    Sys.exit(1);
                }
            }
        }
        None => {
            Std.Console.println("error: SIKO_LSP_PORT must be set for lsp");
            Sys.exit(1);
        }
    }
}

fn handle_http(req: Request) -> Response {
    if req.method() == "GET" && req.path() == "/health" {
        return Response.new("200 OK", "text/plain", "ok");
    }
    if req.method() != "POST" || req.path() != "/rpc" {
        return Response.new("404 Not Found", "text/plain", "Not Found");
    }
    let message = match JsonUtil.parse(req.body()) {
        Ok(m) => m,
        Err(e) => {
            let body = JsonUtil.serialize(obj([("error", Json.Str(e.to_string()))]));
            return Response.new("400 Bad Request", "application/json", body);
        }
    };
    let body = JsonUtil.serialize(Json.Array(handle_message(message)));
    Response.new("200 OK", "application/json", body)
}

fn make_handler() -> fn(Request) -> Response {
    |req| handle_http(req)
}

fn handle_message(message: Json) -> Vec[Json] {
    let out: Vec[Json] = Vec.new();
    let method = match message.get_field("method") {
        Ok(Json.Str(method)) => method,
        _ => return out,
    };
    let id = match message.get_field("id") {
        Ok(id) => Some(id),
        Err(_) => None,
    };
    match method {
        "initialize" => out.push(make_response(id, initialize_result())),
        "initialized" => out.extend(check_and_publish()),
        "textDocument/didSave" => out.extend(check_and_publish()),
        "shutdown" => out.push(make_response(id, Json.Null)),
        "exit" => { Async.stop(); }
        _ => {
            // requests must be answered, unknown notifications can be dropped
            match id {
                Some(_) => out.push(method_not_found(id, method)),
                None => {}
            }
        }
    }
    out
}

fn obj(fields: Vec[(String, Json)]) -> Json {
    let m: Map[String, Json] = Map.new();
    for (name, value) in fields {
        m.insert(name, value);
    }
    Json.Object(m)
}

fn make_response(id: Option[Json], result: Json) -> Json {
    let id = match id {
        Some(id) => id,
        None => Json.Null,
    };
    obj([("jsonrpc", Json.Str("2.0")), ("id", id), ("result", result)])
}

fn method_not_found(id: Option[Json], method: String) -> Json {
    let id = match id {
        Some(id) => id,
        None => Json.Null,
    };
    let error = obj([("code", Json.Number(-32601)), ("message", Json.Str("method not found: ${method}"))]);
    obj([("jsonrpc", Json.Str("2.0")), ("id", id), ("error", error)])
}

fn notification(method: String, params: Json) -> Json {
    obj([("jsonrpc", Json.Str("2.0")), ("method", Json.Str(method)), ("params", params)])
}

fn initialize_result() -> Json {
    let sync = obj([("openClose", Json.Boolean(True)),
                    ("change", Json.Number(0)),
                    ("save", Json.Boolean(True))]);
    obj([("capabilities", obj([("textDocumentSync", sync)])),
         ("serverInfo", obj([("name", Json.Str("siko"))]))])
}

// Check the whole project and return fresh diagnostics for every affected file.
// The client clears its diagnostic collection before applying this batch.
fn check_and_publish() -> Vec[Json] {
    let messages: Vec[Json] = Vec.new();
    let diagnostics = run_check();
    let root = Directory.get_current_dir().expect("getcwd failed");
    let by_uri: Map[String, Vec[Json]] = Map.new();
    for d in diagnostics {
        match d.file {
            Some(file) => {
                let uri = path_to_uri(root, file);
                let items = match by_uri.get(uri) {
                    Some(items) => items,
                    None => Vec.new(),
                };
                items.push(to_lsp_diagnostic(d));
                by_uri.insert(uri, items);
            }
            None => {
                // no location: surface it in the editor as a message
                let params = obj([("type", Json.Number(severity_code(d.severity))),
                                  ("message", Json.Str(d.message))]);
                messages.push(notification("window/showMessage", params));
            }
        }
    }
    for (uri, items) in by_uri {
        let params = obj([("uri", Json.Str(uri)), ("diagnostics", Json.Array(items))]);
        messages.push(notification("textDocument/publishDiagnostics", params));
    }
    messages
}

// Run the check passes with fresh compiler state and collect the diagnostics
fn run_check() -> Vec[FileDiagnostic] {
    let fm = FileManager.new();
    with Siko.FileManager.filemanager = fm {
        let driver = Driver.new();
        with Siko.Driver.current = driver {
            driver.compile(None, Passes.build_check_passes(driver));
        }
        resolve_diagnostics(driver)
    }
}

// Turn the collected diagnostics into path + line/column form
// while the file manager of the check run is still in scope
fn resolve_diagnostics(d: Driver) -> Vec[FileDiagnostic] {
    let result: Vec[FileDiagnostic] = Vec.new();
    for d in d.get_diagnostics() {
        match d.location {
            Some(location) => {
                let path = Siko.FileManager.get_name(location.file_id);
                let source = Siko.FileManager.get_content(location.file_id);
                let line_starts = D.compute_line_starts(source);
                let (line, col) = D.line_col(line_starts, location.span.start);
                let span_end = location.span.end.max(location.span.start);
                let (end_line, end_col) = D.line_col(line_starts, span_end);
                result.push(FileDiagnostic(Some(path), line, col, end_line, end_col, d.severity, d.message));
            }
            None => {
                result.push(FileDiagnostic(None, 0, 0, 0, 0, d.severity, d.message));
            }
        }
    }
    result
}

fn to_lsp_diagnostic(d: FileDiagnostic) -> Json {
    let start = obj([("line", Json.Number(d.line)), ("character", Json.Number(d.col))]);
    let end = obj([("line", Json.Number(d.end_line)), ("character", Json.Number(d.end_col))]);
    let range = obj([("start", start), ("end", end)]);
    obj([("range", range),
         ("severity", Json.Number(severity_code(d.severity))),
         ("source", Json.Str("siko")),
         ("message", Json.Str(d.message))])
}

fn severity_code(severity: D.Severity) -> Int {
    match severity {
        D.Severity.Error => 1,
        D.Severity.Warning => 2,
    }
}

// Build a file:// URI from a possibly relative path, e.g. "siko/Report.sk" -> "file:///root/siko/Report.sk"
fn path_to_uri(root: String, path: String) -> String {
    let abs = if path.starts_with("/") {
        path
    } else {
        "${root}/${path}"
    };
    let sb = StringBuilder.new();
    sb.push("file://");
    let bytes = abs.as_slice();
    for i in 0..abs.len() {
        let c = bytes[i];
        if c >= 'a' && c <= 'z' || c >= 'A' && c <= 'Z' || c >= '0' && c <= '9'
           || c == '/' || c == '.' || c == '-' || c == '_' || c == '~' {
            sb.push(String.from_byte(c));
        } else {
            sb.push("%" + to_hex(c.as_int(), uppercase: True));
        }
    }
    sb.to_string()
}

}
