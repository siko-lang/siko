module Siko.Monomorphizer {

import Siko.Monomorphizer.Error
import Siko.Monomorphizer.Function
import Siko.Monomorphizer.Data
import Siko.Monomorphizer.Specialize
import Siko.Monomorphizer.DataPreprocessor
import Siko.Monomorphizer.Statistics
import Siko.AST.Type
import Siko.AST.QualifiedName
import Siko.Constants.Builtins as B
import Siko.AST.Expr
import Siko.Location
import Siko.HIR.Program
import Siko.Instances.InstanceResolver
import Siko.Instances.FunctionInstanceResolver
import Siko.Unification.Sub
import Siko.Unification.Apply
import Siko.Config
import Std.Map
import Std.Set
import Std.VecDeque
import Siko.Interner as I
import Siko.Format.Utils

pub struct DataWork {
    pub qname: QualifiedName,
    pub type_args: Vec[TypeDef],
    pub mono_ctx: MonoContext,
}

pub struct FnWork {
    pub qname: QualifiedName,
    pub type_args: Vec[TypeDef],
    pub witnesses: Vec[ResolvedWitness],
    pub mono_ctx: MonoContext,
}

@derive(PartialEq, Std.Ops.Eq, PartialOrd, Ord, Clone)
pub struct MonoKeyCacheKey {
    pub base: QualifiedName,
    pub type_args: Vec[TypeDef],
    pub effect_associated_type_ctx: Map[QualifiedName, TypeHandlerInfo],
}

@derive(PartialEq, Std.Ops.Eq, PartialOrd, Ord, Clone)
pub struct FnMonoKeyCacheKey {
    pub base: QualifiedName,
    pub type_args: Vec[TypeDef],
    pub witnesses: Vec[ResolvedWitness],
    pub mono_ctx: MonoContext,
}

pub fn fn_mono_key(
    mono: Monomorphizer,
    base: QualifiedName,
    type_args: Vec[TypeDef],
    witnesses: Vec[ResolvedWitness],
    mono_ctx: MonoContext,
) -> QualifiedName {
    mono.statistics.fn_mono_key_start();
    defer mono.statistics.fn_mono_key_end();
    let cache_key = FnMonoKeyCacheKey(
        base.clone(),
        type_args.clone(),
        witnesses.clone(),
        mono_ctx,
    );
    match mono.fnmonokey_cache.get(cache_key) {
        Some(result) => {
            return result;
        }
        None => {}
    }
    for ty in type_args {
        if ty.is_mono(False) {
            println("Mono type in fn_mono_key args ${format_types(type_args)}");
            println("base ${base.name()}");
            panic("Mono type in fn_mono_key");
        }
    }
    let result = base.as_mono(
        type_args.clone(),
        witnesses.clone(),
        mono_ctx,
    );
    mono.fnmonokey_cache.insert(cache_key, result.clone());
    result
}


pub struct Monomorphizer {
    pub source: Program,
    pub instance_resolver: InstanceResolver,
    pub output: Program,
    pub fn_queue: VecDeque[FnWork],
    pub struct_queue: VecDeque[DataWork],
    pub enum_queue: VecDeque[DataWork],
    pub fn_done: Set[QualifiedName],
    pub struct_done: Set[QualifiedName],
    pub enum_done: Set[QualifiedName],
    pub used_implicits: Set[QualifiedName],
    pub current_module: I.String,
    pub current_fn_witnesses: Vec[ResolvedWitness],
    pub current_mono_ctx: MonoContext,
    pub errors: Vec[MonoError],
    pub sub: Substitution,
    pub current_location: Option[Location],
    pub current_expr_ty: Option[TypeDef],
    pub data_eat_deps: DataEATDeps,
    pub fnmonokey_cache: Map[FnMonoKeyCacheKey, QualifiedName],
    pub datamonokey_cache: Map[MonoKeyCacheKey, QualifiedName],
    pub ty_cache: Map[TypeDef, TypeDef],
    pub statistics: Statistics,

    fn new(source: Program, instance_resolver: InstanceResolver) -> Monomorphizer {
        Monomorphizer(
            source: source,
            instance_resolver: instance_resolver,
            output: Program.new(),
            fn_queue: VecDeque.new(),
            struct_queue: VecDeque.new(),
            enum_queue: VecDeque.new(),
            fn_done: Set.new(),
            struct_done: Set.new(),
            enum_done: Set.new(),
            used_implicits: Set.new(),
            current_module: I.intern(""),
            current_fn_witnesses: [],
            current_mono_ctx: MonoContext.new(),
            errors: [],
            sub: Substitution.new(),
            current_location: None,
            current_expr_ty: None,
            data_eat_deps: DataEATDeps.new(),
            fnmonokey_cache: Map.new(),
            datamonokey_cache: Map.new(),
            ty_cache: Map.new(),
            statistics: Statistics.new(),
        )
    }

    pub fn data_mono_key(mono: Monomorphizer, base: QualifiedName, type_args: Vec[TypeDef], mono_ctx: MonoContext) -> QualifiedName {
        mono.statistics.data_mono_key_start();
        defer mono.statistics.data_mono_key_end();
        let effect_associated_type_ctx = mono_ctx.effect_associated_type_ctx;
        let cache_key = MonoKeyCacheKey(base.clone(), type_args.clone(), effect_associated_type_ctx);
        match mono.datamonokey_cache.get(cache_key) {
            Some(result) => {
                return result;
            }
            None => {}
        }
        for ty in type_args {
            if ty.is_mono(False) {
                println("Mono type in data_mono_key args ${format_types(type_args)}");
                println("base ${base.name()}");
                panic("Mono type in data_mono_key");
            }
        }
        let effect_associated_type_ctx = if !effect_associated_type_ctx.is_empty() {
            let relevant_eats = mono.data_eat_deps.get(base);
            for type_arg in type_args {
                if let Some(arg_name) = type_arg.name_opt() {
                    for eat in mono.data_eat_deps.get(arg_name) {
                        relevant_eats.insert(eat);
                    }
                }
            }
            let filtered: Map[QualifiedName, TypeHandlerInfo] = effect_associated_type_ctx.iter()
                .filter(|(k, _)| relevant_eats.contains(k))
                .map(|(k, v)| (k, v))
                .collect();
            filtered
        } else {
            effect_associated_type_ctx
        };
        let ctx = MonoContext(Map.new(), effect_associated_type_ctx, Vec.new());
        let result = base.as_mono(type_args.clone(), Vec.new(), ctx);
        mono.datamonokey_cache.insert(cache_key, result.clone());
        result
    }

    pub fn clear_type_cache(mono: Monomorphizer) {
        mono.ty_cache.clear();
    }

    pub fn enqueue_named_types(mono: Monomorphizer, name: QualifiedName, args: Vec[TypeDef]) {
        let mono_key = mono.data_mono_key(name, args, mono.current_mono_ctx);
        if mono.source.structs.contains_key(name)
            && !mono.struct_done.contains(mono_key)
        {
            mono.struct_queue.push_back(DataWork(name, args.clone(), mono.current_mono_ctx));
        } else if mono.source.enums.contains_key(name)
            && !mono.enum_done.contains(mono_key)
        {
            mono.enum_queue.push_back(DataWork(name, args.clone(), mono.current_mono_ctx));
        }
    }

    pub fn extract_type_args(
        param_types: Vec[TypeDef],
        arg_types: Vec[TypeDef],
        generic_params: Vec[I.String],
    ) -> Vec[TypeDef] {
        if generic_params.is_empty() {
            return [];
        }
        let mapping = Substitution.new();
        for (p, a) in param_types.iter().zip(arg_types.iter()) {
            extract_named_bindings(p, a, mapping);
        }
        generic_params
            .iter()
            .map(|p| mapping.lookup_named(p).unwrap().clone())
            .collect()
    }

    // Resolve a witness against the current frame into a fully concrete dictionary:
    // a FunctionBound forwards to the caller-provided witness at that index (which
    // is already resolved), an Instance keeps its module/qname and resolves each
    // child. The ResolvedWitness type guarantees no FunctionBound survives.
    pub fn resolve_witness(mono: Monomorphizer, witness: BoundWitness) -> Option[ResolvedWitness] {
        match witness {
            BoundWitness.FunctionBound(idx) =>
                Some(mono.current_fn_witnesses
                    .get_opt(idx)
                    .expect("bound index not found: idx=${idx} in ${mono.current_module}")),
            BoundWitness.Instance(module_name, qname, children) => {
                let resolved_children = match mono.resolve_witnesses(children) {
                    Some(children) => children,
                    None => return None,
                };
                Some(ResolvedWitness(module_name, qname, resolved_children))
            }
            BoundWitness.EffectAssociatedTypeBound(assoc_qname, index) => {
                match mono.current_mono_ctx.get_effect_associated_type(assoc_qname) {
                    Some(info) => Some(info.witnesses[index].clone()),
                    None => {
                        mono.errors.push(MonoError.UnboundEffectAssociatedType(assoc_qname.name(), mono.current_location.unwrap()));
                        None
                    }
                }
            }
        }
    }

    pub fn resolve_witnesses(mono: Monomorphizer, witnesses: Vec[BoundWitness]) -> Option[Vec[ResolvedWitness]] {
        let result: Vec[ResolvedWitness] = Vec.new();
        for witness in witnesses {
            match mono.resolve_witness(witness) {
                Some(resolved) => result.push(resolved),
                None => return None,
            }
        }
        Some(result)
    }

    pub fn expr_ty(mono: Monomorphizer, expr: Expr) -> TypeDef {
        mono.sub.apply(expr.ty.unwrap())
    }

    fn run(mono: Monomorphizer) {
        mono.data_eat_deps = preprocess_data_eat_deps(mono.source);
        let main_key = B.get_main_entry_qn();
        if !mono.source.functions.contains_key(main_key) {
            panic("mono: `Main.main` not found in program");
        }
        mono.fn_queue.push_back(FnWork(
            main_key,
            [],
            [],
            MonoContext.new(),
        ));

        loop {
            mono.clear_type_cache();
            if let Some(work) = mono.fn_queue.pop_front() {
                let mono_name = fn_mono_key(
                    mono,
                    work.qname,
                    work.type_args,
                    work.witnesses,
                    work.mono_ctx,
                );
                if mono.fn_done.insert(mono_name) {
                    process_function(
                        work.qname,
                        work.type_args,
                        work.witnesses,
                        work.mono_ctx,
                        mono_name,
                        mono,
                    );
                }
            } else if let Some(work) = mono.struct_queue.pop_front() {
                let mono_name = mono.data_mono_key(work.qname, work.type_args, work.mono_ctx);
                if mono.struct_done.insert(mono_name) {
                    process_struct(work.qname, work.type_args, work.mono_ctx, mono_name, mono);
                }
            } else if let Some(work) = mono.enum_queue.pop_front() {
                let mono_name = mono.data_mono_key(work.qname, work.type_args, work.mono_ctx);
                if mono.enum_done.insert(mono_name) {
                    process_enum(work.qname, work.type_args, work.mono_ctx, mono_name, mono);
                }
            } else {
                break;
            }
        }
        if get_config().debug_mono_stats {
            mono.statistics.print();
        }
    }
}

pub fn monomorphize(
    source: Program,
) -> Result[Program, Vec[MonoError]] {
    let mono = Monomorphizer.new(source, source.instance_resolver);
    mono.run();
    if !mono.errors.is_empty() {
        return Err(mono.errors);
    }
    mono.output.implicits = source
        .implicits
        .iter()
        .filter(|(k, _)| mono.used_implicits.contains(k))
        .map(|(k, v)| {
            let def = v.clone();
            def.ty = def.ty.specialize(mono);
            (k.clone(), def)
        })
        .collect();
    fixup_variant_enum_map(mono.output);
    Ok(mono.output)
}

fn fixup_variant_enum_map(program: Program) {
    program.variant_enum_map = Map.new();
    let enum_keys: Vec[QualifiedName] = program.enums.keys().cloned().collect();
    for enum_qname in enum_keys {
        let edef = program.enums.get(enum_qname).unwrap();
        for variant in edef.variants.iter() {
            let variant_mono_qname = get_mono_variant_qn(edef.qualified_name.unwrap(), variant.qualified_name.unwrap());
            variant.qualified_name = Some(variant_mono_qname);
            program.variant_enum_map.insert(variant_mono_qname, enum_qname);
        }
    }
}

pub fn get_mono_variant_qn(enum_qn: QualifiedName, variant_qn: QualifiedName) -> QualifiedName {
    match enum_qn {
        QualifiedName.Mono(m) => {
            let (module_name, enum_name) = match m.name.base() {
                BaseName.Enum(module_name, enum_name) => (module_name, enum_name),
                _ => panic("enum qname is not enum!"),
            };
            let variant_base = match variant_qn.base() {
                BaseName.Variant(_, _, variant_base) => variant_base,
                _ => panic("variant qname is not variant!"),
            };
            let base = BaseName.Variant(module_name, enum_name, variant_base);
            let m = m.clone();
            // FIXME: maybe we should rebuild the mono qn by copying the args and then we dont have to rehash?
            m.name = BaseNameInfo.new(base);
            let qn = QualifiedName.Mono(m);
            qn.rehash();
            qn
        }
        _ => panic("get_mono_variant_qn enum name is not mono"),
    }
}

}
