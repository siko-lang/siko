// ─── Enums ───────────────────────────────────────────────────────────────────

pub enum Linkage {
    External,
    Internal,
    Private,
    Appending,
    LinkOnceODR,
    WeakODR,

    // Codes from LLVMLinkage in llvm-c/Core.h.
    fn code(l: Linkage) -> I32 {
        match l {
            Linkage.External => 0,
            Linkage.LinkOnceODR => 3,
            Linkage.WeakODR => 6,
            Linkage.Appending => 7,
            Linkage.Internal => 8,
            Linkage.Private => 9,
        }
    }
}

pub enum UnnamedAddr {
    NoUnnamedAddr,
    LocalUnnamedAddr,
    GlobalUnnamedAddr,

    // Codes from LLVMUnnamedAddr in llvm-c/Core.h.
    fn code(ua: UnnamedAddr) -> I32 {
        match ua {
            UnnamedAddr.NoUnnamedAddr => 0,
            UnnamedAddr.LocalUnnamedAddr => 1,
            UnnamedAddr.GlobalUnnamedAddr => 2,
        }
    }
}

pub enum IntPredicate {
    Eq,
    Ne,
    Ugt,
    Uge,
    Ult,
    Ule,
    Sgt,
    Sge,
    Slt,
    Sle,

    // Codes from LLVMIntPredicate in llvm-c/Core.h (LLVMIntEQ = 32, ...).
    fn code(p: IntPredicate) -> I32 {
        match p {
            IntPredicate.Eq => 32,
            IntPredicate.Ne => 33,
            IntPredicate.Ugt => 34,
            IntPredicate.Uge => 35,
            IntPredicate.Ult => 36,
            IntPredicate.Ule => 37,
            IntPredicate.Sgt => 38,
            IntPredicate.Sge => 39,
            IntPredicate.Slt => 40,
            IntPredicate.Sle => 41,
        }
    }
}

pub enum BinaryOp {
    Add,
    Sub,
    Mul,
    UDiv,
    SDiv,
    URem,
    SRem,
    And,
    Or,
    Xor,
    Shl,
    LShr,
    AShr,
}

pub enum CastOp {
    Trunc,
    ZExt,
    SExt,
    BitCast,
    PtrToInt,
    IntToPtr,
}

// ─── Argument marshalling ────────────────────────────────────────────────────

@unsafe
fn null_handles() -> *void* {
    transmute(0)
}

@unsafe
fn handle_ptr(handles: Vec[void*]) -> *void* {
    if handles.is_empty() {
        null_handles()
    } else {
        handles.as_ptr()
    }
}

@safe
fn type_handles(types: Vec[TypeRef]) -> Vec[void*] {
    let handles: Vec[void*] = Vec.new(types.len());
    for ty in types {
        handles.push(ty.handle);
    }
    handles
}

@safe
fn value_handles(values: Vec[Value]) -> Vec[void*] {
    let handles: Vec[void*] = Vec.new(values.len());
    for v in values {
        handles.push(v.handle);
    }
    handles
}

@safe
fn block_handles(blocks: Vec[BasicBlock]) -> Vec[void*] {
    let handles: Vec[void*] = Vec.new(blocks.len());
    for bb in blocks {
        handles.push(bb.handle);
    }
    handles
}

fn bool_flag(b: Bool) -> I32 {
    if b { 1 } else { 0 }
}

@unsafe
fn empty_name() -> *I8 {
    transmute("".as_ptr())
}

// ─── Wrapper objects ─────────────────────────────────────────────────────────

@value_type
pub struct TypeRef {
    handle: void*,

    @safe
    pub fn array_type(elem: TypeRef, count: Int) -> TypeRef {
        TypeRef(llvm_array_type2(elem.handle, count.as_u64()))
    }

    @safe
    pub fn vector_type(elem: TypeRef, count: Int) -> TypeRef {
        TypeRef(llvm_vector_type(elem.handle, count.as_u32()))
    }

    @safe
    pub fn function_type(ret: TypeRef, params: Vec[TypeRef], varargs: Bool) -> TypeRef {
        let handles = type_handles(params);
        TypeRef(llvm_function_type(ret.handle, handle_ptr(handles), handles.len().as_u32(), bool_flag(varargs)))
    }

    @safe
    pub fn set_body(st: TypeRef, fields: Vec[TypeRef], packed: Bool) {
        let handles = type_handles(fields);
        llvm_struct_set_body(st.handle, handle_ptr(handles), handles.len().as_u32(), bool_flag(packed));
    }

    @safe
    pub fn const_int(ty: TypeRef, value: U64, sign_extend: Bool) -> Value {
        Value(llvm_const_int(ty.handle, value, bool_flag(sign_extend)))
    }

    // Parses decimal text, including a leading minus sign.
    @safe
    pub fn const_int_text(ty: TypeRef, text: String) -> Value {
        let c_text = CString.from_string(text);
        Value(llvm_const_int_of_string(ty.handle, c_text.as_ptr(), 10))
    }

    // Also produces zeroinitializer for aggregate types.
    @safe
    pub fn const_null(ty: TypeRef) -> Value {
        Value(llvm_const_null(ty.handle))
    }

    @safe
    pub fn undef(ty: TypeRef) -> Value {
        Value(llvm_get_undef(ty.handle))
    }

    @safe
    pub fn poison(ty: TypeRef) -> Value {
        Value(llvm_get_poison(ty.handle))
    }

    @safe
    pub fn const_array(elem_ty: TypeRef, values: Vec[Value]) -> Value {
        let handles = value_handles(values);
        Value(llvm_const_array2(elem_ty.handle, handle_ptr(handles), handles.len().as_u64()))
    }

    @safe
    pub fn const_named_struct(st: TypeRef, values: Vec[Value]) -> Value {
        let handles = value_handles(values);
        Value(llvm_const_named_struct(st.handle, handle_ptr(handles), handles.len().as_u32()))
    }
}

@value_type
pub struct Value {
    handle: void*,

    @safe
    pub fn set_initializer(g: Value, value: Value) {
        llvm_set_initializer(g.handle, value.handle);
    }

    @safe
    pub fn set_global_constant(g: Value, constant: Bool) {
        llvm_set_global_constant(g.handle, bool_flag(constant));
    }

    @safe
    pub fn set_linkage(g: Value, linkage: Linkage) {
        llvm_set_linkage(g.handle, linkage.code());
    }

    @safe
    pub fn set_unnamed_addr(g: Value, ua: UnnamedAddr) {
        llvm_set_unnamed_address(g.handle, ua.code());
    }

    @safe
    pub fn set_alignment(v: Value, align: Int) {
        llvm_set_alignment(v.handle, align.as_u32());
    }

    @safe
    pub fn set_name(v: Value, name: String) {
        llvm_set_value_name2(v.handle, name.as_ptr(), name.len().as_u64());
    }

    @safe
    pub fn add_fn_attribute(f: Value, attr: Attribute) {
        // LLVMAttributeFunctionIndex is -1; the C API takes it as unsigned.
        llvm_add_attribute_at_index(f.handle, 4294967295, attr.handle);
    }

    @safe
    pub fn param(f: Value, index: Int) -> Value {
        Value(llvm_get_param(f.handle, index.as_u32()))
    }

    @safe
    pub fn add_incoming(phi: Value, values: Vec[Value], blocks: Vec[BasicBlock]) {
        let value_hs = value_handles(values);
        let block_hs = block_handles(blocks);
        llvm_add_incoming(phi.handle, handle_ptr(value_hs), handle_ptr(block_hs), value_hs.len().as_u32());
    }

    @safe
    pub fn add_case(switch_instr: Value, on_value: Value, bb: BasicBlock) {
        llvm_add_case(switch_instr.handle, on_value.handle, bb.handle);
    }
}

@value_type
pub struct BasicBlock {
    handle: void*,

    @safe
    pub fn first_instruction(bb: BasicBlock) -> Option[Value] {
        let instruction = llvm_get_first_instruction(bb.handle);
        if is_null_voidptr(instruction) {
            None
        } else {
            Some(Value(instruction))
        }
    }
}

@value_type
pub struct Attribute {
    handle: void*,
}

@value_type
pub struct Context {
    handle: void*,

    @safe
    pub fn new() -> Context {
        Context(llvm_context_create())
    }

    @safe
    pub fn create_module(ctx: Context, name: String) -> Module {
        let c_name = CString.from_string(name);
        Module(llvm_module_create_with_name_in_context(c_name.as_ptr(), ctx.handle))
    }

    @safe
    pub fn void_type(ctx: Context) -> TypeRef {
        TypeRef(llvm_void_type_in_context(ctx.handle))
    }

    @safe
    pub fn int_type(ctx: Context, bits: Int) -> TypeRef {
        TypeRef(llvm_int_type_in_context(ctx.handle, bits.as_u32()))
    }

    @safe
    pub fn ptr_type(ctx: Context) -> TypeRef {
        TypeRef(llvm_pointer_type_in_context(ctx.handle, 0))
    }

    @safe
    pub fn struct_type(ctx: Context, fields: Vec[TypeRef], packed: Bool) -> TypeRef {
        let handles = type_handles(fields);
        TypeRef(llvm_struct_type_in_context(ctx.handle, handle_ptr(handles), handles.len().as_u32(), bool_flag(packed)))
    }

    @safe
    pub fn named_struct(ctx: Context, name: String) -> TypeRef {
        let c_name = CString.from_string(name);
        TypeRef(llvm_struct_create_named(ctx.handle, c_name.as_ptr()))
    }

    // The bytes are used verbatim (embedded NULs allowed), no NUL is appended.
    @safe
    pub fn const_string(ctx: Context, s: String) -> Value {
        Value(llvm_const_string_in_context(ctx.handle, s.as_ptr(), s.len().as_u32(), 1))
    }

    @safe
    pub fn const_struct(ctx: Context, values: Vec[Value], packed: Bool) -> Value {
        let handles = value_handles(values);
        Value(llvm_const_struct_in_context(ctx.handle, handle_ptr(handles), handles.len().as_u32(), bool_flag(packed)))
    }

    @safe
    pub fn enum_attr(ctx: Context, name: String) -> Attribute {
        let kind = llvm_get_enum_attribute_kind_for_name(name.as_ptr(), name.len().as_u64());
        if kind == 0 {
            panic("llvm capi: unknown enum attribute: ${name}");
        }
        Attribute(llvm_create_enum_attribute(ctx.handle, kind, 0))
    }

    @safe
    pub fn string_attr(ctx: Context, key: String, value: String) -> Attribute {
        Attribute(llvm_create_string_attribute(
            ctx.handle,
            key.as_ptr(),
            key.len().as_u32(),
            value.as_ptr(),
            value.len().as_u32(),
        ))
    }

    @safe
    pub fn append_block(ctx: Context, f: Value, name: String) -> BasicBlock {
        let c_name = CString.from_string(name);
        BasicBlock(llvm_append_basic_block_in_context(ctx.handle, f.handle, c_name.as_ptr()))
    }

    @safe
    pub fn create_builder(ctx: Context) -> Builder {
        Builder(llvm_create_builder_in_context(ctx.handle))
    }

    // All modules created in this context must be disposed first.
    @safe
    pub fn dispose(ctx: Context) {
        llvm_context_dispose(ctx.handle);
    }
}

@value_type
pub struct Module {
    handle: void*,

    @safe
    pub fn set_target_triple(m: Module, triple: String) {
        let c_triple = CString.from_string(triple);
        llvm_set_target(m.handle, c_triple.as_ptr());
    }

    @safe
    pub fn set_data_layout(m: Module, layout: String) {
        let c_layout = CString.from_string(layout);
        llvm_set_data_layout(m.handle, c_layout.as_ptr());
    }

    @safe
    pub fn set_source_file_name(m: Module, name: String) {
        llvm_set_source_file_name(m.handle, name.as_ptr(), name.len().as_u64());
    }

    @safe
    pub fn add_global(m: Module, ty: TypeRef, name: String) -> Value {
        let c_name = CString.from_string(name);
        Value(llvm_add_global(m.handle, ty.handle, c_name.as_ptr()))
    }

    @safe
    pub fn add_function(m: Module, name: String, fn_ty: TypeRef) -> Value {
        let c_name = CString.from_string(name);
        Value(llvm_add_function(m.handle, c_name.as_ptr(), fn_ty.handle))
    }

    @safe
    pub fn print_to_string(m: Module) -> String {
        let msg = llvm_print_module_to_string(m.handle);
        let text = from_cstring(msg);
        llvm_dispose_message(msg);
        text
    }

    // Returns the verifier error message, or None if the module is valid.
    @safe
    pub fn verify(m: Module) -> Option[String] {
        let msg = get_null_ptr();
        // 2 = LLVMReturnStatusAction.
        let failed = llvm_verify_module(m.handle, 2, &msg);
        if failed == 0 {
            if !is_null_ptr(msg) {
                llvm_dispose_message(msg);
            }
            return None;
        }
        let text = from_cstring(msg);
        llvm_dispose_message(msg);
        Some(text)
    }

    // Runs a new-pass-manager pipeline described by a textual pipeline string,
    // e.g. "default<O3>". Panics if the pipeline fails.
    @safe
    pub fn run_passes(m: Module, passes: String, tm: TargetMachine) {
        let c_passes = CString.from_string(passes);
        let options = llvm_create_pass_builder_options();
        let err = llvm_run_passes(m.handle, c_passes.as_ptr(), tm.handle, options);
        llvm_dispose_pass_builder_options(options);
        if !is_null_voidptr(err) {
            let msg = llvm_get_error_message(err);
            let text = from_cstring(msg);
            llvm_dispose_error_message(msg);
            panic("llvm capi: pass pipeline ${passes} failed: ${text}");
        }
    }

    @safe
    pub fn dispose(m: Module) {
        llvm_dispose_module(m.handle);
    }
}

// Registers the codegen backends for the supported targets (AArch64 and X86).
// Must be called before Target.from_triple.
@safe
pub fn initialize_targets() {
    llvm_initialize_aarch64_target_info();
    llvm_initialize_aarch64_target();
    llvm_initialize_aarch64_target_mc();
    llvm_initialize_aarch64_asm_printer();
    llvm_initialize_x86_target_info();
    llvm_initialize_x86_target();
    llvm_initialize_x86_target_mc();
    llvm_initialize_x86_asm_printer();
}

@value_type
pub struct Target {
    handle: void*,

    @safe
    pub fn from_triple(triple: String) -> Target {
        let c_triple = CString.from_string(triple);
        let target = get_null_voidptr();
        let msg = get_null_ptr();
        let failed = llvm_get_target_from_triple(c_triple.as_ptr(), &target, &msg);
        if failed != 0 {
            let text = from_cstring(msg);
            llvm_dispose_message(msg);
            panic("llvm capi: no target for triple ${triple}: ${text}");
        }
        Target(target)
    }

    @safe
    pub fn create_machine(t: Target, triple: String, optimize: Bool) -> TargetMachine {
        let c_triple = CString.from_string(triple);
        let c_cpu = CString.from_string("");
        let c_features = CString.from_string("");
        // Codes from llvm-c/TargetMachine.h: codegen level None = 0,
        // Aggressive = 3; reloc PIC = 2; code model default = 0.
        let level = if optimize { 3 } else { 0 };
        TargetMachine(llvm_create_target_machine(t.handle, c_triple.as_ptr(), c_cpu.as_ptr(), c_features.as_ptr(), level, 2, 0))
    }
}

@value_type
pub struct TargetMachine {
    handle: void*,

    // Stamps the target's data layout onto the module. Without it the
    // optimization pipeline would run with a default layout and miscompile.
    @safe
    pub fn apply_data_layout(tm: TargetMachine, m: Module) {
        let td = llvm_create_target_data_layout(tm.handle);
        llvm_set_module_data_layout(m.handle, td);
        llvm_dispose_target_data(td);
    }

    @safe
    pub fn emit_object(tm: TargetMachine, m: Module, path: String) {
        let c_path = CString.from_string(path);
        let msg = get_null_ptr();
        // 1 = LLVMObjectFile.
        let failed = llvm_target_machine_emit_to_file(tm.handle, m.handle, c_path.as_ptr(), 1, &msg);
        if failed != 0 {
            let text = from_cstring(msg);
            llvm_dispose_message(msg);
            panic("llvm capi: emitting object file ${path} failed: ${text}");
        }
    }

    @safe
    pub fn dispose(tm: TargetMachine) {
        llvm_dispose_target_machine(tm.handle);
    }
}

@value_type
pub struct Builder {
    handle: void*,

    @safe
    pub fn position_at_end(b: Builder, bb: BasicBlock) {
        llvm_position_builder_at_end(b.handle, bb.handle);
    }

    @safe
    pub fn position_before(b: Builder, instruction: Value) {
        llvm_position_builder_before(b.handle, instruction.handle);
    }

    @safe
    pub fn dispose(b: Builder) {
        llvm_dispose_builder(b.handle);
    }

    @safe
    pub fn build_alloca(b: Builder, ty: TypeRef, name: String) -> Value {
        let c_name = CString.from_string(name);
        Value(llvm_build_alloca(b.handle, ty.handle, c_name.as_ptr()))
    }

    @safe
    pub fn build_load(b: Builder, ty: TypeRef, ptr: Value) -> Value {
        Value(llvm_build_load2(b.handle, ty.handle, ptr.handle, empty_name()))
    }

    @safe
    pub fn build_store(b: Builder, value: Value, ptr: Value) -> Value {
        Value(llvm_build_store(b.handle, value.handle, ptr.handle))
    }

    @safe
    pub fn build_binary(b: Builder, op: BinaryOp, lhs: Value, rhs: Value) -> Value {
        let handle = match op {
            BinaryOp.Add => llvm_build_add(b.handle, lhs.handle, rhs.handle, empty_name()),
            BinaryOp.Sub => llvm_build_sub(b.handle, lhs.handle, rhs.handle, empty_name()),
            BinaryOp.Mul => llvm_build_mul(b.handle, lhs.handle, rhs.handle, empty_name()),
            BinaryOp.UDiv => llvm_build_udiv(b.handle, lhs.handle, rhs.handle, empty_name()),
            BinaryOp.SDiv => llvm_build_sdiv(b.handle, lhs.handle, rhs.handle, empty_name()),
            BinaryOp.URem => llvm_build_urem(b.handle, lhs.handle, rhs.handle, empty_name()),
            BinaryOp.SRem => llvm_build_srem(b.handle, lhs.handle, rhs.handle, empty_name()),
            BinaryOp.And => llvm_build_and(b.handle, lhs.handle, rhs.handle, empty_name()),
            BinaryOp.Or => llvm_build_or(b.handle, lhs.handle, rhs.handle, empty_name()),
            BinaryOp.Xor => llvm_build_xor(b.handle, lhs.handle, rhs.handle, empty_name()),
            BinaryOp.Shl => llvm_build_shl(b.handle, lhs.handle, rhs.handle, empty_name()),
            BinaryOp.LShr => llvm_build_lshr(b.handle, lhs.handle, rhs.handle, empty_name()),
            BinaryOp.AShr => llvm_build_ashr(b.handle, lhs.handle, rhs.handle, empty_name()),
        };
        Value(handle)
    }

    @safe
    pub fn build_icmp(b: Builder, pred: IntPredicate, lhs: Value, rhs: Value) -> Value {
        Value(llvm_build_icmp(b.handle, pred.code(), lhs.handle, rhs.handle, empty_name()))
    }

    @safe
    pub fn build_gep(b: Builder, ty: TypeRef, ptr: Value, indices: Vec[Value], inbounds: Bool) -> Value {
        let handles = value_handles(indices);
        let handle = if inbounds {
            llvm_build_in_bounds_gep2(b.handle, ty.handle, ptr.handle, handle_ptr(handles), handles.len().as_u32(), empty_name())
        } else {
            llvm_build_gep2(b.handle, ty.handle, ptr.handle, handle_ptr(handles), handles.len().as_u32(), empty_name())
        };
        Value(handle)
    }

    @safe
    pub fn build_extract_value(b: Builder, agg: Value, index: Int) -> Value {
        Value(llvm_build_extract_value(b.handle, agg.handle, index.as_u32(), empty_name()))
    }

    @safe
    pub fn build_insert_value(b: Builder, agg: Value, value: Value, index: Int) -> Value {
        Value(llvm_build_insert_value(b.handle, agg.handle, value.handle, index.as_u32(), empty_name()))
    }

    @safe
    pub fn build_cast(b: Builder, op: CastOp, value: Value, ty: TypeRef) -> Value {
        let handle = match op {
            CastOp.Trunc => llvm_build_trunc(b.handle, value.handle, ty.handle, empty_name()),
            CastOp.ZExt => llvm_build_zext(b.handle, value.handle, ty.handle, empty_name()),
            CastOp.SExt => llvm_build_sext(b.handle, value.handle, ty.handle, empty_name()),
            CastOp.BitCast => llvm_build_bit_cast(b.handle, value.handle, ty.handle, empty_name()),
            CastOp.PtrToInt => llvm_build_ptr_to_int(b.handle, value.handle, ty.handle, empty_name()),
            CastOp.IntToPtr => llvm_build_int_to_ptr(b.handle, value.handle, ty.handle, empty_name()),
        };
        Value(handle)
    }

    @safe
    pub fn build_call(b: Builder, fn_ty: TypeRef, callee: Value, args: Vec[Value]) -> Value {
        let handles = value_handles(args);
        Value(llvm_build_call2(b.handle, fn_ty.handle, callee.handle, handle_ptr(handles), handles.len().as_u32(), empty_name()))
    }

    @safe
    pub fn build_phi(b: Builder, ty: TypeRef) -> Value {
        Value(llvm_build_phi(b.handle, ty.handle, empty_name()))
    }

    @safe
    pub fn build_ret(b: Builder, value: Value) {
        llvm_build_ret(b.handle, value.handle);
    }

    @safe
    pub fn build_ret_void(b: Builder) {
        llvm_build_ret_void(b.handle);
    }

    @safe
    pub fn build_br(b: Builder, bb: BasicBlock) {
        llvm_build_br(b.handle, bb.handle);
    }

    @safe
    pub fn build_cond_br(b: Builder, cond: Value, then_bb: BasicBlock, else_bb: BasicBlock) {
        llvm_build_cond_br(b.handle, cond.handle, then_bb.handle, else_bb.handle);
    }

    @safe
    pub fn build_switch(b: Builder, value: Value, else_bb: BasicBlock, num_cases: Int) -> Value {
        Value(llvm_build_switch(b.handle, value.handle, else_bb.handle, num_cases.as_u32()))
    }

    @safe
    pub fn build_unreachable(b: Builder) {
        llvm_build_unreachable(b.handle);
    }
}


}
