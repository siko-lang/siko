module Siko.LLVM.CApi {

// Object-oriented wrapper over the LLVM-C builder API. The raw externs stay
// private; users go through Context/Module/Builder/TypeRef/Value methods.
//
// Enum codes below mirror the LLVM-C enums in llvm-c/Core.h and must stay in
// sync with the linked LLVM version.

import Std.Libc.String
import Std.Ptr
import Std.Intrinsics

