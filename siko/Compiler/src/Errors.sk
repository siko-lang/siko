module Siko.Compiler.Errors {

import Siko.Report
import Siko.ValueTypes

pub fn report_value_type_errors(errors: Vec[ValueTypeError]) {
    for e in errors { report_value_type_error(e); }
}

pub fn report_value_type_error(e: ValueTypeError) {
    match e {
        ValueTypeError.ExplicitValueTypeInCycle(location) =>
            report("@value_type type is in a recursive value-layout cycle", Some(location)),
    }
}

}
