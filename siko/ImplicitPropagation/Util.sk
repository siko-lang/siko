module Siko.ImplicitPropagation.Util {

import Std.Map
import Siko.AST.Type
import Siko.AST.Expr
import Siko.AST.Name
import Siko.AST.QualifiedName
import Siko.AST.Identifier
import Siko.Interner as I
import Siko.Location

pub fn wrapper_struct_name(implicit_name: String) -> I.String {
    I.intern("_siko_ctx_value_${implicit_name.replace(".", "_")}")
}

pub fn ctx_field_name(implicit_name: String) -> I.String {
    I.intern(implicit_name.replace(".", "_"))
}

pub fn ctx_struct_name(implicits: Vec[String]) -> I.String {
    if implicits.is_empty() {
        I.intern("_siko_ctx_0")
    } else {
        let parts: Vec[String] = implicits
            .iter()
            .map(|s| s.replace(".", "_"))
            .collect();
        I.intern("_siko_ctx_${join(parts, "_")}")
    }
}

pub fn named_ty(name: I.String) -> TypeDef {
    TypeDef.Named(
        Name.Resolved(QualifiedName.new_mono(name, [], [], Map.new(), [])),
        [],
    )
}

pub fn typed_var_expr(v: VariableName, ty: Option[TypeDef], loc: Location) -> Expr {
    Expr(ExprKind.Var(v.clone()), loc.clone(), ty)
}

pub fn typed_field_expr(base: Expr, field: I.String, ty: Option[TypeDef], loc: Location) -> Expr {
    Expr(
        ExprKind.FieldAccess(
            base,
            Identifier.new(field, loc.clone()),
        ),
        loc.clone(),
        ty,
    )
}

}
