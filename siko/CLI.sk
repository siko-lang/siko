module Siko.CLI {

import Std.Sys.Process as Sys
import Std.Fs.Directory
import Siko.Config

fn read_target_info() -> Option[TargetInfo] {
    match Sys.getenv("SIKO_TARGET_OS") {
        Some("linux") => Some(TargetInfo("Linux", "x86_64-pc-linux-gnu")),
        Some("macos") => Some(TargetInfo("Darwin", "arm64-apple-macosx26.0.0")),
        Some(target_os) => {
            println("error: unsupported target os: ${target_os}");
            None
        }
        None => {
            println("error: unsupported target os: <unset>");
            None
        }
    }
}

pub fn parse_cli_args() -> Option[Config] {
    let args = Sys.get_args();
    if args.len() < 2 {
        println("usage: siko build|check|lsp [--llvm] [--pass <resolve|normalize>] <path> [path ...]");
        return None;
    }
    let check_only = False;
    let cmd = args[1];
    let test = False;
    let lsp = False;
    match cmd {
        "build" => {}
        "check" => {
            check_only = True;
        }
        "lsp" => {
            check_only = True;
            lsp = True;
        }
        "test" => {
            test = True;
        }
        _ => {
            println("unknown command: " + cmd);
            println("usage: siko build|check|test|lsp [--llvm] [--pass <resolve|normalize>] <path> [path ...]");
            return None;
        }
    }
    let pass = None;
    let debug_typecheck = False;
    let debug_typecheck_stats = False;
    let debug_mono = False;
    let debug_mono_stats = False;
    let debug_co= False;
    let debug_closure = False;
    let debug_closure_datatypes = False;
    let debug_closure_profiles = False;
    let debug_closure_mono = False;
    let debug_closure_stats = False;
    let trace = False;
    let paths = Vec.new();
    let check_safety = True;
    let output = None;
    let optimize = False;
    let no_std = False;
    let dump_package_purity = False;
    let obj = False;
    let link_args = Vec.new();
    let i = 2;
    while i < args.len() {
        if args[i] == "--link-arg" {
            i += 1;
            if i >= args.len() {
                println("error: --link-arg requires an argument");
                return None;
            }
            link_args.push(args[i]);
        } else if args[i] == "--pass" {
            i += 1;
            if i >= args.len() {
                println("error: --pass requires an argument");
                return None;
            }
            pass = Some(args[i]);
        } else if args[i] == "-o" {
            i += 1;
            if i >= args.len() {
                println("error: -o requires an argument");
                return None;
            }
            output = Some(args[i]);
        } else {
            match args[i] {
                "--debug-typecheck" => { debug_typecheck = True; }
                "--debug-typecheck-stats" => { debug_typecheck_stats = True; }
                "--debug-mono"      => { debug_mono = True; }
                "--debug-mono-stats" => { debug_mono_stats = True; }
                "--debug-co"        => { debug_co = True; }
                "--debug-closure"   => { debug_closure = True; }
                "--debug-closure-datatypes" => {
                    debug_closure_datatypes = True;
                }
                "--debug-closure-profiles" => {
                    debug_closure_profiles = True;
                }
                "--debug-closure-mono" => {
                    debug_closure_mono = True;
                }
                "--debug-closure-stats" => { debug_closure_stats = True; }
                "--trace"           => { trace = True; }
                "--no-check-safety" => { check_safety = False; }
                "-O"                => { optimize = True; }
                "-c"                => { obj = True; }
                "--no-std"              => { no_std = True; }
                "--dump-package-purity" => { dump_package_purity = True; }
                _                   => { paths.push(args[i]); }
            }
        }
        i += 1;
    }
    if obj && output == None {
        println("error: -c requires -o <output>");
        return None;
    }
    let std_path = if no_std {
        None
    } else {
        Sys.getenv("SIKO_ROOT").map(|root| root + "/std")
    };
    let target_info = match read_target_info() {
        Some(info) => info,
        None => return None,
    };
    if paths.is_empty() {
        match Std.Fs.Directory.get_current_dir() {
            Ok(cwd) => paths.push(cwd),
            Err(e) => {
                println("error: no input paths given and could not get current directory: ${e}");
                return None;
            }
        }
    }
    Some(Config(
        check_only: check_only,
        pass: pass,
        debug_typecheck: debug_typecheck,
        debug_typecheck_stats: debug_typecheck_stats,
        debug_mono: debug_mono,
        debug_mono_stats: debug_mono_stats,
        debug_co: debug_co,
        debug_closure: debug_closure,
        debug_closure_datatypes: debug_closure_datatypes,
        debug_closure_profiles: debug_closure_profiles,
        debug_closure_mono: debug_closure_mono,
        debug_closure_stats: debug_closure_stats,
        trace: trace,
        paths: paths,
        check_safety: check_safety,
        dump_package_purity: dump_package_purity,
        output: output,
        optimize: optimize,
        no_std: no_std,
        std_path: std_path,
        target_info: target_info,
        test: test,
        lsp: lsp,
        obj: obj,
        link_args: link_args))
}

}
