module Siko.Report {

import Siko.Location
import Siko.Diagnostics
import Siko.Driver

pub fn warn(message: String, location: Option[Location]) {
    add_diagnostic(Diagnostic(Severity.Warning, message, location))
}

pub fn report(message: String, location: Option[Location]) {
    add_diagnostic(Diagnostic(Severity.Error, message, location))
}

}
