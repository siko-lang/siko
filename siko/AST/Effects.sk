module Siko.AST.Effects {

import Siko.AST.Function
import Siko.AST.Identifier
import Siko.AST.Data
import Siko.AST.Generics
import Siko.AST.Annotations

pub struct AssociatedType {
    pub name: Identifier,
}

pub struct EffectDef {
    pub annotations: Vec[Annotation],
    pub public: Bool,
    pub name: Identifier,
    pub associated_types: Vec[AssociatedType],
    pub type_arg_defs: Option[TypeArgDefs],
    pub methods: Vec[FunctionDef],
    pub method_map: MethodMap,
}

}
