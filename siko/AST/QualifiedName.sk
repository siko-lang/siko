module Siko.AST.QualifiedName {

import Std.Map
import Std.Util
import Std.MD5 as MD5
import Siko.Interner as I
import Siko.AST.Type
import Siko.Format.Utils

@derive(PartialEq, Eq, PartialOrd, Ord, Clone)
pub enum BaseName {
    Struct(module_name: I.String, struct_name: I.String),
    Enum(module_name: I.String, enum_name: I.String),
    Variant(module_name: I.String, enum_name: I.String, variant_name: I.String),
    Trait(module_name: I.String, trait_name: I.String),
    Effect(module_name: I.String, effect_name: I.String),
    EffectAssociatedType(module_name: I.String, effect_name: I.String, name: I.String),
    Global(module_name: I.String, global_name: I.String),
    Implicit(module_name: I.String, implicit_name: I.String),
    Function(module_name: I.String, fn_name: I.String),
    Lambda(parent_name: I.String, index: Int),
    ClosureEnum(index: Int),
    ClosureVariant(enum_index: Int, variant_index: Int),
    ClosureHandler(index: Int),
    CoroutineWrap(co_index: Int),
    CoroutineState(co_index: Int),
    CoroutineStateVariant(co_index: Int, variant_index: Int),
    CoroutineFrame(co_index: Int, variant_index: Int),
    CoroutineHandler(co_index: Int, variant_index: Int),
    CoroutineFrameState(co_index: Int, variant_index: Int),
    CoroutineFrameStateVariant(co_index: Int, variant_index: Int, state_index: Int),
    UnnamedInstance(trait_name: I.String, args: Vec[TypeDef]),
    NamedInstance(module_name: I.String, instance_name: I.String),
    Method(parent_name: I.String, method_name: I.String),
    DefaultArg(parent_name: I.String, index: Int),
    ImplicitWrap(parent_name: I.String),
    ImplicitContext(implicits: Vec[I.String]),
    Tuple(args: Vec[TypeDef]),
    // Compiler-generated payload struct of one monomorphic enum variant.
    // enum_name is the owning enum's hashed monomorphic name, so the payload
    // identity is unique per enum instantiation and never collides with user
    // structs.
    VariantPayload(enum_name: I.String, variant_name: I.String),
    // The generated constructor function of a struct or enum variant.
    // owner is the hashed monomorphic name of what it constructs, so the
    // ctor identity is unique per instantiation and never collides with
    // user functions.
    Ctor(owner: I.String),

    pub fn name(bn: BaseName) -> I.String {
        match bn {
            Struct(m, n)
            | Enum(m, n)
            | Trait(m, n)
            | Effect(m, n)
            | Global(m, n)
            | Implicit(m, n)
            | Function(m, n)
            | NamedInstance(m, n) => I.intern(I.resolve(m) + "." + I.resolve(n)),
            Variant(m, e, v) => I.intern(I.resolve(m) + "." + I.resolve(e) + "." + I.resolve(v)),
            Lambda(parent, i) => I.intern(I.resolve(parent) + "_lambda_" + i.to_string()),
            ClosureEnum(i) => I.intern("closure_" + i.to_string()),
            ClosureVariant(ei, vi) => I.intern("closure_" + ei.to_string() + ".Variant" + vi.to_string()),
            ClosureHandler(i) => I.intern("closure_" + i.to_string() + "_handler"),
            CoroutineWrap(i) => I.intern("co_wrap_" + i.to_string()),
            CoroutineState(i) => I.intern("co_state_" + i.to_string()),
            CoroutineStateVariant(ci, vi) => I.intern("co_state_" + ci.to_string() + ".Variant" + vi.to_string()),
            CoroutineFrame(ci, vi) => I.intern("co_frame_" + ci.to_string() + "_" + vi.to_string()),
            CoroutineHandler(ci, vi) => I.intern("co_handler_" + ci.to_string() + "_" + vi.to_string()),
            CoroutineFrameState(ci, vi) => I.intern("co_fstate_" + ci.to_string() + "_" + vi.to_string()),
            CoroutineFrameStateVariant(ci, vi, si) => I.intern("co_fstate_" + ci.to_string() + "_" + vi.to_string() + ".V" + si.to_string()),
            UnnamedInstance(t, args) => I.intern(I.resolve(t) + "#[" + format_types(args) + "]"),
            Method(parent, m) => I.intern(I.resolve(parent) + "." + I.resolve(m)),
            DefaultArg(parent, i) => I.intern(I.resolve(parent) + "def_arg_" + i.to_string()),
            ImplicitWrap(parent) => I.intern(I.resolve(parent) + "__implicit_wrap"),
            ImplicitContext(implicits) => I.intern("__implicit_context_" + join(implicits.iter().map(|n| I.resolve(n)).collect(), "_")),
            Tuple(args) => I.intern("__tuple_" + format_types(args) + "_"),
            EffectAssociatedType(m, e, t) => I.intern(I.resolve(m) + "." + I.resolve(e) + "." + I.resolve(t)),
            VariantPayload(e, v) => I.intern(I.resolve(e) + "." + I.resolve(v) + ".payload"),
            Ctor(owner) => I.intern(I.resolve(owner) + ".ctor"),
        }
    }
}

@derive(PartialEq, Eq, PartialOrd, Ord, Clone)
pub struct BaseNameInfo {
    base_name: BaseName,
    name: I.String,

    pub fn new(n: BaseName) -> BaseNameInfo {
        BaseNameInfo(n, n.name())
    }

    pub fn name(n: BaseNameInfo) -> I.String {
        n.name
    }

    pub fn base(n: BaseNameInfo) -> BaseName {
        n.base_name
    }
}

// A fully resolved witness (a monomorphized dictionary): the instance, the
// module that certifies it, and the sub-dictionaries it closes over. The pre-mono
// BoundWitness can still be a FunctionBound; resolving against a frame turns it
// into one of these, which never contains an unresolved forward.
@derive(PartialEq, Eq, PartialOrd, Ord, Clone)
pub struct ResolvedWitness {
    pub module_name: I.String,
    pub instance_qname: QualifiedName,
    pub children: Vec[ResolvedWitness],

    pub fn format(w: ResolvedWitness) -> String {
        if w.children.is_empty() {
            I.resolve(w.module_name)
        } else {
            let cs: Vec[String] = w.children.iter().map(|c| c.format()).collect();
            I.resolve(w.module_name) + "<" + join(cs, ",") + ">"
        }
    }
}

// A resolved effect handler: the (pre-mono) handler function plus the witnesses
// for its bounds, resolved at the `with` site. Part of MonoContext so that the
// full effect resolution — handler AND witnesses — is structurally part of a
// function's mono identity. Two `with` sites binding the same handler with
// different witnesses produce distinct keys for any function in their dynamic
// extent, so each specializes separately instead of collapsing onto the first.
@derive(PartialEq, Eq, PartialOrd, Ord, Clone)
pub struct HandlerInfo {
    pub name: QualifiedName,
    pub witnesses: Vec[ResolvedWitness],
}

// An effect associated type binding: the concrete type chosen at the `with` site
// plus the witnesses for the EAT's bounds, resolved there. In MonoContext so the
// witnesses are part of mono identity (two `with`s binding the same EAT to the
// same type but resolving its bounds in different modules must not collapse).
@derive(PartialEq, Eq, PartialOrd, Ord, Clone)
pub struct TypeHandlerInfo {
    pub ty: TypeDef,
    pub witnesses: Vec[ResolvedWitness],
}

@derive(PartialEq, Eq, PartialOrd, Ord, Clone)
pub struct MonoContext {
    pub witnesses: Vec[ResolvedWitness],
    pub effect_ctx: Map[QualifiedName, HandlerInfo],
    pub effect_associated_type_ctx: Map[QualifiedName, TypeHandlerInfo],
    pub implicit_ctx: Vec[QualifiedName],
    // Closure-content duplication index (lower-closures v2): functions and
    // datatypes reached with different concrete closure sets are duplicated,
    // and the copy's index is part of its mono identity — the same way
    // witnesses and effect contexts already are. 0 = the sole/first copy.
    pub closure_instance: Int = 0,

    pub fn new() -> MonoContext {
        MonoContext(Vec.new(), Map.new(), Map.new(), Vec.new(), 0)
    }
}

@derive(PartialEq, Eq, PartialOrd, Ord, Clone)
pub struct MonoName {
    pub name: BaseNameInfo,
    pub args: Vec[TypeDef],
    pub ctx: MonoContext,
    hashed: String,
    // Cached result of QualifiedName.name(): computing it involves recursively
    // formatting args/witnesses/effect ctx and interning the result, which is
    // too expensive to redo on every Ord/PartialEq comparison (the hot path for
    // every Map[QualifiedName, _] operation during monomorphization).
    interned_name: I.String,
}

@derive(Clone)
pub enum QualifiedName {
    Base(BaseNameInfo),
    Mono(MonoName),

    pub fn as_mono(
            name: QualifiedName,
            args: Vec[TypeDef] = Vec.new(),
            mono_ctx: MonoContext = MonoContext.new()) -> QualifiedName {
        let base = match name {
            Base(bn) => bn,
            Mono(_) => {
                println("Already mono qn ${name.name()}, args: ${format_types(args)}");
                panic("as_mono: cannot mono a Mono")
            }
        };
        let qn = Mono(MonoName(base, args, mono_ctx, "", I.intern("")));
        qn.rehash();
        qn
    }

    pub fn new_struct(module_name: I.String, struct_name: I.String) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.Struct(module_name, struct_name)))
    }

    pub fn new_enum(module_name: I.String, enum_name: I.String) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.Enum(module_name, enum_name)))
    }

    pub fn new_variant(module_name: I.String, enum_name: I.String, variant_name: I.String) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.Variant(module_name, enum_name, variant_name)))
    }

    pub fn new_trait(module_name: I.String, trait_name: I.String) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.Trait(module_name, trait_name)))
    }

    pub fn new_effect(module_name: I.String, effect_name: I.String) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.Effect(module_name, effect_name)))
    }

    pub fn new_effect_associated_type(module_name: I.String, effect_name: I.String, name: I.String) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.EffectAssociatedType(module_name, effect_name, name)))
    }

    pub fn new_global(module_name: I.String, global_name: I.String) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.Global(module_name, global_name)))
    }

    pub fn new_implicit(module_name: I.String, implicit_name: I.String) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.Implicit(module_name, implicit_name)))
    }

    pub fn new_function(module_name: I.String, fn_name: I.String) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.Function(module_name, fn_name)))
    }

    pub fn new_lambda(parent_name: I.String, index: Int) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.Lambda(parent_name, index)))
    }

    pub fn new_closure_enum(index: Int) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.ClosureEnum(index)))
    }

    pub fn new_closure_variant(enum_index: Int, variant_index: Int) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.ClosureVariant(enum_index, variant_index)))
    }

    pub fn new_closure_handler(index: Int) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.ClosureHandler(index)))
    }

    pub fn new_coroutine_wrap(co_index: Int) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.CoroutineWrap(co_index)))
    }

    pub fn new_coroutine_state(co_index: Int) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.CoroutineState(co_index)))
    }

    pub fn new_coroutine_state_variant(co_index: Int, variant_index: Int) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.CoroutineStateVariant(co_index, variant_index)))
    }

    pub fn new_coroutine_frame(co_index: Int, variant_index: Int) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.CoroutineFrame(co_index, variant_index)))
    }

    pub fn new_coroutine_handler(co_index: Int, variant_index: Int) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.CoroutineHandler(co_index, variant_index)))
    }

    pub fn new_coroutine_frame_state(co_index: Int, variant_index: Int) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.CoroutineFrameState(co_index, variant_index)))
    }

    pub fn new_coroutine_frame_state_variant(co_index: Int, variant_index: Int, state_index: Int) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.CoroutineFrameStateVariant(co_index, variant_index, state_index)))
    }

    pub fn new_unnamed_instance(trait_name: I.String, args: Vec[TypeDef]) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.UnnamedInstance(trait_name, args)))
    }

    pub fn new_named_instance(module_name: I.String, instance_name: I.String) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.NamedInstance(module_name, instance_name)))
    }

    pub fn new_method(parent_name: I.String, method_name: I.String) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.Method(parent_name, method_name)))
    }

    pub fn new_default_arg(parent_name: I.String, index: Int) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.DefaultArg(parent_name, index)))
    }

    pub fn new_implicit_wrap(parent_name: I.String) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.ImplicitWrap(parent_name)))
    }

    pub fn new_implicit_context(implicits: Vec[I.String]) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.ImplicitContext(implicits)))
    }

    pub fn new_tuple(args: Vec[TypeDef]) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.Tuple(args)))
    }

    pub fn new_variant_payload(enum_name: I.String, variant_name: I.String) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.VariantPayload(enum_name, variant_name)))
    }

    // The generated constructor function for a struct or enum variant.
    pub fn new_ctor(owner: QualifiedName) -> QualifiedName {
        Base(BaseNameInfo.new(BaseName.Ctor(I.intern(owner.hashed()))))
    }

    // Returns the short identifier name: the last component of the base name
    // (e.g. "CoResult" from Enum, "Yielded" from Variant, "String" from Struct).
    pub fn short_name(qn: QualifiedName) -> I.String {
        let base_name = match qn {
            Base(bn) => bn.base(),
            Mono(m) => m.name.base(),
        };
        match base_name {
            BaseName.Struct(_, n)
            | BaseName.Enum(_, n)
            | BaseName.Trait(_, n)
            | BaseName.Effect(_, n)
            | BaseName.Global(_, n)
            | BaseName.Implicit(_, n)
            | BaseName.Function(_, n)
            | BaseName.NamedInstance(_, n) => n,
            BaseName.Variant(_, _, v) => v,
            BaseName.VariantPayload(_, v) => v,
            _ => panic("short_name: unsupported base name kind"),
        }
    }

    pub fn rehash(qn: QualifiedName) {
        let h = qn.get_hashed();
        qn.save_hashed(h);
        let n = qn.compute_name();
        qn.save_name(n);
    }

    fn compute_name(qn: QualifiedName) -> I.String {
        match qn {
            Base(bn) => bn.name(),
            Mono(m) => {
                let base = I.resolve(m.name.name());
                let (args_str, extras) = qn.extra();
                I.intern(base + args_str + extras)
            }
        }
    }

    pub fn name(qn: QualifiedName) -> I.String {
        match qn {
            Base(bn) => bn.name(),
            Mono(m) => m.interned_name,
        }
    }

    pub fn extra(qn: QualifiedName) -> (String, String) {
        match qn {
            Base(_) => ("", ""),
            Mono(m) => {
                let args_str = if m.args.is_empty() {
                    ""
                } else {
                    let parts: Vec[String] = m.args.iter().map(|a| format_type(a)).collect();
                    "[" + join(parts, ", ") + "]"
                };
                let witness_str = if m.ctx.witnesses.is_empty() {
                    ""
                } else {
                    let parts: Vec[String] = m.ctx.witnesses.iter().map(|w| w.format()).collect();
                    "(" + join(parts, ", ") + ")"
                };
                let effect_str = if m.ctx.effect_ctx.is_empty() {
                    ""
                } else {
                    let entries: Vec[String] = m.ctx.effect_ctx.iter()
                        .map(|(k, v)| {
                            let wit = if v.witnesses.is_empty() {
                                ""
                            } else {
                                "(" + join(v.witnesses.iter().map(|w| w.format()).collect(), ", ") + ")"
                            };
                            I.resolve(k.name()) + "->" + I.resolve(v.name.name()) + wit
                        })
                        .collect();
                    "{" + join(entries, ",") + "}"
                };
                let effect_associated_type_str = if m.ctx.effect_associated_type_ctx.is_empty() {
                    ""
                } else {
                    let entries: Vec[String] = m.ctx.effect_associated_type_ctx.iter()
                        .map(|(k, v)| {
                            let wit = if v.witnesses.is_empty() {
                                ""
                            } else {
                                "(" + join(v.witnesses.iter().map(|w| w.format()).collect(), ", ") + ")"
                            };
                            I.resolve(k.name()) + "->" + format_type(v.ty) + wit
                        })
                        .collect();
                    "{" + join(entries, ",") + "}"
                };
                let implicit_str = if m.ctx.implicit_ctx.is_empty() {
                    ""
                } else {
                    let parts: Vec[String] = m.ctx.implicit_ctx.iter().map(|q| I.resolve(q.name())).collect();
                    "{" + join(parts, ",") + "}"
                };
                let instance_str = if m.ctx.closure_instance == 0 {
                    ""
                } else {
                    "#" + m.ctx.closure_instance.to_string()
                };
                (args_str, witness_str + effect_str + effect_associated_type_str + implicit_str + instance_str)
            }
        }
    }

    // A closure-content duplicate of this name (lower-closures v2): same
    // mono identity plus a distinguishing instance index. Index 0 returns
    // the name unchanged.
    pub fn with_closure_instance(qn: QualifiedName, index: Int) -> QualifiedName {
        if index == 0 {
            return qn;
        }
        let new_qn = match qn {
            Base(bn) => {
                let ctx = MonoContext.new();
                ctx.closure_instance = index;
                Mono(MonoName(bn, Vec.new(), ctx, "", I.intern("")))
            }
            Mono(m) => {
                let ctx = m.ctx.clone();
                ctx.closure_instance = index;
                Mono(MonoName(m.name, m.args.clone(), ctx, "", I.intern("")))
            }
        };
        new_qn.rehash();
        new_qn
    }

    pub fn base(qn: QualifiedName) -> BaseName {
        match qn {
            Base(bn) => bn.base_name,
            Mono(m) => m.name.base_name,
        }
    }

    pub fn base_name(qn: QualifiedName) -> QualifiedName {
        match qn {
            Base(bn) => Base(bn),
            Mono(m) => Base(m.name),
        }
    }

    pub fn is_simple(qn: QualifiedName) -> Bool {
        match qn {
            Base(_) => True,
            Mono(_) => False,
        }
    }

    pub fn is_mono(qn: QualifiedName) -> Bool {
        match qn {
            Base(_) => False,
            Mono(_) => True,
        }
    }

    pub fn type_args(qn: QualifiedName) -> Vec[TypeDef] {
        match qn {
            Base(_) => Vec.new(),
            Mono(m) => m.args,
        }
    }

    pub fn implicit_ctx(qn: QualifiedName) -> Vec[QualifiedName] {
        match qn {
            Base(_) => Vec.new(),
            Mono(m) => m.ctx.implicit_ctx,
        }
    }

    fn get_hashed(qn: QualifiedName) -> String {
        let (type_args, extra) = qn.extra();
        if extra.is_empty() {
            return I.resolve(qn.compute_name());
        }
        let digest = MD5.compute(extra.to_bytes());
        let hash = bytes_to_hex(digest);
        let simple_name = match qn {
            Base(bn) => bn.name(),
            Mono(m) => m.name.name(),
        };
        "${simple_name}${type_args}_${hash}"
    }

    fn save_hashed(qn: QualifiedName, hashed: String) {
        match qn {
            Base(_) => (),
            Mono(m) => { m.hashed = hashed; }
        }
    }

    fn save_name(qn: QualifiedName, name: I.String) {
        match qn {
            Base(_) => (),
            Mono(m) => { m.interned_name = name; }
        }
    }

    pub fn hashed(qn: QualifiedName) -> String {
        match qn {
            Base(bn) => I.resolve(bn.name()),
            Mono(m) => m.hashed,
        }
    }
}

instance PartialEq[QualifiedName] {
    fn eq(a: QualifiedName, b: QualifiedName) -> Bool {
        a.name() == b.name()
    }
}

instance Eq[QualifiedName] {}

instance PartialOrd[QualifiedName] {
    fn partial_cmp(a: QualifiedName, b: QualifiedName) -> Option[Ordering] {
        Some(a.name().cmp(b.name()))
    }
}

instance Ord[QualifiedName] {
    fn cmp(a: QualifiedName, b: QualifiedName) -> Ordering {
        a.name().cmp(b.name())
    }
}

}
