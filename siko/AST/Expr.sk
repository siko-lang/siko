module Siko.AST.Expr {

import Siko.Interner as I
import Siko.Location
import Siko.Instances.FunctionInstanceResolver
import Siko.AST.Name
import Siko.AST.Type
import Siko.AST.Pattern
import Siko.AST.Identifier
import Siko.AST.Statement as S
import Siko.AST.QualifiedName

@derive(Clone, PartialEq, Std.Ops.Eq)
pub struct WitnessInfo {
    pub witnesses: Vec[BoundWitness],

    pub fn new() -> WitnessInfo {
        WitnessInfo(Vec.new())
    }
}

@derive(Clone, PartialEq, Std.Ops.Eq)
pub struct Expr {
    pub kind: ExprKind,
    pub location: Location,
    pub ty: Option[TypeDef],

    pub fn new(kind: ExprKind, location: Location) -> Expr {
        Siko.AST.Expr.Expr(kind, location, None)
    }

    fn is_divergent(expr: Expr) -> Bool {
        match expr.kind {
            Return(_) | Break | Continue => True,
            Block(BlockInfo(stmts)) => {
                match stmts.last() {
                    Some(S.TrailingExpr(e)) => e.is_divergent(),
                    Some(S.Expr(e)) => e.is_divergent(),
                    _                       => False,
                }
            }
            If(_, then_branch, else_branch) => {
                then_branch.is_divergent() && match else_branch {
                    Some(e) => e.is_divergent(),
                    None    => False,
                }
            }
            IfLet(_, _, then_branch, else_branch) => {
                then_branch.is_divergent() && match else_branch {
                    Some(e) => e.is_divergent(),
                    None    => False,
                }
            }
            _ => False,
        }
    }
}

@derive(Clone, PartialEq, Std.Ops.Eq)
pub enum FunctionKind {
    UserDefined,
    StructCtor,
    VariantCtor,
    Extern(Option[I.String]), // Some(name) = extern "C" with original C name
    Builtin,
}

instance ToString[FunctionKind] {
    fn to_string(k: FunctionKind) -> String {
        match k {
            FunctionKind.UserDefined => "UserDefined",
            FunctionKind.StructCtor => "StructCtor",
            FunctionKind.VariantCtor => "VariantCtor",
            FunctionKind.Extern(_) => "Extern",
            FunctionKind.Builtin => "Builtin",
        }
    }
}

@derive(Clone, PartialEq, Std.Ops.Eq)
pub struct MatchArm {
    pub pattern: Pattern,
    pub body: Expr,
}

@derive(Clone, PartialEq, Std.Ops.Eq)
pub enum HandlerSelection {
    Unresolved(method: Identifier, handler: Identifier),
    UnresolvedType(method: Identifier, handler: TypeDef),
    EffectFunction(method: QualifiedName, handler: QualifiedName, location: Location, witnesses: WitnessInfo),
    Implicit(implicit_def: QualifiedName, var: VariableName),
    TypeAssociation(associated_type: QualifiedName, handler: TypeDef, location: Location, witnesses: WitnessInfo),
}

@derive(Clone, PartialEq, Std.Ops.Eq)
pub struct MatchInfo {
    pub scrutinee: Expr,
    pub arms: Vec[MatchArm],
}

@derive(Clone, PartialEq, Std.Ops.Eq)
pub struct NamedArgument {
    pub index: Int,
    pub name: I.String,
}

@derive(Clone, PartialEq, Std.Ops.Eq)
pub struct FunctionCallInfo {
    pub qname: QualifiedName,
    pub kind: FunctionKind,
    pub args: Vec[Expr],
    pub witnesses: WitnessInfo = WitnessInfo.new(),
    pub named_args: Vec[NamedArgument] = Vec.new(),
    pub is_coroutine_create: Bool = False,
}

@derive(Clone, PartialEq, Std.Ops.Eq)
pub struct MethodCallInfo {
    pub receiver: Expr,
    pub name: Identifier,
    pub args: Vec[Expr],
    pub named_args: Vec[NamedArgument],
}

@derive(Clone, PartialEq, Std.Ops.Eq)
pub struct CallInfo {
    pub callee: Expr,
    pub args: Vec[Expr],
    pub named_args: Vec[NamedArgument],
    pub is_coroutine_create: Bool,
}

@derive(Clone, PartialEq, Std.Ops.Eq)
pub struct WithInfo {
    pub selections: Vec[HandlerSelection],
    pub body: Expr,
}

@derive(Clone, PartialEq, Std.Ops.Eq)
pub struct ImplicitRefInfo {
    pub name: QualifiedName,
}

@derive(Clone, PartialEq, Std.Ops.Eq)
pub struct LambdaArg {
    pub name: VariableName,
    pub ty: Option[TypeDef],
}

@derive(Clone, PartialEq, Std.Ops.Eq)
pub struct CreateClosureInfo {
    pub name: QualifiedName,
    pub params: Vec[VariableName],
    pub witnesses: WitnessInfo,
}

@derive(Clone, PartialEq, Std.Ops.Eq)
pub struct FunctionPtrInfo {
    pub name: QualifiedName,
    pub witnesses: WitnessInfo,
}

@derive(Clone, PartialEq, Std.Ops.Eq)
pub struct TypeAssociatedCallInfo {
    pub type_def: TypeDef,
    pub fn_name: QualifiedName,
    pub args: Vec[Expr],
    pub witnesses: WitnessInfo,
    pub named_args: Vec[NamedArgument],
}

@derive(Clone, PartialEq, Std.Ops.Eq)
pub struct BlockInfo {
    pub stmts: Vec[S.Statement],
}

@derive(Clone, PartialEq, Std.Ops.Eq)
pub struct YieldInfo {
    pub arg: Expr,
}

@derive(Clone, PartialEq, Std.Ops.Eq)
pub enum ExprKind {
    IntLiteral(String),
    StringLiteral(String),
    CharLiteral(U8),
    Var(VariableName),
    Name(Name),
    BinaryOp(BinaryOp, Expr, Expr),
    UnaryOp(UnaryOp, Expr),
    Call(CallInfo),
    MethodCall(MethodCallInfo),
    FieldAccess(Expr, Identifier),
    TupleIndex(Expr, Int),
    FunctionCall(FunctionCallInfo),
    DynamicCall(Expr, Vec[Expr]),
    FunctionPtr(FunctionPtrInfo),
    FunctionPtrCall(Expr, Vec[Expr]),
    If(Expr, Expr, Option[Expr]),
    IfLet(Pattern, Expr, Expr, Option[Expr]),
    Range(Expr, Expr),
    Block(BlockInfo),
    Tuple(Vec[Expr]),
    Paren(Expr),
    Return(Expr),
    Break,
    Continue,
    Match(MatchInfo),
    With(WithInfo),
    ImplicitRef(ImplicitRefInfo),
    UnresolvedLambda(Vec[Pattern], Expr),
    ResolvedLambda(Vec[LambdaArg], Expr, Int),
    CreateClosure(CreateClosureInfo),
    List(Vec[Expr]),
    Index(Expr, Expr),
    Try(Expr),
    Transmute(Expr),
    SizeOf(TypeDef),
    Discriminator(Expr),
    Deref(Expr),
    AddrOf(Expr),
    TypeAssociatedCall(TypeAssociatedCallInfo),
    Yield(YieldInfo),
    EnumTag(Expr),
    Switch(Expr, Vec[Expr]),
    ReadVariant(Expr, Expr),
    Goto(String),
    Label(String),
}

@derive(PartialEq, Std.Ops.Eq, PartialOrd, Ord, Clone)
pub enum VariableName {
    Unresolved(Identifier),
    UserDefined(I.String, Int),
    Temp(Int),

    pub fn get_user_name(v: VariableName) -> I.String {
        match v {
            VariableName.Unresolved(id)        => id.name(),
            VariableName.UserDefined(name, _)  => name,
            Temp(i)               => I.intern("$tmp_" + i.to_string()),
        }
    }

    pub fn unresolved(v: VariableName) -> Identifier {
        match v {
            VariableName.Unresolved(id) => id,
            _              => panic("not unresolved variable"),
        }
    }

    pub fn format(v: VariableName) -> String {
        match v {
            VariableName.Unresolved(id)        => I.resolve(id.name),
            VariableName.UserDefined(name, id) => I.resolve(name) + "_" + id.to_string(),
            Temp(id)              => "$tmp_" + id.to_string(),
        }
    }
}

@derive(Clone, PartialEq, Std.Ops.Eq)
pub enum BinaryOp {
    Add,
    Sub,
    Mul,
    Div,
    And,
    Or,
    Eq,
    NotEq,
    Less,
    Greater,
    LessEq,
    GreaterEq,
    Mod,
    BitAnd,
    BitOr,
    Xor,
    Shl,
    Shr,
}

@derive(Clone, PartialEq, Std.Ops.Eq)
pub enum UnaryOp {
    Neg,
    Not,
    BNot,
}

}
