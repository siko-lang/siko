            }
            None => {}
        }
    }

    pub fn dump(stats: Statistics) {
        if !stats.enabled {
            return;
        }
        println("Closure lowering v3 statistics:");
        print_count_stat("generalized_datatype_sccs", stats.generalized_datatype_sccs);
        print_count_stat("generalized_datatypes", stats.generalized_datatypes);
        print_count_stat("datatype_slots", stats.datatype_slots);
        print_count_stat("generalized_functions", stats.generalized_functions);
        print_count_stat("function_slots", stats.function_slots);
        print_count_stat("profile_sccs", stats.profile_sccs);
        print_size_stat("profile_scc_size", stats.profile_sccs, stats.profile_scc_size_total, stats.profile_scc_size_min, stats.profile_scc_size_max);
        print_count_stat("profile_flow_functions", stats.profile_flow_functions);
        print_count_stat("profile_bodyless_functions", stats.profile_bodyless_functions);
        print_count_stat("profiles_published", stats.profiles_published);
        print_size_stat("profile_size", stats.profile_size_count, stats.profile_size_total, stats.profile_size_min, stats.profile_size_max);
        println("  profile_size_min_name: ${stats.profile_size_min_name}");
        println("  profile_size_max_name: ${stats.profile_size_max_name}");
        print_count_stat("flow_unifications", stats.flow_unifications);
        print_count_stat("flow_cross_unifications", stats.flow_cross_unifications);
        print_count_stat("flow_creations", stats.flow_creations);
        print_count_stat("flow_static_calls", stats.flow_static_calls);
        print_count_stat("flow_dynamic_calls", stats.flow_dynamic_calls);
        print_count_stat("resolve_passes", stats.resolve_passes);
        print_count_stat("resolver_process_instances", stats.resolver_process_instances);
        print_count_stat("resolver_local_iterations", stats.resolver_local_iterations);
        print_count_stat("resolver_walk_data_builds", stats.resolver_walk_data_builds);
        print_count_stat("resolver_walk_data_hits", stats.resolver_walk_data_hits);
        print_count_stat("resolver_static_calls", stats.resolver_static_calls);
        print_count_stat("resolver_dynamic_calls", stats.resolver_dynamic_calls);
        print_count_stat("resolver_creations", stats.resolver_creations);
        print_count_stat("resolver_closure_instances", stats.resolver_closure_instances);
        print_count_stat("resolver_function_instances", stats.resolver_function_instances);
        print_count_stat("resolver_reachable_instances", stats.resolver_reachable_instances);
        print_count_stat("rewritten_functions", stats.rewritten_functions);
        print_count_stat("lowered_create_closures", stats.lowered_create_closures);
        print_count_stat("lowered_dynamic_calls", stats.lowered_dynamic_calls);
        print_count_stat("retargeted_static_calls", stats.retargeted_static_calls);
        print_count_stat("retargeted_function_ptrs", stats.retargeted_function_ptrs);
        print_count_stat("rewrite_type_requests", stats.rewrite_type_requests);
        print_count_stat("rewrite_type_cache_misses", stats.rewrite_type_cache_misses);
        print_size_stat("rewrite_exprs_per_function", stats.rewrite_function_calls, stats.rewrite_exprs_total, stats.rewrite_exprs_min, stats.rewrite_exprs_max);
        print_count_stat("instantiated_data_types", stats.instantiated_data_types);
        print_count_stat("instantiated_structs", stats.instantiated_structs);
        print_count_stat("instantiated_enums", stats.instantiated_enums);
        print_count_stat("generated_closure_enums", stats.generated_closure_enums);
        print_count_stat("generated_handlers", stats.generated_handlers);
        print_time_stat("generalize_datatypes", stats.generalize_datatypes_calls, stats.generalize_datatypes_time);
        print_time_stat("generalize_functions", stats.generalize_functions_calls, stats.generalize_functions_time);
        print_time_stat("profile_build", stats.profile_build_calls, stats.profile_build_time);
        print_time_sample_stat("profile_scc", stats.profile_scc_calls, stats.profile_scc_time, stats.profile_scc_time_min_us, stats.profile_scc_time_max_us);
        print_time_stat("profile_flow", stats.profile_flow_calls, stats.profile_flow_time);
        print_time_stat("profile_publish", stats.profile_publish_calls, stats.profile_publish_time);
        print_time_stat("resolve", stats.resolve_calls, stats.resolve_time);
        print_time_stat("resolver_walk_data", stats.resolver_walk_data_calls, stats.resolver_walk_data_time);
        print_time_stat("resolver_process_instance", stats.resolver_process_instance_calls, stats.resolver_process_instance_time);
        print_time_stat("rewrite", stats.rewrite_calls, stats.rewrite_time);
        print_time_sample_stat("rewrite_function", stats.rewrite_function_calls, stats.rewrite_function_time, stats.rewrite_function_time_min_us, stats.rewrite_function_time_max_us);
        print_timed_stat("rewrite_function_walk_data", stats.rewrite_function_walk_data_timing);
        print_timed_stat("rewrite_function_rw", stats.rewrite_function_rw_timing);
        print_timed_stat("rewrite_type", stats.rewrite_type_timing);
        print_timed_stat("rewrite_type_miss", stats.rewrite_type_miss_timing);
        print_timed_stat("rewrite_var_set", stats.rewrite_var_set_timing);
        print_timed_stat("rewrite_instantiate_data", stats.rewrite_instantiate_data_timing);
        print_timed_stat("rewrite_retarget_data_name", stats.rewrite_retarget_data_name_timing);
        print_timed_stat("rewrite_create_closure", stats.rewrite_create_closure_timing);
        print_timed_stat("rewrite_dynamic_call", stats.rewrite_dynamic_call_timing);
        print_timed_stat("rewrite_retarget_static_call", stats.rewrite_retarget_static_call_timing);
        print_timed_stat("rewrite_retarget_fn_ptr", stats.rewrite_retarget_fn_ptr_timing);
        print_time_stat("generate_handler", stats.generate_handler_calls, stats.generate_handler_time);
        print_time_stat("generate_enum", stats.generate_enum_calls, stats.generate_enum_time);
    }
}

