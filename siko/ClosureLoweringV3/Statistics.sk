            }
            None => {}
        }
    }

    pub fn rewrite_function_start(stats: Statistics) {
        statistics_start(stats.enabled, stats.rewrite_function_starts);
    }

    pub fn rewrite_function_end(stats: Statistics) {
        match statistics_elapsed(stats.enabled, stats.rewrite_function_starts) {
            Some(elapsed) => {
                let us = elapsed.to_microseconds();
                if stats.rewrite_function_calls == 0 {
                    stats.rewrite_function_time_min_us = us;
                    stats.rewrite_function_time_max_us = us;
                } else {
                    if us < stats.rewrite_function_time_min_us {
                        stats.rewrite_function_time_min_us = us;
                    }
                    if us > stats.rewrite_function_time_max_us {
                        stats.rewrite_function_time_max_us = us;
                    }
                }
                stats.rewrite_function_calls += 1;
                stats.rewrite_function_time += elapsed;
            }
            None => {}
        }
    }

    pub fn generate_handler_start(stats: Statistics) {
        statistics_start(stats.enabled, stats.generate_handler_starts);
    }

    pub fn generate_handler_end(stats: Statistics) {
