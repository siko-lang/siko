import Siko.Interner as I

pub implicit stats: Statistics

fn format_microseconds_as_millis(us: I64) -> String {
    let ms = us / 1000.as_i64();
    let frac = (us % 1000.as_i64()).as_int().to_string();
    while frac.len() < 3 {
        frac = "0" + frac;
    }
    "${ms}.${frac}ms"
}

fn format_duration(total: Duration) -> String {
    format_microseconds_as_millis(total.to_microseconds())
}

fn format_average_duration(total: Duration, count: Int) -> String {
    if count == 0 {
        return "0.000ms";
    }
    format_microseconds_as_millis(total.to_microseconds() / count.as_i64())
}

fn format_average_count(total: Int, count: Int) -> String {
    if count == 0 {
        return "0.000";
    }
    let scaled = (total * 1000) / count;
    let whole = scaled / 1000;
    let frac = (scaled % 1000).to_string();
    while frac.len() < 3 {
        frac = "0" + frac;
    }
    "${whole}.${frac}"
}

fn statistics_start(enabled: Bool, starts: Vec[Instant]) {
    if enabled {
        starts.push(Instant.now());
    }
}

fn statistics_elapsed(enabled: Bool, starts: Vec[Instant]) -> Option[Duration] {
    if !enabled {
        return None;
    }
    match starts.pop() {
        Some(start) => Some(start.elapsed()),
        None => None,
    }
}

fn print_time_stat(name: String, count: Int, total: Duration) {
    println("  ${name}: calls=${count}, total=${format_duration(total)}, avg=${format_average_duration(total, count)}");
}

fn print_time_sample_stat(name: String, count: Int, total: Duration, min_us: I64, max_us: I64) {
    let actual_min = if count == 0 { 0.as_i64() } else { min_us };
    let actual_max = if count == 0 { 0.as_i64() } else { max_us };
    println("  ${name}: calls=${count}, total=${format_duration(total)}, avg=${format_average_duration(total, count)}, min=${format_microseconds_as_millis(actual_min)}, max=${format_microseconds_as_millis(actual_max)}");
}

fn print_count_stat(name: String, count: Int) {
    println("  ${name}: ${count}");
}

fn print_size_stat(name: String, count: Int, total: Int, min: Int, max: Int) {
    let actual_min = if count == 0 { 0 } else { min };
    let actual_max = if count == 0 { 0 } else { max };
    println("  ${name}: count=${count}, total=${total}, avg=${format_average_count(total, count)}, min=${actual_min}, max=${actual_max}");
}

pub struct TimedStat {
    pub calls: Int,
    pub total: Duration,
    pub min_us: I64,
    pub max_us: I64,
    starts: Vec[Instant],

    pub fn new() -> TimedStat {
        TimedStat(
            calls: 0,
            total: Duration.zero(),
            min_us: 0.as_i64(),
            max_us: 0.as_i64(),
            starts: Vec.new(),
        )
    }
}

fn timed_start(enabled: Bool, t: TimedStat) {
    statistics_start(enabled, t.starts);
}

fn timed_end(enabled: Bool, t: TimedStat) {
    match statistics_elapsed(enabled, t.starts) {
        Some(elapsed) => {
            let us = elapsed.to_microseconds();
            if t.calls == 0 {
                t.min_us = us;
                t.max_us = us;
            } else {
                if us < t.min_us {
                    t.min_us = us;
                }
                if us > t.max_us {
                    t.max_us = us;
                }
            }
            t.calls += 1;
            t.total += elapsed;
        }
        None => {}
    }
}

fn print_timed_stat(name: String, t: TimedStat) {
    print_time_sample_stat(name, t.calls, t.total, t.min_us, t.max_us);
}

