    }

    pub fn rewrite_start(stats: Statistics) {
        statistics_start(stats.enabled, stats.rewrite_starts);
    }

    pub fn rewrite_end(stats: Statistics) {
        match statistics_elapsed(stats.enabled, stats.rewrite_starts) {
            Some(elapsed) => {
