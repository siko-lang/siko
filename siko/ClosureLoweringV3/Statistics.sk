    pub fn inc(stats: Statistics, field: fn(Statistics) -> ()) {
        if stats.enabled {
            field(stats);
        }
    }

    pub fn generalized_datatype_scc(stats: Statistics) {
        if stats.enabled { stats.generalized_datatype_sccs += 1; }
    }

