    pub fn profile_scc_start(stats: Statistics) {
        statistics_start(stats.enabled, stats.profile_scc_starts);
    }

    pub fn profile_scc_end(stats: Statistics) {
        match statistics_elapsed(stats.enabled, stats.profile_scc_starts) {
            Some(elapsed) => {
                let us = elapsed.to_microseconds();
                if stats.profile_scc_calls == 0 {
                    stats.profile_scc_time_min_us = us;
                    stats.profile_scc_time_max_us = us;
                } else {
                    if us < stats.profile_scc_time_min_us {
                        stats.profile_scc_time_min_us = us;
                    }
                    if us > stats.profile_scc_time_max_us {
                        stats.profile_scc_time_max_us = us;
                    }
                }
                stats.profile_scc_calls += 1;
                stats.profile_scc_time += elapsed;
            }
            None => {}
        }
    }

    pub fn profile_flow_start(stats: Statistics) {
        statistics_start(stats.enabled, stats.profile_flow_starts);
    }

    pub fn profile_flow_end(stats: Statistics) {
        match statistics_elapsed(stats.enabled, stats.profile_flow_starts) {
            Some(elapsed) => {
                stats.profile_flow_calls += 1;
                stats.profile_flow_time += elapsed;
            }
            None => {}
        }
    }

    pub fn profile_publish_start(stats: Statistics) {
        statistics_start(stats.enabled, stats.profile_publish_starts);
    }

    pub fn profile_publish_end(stats: Statistics) {
