    pub fn function_slot(stats: Statistics) {
        if stats.enabled { stats.function_slots += 1; }
    }

    pub fn profile_scc(stats: Statistics, size: Int) {
        if stats.enabled {
            if stats.profile_sccs == 0 {
                stats.profile_scc_size_min = size;
                stats.profile_scc_size_max = size;
            } else {
                if size < stats.profile_scc_size_min {
                    stats.profile_scc_size_min = size;
                }
                if size > stats.profile_scc_size_max {
                    stats.profile_scc_size_max = size;
                }
            }
            stats.profile_sccs += 1;
            stats.profile_scc_size_total += size;
        }
    }

    pub fn profile_flow_function(stats: Statistics) {
        if stats.enabled { stats.profile_flow_functions += 1; }
    }

    pub fn profile_bodyless_function(stats: Statistics) {
        if stats.enabled { stats.profile_bodyless_functions += 1; }
    }

    pub fn profile_published(stats: Statistics) {
        if stats.enabled { stats.profiles_published += 1; }
    }

    pub fn profile_size(stats: Statistics, qname: QualifiedName, profile: FunctionProfile) {
        if !stats.enabled {
            return;
        }
        let size = Debug.format_profile(qname.clone(), profile).len();
        let name = I.resolve(qname.name());
        if stats.profile_size_count == 0 {
            stats.profile_size_min = size;
            stats.profile_size_max = size;
            stats.profile_size_min_name = name.clone();
            stats.profile_size_max_name = name.clone();
        } else {
            if size < stats.profile_size_min {
                stats.profile_size_min = size;
                stats.profile_size_min_name = name.clone();
            }
            if size > stats.profile_size_max {
                stats.profile_size_max = size;
                stats.profile_size_max_name = name.clone();
            }
        }
        stats.profile_size_count += 1;
        stats.profile_size_total += size;
    }

