module Siko.ClosureLoweringV3.InferProfiles.Debug {

import Std.Map
import Std.Set
import Siko.AST.QualifiedName
import Siko.AST.Type
import Siko.ClosureLoweringV3.InferProfiles.Flow
import Siko.Interner as I

fn format_var(v: TypeVar) -> String {
    match v.name() {
        Some(n) => I.resolve(n),
        None => "?",
    }
}

fn format_node(n: FlowNode) -> String {
    "${I.resolve(n.owner.name())}.${format_var(n.var)}"
}

fn format_nodes(ns: Vec[FlowNode]) -> String {
    let parts: Vec[String] = ns.iter().map(|n| format_node(n.clone())).collect();
    Std.Vec.join(parts, ", ")
}

// Debug dump of one SCC's slot partition: every non-trivial equivalence
// class, plus the residual apply/create records with fully qualified node
// names.
pub fn debug_dump_classes(ctx: FlowCtx, scc: Vec[QualifiedName]) {
    let all: Set[FlowNode] = Set.new();
    for (n, p) in ctx.uf.parent.iter() {
        all.insert(n);
        all.insert(p);
    }
    for (n, _) in ctx.uf.lambdas.iter() {
        all.insert(n);
    }
    let all_nodes: Vec[FlowNode] = all.iter().cloned().collect();
    let classes: Map[FlowNode, Vec[FlowNode]] = Map.new();
    for n in all_nodes {
        let root = ctx.uf.find(n.clone());
        let members = classes.get(root.clone()).unwrap_or(Vec.new());
        members.push(n);
        classes.insert(root, members);
    }

    if classes.is_empty() && ctx.applies.is_empty() && ctx.creations.is_empty() {
        return;
    }
    let names: Vec[String] = scc.iter().map(|q| I.resolve(q.name())).collect();
    println("--- closure-v3 group [${Std.Vec.join(names, ", ")}]");
    for (root, members) in classes.iter() {
        let lambdas = ctx.uf.lambdas.get(root).unwrap_or(Set.new());
        if members.len() > 1 || !lambdas.is_empty() {
            let lambda_parts: Vec[String] = lambdas.iter().map(|l| "lambda ${I.resolve(l.name())}").collect();
            let suffix = if lambda_parts.is_empty() { "" } else { " <- {${Std.Vec.join(lambda_parts, ", ")}}" };
            println("  class {${format_nodes(members)}}${suffix}");
        }
    }
    for r in ctx.applies.iter() {
        let arg_parts: Vec[String] = r.args.iter().map(|ns| "{${format_nodes(ns.clone())}}").collect();
        println("  apply in ${I.resolve(r.owner.name())} callee={${format_nodes(r.callee)}} args=[${Std.Vec.join(arg_parts, ", ")}] result={${format_nodes(r.result)}}");
    }
    for r in ctx.creations.iter() {
        let capture_parts: Vec[String] = r.captures.iter().map(|ns| "{${format_nodes(ns.clone())}}").collect();
        println("  create in ${I.resolve(r.owner.name())} lambda ${I.resolve(r.lambda.name())} captures=[${Std.Vec.join(capture_parts, ", ")}]");
    }
}

}
