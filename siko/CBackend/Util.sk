module Siko.CBackend.Util {

import Std.Map
import Siko.AST.Data
import Siko.AST.Expr
import Siko.AST.Function
import Siko.AST.Name
import Siko.AST.QualifiedName
import Siko.AST.Type
import Siko.Constants.Builtins as B
import Siko.Interner as I

pub fn normalize_tuple_type(ty: TypeDef) -> TypeDef {
    match ty {
        TypeDef.Tuple(elems) => {
            let rewritten: Vec[TypeDef] = elems.into_iter().map(|t| normalize_tuple_type(t)).collect();
            let qname = QualifiedName.new_mono(
                B.get_siko_tuple(),
                rewritten,
                [],
                Map.new(),
                [],
            );
            TypeDef.Named(Name.Resolved(qname), [])
        }
        TypeDef.Named(name, args) => {
            TypeDef.Named(name, args.into_iter().map(|t| normalize_tuple_type(t)).collect())
        }
        other => other,
    }
}

pub fn escape_c_string(s: String) -> String {
    let out = "";
    for c in s.chars() {
        match c {
            '"' => { out = out + "\\\""; }
            '\\' => { out = out + "\\\\"; }
            '\n' => { out = out + "\\n"; }
            '\t' => { out = out + "\\t"; }
            '\r' => { out = out + "\\r"; }
            '\0' => { out = out + "\\0"; }
            c => { out = out + String.from_byte(c); }
        }
    }
    out
}

pub fn mangle(name: String) -> String {
    let s = name.trim_start_matches("$");
    let result = "";
    let prev_sep = False;
    for c in s.chars() {
        match c {
            '(' => {
                result = result + "_lp_";
                prev_sep = False;
            }
            ')' => {
                result = result + "_rp_";
                prev_sep = False;
            }
            '*' => {
                result = result + "ptr_";
                prev_sep = False;
            }
            '.' | '[' | '{' | ',' | '-' | '<' | '>' | ':' | '!' | '@' | '&' | '+' | '='
            | '|' | '^' | '~' | '?' | '/' | '\\' | '#' => {
                if !prev_sep {
                    result = result + "_";
                }
                prev_sep = True;
            }
            ']' | '}' | ' ' | '\'' | '`' | '"' | ';' => {}
            _ => {
                result = result + String.from_byte(c);
                prev_sep = False;
            }
        }
    }
    loop {
        if !result.ends_with("__") { break; }
        result = result.strip_suffix("__").unwrap();
    }
    result
}

pub fn variant_struct_name(edef: EnumDef, variant: VariantDef) -> String {
    mangle("${edef.qualified_name.hashed()}.${variant.name.name()}")
}

pub fn variant_field_name(index: Int) -> String {
    "field_${index}"
}

pub fn variant_payload_name(variant: VariantDef) -> String {
    "v_${I.resolve(variant.name.name())}"
}

pub fn fn_name(qualified_name: QualifiedName) -> String {
    mangle(qualified_name.hashed())
}

pub fn var_name(n: VariableName) -> String {
    mangle(n.format())
}

pub fn closure_env_name(fdef: FunctionDef) -> String {
    "_siko_env_${fn_name(fdef.qualified_name)}"
}

pub fn closure_wrap_name(fdef: FunctionDef) -> String {
    "_siko_wrap_${fn_name(fdef.qualified_name)}"
}

}
